{
  "ignoreCommand": "[ \"$VERCEL_GIT_COMMIT_REF\" = \"deploy\" ] && exit 0 || exit 1",
  "headers": [
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/api/admin-auth",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/portfolio/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=60" }
      ]
    },
    {
      "source": "/dev/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=60" }
      ]
    }
  ],
  "redirects": [
    { "source": "/inizia-da-qui", "destination": "/risorse/", "permanent": true },
    { "source": "/inizia-da-qui/", "destination": "/risorse/", "permanent": true },
    { "source": "/percorsi-online", "destination": "/servizi/", "permanent": true },
    { "source": "/percorsi-online/", "destination": "/servizi/", "permanent": true }
  ]
}
