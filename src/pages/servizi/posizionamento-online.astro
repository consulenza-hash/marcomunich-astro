---
import BaseLayout from '@layouts/BaseLayout.astro';

const targets = [
  "Hai studiato per anni e ti sembra che online passi solo una versione superficiale di quello che sai fare.",
  "Pubblichi e ricevi like, ma i clienti che ti contattano spesso non sono quelli che vorresti seguire davvero.",
  "Quando guardi i profili dei tuoi colleghi ti accorgi che si assomigliano tutti, e il tuo è uno di quelli.",
  "Hai provato a scrivere come scrivono \"quelli bravi\" ma il risultato non sembra mai tuo, e infatti non lo è."
];

const steps = [
  { n: "01", title: "Capisco chi sei e come pensi.", body: "Partiamo da quello che già sai fare bene, dal tipo di clienti che hai seguito finora, dalle frasi che usi quando spieghi il tuo lavoro a una persona seduta di fronte a te. Lì dentro c'è già il tuo punto di vista, va solo riconosciuto e portato in superficie. Non costruiamo un personaggio nuovo, smontiamo il personaggio che ti sei costruito per imitazione." },
  { n: "02", title: "Definiamo il messaggio.", body: "Una sola idea forte che spiega in che modo il tuo lavoro è diverso da quello dei tuoi colleghi. Non serve una tagline, serve una posizione difendibile. Una cosa che potresti dire a cena e che chi ti ascolta capisce subito, anche se non ha mai sentito parlare di counseling o di coaching o del tuo settore specifico." },
  { n: "03", title: "Costruiamo la voce sul tuo modo di parlare.", body: "La tua voce online deve assomigliare alla tua voce parlata. Lavoriamo sul ritmo delle tue frasi, sui connettivi che usi davvero, sul tipo di esempi che ti vengono naturali. Smetti di scrivere come scrivono \"quelli bravi\" e inizi a scrivere come parli tu in studio. Chi ti cerca riconosce subito che la persona online e la persona dal vivo sono la stessa." },
  { n: "04", title: "Mettiamo il sistema in moto.", body: "Bio, profili social, articoli, eventuali pagine del sito. Ogni testo passa attraverso il filtro del posizionamento che abbiamo costruito insieme, e ogni contenuto futuro lo riconosci subito perché è coerente con quello che siamo. A questo punto la presenza online ti rappresenta davvero, e i clienti che ti scrivono ti scrivono per i motivi giusti." }
];

const results = [
  { t: "Ti riconoscono prima.", d: "Chi ti scopre online capisce in pochi secondi se sei la persona giusta per lui, senza dover leggere tre paragrafi di \"chi sono\" pieni di certificazioni." },
  { t: "Ricevi richieste mirate.", d: "I messaggi che ti arrivano cominciano già con un livello di chiarezza diverso. Non parti più da zero a ogni call, parti da gente che ha già capito come lavori." },
  { t: "Scrivi senza fatica.", d: "Hai una posizione, hai una voce, sai cosa rientra nel tuo perimetro e cosa no. Pubblicare smette di essere una corvée e torna a essere quello che era all'inizio: dire le cose che pensi a chi le sta cercando." },
  { t: "Smetti di copiare.", d: "Il tuo profilo non assomiglia più a quello di nessun altro. Le persone che ti seguono lo fanno perché sei tu, non perché sei una versione presentabile di un altro." }
];

const faqs = [
  { q: "Quanto dura il percorso?", a: "Dipende da dove sei. Chi parte da zero ci mette di più, chi ha già anni di pubblicazioni dietro le spalle ci mette meno perché c'è più materiale da cui partire. In media ci si vede una volta a settimana per qualche mese, ma il ritmo lo decidiamo insieme alla prima chiamata." },
  { q: "Funziona solo per il settore olistico?", a: "No. Funziona per chiunque venda un servizio in cui il prodotto sia te. Coach, terapeuti, counselor, consulenti, formatori, professionisti tecnici che lavorano in proprio. La maggior parte dei clienti che ho seguito viene dal mondo olistico perché lì sono cresciuto, ma il metodo non è legato a una nicchia." },
  { q: "Mi date un copione da usare sui social?", a: "No, e se qualcuno te lo offre stai attento. Un copione standard è esattamente il problema da cui parti. Costruiamo invece una serie di principi che valgono per te in particolare, e quei principi li applichi tu ai tuoi contenuti, in modo che la voce resti tua anche quando io non ci sono più." },
  { q: "Quanto costa?", a: "Il costo dipende dalla quantità di lavoro necessaria, e quella la valutiamo nella prima chiamata che è gratuita. Quello che posso dirti adesso è che non è un investimento da poche centinaia di euro, ed è pensato per chi un'attività la sta già portando avanti e vuole farla funzionare meglio, non per chi sta partendo da zero come hobby." },
  { q: "Posso fare anche solo il sito senza la consulenza?", a: "Sì, e capita spesso. La parte sviluppo siti e applicazioni è un servizio a sé, lo trovi sulla home. Se invece vuoi entrambe le cose insieme, il posizionamento entra direttamente nel sito che costruisco, e il costo complessivo è inferiore rispetto a farle separatamente." }
];
---

<BaseLayout
  title="Posizionamento Online — Marco Munich"
  description="Consulenza di posizionamento online per coach, counselor, operatori olistici e professionisti che vendono se stessi. Costruiamo un punto di vista riconoscibile a partire da chi sei davvero."
  currentPath="/servizi/posizionamento-online/"
>

<div class="po-page">

  <!-- HERO -->
  <section class="po-hero">
    <div class="po-container">
      <div class="po-status-bar">
        <span class="po-pill"><span class="po-pulse"></span> CONSULENZA · 1:1</span>
        <span class="po-pill">SVC · positioning</span>
        <span class="po-pill">v.handcrafted</span>
      </div>
      <h1 class="po-h1">
        <span class="po-h1__chrome">POSIZIONAMENTO</span>
        <span class="po-h1__chrome po-h1__chrome--violet">ONLINE.</span>
      </h1>
      <p class="po-hero__tag">
        Ti aiuto a trovare il modo di presentarti online che corrisponde a chi sei davvero, non al personaggio che pensi di dover recitare per essere preso sul serio. Il risultato è una presenza riconoscibile, che attira le persone giuste e fa risparmiare tempo a entrambi. ✦
      </p>
    </div>
  </section>

  <!-- PER CHI -->
  <section class="po-section" id="per-chi">
    <div class="po-container">
      <h2 class="po-section__title"><span class="po-arrow">▸</span> PER CHI VENDE SE STESSO</h2>
      <p class="po-text po-text--lead">
        Coach, counselor, operatori olistici, terapeuti, consulenti, professionisti del benessere e chiunque venda un servizio in cui il prodotto sei tu. Le persone che ti sceglieranno non comprano una procedura standard, comprano il tuo modo di guardare le cose. Se il tuo modo di guardare le cose non si vede da fuori, le persone giuste non sanno di doverti scegliere.
      </p>
      <ul class="po-targets">
        {targets.map((t, i) => (
          <li class="po-target">
            <span class="po-target__num">[ 0{i + 1} ]</span>
            <p>{t}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- IL PROBLEMA -->
  <section class="po-section po-section--alt">
    <div class="po-container po-problem">
      <div>
        <h2 class="po-section__title"><span class="po-arrow">▸</span> IL PROBLEMA REALE</h2>
        <h3 class="po-problem__head"><span class="po-h1__chrome--cyan po-inline">"Sii autentico"</span> è diventato un cliché.</h3>
      </div>
      <div class="po-problem__body">
        <p class="po-text">
          Lo dicono tutti i coach a tutti gli altri coach, e ognuno costruisce una versione di sé che assomiglia all'autenticità solo perché segue il formato giusto. La voce che hai sviluppato dopo anni di studio finisce sotto un livello di vernice che la rende uguale a tutte le altre, e chi cerca un professionista vero passa oltre senza accorgersi di te.
        </p>
        <p class="po-text">
          Il problema non è che ti manca il talento, né che non hai studiato abbastanza. Il problema è che il modo in cui ti stai raccontando online sta scegliendo i clienti al posto tuo, e li sta scegliendo male. Lavoriamo proprio su questo.
        </p>
      </div>
    </div>
  </section>

  <!-- METODO -->
  <section class="po-section">
    <div class="po-container">
      <h2 class="po-section__title"><span class="po-arrow">▸</span> COME LAVORO · QUATTRO FASI</h2>
      <p class="po-text po-text--intro">
        Non è un corso. Non è un template. È una consulenza individuale, fatta in tempi che dipendono da dove sei adesso e da dove vuoi arrivare.
      </p>
      <ol class="po-steps">
        {steps.map(s => (
          <li class="po-step">
            <span class="po-step__n">{s.n}</span>
            <div class="po-step__body">
              <h3 class="po-step__title">{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- RISULTATI -->
  <section class="po-section po-section--alt">
    <div class="po-container">
      <h2 class="po-section__title"><span class="po-arrow">▸</span> COSA CAMBIA DOPO</h2>
      <p class="po-text po-text--intro">Una presenza online che lavora per te.</p>
      <div class="po-results">
        {results.map((r, i) => (
          <div class="po-result">
            <span class="po-result__num">[ 0{i + 1} ]</span>
            <h3 class="po-result__title">{r.t}</h3>
            <p>{r.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="po-section">
    <div class="po-container po-container--narrow">
      <h2 class="po-section__title"><span class="po-arrow">▸</span> DOMANDE FREQUENTI</h2>
      <div class="po-faq-list">
        {faqs.map((f, i) => (
          <details class="po-faq">
            <summary>
              <span class="po-faq__num">[ {String(i + 1).padStart(2, '0')} ]</span>
              <span class="po-faq__q">{f.q}</span>
              <span class="po-faq__icon">+</span>
            </summary>
            <div class="po-faq__answer">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="po-cta">
    <div class="po-container">
      <div class="po-cta__box">
        <p class="po-cta__kicker">// PRIMA CHIAMATA · GRATUITA</p>
        <h2 class="po-cta__title"><span class="po-h1__chrome">PARLIAMONE.</span></h2>
        <p class="po-cta__sub">
          Trenta minuti. Capisco la tua situazione, ti dico cosa farei al tuo posto e se posso esserti utile davvero. Se non posso, te lo dico e ti indirizzo verso qualcun altro.
        </p>
        <a href="/#contatti" class="po-btn po-btn--big">[ FISSA LA CHIAMATA → ]</a>
      </div>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .po-page { color: #f0e9ff; font-family: 'Inter', system-ui, sans-serif; position: relative; min-height: 100vh; }
  .po-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; width: 100%; position: relative; z-index: 2; }
  .po-container--narrow { max-width: 820px; }

  /* HERO */
  .po-hero { padding: 5rem 0 4rem; }
  .po-status-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .po-pill { display: inline-flex; align-items: center; gap: 0.4rem; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; color: #00e5ff; background: rgba(0,229,255,0.08); border: 1px solid rgba(0,229,255,0.4); padding: 0.35rem 0.8rem; border-radius: 999px; }
  .po-pulse { width: 7px; height: 7px; background: #6ee870; border-radius: 50%; animation: populse 2s infinite; }
  @keyframes populse { 0%,100% { box-shadow: 0 0 0 0 rgba(110,232,112,0.5); } 50% { box-shadow: 0 0 0 6px transparent; } }

  .po-h1 { font-family: 'Inter', sans-serif; font-weight: 900; font-size: clamp(2.6rem, 9vw, 7.5rem); line-height: 0.92; letter-spacing: -0.04em; margin: 0 0 2rem; }
  .po-h1__chrome { display: block; background: linear-gradient(180deg, #ffffff 0%, #d8d8d8 25%, #909090 45%, #ffffff 55%, #f5f5f5 75%, #b5b5b5 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent; text-shadow: 0 4px 30px rgba(255,255,255,0.15); }
  .po-h1__chrome--violet { background: linear-gradient(180deg, #ff2d92 0%, #ffe2f0 30%, #8a3aff 70%, #4a0066 100%); -webkit-background-clip: text; background-clip: text; }
  .po-h1__chrome--cyan { background: linear-gradient(180deg, #00e5ff 0%, #b8faff 35%, #007a99 70%, #002a33 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .po-inline { display: inline; }
  .po-hero__tag { font-size: 1.1rem; line-height: 1.7; color: rgba(240,233,255,0.8); max-width: 640px; margin: 0; }

  /* SECTIONS */
  .po-section { padding: 5rem 0; position: relative; }
  .po-section--alt { background: rgba(10,5,18,0.4); }
  .po-section__title { font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: 700; letter-spacing: 0.2em; color: #ff2d92; margin: 0 0 2.5rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,45,146,0.3); }
  .po-arrow { color: #00e5ff; }
  .po-text { font-size: 1rem; line-height: 1.85; color: rgba(240,233,255,0.78); margin: 0 0 1.4rem; }
  .po-text:last-child { margin-bottom: 0; }
  .po-text--lead { max-width: 760px; margin-bottom: 3rem; }
  .po-text--intro { color: rgba(240,233,255,0.6); font-family: 'JetBrains Mono', monospace; font-size: 0.92rem; max-width: 600px; margin-bottom: 3rem; }

  /* TARGETS */
  .po-targets { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .po-target { background: rgba(255,255,255,0.03); border: 1px solid rgba(240,233,255,0.15); border-left: 3px solid #ff2d92; border-radius: 10px; padding: 1.4rem 1.6rem; backdrop-filter: blur(10px); display: grid; grid-template-rows: auto 1fr; gap: 0.6rem; }
  .po-target__num { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #ff2d92; letter-spacing: 0.1em; }
  .po-target p { font-size: 0.95rem; line-height: 1.7; color: rgba(240,233,255,0.78); margin: 0; }

  /* PROBLEMA */
  .po-problem { display: grid; grid-template-columns: 1fr 1.3fr; gap: 4rem; align-items: start; }
  .po-problem__head { font-family: 'Inter', sans-serif; font-weight: 900; font-size: clamp(1.5rem, 3vw, 2.4rem); line-height: 1.15; letter-spacing: -0.02em; margin: 0; color: #fff; }
  .po-problem__body p { font-size: 1.02rem; line-height: 1.85; color: rgba(240,233,255,0.78); margin: 0 0 1.4rem; }
  .po-problem__body p:last-child { margin-bottom: 0; }

  /* STEPS */
  .po-steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.2rem; }
  .po-step { background: rgba(255,255,255,0.03); border: 1px solid rgba(240,233,255,0.15); border-radius: 12px; padding: 2rem 2.2rem; backdrop-filter: blur(10px); display: grid; grid-template-columns: 90px 1fr; gap: 2rem; align-items: start; transition: border-color 0.2s ease, box-shadow 0.2s ease; }
  .po-step:hover { border-color: rgba(0,229,255,0.4); box-shadow: 0 0 40px rgba(0,229,255,0.08); }
  .po-step__n { font-family: 'Inter', sans-serif; font-weight: 900; font-size: 3rem; line-height: 0.9; background: linear-gradient(180deg, #00e5ff 0%, #007a99 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .po-step__title { font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.3rem; color: #fff; margin: 0 0 0.8rem; letter-spacing: -0.01em; }
  .po-step__body p { font-size: 0.95rem; line-height: 1.8; color: rgba(240,233,255,0.72); margin: 0; }

  /* RESULTS */
  .po-results { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .po-result { background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,45,146,0.04) 100%); border: 1px solid rgba(240,233,255,0.18); border-radius: 14px; padding: 2rem; backdrop-filter: blur(15px); }
  .po-result:nth-child(even) { background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(0,229,255,0.04) 100%); }
  .po-result__num { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #ff2d92; letter-spacing: 0.1em; display: block; margin-bottom: 0.8rem; }
  .po-result__title { font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.2rem; color: #fff; margin: 0 0 0.7rem; letter-spacing: -0.01em; }
  .po-result p { font-size: 0.92rem; line-height: 1.7; color: rgba(240,233,255,0.72); margin: 0; }

  /* FAQ */
  .po-faq-list { display: flex; flex-direction: column; gap: 0.9rem; }
  .po-faq { background: rgba(255,255,255,0.03); border: 1px solid rgba(240,233,255,0.15); border-left: 3px solid #ff2d92; border-radius: 10px; overflow: hidden; backdrop-filter: blur(10px); transition: border-color 0.2s ease, box-shadow 0.2s ease; }
  .po-faq:hover { border-color: rgba(0,229,255,0.4); box-shadow: 0 0 30px rgba(0,229,255,0.08); }
  .po-faq[open] { border-left-color: #00e5ff; }
  .po-faq summary { padding: 1.2rem 1.5rem; cursor: pointer; display: grid; grid-template-columns: auto 1fr auto; gap: 1rem; align-items: center; list-style: none; user-select: none; }
  .po-faq summary::-webkit-details-marker { display: none; }
  .po-faq__num { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: #ff2d92; letter-spacing: 0.1em; }
  .po-faq__q { font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1.02rem; color: #f0e9ff; }
  .po-faq__icon { font-family: 'JetBrains Mono', monospace; width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #00e5ff; transition: transform 0.3s ease; font-weight: 300; }
  .po-faq[open] .po-faq__icon { transform: rotate(45deg); }
  .po-faq__answer { padding: 0 1.5rem 1.4rem 4rem; color: rgba(240,233,255,0.75); line-height: 1.8; font-size: 0.95rem; }
  .po-faq__answer a { color: #00e5ff; text-decoration: none; border-bottom: 1px solid rgba(0,229,255,0.4); }

  /* CTA */
  .po-cta { padding: 6rem 0 7rem; }
  .po-cta__box { text-align: center; background: linear-gradient(135deg, rgba(138,58,255,0.1) 0%, rgba(0,229,255,0.08) 100%); border: 1px solid rgba(240,233,255,0.2); border-radius: 24px; padding: 5rem 3rem; backdrop-filter: blur(20px); box-shadow: 0 0 80px rgba(255,45,146,0.15); }
  .po-cta__kicker { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #00e5ff; margin: 0 0 2rem; letter-spacing: 0.2em; }
  .po-cta__title { font-size: clamp(2.5rem, 7vw, 5.5rem); line-height: 0.9; margin: 0 0 2rem; }
  .po-cta__sub { font-size: 1.05rem; color: rgba(240,233,255,0.75); max-width: 560px; margin: 0 auto 3rem; line-height: 1.7; }
  .po-btn { font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 700; letter-spacing: 0.05em; padding: 1.3rem 2.4rem; text-decoration: none; border-radius: 4px; display: inline-block; background: linear-gradient(180deg, #ffffff 0%, #cccccc 100%); color: #0a0512; box-shadow: 0 0 40px rgba(255,45,146,0.4); border: 1px solid #fff; transition: all 0.2s ease; }
  .po-btn--big:hover { box-shadow: 0 0 60px rgba(255,45,146,0.7); transform: translateY(-2px); }

  @media (max-width: 768px) {
    .po-hero { padding: 3.5rem 0 2.5rem; }
    .po-section { padding: 3.5rem 0; }
    .po-section__title { font-size: 0.78rem; margin-bottom: 1.8rem; }
    .po-targets, .po-results { grid-template-columns: 1fr; }
    .po-problem { grid-template-columns: 1fr; gap: 1.5rem; }
    .po-step { grid-template-columns: 1fr; gap: 0.8rem; padding: 1.6rem 1.6rem; }
    .po-step__n { font-size: 2.2rem; }
    .po-faq summary { padding: 1rem 1.2rem; grid-template-columns: 1fr auto; gap: 0.6rem; }
    .po-faq__num { display: none; }
    .po-faq__q { font-size: 0.95rem; }
    .po-faq__answer { padding: 0 1.2rem 1.2rem; font-size: 0.9rem; }
    .po-cta__box { padding: 3rem 1.6rem; }
  }
</style>
