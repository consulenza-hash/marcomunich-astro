---
import BaseLayout from '@layouts/BaseLayout.astro';

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>`,
    title: "Identificare il tuo Messaggio",
    text: "Trovare le parole che ti descrivono davvero, senza copiare modelli altrui o usare formule preconfezionate."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>`,
    title: "Attirare le persone giuste",
    text: "Chi risuona con te ti troverà da solo — smetti di cercare di convincere tutti e inizia a parlare ai tuoi veri clienti."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    title: "Comunicare senza fingerire",
    text: "Smettere di indossare maschere professionali e imparare a parlare da cuore a cuore con il tuo pubblico."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: "Uscire dalla genericità",
    text: "Superare la paura di essere troppo specifici e scoprire che più sei preciso, più attiri le persone giuste."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>`,
    title: "Trovare continuità",
    text: "Non sentirti più in ansia prima di scrivere un post — avere un messaggio chiaro rende tutto più semplice e naturale."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: "Partire da te stesso",
    text: "Capire che il miglior punto di partenza è la tua storia e la tua esperienza — non le ultime tendenze del marketing."
  },
];

const topics = [
  "Come identificare il tuo messaggio autentico unico",
  "Come parlare del tuo lavoro senza sentirti in vendita",
  "Come attirare solo le persone a cui risuoni davvero",
  "Come creare contenuti partendo dalla tua storia personale",
  "Come superare la paura del giudizio nella comunicazione",
  "Come uscire dalla genericità e differenziarti autenticamente",
  "Come gestire commenti, critiche e i 'non capiti'",
  "Come mantenere la continuità senza esaurirti",
  "Strumenti pratici per la creazione di contenuti",
  "Come adattare il tuo messaggio ai diversi canali",
  "Come costruire fiducia con il tuo pubblico nel tempo",
  "Come misurare se il tuo messaggio sta funzionando",
];

const ideals = [
  { title: "Ricevi consensi ma poca concretezza", text: "Fan, like, commenti, messaggi privati — ma nessuno poi acquista. Il tuo messaggio non sta passando nel modo giusto." },
  { title: "Ti senti generico/a", text: "Non sai come differenziarti da chi fa il tuo stesso lavoro, e hai paura di essere troppo specifico/a." },
  { title: "Ti manca la continuità", text: "Non sai di cosa parlare quando ti siedi a scrivere. Vedi la creazione di contenuti come un peso, non un piacere." },
  { title: "Non ti stai mostrando per chi sei", text: "Ti esprimi con una maschera professionale, e in cuor tuo sai che quello che pubblichi non è davvero tu." },
];
---

<BaseLayout
  title="Creazione del Messaggio Autentico - Marco Munich"
  description="5 Video Lezioni per fare chiarezza interna sugli argomenti di cui parlare quando ci si promuove online, attirando solo persone a cui risuona la tua vera essenza."
  currentPath="/creazione-messaggio-autentico/"
>

<style is:global>
  .copy-page .btn-blue {
    display: inline-block;
    background: #5551D3;
    color: #fff;
    padding: 16px 36px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    letter-spacing: .5px;
    transition: background .2s;
  }
  .copy-page .btn-blue:hover { background: #3730A3; opacity: 1; }

  .copy-page .btn-outline-blue {
    display: inline-block;
    background: transparent;
    color: #5551D3;
    padding: 14px 32px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    border: 2px solid #5551D3;
    transition: all .2s;
  }
  .copy-page .btn-outline-blue:hover { background: #5551D3; color: #fff; opacity: 1; }

  .copy-page .feature-icon svg { width: 36px; height: 36px; color: #5551D3; }
  .copy-page .topic-item { display: flex; gap: 12px; align-items: flex-start; padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .copy-page .topic-item:last-child { border: none; }

  @media (max-width: 768px) {
    .copy-page .hero-grid,
    .copy-page .two-col { grid-template-columns: 1fr !important; }
    .copy-page .hero-image { display: none; }
    .copy-page .reverse-mobile { order: -1; }
  }
</style>

<div class="copy-page">

<!-- ── HERO ──────────────────────────────────────────────────────────────── -->
<section style="background: #06061A; color: #fff; padding: 80px 24px 0;">
  <div class="hero-grid" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">

    <!-- Testo -->
    <div>
      <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(85,81,211,.15); border: 1px solid rgba(85,81,211,.4); color: #a5b4fc; padding: 6px 14px; border-radius: 100px; font-size: 13px; font-weight: 700; letter-spacing: 2px; margin-bottom: 24px;">
        ✦ VIDEO CORSO
      </div>
      <h1 style="font-size: clamp(34px, 4.5vw, 52px); font-weight: 800; line-height: 1.1; color: #fff; margin-bottom: 20px;">
        Creazione del<br><span style="color: #5551D3;">Messaggio Autentico</span>
      </h1>
      <p style="font-size: 18px; line-height: 1.7; color: #bbb; margin-bottom: 12px; font-style: italic;">
        Come cambierebbe il tuo lavoro se mostrassi davvero chi sei?
      </p>
      <p style="font-size: 16px; line-height: 1.7; color: #999; margin-bottom: 36px;">
        5 Video Lezioni per fare chiarezza interna sugli argomenti di cui parlare
        quando ci si promuove online — attirando solo persone a cui risuona la tua vera essenza.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <a href="#costi" class="btn-blue">Scopri i costi →</a>
        <a href="https://youtu.be/rRAJz-LydLo?list=PLKgzAWOyM8xuq8wC6UBXhqze9Odan9JhM" target="_blank" rel="noopener" class="btn-outline-blue">Guarda la lezione gratuita</a>
      </div>
    </div>

    <!-- Immagine -->
    <div class="hero-image" style="padding-bottom: 48px;">
      <div style="border-radius: 12px; overflow: hidden; aspect-ratio: 4/3; background: #1a0808; position: relative;">
        <img
          src="https://images.unsplash.com/photo-1488190211105-8b0e65b80b4e?w=700&q=80&fit=crop"
          alt="Persona che scrive autenticamente il proprio messaggio"
          style="width:100%; height:100%; object-fit:cover; display:block; opacity:.75;"
          loading="eager"
        />
        <!-- Quote overlay -->
        <div style="position:absolute; bottom:0; left:0; right:0; padding:20px 20px; background:linear-gradient(transparent,rgba(0,0,0,.8));">
          <p style="color:#a5b4fc; font-size:13px; font-style:italic; margin:0; line-height:1.5;">
            "Comunicare in modo autentico è il miglior marketing che esiste."
          </p>
          <p style="color:#888; font-size:12px; margin:6px 0 0;">— Marco Munich</p>
        </div>
      </div>
    </div>

  </div>

  <!-- Striscia statistica -->
  <div style="max-width:1100px; margin:48px auto 0; display:flex; gap:32px; flex-wrap:wrap; padding-bottom:40px; border-top:1px solid rgba(255,255,255,.07); padding-top:32px;">
    {[
      { n: "5", label: "Video lezioni" },
      { n: "5h+", label: "di contenuto" },
      { n: "1", label: "Risorsa PDF da 15 pagine" },
      { n: "1", label: "Gruppo Telegram privato" },
    ].map(s => (
      <div>
        <p style="font-size:32px; font-weight:800; color:#5551D3; margin:0; line-height:1;">{s.n}</p>
        <p style="font-size:13px; color:#888; margin:4px 0 0; letter-spacing:.5px;">{s.label}</p>
      </div>
    ))}
  </div>
</section>

<!-- ── FARE CHIAREZZA ──────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div style="max-width: 1080px; margin: 0 auto;">
    <div class="two-col" style="display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center; margin-bottom:60px;">
      <div>
        <p style="color:#5551D3; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Il percorso</p>
        <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:16px;">Avere un Messaggio Autentico significa creare Terreno fertile</h2>
        <p style="color:#555; font-size:16px; line-height:1.8; margin-bottom:16px;">
          Agli albori della nostra attività siamo sempre in ansia da prestazione
          e vorremmo un "porto sicuro" da cui cominciare il nostro viaggio.
        </p>
        <p style="color:#555; font-size:16px; line-height:1.8;">
          Scrivere sapendo che stai attingendo da un tuo spazio personale,
          che ti permette di farti amare per quello che sei — non per la maschera
          che molti indossano per paura di mostrarsi realmente.
        </p>
      </div>
      <div style="border-radius:12px; overflow:hidden; aspect-ratio:16/10; background:#111;">
        <img
          src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=700&q=80&fit=crop"
          alt="Professionista olistica che lavora sul proprio messaggio autentico"
          style="width:100%; height:100%; object-fit:cover; display:block;"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Feature grid -->
    <h3 style="text-align:center; font-size:18px; font-weight:600; color:#555; margin-bottom:36px;">In questo percorso imparerai a:</h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px,1fr)); gap:20px;">
      {features.map(f => (
        <div style="border:1px solid #f0f0f0; border-top:3px solid #5551D3; border-radius:8px; padding:24px;">
          <div class="feature-icon" style="margin-bottom:12px;" set:html={f.icon} />
          <h4 style="font-size:15px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin-bottom:8px;">{f.title}</h4>
          <p style="color:#555; font-size:14px; line-height:1.6; margin:0;">{f.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TI RISUONA ─────────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #EEF2FF;">
  <div class="two-col" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
    <div style="border-radius:12px; overflow:hidden; aspect-ratio:4/5; background:#111; position:relative;">
      <img
        src="https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=600&q=80&fit=crop"
        alt="Operatrice olistica che scrive i suoi contenuti autentici"
        style="width:100%; height:100%; object-fit:cover; display:block;"
        loading="lazy"
      />
      <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent,rgba(6,6,26,.85)); padding:28px 24px;">
        <p style="color:#fff; font-size:16px; font-style:italic; margin:0; line-height:1.5;">
          "Il concetto di marketing è spesso percepito negativamente — e capisco perché."
        </p>
        <p style="color:#a5b4fc; font-size:13px; margin:8px 0 0;">— Marco Munich</p>
      </div>
    </div>
    <div>
      <p style="color:#5551D3; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Perché il messaggio autentico?</p>
      <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:20px;">Ti risuona?</h2>
      <p style="font-size:16px; line-height:1.8; color:#333; margin-bottom:16px;">
        Il percorso è dedicato a chi <strong>non ama "fare marketing"</strong> nel senso
        tradizionale del termine — e in tutta onestà, non posso che concordare.
      </p>
      <p style="font-size:16px; line-height:1.8; color:#333; margin-bottom:24px;">
        Il marketing classico è quasi sempre sinonimo di "azioni finalizzate a ottenere qualcosa
        in cambio". Ma noi partiamo da un posto diverso: la tua vera essenza.
      </p>
      <div style="background:#fff; border-left:4px solid #5551D3; padding:16px 20px; border-radius:0 8px 8px 0;">
        <p style="margin:0; font-size:15px; color:#333; font-weight:500;">
          Quando accettiamo di mostrarci davvero, <strong>non servono più strategie</strong>
          — diventiamo noi stessi un flusso che risuona solo con le persone giuste.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── ARGOMENTI ──────────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #0D0B2E;">
  <div style="max-width:1000px; margin:0 auto;">
    <p style="color:#a5b4fc; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Il programma</p>
    <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; color:#fff; margin-bottom:12px;">Ecco di cosa parleremo</h2>
    <p style="color:#999; margin-bottom:44px; font-size:16px;">Un elenco completo degli argomenti che affronteremo nelle 5 video lezioni.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr)); gap:0;">
      {topics.map(item => (
        <div class="topic-item">
          <span style="color:#5551D3; font-weight:700; flex-shrink:0; font-size:16px; margin-top:1px;">▸</span>
          <span style="color:#ddd; font-size:15px; line-height:1.5;">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── VIDEO LEZIONE GRATUITA ─────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div style="max-width:800px; margin:0 auto; text-align:center;">
    <p style="color:#5551D3; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Assaggia il percorso</p>
    <h2 style="font-size:clamp(24px,2.5vw,34px); font-weight:800; margin-bottom:16px;">Guarda la Lezione Introduttiva Gratuita</h2>
    <p style="color:#555; font-size:16px; margin-bottom:36px;">Prima di acquistare, vedi con i tuoi occhi il metodo e il mio approccio.</p>
    <div style="border-radius:12px; overflow:hidden; position:relative; background:#111; aspect-ratio:16/9;">
      <iframe
        src="https://www.youtube-nocookie.com/embed/rRAJz-LydLo?list=PLKgzAWOyM8xuq8wC6UBXhqze9Odan9JhM&rel=0&modestbranding=1"
        title="Creazione del Messaggio Autentico - Lezione Introduttiva"
        frameborder="0"
        allowfullscreen
        loading="lazy"
        style="position:absolute; top:0; left:0; width:100%; height:100%;"
      ></iframe>
    </div>
  </div>
</section>

<!-- ── A QUALI PROFESSIONISTI ─────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #f7f7f7;">
  <div style="max-width:1000px; margin:0 auto;">
    <h2 style="text-align:center; font-size:clamp(24px,3vw,36px); font-weight:800; margin-bottom:16px;">A quali figure professionali è adatto?</h2>
    <p style="text-align:center; color:#555; margin-bottom:48px; font-size:16px;">Se lavori nel mondo dell'aiuto, della crescita personale o del benessere, questo percorso è per te.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:20px;">
      {[
        { title: "Life-Coach", text: "Hai già lavorato con esperti di marketing che proponevano solo strategie. Qui non ne troverai: partiamo dal cuore." },
        { title: "Counselor", text: "Hai paura di risultare 'piazzista' o di mettere in vendita le emozioni. In questo percorso ci sei tu — loro si specchieranno." },
        { title: "Operatori Olistici", text: "Tra mille tecniche è facile perdersi. Qualunque sia la tua disciplina, al centro devi esserci sempre tu." },
        { title: "Chiunque voglia comunicare dal cuore", text: "Se senti che quello che pubblichi non è davvero te, questo percorso ti aiuterà a trovare le parole giuste." },
      ].map((item, i) => (
        <div style="background:#fff; border-radius:8px; padding:28px; position:relative; overflow:hidden;">
          <div style="font-size:42px; font-weight:900; color:rgba(85,81,211,.08); position:absolute; top:8px; right:16px; line-height:1;">{i+1}</div>
          <h4 style="font-size:15px; font-weight:700; margin-bottom:10px; padding-right:20px; color:#5551D3;">{item.title}</h4>
          <p style="color:#555; font-size:14px; line-height:1.6; margin:0;">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── CHI SONO ───────────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div class="two-col" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
    <div style="border-radius:12px; overflow:hidden; aspect-ratio:1/1; background:#111;">
      <img
        src="https://marcomunich.com/wp-content/uploads/2020/09/119536256_3677336615611976_7436592590631298239_n.jpg"
        alt="Marco Munich - Consulente Marketing Olistico"
        style="width:100%; height:100%; object-fit:cover; display:block;"
        loading="lazy"
      />
    </div>
    <div>
      <p style="color:#5551D3; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Chi sono</p>
      <p style="font-size:17px; color:#999; margin-bottom:4px;">Ciao,</p>
      <h2 style="font-size:clamp(24px,2.5vw,34px); font-weight:800; margin-bottom:20px;">Mi chiamo Marco Munich</h2>
      <p style="font-size:15px; line-height:1.8; color:#444; margin-bottom:14px;">
        <strong>Sono un Consulente Marketing Olistico.</strong> Nato il 19 Gennaio 1983,
        ex "Media Strategist super-mega-iper-expert". Creavo funnel, mi occupavo di Instagram
        Marketing e restyling — ero convinto che il successo di un messaggio fosse una questione
        di "dire la cosa giusta". Ero un fanatico della persuasione.
      </p>
      <p style="font-size:15px; line-height:1.8; color:#444; margin-bottom:20px;">
        Mi sono reso conto, abbastanza presto, di come in queste fredde azioni ripetitive
        si perdesse tutta quella magia del nostro essere umani. Ho così deciso di cambiare
        modalità ed eliminare tutti i sistemi che non aiutavano a mostrarmi per come sono realmente.
      </p>
      <div style="background:#EEF2FF; border-left:4px solid #5551D3; padding:16px 20px; border-radius:0 8px 8px 0;">
        <p style="margin:0; font-size:15px; color:#333; font-style:italic; line-height:1.7;">
          "Oggi promuoversi significa parlare onestamente, ascoltare con presenza,
          agire in compassione e comprensione, accettando l'imperfezione. Quando accettiamo
          la critica e impariamo a lasciare andare, non servono più strategie — diventiamo
          noi stessi un flusso di creatività che risuona solo con i nostri clienti ideali."
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── È IDEALE PER TE SE ─────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #EEF2FF;">
  <div style="max-width:1000px; margin:0 auto;">
    <h2 style="text-align:center; font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:48px;">È ideale per te <span style="color:#5551D3;">se:</span></h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:20px;">
      {ideals.map((item, i) => (
        <div style="background:#fff; border-radius:8px; padding:28px; position:relative; overflow:hidden;">
          <div style="font-size:42px; font-weight:900; color:rgba(85,81,211,.08); position:absolute; top:8px; right:16px; line-height:1;">{i+1}</div>
          <h4 style="font-size:15px; font-weight:700; margin-bottom:10px; padding-right:20px;">{item.title}</h4>
          <p style="color:#555; font-size:14px; line-height:1.6; margin:0;">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── COSTI ───────────────────────────────────────────────────────────── -->
<section id="costi" style="padding: 80px 24px; background: #f7f7f7;">
  <div style="max-width:1000px; margin:0 auto;">
    <p style="color:#5551D3; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:12px;">Costi</p>
    <h2 style="text-align:center; font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:12px;">Scegli come vuoi iniziare</h2>
    <p style="text-align:center; color:#555; margin-bottom:48px; font-size:16px;">Puoi fare il percorso in autonomia o con il mio supporto diretto.</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">

      <!-- Card €90 -->
      <div style="background:#fff; border-radius:12px; padding:36px; border:2px solid #eee;">
        <p style="font-size:13px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">Percorso Pre-registrato</p>
        <div style="margin-bottom:4px;">
          <span style="font-size:48px; font-weight:900; color:#06061A;">€90</span>
