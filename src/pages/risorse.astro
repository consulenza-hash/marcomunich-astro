---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Risorse — Marco Munich"
  description="Corsi gratuiti, libri, podcast e strumenti per costruire un personal branding olistico autentico. Tutto quello che serve, in un posto solo."
  currentPath="/risorse/"
>

<div class="mm-page">

  <!-- HERO -->
  <section class="rs-hero">
    <div class="rs-hero__inner mm-container">
      <p class="mm-tag" style="margin-bottom:1.2rem">Materiale gratuito e a pagamento</p>
      <h1 class="mm-h1" style="margin-bottom:2rem">Risorse.</h1>
      <p style="font-size:1.05rem;line-height:1.75;color:rgba(255,255,255,0.65);max-width:500px;font-weight:300">
        Tutto quello che ho costruito in sette anni di lavoro con coach, counselor e operatori olistici. Corsi, libri, podcast, strumenti. La maggior parte è gratuita.
      </p>
    </div>
  </section>

  <!-- PERCORSO FORMATIVO -->
  <section class="mm-section-light rs-percorso">
    <div class="mm-container">
      <p class="mm-tag mm-tag-dark" style="margin-bottom:1rem">Percorso consigliato</p>
      <h2 class="mm-h2" style="color:#0d0d0d;margin-bottom:0.8rem">Da dove partire.</h2>
      <p style="font-size:0.85rem;line-height:1.75;color:#777;margin-bottom:3rem;max-width:480px">
        Questi corsi hanno una sequenza precisa. Ognuno costruisce su quello precedente.
      </p>
      <div class="rs-steps">

        <div class="rs-step">
          <div class="rs-step__n">01</div>
          <div class="rs-step__body">
            <p class="rs-step__tag">Se sei all'inizio</p>
            <h3 class="rs-step__title">Metterci la faccia online</h3>
            <p class="rs-step__desc">Il punto di partenza. Come promuoverti senza dover fingere di essere qualcun altro. Video-corso gratuito.</p>
            <a href="/metterci-la-faccia-online/" class="mm-btn mm-btn-orange" style="font-size:0.8rem;padding:0.6rem 1.4rem">Guarda gratis →</a>
          </div>
        </div>

        <div class="rs-step">
          <div class="rs-step__n">02</div>
          <div class="rs-step__body">
            <p class="rs-step__tag">Il corso fondamentale</p>
            <h3 class="rs-step__title">Creazione del Messaggio Autentico</h3>
            <p class="rs-step__desc">Come trovare il tuo punto di vista unico e costruire un messaggio che rispecchia chi sei, senza copiare nessuno.</p>
            <a href="/creazione-messaggio-autentico/" class="mm-btn mm-btn-orange" style="font-size:0.8rem;padding:0.6rem 1.4rem">Scopri il corso →</a>
          </div>
        </div>

        <div class="rs-step">
          <div class="rs-step__n">03</div>
          <div class="rs-step__body">
            <p class="rs-step__tag">Dopo aver iniziato a scrivere</p>
            <h3 class="rs-step__title">Creazione Video Autentici</h3>
            <p class="rs-step__desc">Come parlare davanti alla camera in modo naturale. Superare la vergogna, trovare il tono giusto.</p>
            <a href="/creazione-video-autentici/" class="mm-btn mm-btn-orange" style="font-size:0.8rem;padding:0.6rem 1.4rem">Guarda gratis →</a>
          </div>
        </div>

        <div class="rs-step">
          <div class="rs-step__n">04</div>
          <div class="rs-step__body">
            <p class="rs-step__tag">Dopo almeno 30 video</p>
            <h3 class="rs-step__title">Lavorare Senza Sito Web</h3>
            <p class="rs-step__desc">Come costruire un sistema di acquisizione clienti che funziona anche partendo dai social, senza investire in un sito.</p>
            <a href="/lavorare-senzasito/" class="mm-btn mm-btn-orange" style="font-size:0.8rem;padding:0.6rem 1.4rem">Guarda il corso →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- RISORSE EXTRA -->
  <section class="mm-section-dark rs-extra">
    <div class="mm-container">
      <p class="mm-tag" style="margin-bottom:1rem">Altre risorse</p>
      <h2 class="mm-h2" style="margin-bottom:3rem">Libri, podcast e strumenti.</h2>
      <div class="rs-extra__grid">

        <a href="/libri/" class="rs-extra-card">
          <div class="rs-extra-card__icon">📚</div>
          <h3 class="rs-extra-card__title">I miei libri</h3>
          <p class="rs-extra-card__desc">Letture consigliate e i libri che ho scritto sul personal branding nel settore olistico.</p>
          <span class="rs-extra-card__link">Vedi i libri →</span>
        </a>

        <a href="https://open.spotify.com/show/2WwJsiCJYSZnawH2TQ6N2n" target="_blank" rel="noopener" class="rs-extra-card">
          <div class="rs-extra-card__icon">🎙️</div>
          <h3 class="rs-extra-card__title">Podcast</h3>
          <p class="rs-extra-card__desc">Episodi su personal branding olistico, marketing autentico e mindset per i professionisti del benessere.</p>
          <span class="rs-extra-card__link">Ascolta su Spotify →</span>
        </a>

        <a href="/prompt-pack/" class="rs-extra-card">
          <div class="rs-extra-card__icon">🤖</div>
          <h3 class="rs-extra-card__title">Prompt Pack AI</h3>
          <p class="rs-extra-card__desc">Una raccolta di prompt per usare l'intelligenza artificiale nel tuo lavoro di coach o counselor, mantenendo la tua voce.</p>
          <span class="rs-extra-card__link">Scarica il pack →</span>
        </a>

        <a href="/blog/" class="rs-extra-card">
          <div class="rs-extra-card__icon">✍️</div>
          <h3 class="rs-extra-card__title">Blog</h3>
          <p class="rs-extra-card__desc">Oltre duecento articoli su personal branding, marketing etico e presenza online per il settore olistico.</p>
          <span class="rs-extra-card__link">Leggi gli articoli →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- AUDIO MESSAGGIO -->
  <section class="mm-section-light rs-audio">
    <div class="mm-container rs-audio__inner">
      <div>
        <p class="mm-tag mm-tag-dark" style="margin-bottom:0.8rem">Messaggio di benvenuto</p>
        <h2 class="mm-h2" style="color:#0d0d0d;margin-bottom:0.8rem">Ascolta prima di iniziare.</h2>
        <p style="font-size:0.85rem;line-height:1.75;color:#777;max-width:420px">
          Un breve audio in cui spiego il metodo e come usare le risorse che trovi qui. Meno di 5 minuti.
        </p>
      </div>
      <div class="rs-audio__player">
        <audio controls class="rs-audio__ctrl" controlslist="nodownload" playsinline>
          <source src="/audio/nuovo-benvenuto-sito.mp3" type="audio/mpeg" />
        </audio>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="home-cta">
    <div class="mm-container home-cta__inner">
      <div>
        <h2 class="mm-h2">Preferisci lavorare insieme?</h2>
        <p style="color:rgba(255,255,255,0.75);font-size:0.9rem;margin-top:0.5rem">Una chiamata gratuita. Capisco la tua situazione e ti dico cosa farei.</p>
      </div>
      <a href="/contatti/" class="mm-btn mm-btn-white">Parliamo →</a>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .rs-hero {
    background: #0d0d0d;
    padding: 9rem 0 5rem;
    min-height: 55vh;
    display: flex;
    align-items: center;
  }
  .rs-percorso { padding: 5rem 0; }
  .rs-steps { display: flex; flex-direction: column; gap: 0; }
  .rs-step {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2.5rem;
    padding: 2.5rem 0;
    border-bottom: 1px solid #e8e8e8;
    align-items: start;
  }
  .rs-step:first-child { border-top: 1px solid #e8e8e8; }
  .rs-step__n {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 2.8rem;
    color: #eee;
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .rs-step__tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #e85d00;
    margin-bottom: 0.4rem;
  }
  .rs-step__title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: #0d0d0d;
    letter-spacing: -0.01em;
    margin-bottom: 0.5rem;
  }
  .rs-step__desc {
    font-size: 0.85rem;
    line-height: 1.75;
    color: #666;
    margin-bottom: 1rem;
    max-width: 480px;
  }

  /* Extra grid */
  .rs-extra { padding: 5rem 0; }
  .rs-extra__grid {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 1px;
    background: #1a1a1a;
    border: 1px solid #1a1a1a;
  }
  .rs-extra-card {
    background: #0d0d0d;
    padding: 2.5rem 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.15s;
  }
  .rs-extra-card:hover { background: #141414; opacity: 1; }
  .rs-extra-card__icon { font-size: 1.8rem; margin-bottom: 0.4rem; }
  .rs-extra-card__title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    color: #fff;
    letter-spacing: -0.01em;
  }
  .rs-extra-card__desc {
    font-size: 0.8rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.4);
    flex: 1;
  }
  .rs-extra-card__link {
    font-size: 0.75rem;
    font-weight: 700;
    color: #e85d00;
    margin-top: 0.5rem;
  }

  /* Audio */
  .rs-audio { padding: 4rem 0; }
  .rs-audio__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .rs-audio__ctrl {
    width: 100%;
    accent-color: #e85d00;
  }

  .home-cta { background: #e85d00; padding: 4.5rem 0; }
  .home-cta__inner { display: flex; justify-content: space-between; align-items: center; gap: 2rem; }

  @media (max-width: 768px) {
    .rs-step { grid-template-columns: 60px 1fr; gap: 1.5rem; }
    .rs-extra__grid { grid-template-columns: 1fr; }
    .rs-audio__inner { grid-template-columns: 1fr; gap: 2rem; }
    .home-cta__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
