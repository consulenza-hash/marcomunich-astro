---
import BaseLayout from '@layouts/BaseLayout.astro';

const steps = [
  {
    n: '01',
    tag: 'Se sei all\'inizio',
    titolo: 'Metterci la faccia online',
    desc: 'Il punto di partenza per chiunque voglia promuoversi online in modo autentico, senza vergogna e senza fingere di essere qualcun altro.',
    href: '/metterci-la-faccia-online/',
    cta: 'Video-Corso Gratuito',
    secondary: { href: '/libri/', cta: 'I miei libri' },
    color: '#D4840A',
    bg: '#FEF6EC',
    border: '#F0A040',
  },
  {
    n: '02',
    tag: 'Il corso fondamentale',
    titolo: 'Creazione del Messaggio Autentico',
    desc: 'Quando senti di avere qualcosa da dire, questo corso ti aiuta a trovare il tuo punto di vista unico e a strutturare un messaggio che rispecchi chi sei davvero.',
    href: '/creazione-messaggio-autentico/',
    cta: 'Scopri il Corso',
    color: '#5551D3',
    bg: '#EEEEFF',
    border: '#5551D3',
  },
  {
    n: '03',
    tag: 'Dopo aver iniziato a scrivere',
    titolo: 'Creazione Video Autentici',
    desc: 'Quando hai già iniziato a scrivere e creare contenuti, questo corso ti aiuta a superare la vergogna di fare video e a parlare davanti alla camera in modo naturale.',
    href: '/creazione-video-autentici/',
    cta: 'Video-Corso Gratuito',
    color: '#C0292A',
    bg: '#FEF0F0',
    border: '#C0292A',
  },
  {
    n: '04',
    tag: 'Dopo almeno 30 video',
    titolo: 'Lavorare Senza Sito Web',
    desc: 'Quando avrai fatto almeno trenta video parlando dal tuo centro, questo corso ti mostra come costruire un sistema di acquisizione clienti senza dipendere da un sito.',
    href: '/lavorare-senzasito/',
    cta: 'Guarda il Corso',
    color: '#1A7A4E',
    bg: '#EBF7EF',
    border: '#1A7A4E',
  },
];

const socials = [
  {
    href: 'https://www.facebook.com/profile.php?id=61569131883012',
    label: 'Facebook',
    icon: `<svg viewBox="0 0 264 512" fill="currentColor"><path d="M76.7 512V283H0v-91h76.7v-71.7C76.7 42.4 124.3 0 193.8 0c33.3 0 61.9 2.5 70.2 3.6V85h-48.2c-37.8 0-45.1 18-45.1 44.3V192H256l-11.7 91h-73.6v229"/></svg>`,
  },
  {
    href: 'https://www.instagram.com/marcomunich1983',
    label: 'Instagram',
    icon: `<svg viewBox="0 0 448 512" fill="currentColor"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z"/></svg>`,
  },
  {
    href: 'https://open.spotify.com/show/2WwJsiCJYSZnawH2TQ6N2n',
    label: 'Spotify',
    icon: `<svg viewBox="0 0 496 512" fill="currentColor"><path d="M248 8C111.1 8 0 119.1 0 256s111.1 248 248 248 248-111.1 248-248S384.9 8 248 8zm100.7 364.9c-4.2 0-6.8-1.3-10.7-3.6-62.4-37.6-135-39.2-206.7-24.5-3.9 1-9 2.6-11.9 2.6-9.7 0-15.8-7.7-15.8-15.8 0-10.3 6.1-15.2 13.6-16.8 81.9-18.1 165.6-16.5 237 26.2 6.1 3.9 9.7 7.4 9.7 16.5s-7.1 15.4-15.2 15.4zm26.9-65.6c-5.2 0-8.7-2.3-12.3-4.2-62.5-37-155.7-51.9-238.6-29.4-4.8 1.3-7.4 2.6-11.9 2.6-10.7 0-19.4-8.7-19.4-19.4s5.2-17.8 15.5-20.7c27.8-7.8 56.2-13.6 97.8-13.6 64.9 0 127.6 16.1 177 45.5 8.1 4.8 11.3 11 11.3 19.7-.1 10.8-8.5 19.5-19.4 19.5zm31-76.2c-5.2 0-8.4-1.3-12.9-3.9-71.2-42.5-198.5-52.7-280.9-29.7-3.6 1-8.1 2.6-12.9 2.6-13.2 0-23.3-10.3-23.3-23.6 0-13.6 8.4-21.3 17.4-23.9 35.2-10.3 74.6-15.2 117.5-15.2 73 0 149.5 15.2 205.4 47.8 7.8 4.5 12.9 10.7 12.9 22.6 0 13.6-11 23.3-23.2 23.3z"/></svg>`,
