<!-- ══ PERCORSO ════════════════════════════════════════════════════════════ -->
<section class="percorso">
  <div class="percorso__inner">
    <div class="section-header">
      <span class="section-label">Il percorso</span>
      <h2 class="section-title">Da dove iniziare</h2>
      <p class="section-subtitle">Segui questi passi nell'ordine che ti propongo. Ogni risorsa si appoggia sulla precedente.</p>
    </div>

    <div class="steps">
      <div class="step step--01">
        <div class="step__number">01</div>
        <div class="step__content">
          <span class="step__tag">Se sei all'inizio</span>
          <h3 class="step__title">Metterci la faccia online</h3>
          <p class="step__desc">Il punto di partenza per chiunque voglia promuoversi online in modo autentico, senza vergogna e senza fingere di essere qualcun altro.</p>
          <div class="step__actions">
            <a href="/metterci-la-faccia-online/" class="step__btn step__btn--primary">Video-Corso Gratuito <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg></a>
            <a href="/libri/" class="step__btn step__btn--secondary">I miei libri</a>
          </div>
        </div>
      </div>

      <div class="step step--02">
        <div class="step__number">02</div>
        <div class="step__content">
          <span class="step__tag">Il corso fondamentale</span>
          <h3 class="step__title">Creazione del Messaggio Autentico</h3>
          <p class="step__desc">Quando senti di avere qualcosa da dire, questo corso ti aiuta a trovare il tuo punto di vista unico e a strutturare un messaggio che rispecchi chi sei davvero.</p>
          <div class="step__actions">
            <a href="/creazione-messaggio-autentico/" class="step__btn step__btn--primary">Scopri il Corso <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg></a>
          </div>
        </div>
      </div>

      <div class="step step--03">
        <div class="step__number">03</div>
        <div class="step__content">
          <span class="step__tag">Dopo aver iniziato a scrivere</span>
          <h3 class="step__title">Creazione Video Autentici</h3>
          <p class="step__desc">Quando hai già iniziato a scrivere e creare contenuti, questo corso ti aiuta a superare la vergogna di fare video e a parlare davanti alla camera in modo naturale.</p>
          <div class="step__actions">
            <a href="/creazione-video-autentici/" class="step__btn step__btn--primary">Video-Corso Gratuito <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg></a>
          </div>
        </div>
      </div>

      <div class="step">
        <div class="step__number">04</div>
        <div class="step__content">
          <span class="step__tag">Dopo almeno 30 video</span>
          <h3 class="step__title">Lavorare Senza Sito Web</h3>
          <p class="step__desc">Quando avrai fatto almeno trenta video parlando dal tuo centro, questo corso ti mostra come costruire un sistema di acquisizione clienti senza dipendere da un sito.</p>
          <div class="step__actions">
            <a href="/lavorare-senzasito/" class="step__btn step__btn--primary">Guarda il Corso <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"/></svg></a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ VIDEO ══════════════════════════════════════════════════════════════ -->
<section class="video-section">
  <div class="video-inner">
    <div class="video-wrap">
      <iframe
        src="https://www.youtube.com/embed/DW-Mj8QxPg8?rel=0&modestbranding=1"
        title="Marco Munich — Personal Branding Olistico"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>

<!-- ══ DELEGATE ═══════════════════════════════════════════════════════════ -->
<section class="delegate">
  <div class="delegate__inner">
    <span class="section-label section-label--light">Collaborazione</span>
    <h2 class="delegate__title">Vuoi delegarmi del lavoro?</h2>
    <p class="delegate__desc">Se senti di avere già un messaggio autentico e cerchi qualcuno che ti metta in piedi un sistema di acquisizione clienti, considera una di queste opzioni.</p>

    <div class="delegate__services">
      <div class="delegate__service delegate__service--highlight">
        <span class="delegate__service-badge">In evidenza</span>
        <h3 class="delegate__service-title">Sviluppo Siti Web ad Alte Prestazioni</h3>
        <p class="delegate__service-desc">Siti veloci, ottimizzati per i motori di ricerca e costruiti per convertire. Niente template generici: ogni progetto viene pensato attorno al tuo messaggio e al tuo sistema di acquisizione clienti.</p>
      </div>
      <div class="delegate__service">
        <h3 class="delegate__service-title">Sistema di Prenotazione Appuntamenti</h3>
        <p class="delegate__service-desc">Installazione e configurazione del sistema automatico di prenotazione, così i tuoi clienti possono fissare una call senza passare per i messaggi.</p>
      </div>
      <div class="delegate__service">
        <h3 class="delegate__service-title">Creazione Corso Online</h3>
        <p class="delegate__service-desc">Trasformo le tue conoscenze in un corso strutturato e vendibile, dalla piattaforma alla pagina di vendita.</p>
      </div>
    </div>

    <a href="https://wa.link/eemovr" target="_blank" class="delegate__cta">
      <svg viewBox="0 0 448 512"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/></svg>
      Contattami su WhatsApp
    </a>
  </div>
</section>

