---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Risorse — Marco Munich"
  description="Il percorso completo per sviluppare un Personal Branding Olistico autentico. Corsi gratuiti, libri, podcast e tutto quello che serve per promuoverti come voce diversa."
  currentPath="/risorse/"
>

<!-- ══ HERO ════════════════════════════════════════════════════════════════ -->
<section class="hero">
  <div class="hero__inner">
    <div class="hero__profile">
      <img class="hero__avatar" src="/og/marco-munich.png" alt="Marco Munich" width="101" height="101" />
      <div class="hero__identity">
        <p class="hero__name">Marco Munich</p>
        <p class="hero__role">Personal Branding Olistico</p>
      </div>
    </div>

    <h1 class="hero__claim">
      Sviluppa un punto di vista per promuoverti online come voce diversa dalle altre.
    </h1>

    <div class="hero__audio-wrap">
      <p class="hero__audio-label">Ascolta il messaggio di benvenuto</p>
      <audio controls class="hero__audio" controlslist="nodownload" playsinline>
        <source src="/audio/nuovo-benvenuto-sito.mp3" type="audio/mpeg" />
      </audio>
    </div>

