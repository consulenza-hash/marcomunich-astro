</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; }

.section-label {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #858585;
  margin-bottom: 0.75rem;
}
.section-label--light { color: rgba(255,255,255,0.45); }
.section-title {
  font-size: clamp(1.75rem, 3vw, 2.4rem);
  font-weight: 800;
  color: #0A0A0A;
  line-height: 1.15;
  margin-bottom: 0.75rem;
}
.section-subtitle {
  font-size: 1rem;
  color: #555;
  line-height: 1.6;
  max-width: 520px;
  margin: 0;
}

/* ── HERO ─────────────────────────────────────────────────────────────── */
.hero { background: #0A0A0A; padding: 5rem 1.5rem 4rem; }
.hero__inner {
  max-width: 660px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.75rem;
}
.hero__profile { display: flex; align-items: center; gap: 1.1rem; }
.hero__avatar {
  width: 101px; height: 101px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255,255,255,0.15);
  flex-shrink: 0;
}
.hero__identity { text-align: left; }
.hero__name {
  font-size: 1.09rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #fff;
  margin: 0;
}
.hero__role {
  font-size: 1.01rem;
  letter-spacing: 0.05em;
  color: rgba(255,255,255,0.4);
  margin: 0.2rem 0 0;
}
.hero__claim {
  font-size: clamp(1.3rem, 3.5vw, 1.85rem);
  font-weight: 300;
  color: #fff;
  line-height: 1.5;
  margin: 0;
}
.hero__audio-wrap { width: 100%; max-width: 460px; }
.hero__audio-label {
  font-size: 0.68rem;
