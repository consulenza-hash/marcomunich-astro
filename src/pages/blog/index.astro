---
/**
 * blog/index.astro
 * Pagina blog — griglia 3 colonne con tutti gli articoli.
 * Replica esatta della pagina /blog-consulenza-marketing/
 * con header scuro, hero banner, search (statica) e griglia card.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import jsYaml from 'js-yaml';

// Legge tutti i .mdoc a build time tramite import.meta.glob (no fetch API)
const rawFiles = import.meta.glob('/src/content/articoli/*/index.mdoc', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

const posts = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug   = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
  const fmStr  = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm     = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    titolo:     (fm.titolo     as string) ?? slug,
    descrizione:(fm.descrizione as string) ?? '',
    data:       fm.data ? String(fm.data) : '',
    immagine:   fm.immagine ? `/images/articoli/${fm.immagine}` : null,
  };
}).sort((a, b) => new Date(b.data).getTime() - new Date(a.data).getTime());
---

<BaseLayout
  title="Blog Marketing Olistico - Marco Munich"
  description="Articoli su personal branding autentico, marketing etico e mindset per coach, counselor e operatori olistici."
  currentPath="/blog/"
>

  <!-- ── Hero banner blog ─────────────────────────────────────────────────── -->
  <section class="blog-hero">
    <div class="blog-hero__overlay"></div>
    <div class="blog-hero__content">
      <h1 class="blog-hero__title">Blog Marketing Olistico</h1>
      <p class="blog-hero__subtitle">Benvenuto</p>
    </div>
  </section>

  <!-- ── Corpo pagina ─────────────────────────────────────────────────────── -->
  <div class="blog-body site-wrapper">

    <!-- Search (statica — filtra via JS leggero) -->
    <div class="blog-search">
      <input
        type="search"
        id="blog-search-input"
        placeholder="Cerca"
        aria-label="Cerca articoli"
        class="blog-search__input"
      />
      <button class="blog-search__btn" aria-label="Cerca">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
        </svg>
        Cerca
      </button>
    </div>

    <!-- Griglia articoli -->
    <div class="blog-grid" id="blog-grid">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>

    <!-- Nessun risultato (nascosto di default) -->
    <p class="blog-noresults" id="blog-noresults" aria-live="polite" hidden>
      Nessun articolo trovato per questa ricerca.
    </p>

  </div>

</BaseLayout>

<!-- Search client-side minimale (filtra per titolo, categoria e tag via data-search) -->
<script>
  function setupBlogSearch() {
    const input  = document.getElementById('blog-search-input') as HTMLInputElement;
    const btn    = document.querySelector('.blog-search__btn');
    const grid   = document.getElementById('blog-grid');
    const noRes  = document.getElementById('blog-noresults');
    const cards  = grid?.querySelectorAll('.post-card');

    function performSearch() {
      const query = input.value.trim().toLowerCase();
      let visible = 0;

      cards?.forEach((card) => {
        const searchData = card.getAttribute('data-search') ?? '';
        const show = !query || searchData.includes(query);
        (card as HTMLElement).style.display = show ? '' : 'none';
        if (show) visible++;
      });

      if (noRes) noRes.hidden = visible > 0;
    }

    input?.addEventListener('input', performSearch);
    
    // Supporto click bottone e tasto Enter
    btn?.addEventListener('click', performSearch);
    input?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        performSearch();
      }
    });

    console.log('Blog search setup complete');
  }

  // Esegui al caricamento e dopo eventuali navigazioni Astro
  setupBlogSearch();
  document.addEventListener('astro:page-load', setupBlogSearch);
</script>

<style>
  /* ── Hero banner ─────────────────────────────────────────────────────────── */
  .blog-hero {
    position: relative;
    height: 280px;
    background-image: url('https://marcomunich.com/wp-content/uploads/thrive-theme/images/Blog-List-simple-_02-1-8-1.jpg');
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Fallback colore se immagine manca */
    background-color: #2a2a2a;
  }

  .blog-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
  }

  .blog-hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: white;
  }

  .blog-hero__title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 700;
    color: white;
    margin-bottom: 8px;
  }

  .blog-hero__subtitle {
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.7);
  }

  /* ── Body ────────────────────────────────────────────────────────────────── */
  .blog-body {
    padding-top: 48px;
    padding-bottom: 80px;
  }

  /* ── Search ──────────────────────────────────────────────────────────────── */
  .blog-search {
    display: flex;
    gap: 0;
    margin-bottom: 40px;
    width: 100%;
  }

  .blog-search__input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid #E5E5E5;
    border-right: none;
    font-size: 14px;
    font-family: inherit;
    outline: none;
  }
  .blog-search__input:focus {
    border-color: #1E2B2F;
  }

  .blog-search__btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 20px;
    background: #1E2B2F;
    color: white;
    border: none;
    font-size: 13px;
    font-family: inherit;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.05em;
    transition: background 0.15s;
  }
  .blog-search__btn:hover { background: #333; }

  /* ── Griglia 3 colonne ───────────────────────────────────────────────────── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 40px 32px;
  }

  .blog-noresults {
    text-align: center;
    color: rgba(10,10,10,0.5);
    padding: 40px 0;
    font-size: 15px;
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .blog-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .blog-grid { grid-template-columns: minmax(0, 1fr); }
    .blog-hero  { height: 200px; }
  }
</style>
