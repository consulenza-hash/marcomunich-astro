---
/**
 * blog/index.astro
 * Pagina blog — lista articoli con ricerca client-side
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import jsYaml from 'js-yaml';

const rawFiles = import.meta.glob('/src/content/articoli/*/index.mdoc', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

const posts = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug   = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
  const fmStr  = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm     = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    titolo:     (fm.titolo     as string) ?? slug,
    descrizione:(fm.descrizione as string) ?? '',
    data:       fm.data ? String(fm.data) : '',
    categoria:  (fm.categoria  as string) ?? '',
    immagine:   fm.immagine ? `/images/articoli/${fm.immagine}` : null,
    bozza:      fm.bozza === true,
  };
}).filter(p => !p.bozza).sort((a, b) => new Date(b.data).getTime() - new Date(a.data).getTime());
---

<BaseLayout
  title="Articoli — Marco Munich"
  description="Oltre 200 articoli su personal branding olistico, marketing autentico e presenza online per coach, counselor e operatori olistici."
  currentPath="/blog/"
>

<div class="mm-page">

  <!-- HERO -->
  <section class="bl-hero">
    <div class="bl-hero__inner mm-container">
      <p class="mm-tag" style="margin-bottom:1.2rem">Articoli</p>
      <h1 class="mm-h1" style="margin-bottom:2rem">Blog.</h1>
      <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.55);max-width:480px;font-weight:300">
        {posts.length} articoli su personal branding olistico, marketing autentico e presenza online per chi lavora nel settore del benessere.
      </p>
    </div>
  </section>

  <!-- RICERCA + LISTA -->
  <section class="mm-section-light bl-body">
    <div class="mm-container">

      <!-- Search -->
      <div class="bl-search">
        <input
          type="search"
          id="bl-search-input"
          placeholder="Cerca tra gli articoli…"
          aria-label="Cerca articoli"
          class="bl-search__input"
        />
      </div>

      <!-- Lista articoli -->
      <div id="bl-grid">
        {posts.map((post, i) => (
          <a
            href={`/${post.slug}/`}
            class="bl-item"
            data-search={`${post.titolo} ${post.categoria} ${post.descrizione}`.toLowerCase()}
          >
            <span class="bl-item__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="bl-item__cat">{post.categoria || 'Articolo'}</span>
            <span class="bl-item__title">{post.titolo}</span>
            <span class="bl-item__arrow">→</span>
          </a>
        ))}
      </div>

      <p class="bl-noresults" id="bl-noresults" aria-live="polite" hidden>
        Nessun articolo trovato.
      </p>

    </div>
  </section>

</div>

</BaseLayout>

<script>
  function setupSearch() {
    const input = document.getElementById('bl-search-input') as HTMLInputElement;
    const grid  = document.getElementById('bl-grid');
    const noRes = document.getElementById('bl-noresults');
    const items = grid?.querySelectorAll('.bl-item');

    input?.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      items?.forEach((item) => {
        const match = !q || (item.getAttribute('data-search') ?? '').includes(q);
        (item as HTMLElement).style.display = match ? '' : 'none';
        if (match) visible++;
      });
      if (noRes) noRes.hidden = visible > 0;
    });
  }
  setupSearch();
  document.addEventListener('astro:page-load', setupSearch);
</script>

<style>
  .bl-hero {
    background: #0d0d0d;
    padding: 9rem 0 5rem;
    min-height: 50vh;
    display: flex;
    align-items: center;
  }
  .bl-body { padding: 4rem 0 6rem; }

  /* Search */
  .bl-search { margin-bottom: 2.5rem; }
  .bl-search__input {
    width: 100%;
    max-width: 480px;
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    padding: 0.75rem 1.2rem;
    border: 1.5px solid #e0e0e0;
    border-radius: 50px;
    background: #fff;
    color: #0d0d0d;
    outline: none;
    transition: border-color 0.15s;
  }
  .bl-search__input::placeholder { color: #aaa; }
  .bl-search__input:focus { border-color: #0d0d0d; }

  /* Lista */
  .bl-item {
    display: grid;
    grid-template-columns: 44px 140px 1fr 24px;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid #ebebeb;
    text-decoration: none;
    transition: background 0.1s;
  }
  .bl-item:first-child { border-top: 1px solid #ebebeb; }
  .bl-item:hover { background: #fafafa; opacity: 1; }
  .bl-item:hover .bl-item__title { color: #e85d00; }
  .bl-item:hover .bl-item__arrow { color: #e85d00; }

  .bl-item__num {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    color: #ccc;
    letter-spacing: 0.05em;
  }
  .bl-item__cat {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #aaa;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bl-item__title {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    color: #0d0d0d;
    line-height: 1.4;
    transition: color 0.15s;
  }
  .bl-item__arrow {
    font-size: 0.9rem;
    color: #ccc;
    text-align: right;
    transition: color 0.15s;
  }
  .bl-noresults {
    font-size: 0.85rem;
    color: #999;
    padding: 2rem 0;
  }

  @media (max-width: 768px) {
    .bl-item {
      grid-template-columns: 36px 1fr 20px;
      gap: 0.8rem;
    }
    .bl-item__cat { display: none; }
  }
</style>
