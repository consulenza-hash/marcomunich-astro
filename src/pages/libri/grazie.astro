---
import BaseLayout from '@layouts/BaseLayout.astro';

const sessionId = Astro.url.searchParams.get('session_id') ?? '';
const bookSlug  = Astro.url.searchParams.get('book') ?? '';

const BUNDLE_SLUGS = ['scrivere-per-restare', 'restare-autentici-con-ai', 'un-anno-di-scrittura'];

const PDF_BOOKS: Record<string, { name: string }> = {
  'scrivere-per-restare':      { name: 'Scrivere per Restare' },
  'restare-autentici-con-ai':  { name: "Restare Autentici Scrivendo con l'AI" },
  'un-anno-di-scrittura':      { name: 'Un Anno di Scrittura per Scoprire Chi Sei Davvero' },
  'bundle-tutti':               { name: 'Pacchetto Completo — tutti i PDF' },
};

const isBundle   = bookSlug === 'bundle-tutti';
const bookName   = PDF_BOOKS[bookSlug]?.name ?? 'il tuo libro';
const hasPdfBook = !!PDF_BOOKS[bookSlug];
---

<BaseLayout
  title="Grazie per l'acquisto — Marco Munich"
  description="Il tuo PDF è in arrivo via email."
  currentPath="/libri/grazie"
  noIndex={true}
>

<section class="gr-section">
  <div class="gr-card">

    <div class="gr-icon" aria-hidden="true">✓</div>

    <h1 class="gr-title">
      {isBundle ? 'I tuoi libri sono in arrivo.' : 'Il tuo libro è in arrivo.'}
    </h1>

    {hasPdfBook ? (
      <p class="gr-body">
        Riceverai un'email con {isBundle ? 'i link per scaricare tutti i PDF' : `il link per scaricare <strong>${bookName}</strong>`} entro uno o due minuti.
        Controlla anche la cartella spam se non la trovi subito.
      </p>
    ) : (
      <p class="gr-body">
        Riceverai il PDF via email entro pochi minuti all'indirizzo usato per il pagamento.
        Controlla anche la cartella spam se non lo trovi subito.
      </p>
    )}

    <p class="gr-note">
      Il link di download è valido per 30 giorni. Se hai problemi o non ricevi l'email entro 5 minuti,
      scrivi su <a href="https://wa.me/3895776332">WhatsApp</a> e lo risolviamo subito.
    </p>

    <div class="gr-actions">
      <a href="/libri" class="gr-btn gr-btn--ghost">← Torna ai libri</a>
      <a href="/" class="gr-btn">Home</a>
    </div>

    {sessionId && (
      <p class="gr-session">Ordine: {sessionId}</p>
    )}

  </div>
</section>

</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.gr-section {
  background: var(--black);
  min-height: 85vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 5rem var(--pad);
}
.gr-card {
  max-width: 560px;
  width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.4rem;
}
.gr-icon {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: rgba(232,89,12,0.12);
  border: 1.5px solid rgba(232,89,12,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
  color: var(--gold);
  margin-bottom: 0.4rem;
}
.gr-title {
  font: 800 clamp(1.8rem, 3.5vw, 2.6rem)/1.1 var(--display);
  color: var(--white);
  letter-spacing: -0.02em;
}
.gr-body {
  font: 400 1rem/1.7 var(--sans);
  color: rgba(255,255,255,0.65);
  max-width: 460px;
}
.gr-body strong { color: var(--white); font-weight: 600; }
.gr-note {
  font: 400 0.85rem/1.65 var(--sans);
  color: rgba(255,255,255,0.35);
  max-width: 440px;
}
.gr-note a { color: var(--gold); text-decoration: none; }
.gr-note a:hover { text-decoration: underline; }
.gr-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 0.4rem;
}
.gr-btn {
  display: inline-block;
  padding: 0.75rem 1.6rem;
  border-radius: 4px;
  font: 700 0.88rem/1 var(--sans);
  text-decoration: none;
  background: var(--gold);
  color: #fff;
  transition: opacity 0.15s;
}
.gr-btn:hover { opacity: 0.85; }
.gr-btn--ghost {
  background: transparent;
  color: rgba(255,255,255,0.45);
  border: 1px solid rgba(255,255,255,0.12);
}
.gr-session {
  font: 400 0.72rem/1 var(--sans);
  color: rgba(255,255,255,0.18);
  margin-top: 0.5rem;
}
</style>
