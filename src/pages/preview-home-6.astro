---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Preview Home 6 — Memphis Play"
  description="Mockup direzione Memphis/playful."
  currentPath="/preview-home-6/"
>

<div class="m6-page">

  <!-- Geometric ornaments -->
  <span class="m6-shape m6-shape--circle" style="top:8vh;right:5%"></span>
  <span class="m6-shape m6-shape--zigzag" style="top:60vh;left:2%"></span>
  <span class="m6-shape m6-shape--triangle" style="top:130vh;right:8%"></span>
  <span class="m6-shape m6-shape--dots" style="top:200vh;left:5%"></span>
  <span class="m6-shape m6-shape--cross" style="top:280vh;right:10%"></span>

  <!-- ── HERO ──────────────────────────────────────────────────────────── -->
  <section class="m6-hero">
    <div class="m6-container">
      <div class="m6-hero__sticker">
        <span>★ AVAILABLE</span>
        <span>★ MAGGIO 2026</span>
      </div>
      <h1 class="m6-hero__title">
        Costruisco
        <span class="m6-pill m6-pill--orange">siti</span>,
        <span class="m6-pill m6-pill--mint">app</span>,<br>
        e <span class="m6-underline">presenze online</span><br>
        che <span class="m6-italic">funzionano davvero.</span>
      </h1>
      <p class="m6-hero__sub">
        Marco Munich, studio indipendente di Vicenza. Sviluppo web e consulenza posizionamento per chi vende se stesso. Niente template. Niente plugin obbligatori. Niente fuffa.
      </p>
      <div class="m6-hero__ctas">
        <a href="#progetti" class="m6-btn m6-btn--orange">Vedi i progetti ↓</a>
        <a href="/contatti/" class="m6-btn m6-btn--ghost">Parliamone</a>
      </div>
    </div>
  </section>

  <!-- ── INFINITE BANNER ───────────────────────────────────────────────── -->
  <div class="m6-banner">
    <div class="m6-banner__track">
      <span>★ SVILUPPO WEB</span>
      <span>● POSIZIONAMENTO</span>
      <span>▲ NIENTE TEMPLATE</span>
      <span>★ DAL 2019</span>
      <span>● VICENZA / IT</span>
      <span>▲ SVILUPPO WEB</span>
      <span>● POSIZIONAMENTO</span>
      <span>★ NIENTE TEMPLATE</span>
      <span>● DAL 2019</span>
      <span>▲ VICENZA / IT</span>
    </div>
  </div>

  <!-- ── SERVIZI ───────────────────────────────────────────────────────── -->
  <section class="m6-services">
    <div class="m6-container">
      <h2 class="m6-section-title">Cosa <span class="m6-italic">faccio</span>.</h2>
      <div class="m6-services__grid">

        <div class="m6-card m6-card--orange">
          <div class="m6-card__icon">⚡</div>
          <h3 class="m6-card__title">Sviluppo</h3>
          <p>
            Siti, landing, e-commerce, web app. Astro, FastAPI, codice pulito. Performance verificabili, piena proprietà dei file alla consegna.
          </p>
          <a href="/portfolio/" class="m6-card__link">Vedi progetti →</a>
        </div>

        <div class="m6-card m6-card--mint">
          <div class="m6-card__icon">✺</div>
          <h3 class="m6-card__title">Posizionamento</h3>
          <p>
            Per chi vende se stesso. Sette anni di consulenza nel settore olistico, oltre duecento articoli, un metodo che non si compra in un corso.
          </p>
          <a href="/servizi/posizionamento-online/" class="m6-card__link">Scopri come →</a>
        </div>

        <div class="m6-card m6-card--cream">
          <div class="m6-card__icon">◐</div>
          <h3 class="m6-card__title">Vibe Coding</h3>
          <p>
            Guidare l'AI per costruire più velocemente, con codice migliore. Il mio metodo, dichiarato apertamente.
          </p>
          <a href="/vibe-coding/" class="m6-card__link">Come funziona →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- ── NUMERI BIG BLOCKS ──────────────────────────────────────────── -->
  <section class="m6-stats">
    <div class="m6-container">
      <div class="m6-stats__grid">
        <div class="m6-stat m6-stat--blue">
          <span class="m6-stat__big">218</span>
          <span class="m6-stat__label">Articoli sul blog</span>
        </div>
        <div class="m6-stat m6-stat--orange">
          <span class="m6-stat__big">7</span>
          <span class="m6-stat__label">Anni di lavoro</span>
        </div>
        <div class="m6-stat m6-stat--mint">
          <span class="m6-stat__big">100</span>
          <span class="m6-stat__label">PageSpeed score</span>
        </div>
        <div class="m6-stat m6-stat--pink">
          <span class="m6-stat__big">0</span>
          <span class="m6-stat__label">Template usati</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROGETTI ─────────────────────────────────────────────────────── -->
  <section class="m6-projects" id="progetti">
    <div class="m6-container">
      <h2 class="m6-section-title">Lavori <span class="m6-italic">recenti</span>.</h2>
      <div class="m6-projects__grid">
        <a href="/portfolio/" class="m6-proj">
          <div class="m6-proj__visual m6-proj__visual--orange">
            <span class="m6-proj__shape m6-proj__shape--c"></span>
          </div>
          <span class="m6-proj__year">2026</span>
          <h3 class="m6-proj__name">marcomunich.com</h3>
          <p class="m6-proj__type">Sito + CMS custom</p>
        </a>
        <a href="/portfolio/" class="m6-proj">
          <div class="m6-proj__visual m6-proj__visual--mint">
            <span class="m6-proj__shape m6-proj__shape--t"></span>
          </div>
          <span class="m6-proj__year">2026</span>
          <h3 class="m6-proj__name">Vela</h3>
          <p class="m6-proj__type">Web app · FastAPI</p>
        </a>
        <a href="/portfolio/" class="m6-proj">
          <div class="m6-proj__visual m6-proj__visual--pink">
            <span class="m6-proj__shape m6-proj__shape--s"></span>
          </div>
          <span class="m6-proj__year">2026</span>
          <h3 class="m6-proj__name">cms.marcomunich</h3>
          <p class="m6-proj__type">Migrazione Ghost</p>
        </a>
        <a href="/portfolio/" class="m6-proj">
          <div class="m6-proj__visual m6-proj__visual--blue">
            <span class="m6-proj__shape m6-proj__shape--c"></span>
          </div>
          <span class="m6-proj__year">2026</span>
          <h3 class="m6-proj__name">Inspiration Bot</h3>
          <p class="m6-proj__type">Pipeline Telegram</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────────────────────── -->
  <section class="m6-cta">
    <div class="m6-container">
      <div class="m6-cta__box">
        <h2>
          Hai un progetto<br>
          <span class="m6-italic">in mente?</span>
        </h2>
        <p>Una chiamata gratuita di 30 min. Capisco la tua situazione, ti dico cosa farei al tuo posto.</p>
        <a href="/contatti/" class="m6-btn m6-btn--white">Fissa una chiamata ★</a>
      </div>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  :root {
    --m6-cream: #faf3e0;
    --m6-orange: #ff7536;
    --m6-mint: #b6e3c5;
    --m6-pink: #f5b3c1;
    --m6-blue: #80a4d6;
    --m6-yellow: #ffd84d;
    --m6-ink: #1a1814;
  }
  .m6-page {
    background: var(--m6-cream);
    color: var(--m6-ink);
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
    position: relative;
  }
  .m6-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
  }
  .m6-italic {
    font-family: 'Caveat', 'Comic Sans MS', cursive;
    font-style: normal;
    color: var(--m6-orange);
    font-weight: 600;
  }

  /* ─── SHAPES (decorative) ─── */
  .m6-shape {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }
  .m6-shape--circle {
    width: 100px; height: 100px;
    border: 4px solid var(--m6-orange);
    border-radius: 50%;
  }
  .m6-shape--zigzag {
    width: 80px; height: 30px;
    background:
      linear-gradient(135deg, transparent 45%, var(--m6-pink) 45%, var(--m6-pink) 55%, transparent 55%) 0 0/20px 20px,
      linear-gradient(45deg, transparent 45%, var(--m6-pink) 45%, var(--m6-pink) 55%, transparent 55%) 0 0/20px 20px;
  }
  .m6-shape--triangle {
    width: 0; height: 0;
    border-left: 35px solid transparent;
    border-right: 35px solid transparent;
    border-bottom: 60px solid var(--m6-mint);
    transform: rotate(15deg);
  }
  .m6-shape--dots {
    width: 90px; height: 90px;
    background-image: radial-gradient(var(--m6-blue) 3px, transparent 3px);
    background-size: 18px 18px;
  }
  .m6-shape--cross {
    width: 40px; height: 40px;
    background:
      linear-gradient(var(--m6-yellow) 0 0) center/100% 6px no-repeat,
      linear-gradient(var(--m6-yellow) 0 0) center/6px 100% no-repeat;
  }

  /* ─── HERO ─── */
  .m6-hero {
    padding: 6rem 0 5rem;
    position: relative;
    z-index: 1;
  }
  .m6-hero__sticker {
    display: inline-flex;
    gap: 0.6rem;
    background: var(--m6-yellow);
    color: var(--m6-ink);
    padding: 0.55rem 1.1rem;
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    border: 3px solid var(--m6-ink);
    border-radius: 999px;
    transform: rotate(-2deg);
    margin-bottom: 2.5rem;
    box-shadow: 4px 4px 0 var(--m6-ink);
  }
  .m6-hero__title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 7vw, 6.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--m6-ink);
    margin: 0 0 2rem;
  }
  .m6-pill {
    display: inline-block;
    padding: 0 0.6rem;
    border-radius: 999px;
    font-weight: 900;
    line-height: 1;
    transform: rotate(-2deg);
    box-shadow: 4px 4px 0 var(--m6-ink);
    border: 3px solid var(--m6-ink);
  }
  .m6-pill--orange {
    background: var(--m6-orange);
    color: #fff;
  }
  .m6-pill--mint {
    background: var(--m6-mint);
    color: var(--m6-ink);
    transform: rotate(2deg);
  }
  .m6-underline {
    background: linear-gradient(transparent 60%, var(--m6-yellow) 60%, var(--m6-yellow) 90%, transparent 90%);
    padding: 0 0.2rem;
  }
  .m6-hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #4a4438;
    max-width: 580px;
    margin: 0 0 2.5rem;
  }
  .m6-hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .m6-btn {
    display: inline-block;
    padding: 1rem 2rem;
    font-weight: 800;
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 999px;
    border: 3px solid var(--m6-ink);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 5px 5px 0 var(--m6-ink);
  }
  .m6-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0 var(--m6-ink);
  }
  .m6-btn--orange { background: var(--m6-orange); color: #fff; }
  .m6-btn--ghost { background: var(--m6-cream); color: var(--m6-ink); }
  .m6-btn--white { background: #fff; color: var(--m6-ink); }

  /* ─── BANNER ─── */
  .m6-banner {
    background: var(--m6-ink);
    color: var(--m6-cream);
    overflow: hidden;
    border-top: 4px solid var(--m6-ink);
    border-bottom: 4px solid var(--m6-ink);
    padding: 1rem 0;
  }
  .m6-banner__track {
    display: flex;
    gap: 3rem;
    white-space: nowrap;
    animation: m6scroll 28s linear infinite;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.15em;
  }
  @keyframes m6scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ─── SECTION TITLE ─── */
  .m6-section-title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--m6-ink);
    margin: 0 0 3.5rem;
  }

  /* ─── SERVIZI ─── */
  .m6-services {
    padding: 6rem 0;
    position: relative;
    z-index: 1;
  }
  .m6-services__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .m6-card {
    border: 3px solid var(--m6-ink);
    border-radius: 28px;
    padding: 2.5rem 2rem;
    box-shadow: 8px 8px 0 var(--m6-ink);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.15s ease;
  }
  .m6-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 11px 11px 0 var(--m6-ink);
  }
  .m6-card--orange { background: var(--m6-orange); color: #fff; }
  .m6-card--mint { background: var(--m6-mint); }
  .m6-card--cream { background: #fff; }
  .m6-card__icon {
    font-size: 2rem;
    width: 60px; height: 60px;
    border: 3px solid var(--m6-ink);
    background: var(--m6-cream);
    color: var(--m6-ink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.5rem;
  }
  .m6-card--orange .m6-card__icon { background: var(--m6-yellow); }
  .m6-card__title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 1.8rem;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .m6-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0;
  }
  .m6-card--orange p { color: #fff5ee; }
  .m6-card__link {
    margin-top: auto;
    font-weight: 800;
    color: inherit;
    text-decoration: none;
    border-bottom: 3px solid currentColor;
    align-self: flex-start;
    padding-bottom: 0.2rem;
  }

  /* ─── STATS ─── */
  .m6-stats {
    padding: 4rem 0;
    position: relative;
    z-index: 1;
  }
  .m6-stats__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
  }
  .m6-stat {
    border: 3px solid var(--m6-ink);
    border-radius: 24px;
    padding: 2rem 1.5rem;
    box-shadow: 6px 6px 0 var(--m6-ink);
    text-align: center;
  }
  .m6-stat--blue { background: var(--m6-blue); color: #fff; }
  .m6-stat--orange { background: var(--m6-orange); color: #fff; }
  .m6-stat--mint { background: var(--m6-mint); }
  .m6-stat--pink { background: var(--m6-pink); }
  .m6-stat__big {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 6vw, 5rem);
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-bottom: 0.6rem;
  }
  .m6-stat__label {
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
  }

  /* ─── PROGETTI ─── */
  .m6-projects {
    padding: 6rem 0;
    position: relative;
    z-index: 1;
  }
  .m6-projects__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .m6-proj {
    text-decoration: none;
    color: var(--m6-ink);
    background: #fff;
    border: 3px solid var(--m6-ink);
    border-radius: 28px;
    padding: 2rem;
    box-shadow: 6px 6px 0 var(--m6-ink);
    transition: transform 0.15s ease;
  }
  .m6-proj:hover { transform: translate(-3px, -3px); box-shadow: 9px 9px 0 var(--m6-ink); }
  .m6-proj__visual {
    aspect-ratio: 16/9;
    border: 3px solid var(--m6-ink);
    border-radius: 16px;
    margin-bottom: 1.4rem;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .m6-proj__visual--orange { background: var(--m6-orange); }
  .m6-proj__visual--mint { background: var(--m6-mint); }
  .m6-proj__visual--pink { background: var(--m6-pink); }
  .m6-proj__visual--blue { background: var(--m6-blue); }
  .m6-proj__shape {
    width: 80px;
    height: 80px;
  }
  .m6-proj__shape--c {
    border-radius: 50%;
    background: #fff;
    border: 4px solid var(--m6-ink);
  }
  .m6-proj__shape--t {
    width: 0; height: 0;
    border-left: 45px solid transparent;
    border-right: 45px solid transparent;
    border-bottom: 80px solid #fff;
    filter: drop-shadow(0 0 0 var(--m6-ink));
  }
  .m6-proj__shape--s {
    background: #fff;
    border: 4px solid var(--m6-ink);
  }
  .m6-proj__year {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--m6-orange);
    letter-spacing: 0.1em;
  }
  .m6-proj__name {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 1.7rem;
    letter-spacing: -0.02em;
    margin: 0.4rem 0 0.5rem;
  }
  .m6-proj__type {
    font-size: 0.95rem;
    color: #4a4438;
    margin: 0;
  }

  /* ─── CTA ─── */
  .m6-cta {
    padding: 5rem 0 7rem;
    position: relative;
    z-index: 1;
  }
  .m6-cta__box {
    background: var(--m6-ink);
    color: var(--m6-cream);
    border-radius: 32px;
    padding: 5rem 3rem;
    text-align: center;
    border: 3px solid var(--m6-ink);
    box-shadow: 10px 10px 0 var(--m6-orange);
  }
  .m6-cta__box h2 {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    margin: 0 0 1.5rem;
  }
  .m6-cta__box p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(250,243,224,0.8);
    max-width: 540px;
    margin: 0 auto 2.5rem;
  }

  @media (max-width: 768px) {
    .m6-services__grid,
    .m6-stats__grid,
    .m6-projects__grid { grid-template-columns: 1fr; }
    .m6-stats__grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
    .m6-cta__box { padding: 3.5rem 2rem; }
  }
</style>

<script>
if (!document.querySelector('link[href*="Caveat"]')) {
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = 'https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&display=swap';
  document.head.appendChild(link);
}
</script>
