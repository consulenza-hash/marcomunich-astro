---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Preview Sito 2 — Modern Tech" description="Sito completo, mood Linear/Vercel." currentPath="/preview-site-2/">

<div class="ps2-page">
  <header class="ps2-nav">
    <div class="ps2-container ps2-nav__inner">
      <a href="#" class="ps2-logo"><span class="ps2-logo__sym">▣</span> Marco Munich</a>
      <nav class="ps2-menu">
        <a href="#cosa">Cosa costruisco</a>
        <a href="#lavori">Lavori</a>
        <a href="#metodo">Metodo</a>
        <a href="/contatti/" class="ps2-menu__cta">Contattami →</a>
      </nav>
    </div>
  </header>

  <!-- ── HERO ──────────────────────────────────────────────────── -->
  <section class="ps2-hero">
    <div class="ps2-hero__glow"></div>
    <div class="ps2-container">
      <span class="ps2-pill">
        <span class="ps2-pulse"></span>
        Disponibile da Maggio 2026
      </span>
      <h1 class="ps2-h1">
        Sviluppo siti<br>
        <span class="ps2-h1__accent">e applicazioni</span> web<br>
        per chi vende se stesso.
      </h1>
      <p class="ps2-hero__sub">
        Astro, FastAPI, codice pulito. Niente template, niente plugin obbligatori, niente abbonamenti mensili. Performance verificabili e file tutti tuoi alla consegna.
      </p>
      <div class="ps2-hero__ctas">
        <a href="/contatti/" class="ps2-btn ps2-btn--primary">Inizia un progetto →</a>
        <a href="#lavori" class="ps2-btn ps2-btn--ghost">Vedi i lavori</a>
      </div>
    </div>
  </section>

  <!-- ── COSA COSTRUISCO ─────────────────────────────────────── -->
  <section class="ps2-section" id="cosa">
    <div class="ps2-container">
      <div class="ps2-section__head">
        <p class="ps2-eyebrow">▸ Cosa costruisco</p>
        <h2 class="ps2-h2">Quattro tipi di lavoro.</h2>
      </div>
      <div class="ps2-services">
        <div class="ps2-service">
          <div class="ps2-service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/></svg>
          </div>
          <h3>Siti vetrina</h3>
          <p>Per professionisti, studi, attività locali. Costruiti sul tuo modo di lavorare e sul cliente che vuoi attirare.</p>
        </div>
        <div class="ps2-service">
          <div class="ps2-service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 3h6v6"/><path d="M10 14L21 3"/><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/></svg>
          </div>
          <h3>Landing page</h3>
          <p>Una pagina sola, costruita per convertire. Per lanci, campagne, raccolta contatti.</p>
        </div>
        <div class="ps2-service">
          <div class="ps2-service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
          </div>
          <h3>E-commerce</h3>
          <p>Negozi online con pagamenti sicuri e gestione prodotti. Stripe o PayPal a seconda del progetto.</p>
        </div>
        <div class="ps2-service">
          <div class="ps2-service__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3>Web app custom</h3>
          <p>Quando il sito non basta più. Dashboard, area riservata, automazioni, integrazione con API esterne.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── LAVORI ────────────────────────────────────────────── -->
  <section class="ps2-section ps2-section--alt" id="lavori">
    <div class="ps2-container">
      <div class="ps2-section__head ps2-section__head--row">
        <div>
          <p class="ps2-eyebrow">▸ Demo navigabili</p>
          <h2 class="ps2-h2">Lavori selezionati.</h2>
        </div>
        <a href="/portfolio/" class="ps2-link">Tutti i lavori →</a>
      </div>
      <p class="ps2-section__lead">
        Una selezione di siti che ho progettato come dimostrazioni del tipo di lavoro che faccio. Sono <span class="ps2-mark">demo</span>, non clienti reali. Ognuna è completamente navigabile.
      </p>

      <div class="ps2-works">
        <a href="/portfolio/yoga-studio" class="ps2-work">
          <div class="ps2-work__cover ps2-work__cover--01"></div>
          <span class="ps2-work__year">2026 · Demo</span>
          <h3>Studio yoga</h3>
          <p>Sito vetrina con prenotazioni e listino corsi.</p>
        </a>
        <a href="/portfolio/ristorante" class="ps2-work">
          <div class="ps2-work__cover ps2-work__cover--02"></div>
          <span class="ps2-work__year">2026 · Demo</span>
          <h3>Ristorante</h3>
          <p>Vetrina, menu, storia, galleria foto.</p>
        </a>
        <a href="/portfolio/ecommerce" class="ps2-work">
          <div class="ps2-work__cover ps2-work__cover--03"></div>
          <span class="ps2-work__year">2026 · Demo</span>
          <h3>E-commerce</h3>
          <p>Catalogo, scheda prodotto, carrello, checkout.</p>
        </a>
        <a href="/portfolio/booking" class="ps2-work">
          <div class="ps2-work__cover ps2-work__cover--04"></div>
          <span class="ps2-work__year">2026 · Demo</span>
          <h3>Studio professionale</h3>
          <p>Booking online, area cliente, pagamenti.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ── METODO ────────────────────────────────────────────── -->
  <section class="ps2-section" id="metodo">
    <div class="ps2-container ps2-method__inner">
      <div>
        <p class="ps2-eyebrow">▸ Come lavoro</p>
        <h2 class="ps2-h2">Più veloce.<br>Stesso risultato.</h2>
        <p class="ps2-section__lead" style="max-width:520px">
          Non scrivo codice riga per riga. Guido <span class="ps2-mark">l'intelligenza artificiale</span> per costruire siti e applicazioni che funzionano. Risultato: stesso output di sviluppo tradizionale, più veloce e con meno errori.
        </p>
        <a href="/vibe-coding/" class="ps2-link">Come funziona, in pratica →</a>
      </div>
      <ul class="ps2-method__list">
        <li><span>01.</span> Capisco il progetto in una chiamata.</li>
        <li><span>02.</span> Disegno la struttura, tu approvi.</li>
        <li><span>03.</span> Costruisco con anteprime live.</li>
        <li><span>04.</span> Consegno: codice, file, documentazione.</li>
      </ul>
    </div>
  </section>

  <!-- ── CTA ─────────────────────────────────────────────── -->
  <section class="ps2-cta">
    <div class="ps2-cta__glow"></div>
    <div class="ps2-container">
      <p class="ps2-eyebrow ps2-eyebrow--accent">▸ Lavoriamo insieme</p>
      <h2 class="ps2-cta__title">
        Hai un progetto<br>
        <span class="ps2-h1__accent">in mente?</span>
      </h2>
      <p class="ps2-cta__sub">
        Una chiamata gratuita di trenta minuti. Capisco la tua situazione, ti dico se posso aiutarti davvero. Se non posso, te lo dico subito.
      </p>
      <a href="/contatti/" class="ps2-btn ps2-btn--primary ps2-btn--big">Fissa una chiamata →</a>
    </div>
  </section>

  <!-- ── FOOTER ────────────────────────────────────────────── -->
  <footer class="ps2-foot">
    <div class="ps2-container ps2-foot__inner">
      <div>
        <p class="ps2-logo"><span class="ps2-logo__sym">▣</span> Marco Munich</p>
        <p class="ps2-foot__tag">Sviluppo web · Vicenza, IT · 2019—2026</p>
      </div>
      <div class="ps2-foot__cols">
        <a href="/portfolio/">Lavori</a>
        <a href="/servizi/posizionamento-online/">Posizionamento</a>
        <a href="/vibe-coding/">Vibe coding</a>
        <a href="/chi-sono/">Chi sono</a>
        <a href="/contatti/">Contatti</a>
      </div>
    </div>
  </footer>
</div>

</BaseLayout>

<style>
  .ps2-page {
    background: #0a0a0d;
    color: #f0f0f5;
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
  }
  .ps2-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; width: 100%; }

  /* ─── NAV ─── */
  .ps2-nav {
    border-bottom: 1px solid rgba(240,240,245,0.08);
    background: rgba(10,10,13,0.85);
    backdrop-filter: blur(20px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .ps2-nav__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }
  .ps2-logo {
    color: #f0f0f5;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .ps2-logo__sym { color: #6cf2ad; font-size: 1.1rem; }
  .ps2-menu { display: flex; gap: 1.8rem; align-items: center; }
  .ps2-menu a {
    color: rgba(240,240,245,0.7);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .ps2-menu a:hover { color: #f0f0f5; }
  .ps2-menu__cta {
    background: linear-gradient(135deg, #6cf2ad 0%, #4ad6ff 100%);
    color: #0a0a0d !important;
    padding: 0.55rem 1.1rem;
    border-radius: 8px;
    font-weight: 600 !important;
  }
  .ps2-menu__cta:hover { opacity: 0.9; }

  /* ─── HERO ─── */
  .ps2-hero {
    padding: 8rem 0 7rem;
    position: relative;
    overflow: hidden;
  }
  .ps2-hero__glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(108,242,173,0.12) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  .ps2-hero > .ps2-container { position: relative; z-index: 1; }
  .ps2-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(108,242,173,0.08);
    border: 1px solid rgba(108,242,173,0.3);
    color: #6cf2ad;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 500;
    margin-bottom: 2.5rem;
  }
  .ps2-pulse {
    width: 8px; height: 8px;
    background: #6cf2ad;
    border-radius: 50%;
    animation: ps2pulse 2s infinite;
  }
  @keyframes ps2pulse {
    0%,100% { box-shadow: 0 0 0 0 rgba(108,242,173,0.5); }
    50% { box-shadow: 0 0 0 8px transparent; }
  }
  .ps2-h1 {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: clamp(2.8rem, 7vw, 6.5rem);
    line-height: 1;
    letter-spacing: -0.045em;
    margin: 0 0 2rem;
    color: #fff;
  }
  .ps2-h1__accent {
    background: linear-gradient(120deg, #6cf2ad 0%, #4ad6ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .ps2-hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(240,240,245,0.7);
    max-width: 560px;
    margin: 0 0 2.5rem;
  }
  .ps2-hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .ps2-btn {
    padding: 0.85rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .ps2-btn--primary {
    background: linear-gradient(135deg, #6cf2ad 0%, #4ad6ff 100%);
    color: #0a0a0d;
    box-shadow: 0 0 30px rgba(108,242,173,0.25);
  }
  .ps2-btn--primary:hover { transform: translateY(-2px); box-shadow: 0 0 40px rgba(108,242,173,0.4); }
  .ps2-btn--ghost {
    background: rgba(240,240,245,0.05);
    color: #f0f0f5;
    border: 1px solid rgba(240,240,245,0.15);
  }
  .ps2-btn--ghost:hover { background: rgba(240,240,245,0.1); }
  .ps2-btn--big { padding: 1.1rem 2rem; font-size: 1rem; }

  /* ─── SECTIONS ─── */
  .ps2-section { padding: 7rem 0; border-top: 1px solid rgba(240,240,245,0.06); }
  .ps2-section--alt { background: rgba(255,255,255,0.02); }
  .ps2-section__head { margin-bottom: 3.5rem; max-width: 720px; }
  .ps2-section__head--row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 100%;
  }
  .ps2-eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #6cf2ad;
    letter-spacing: 0.05em;
    margin: 0 0 1rem;
  }
  .ps2-eyebrow--accent { color: #4ad6ff; }
  .ps2-h2 {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: clamp(2.2rem, 4.5vw, 3.8rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 0 0 1.5rem;
  }
  .ps2-section__lead {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(240,240,245,0.7);
    max-width: 580px;
    margin: 0;
  }
  .ps2-mark {
    background: rgba(108,242,173,0.15);
    color: #6cf2ad;
    padding: 0.05em 0.3em;
    border-radius: 4px;
    font-weight: 500;
  }
  .ps2-link {
    color: #6cf2ad;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    border-bottom: 1px solid rgba(108,242,173,0.4);
    padding-bottom: 0.2rem;
  }

  /* ─── SERVICES ─── */
  .ps2-services {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(240,240,245,0.08);
    border: 1px solid rgba(240,240,245,0.08);
    border-radius: 12px;
    overflow: hidden;
  }
  .ps2-service {
    background: #0d0d11;
    padding: 2.5rem 2rem;
    transition: background 0.2s ease;
  }
  .ps2-service:hover { background: #12121a; }
  .ps2-service__icon {
    width: 44px; height: 44px;
    background: rgba(108,242,173,0.1);
    color: #6cf2ad;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .ps2-service__icon svg { width: 22px; height: 22px; }
  .ps2-service h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.25rem;
    color: #f0f0f5;
    margin: 0 0 0.6rem;
    letter-spacing: -0.02em;
  }
  .ps2-service p {
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgba(240,240,245,0.65);
    margin: 0;
  }

  /* ─── WORKS ─── */
  .ps2-works {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .ps2-work {
    background: #0d0d11;
    border: 1px solid rgba(240,240,245,0.08);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: #f0f0f5;
    transition: all 0.25s ease;
  }
  .ps2-work:hover {
    border-color: rgba(108,242,173,0.4);
    transform: translateY(-3px);
  }
  .ps2-work__cover {
    height: 200px;
    border-radius: 8px;
    margin-bottom: 1.4rem;
  }
  .ps2-work__cover--01 { background: linear-gradient(135deg, #6cf2ad 0%, #2a8a5e 100%); }
  .ps2-work__cover--02 { background: linear-gradient(135deg, #ff8b4a 0%, #c43e00 100%); }
  .ps2-work__cover--03 { background: linear-gradient(135deg, #4ad6ff 0%, #1a5a85 100%); }
  .ps2-work__cover--04 { background: linear-gradient(135deg, #c08eff 0%, #5a2a8a 100%); }
  .ps2-work__year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: rgba(240,240,245,0.5);
    display: block;
    margin-bottom: 0.4rem;
  }
  .ps2-work h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 1.3rem;
    margin: 0 0 0.4rem;
    letter-spacing: -0.02em;
  }
  .ps2-work p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(240,240,245,0.65);
    margin: 0;
  }

  /* ─── METHOD ─── */
  .ps2-method__inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .ps2-method__list {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
  }
  .ps2-method__list li {
    padding: 1.4rem 0;
    border-top: 1px solid rgba(240,240,245,0.1);
    color: #f0f0f5;
    font-size: 1.02rem;
    line-height: 1.5;
    display: grid;
    grid-template-columns: 50px 1fr;
    gap: 1rem;
    align-items: start;
  }
  .ps2-method__list li:last-child { border-bottom: 1px solid rgba(240,240,245,0.1); }
  .ps2-method__list span {
    font-family: 'JetBrains Mono', monospace;
    color: #6cf2ad;
    font-size: 0.9rem;
  }

  /* ─── CTA ─── */
  .ps2-cta {
    padding: 9rem 0;
    text-align: center;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(240,240,245,0.08);
  }
  .ps2-cta__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%,-50%);
    width: 800px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(74,214,255,0.15) 0%, transparent 60%);
    pointer-events: none;
  }
  .ps2-cta > .ps2-container { position: relative; z-index: 1; }
  .ps2-cta__title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: #fff;
    margin: 1rem 0 1.5rem;
  }
  .ps2-cta__sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(240,240,245,0.65);
    max-width: 540px;
    margin: 0 auto 3rem;
  }

  /* ─── FOOTER ─── */
  .ps2-foot {
    border-top: 1px solid rgba(240,240,245,0.06);
    padding: 4rem 0 3rem;
  }
  .ps2-foot__inner {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .ps2-foot__tag { font-size: 0.85rem; color: rgba(240,240,245,0.5); margin: 0.4rem 0 0; }
  .ps2-foot__cols { display: flex; gap: 2rem; flex-wrap: wrap; }
  .ps2-foot__cols a {
    color: rgba(240,240,245,0.7);
    text-decoration: none;
    font-size: 0.92rem;
  }
  .ps2-foot__cols a:hover { color: #6cf2ad; }

  @media (max-width: 768px) {
    .ps2-menu { gap: 0.8rem; }
    .ps2-menu a:not(.ps2-menu__cta) { display: none; }
    .ps2-services, .ps2-works { grid-template-columns: 1fr; }
    .ps2-method__inner { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
