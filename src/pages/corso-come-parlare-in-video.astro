---
import BaseLayout from '@layouts/BaseLayout.astro';

const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3" fill="currentColor" stroke="none"/></svg>`,
    title: "Andare oltre la vergogna",
    text: "Superare la paura di stare davanti alla telecamera e imparare a divertirti pure!"
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>`,
    title: "Parlare con sicurezza",
    text: "Come parlare con sicurezza senza qualcuno che ti dice cosa dire o ti tira fuori le parole."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="15" height="14" rx="2"/><path d="M17 9l5-3v12l-5-3"/></svg>`,
    title: "Evitare di leggere cosa dire",
    text: "Ricordare cosa dire senza testo davanti: la spontaneità conta più del discorso perfetto."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    title: "Mostrarsi per come sei",
    text: "Aprirti al mondo con il tuo modo di essere, attirando solo persone a cui risuoni davvero."
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12" y2="18" stroke-width="3" stroke-linecap="round"/></svg>`,
    title: "Strumenti semplici",
    text: "Essere conciso e naturale senza imparare video editing o tecniche complesse."
  },
];

const topics = [
  "Come mi faccio venire le idee per i miei video",
  "Come li pianifico e preparo per la pubblicazione",
  "Come creo i video (condizioni ambientali e strumenti)",
  "Come decido quanto lunghi farli, senza sforzo",
  "Quali mezzi utilizzo (camera/webcam/microfoni)",
  "Metodi semplici per avere un'ottima luce senza spendere troppo",
  "Cosa uso per registrare lo schermo e fare video lezioni",
  "Come decidere se fare una live o una sessione registrata",
  "Montaggio semplicissimo con PC o Smartphone",
  "Dove pubblicare e tutte le informazioni necessarie",
  "Come catturare l'attenzione nei primi 15 secondi",
  "Come porto interazioni sui miei video",
];

const ideals = [
  { title: "Ti vergogni di mostrarti", text: "Hai un blocco e senti che non c'è modo di capire da dove venga o come aggirarlo." },
  { title: "Ti manca la continuità", text: "Hai difficoltà ad essere continuo/a nella creazione, e così l'algoritmo non ti promuove." },
  { title: "Ti piace l'autenticità che presento", text: "Hai visto i miei video e ti è stato chiesto \"come faccio\" — questo percorso risponde a questa domanda." },
  { title: "Fare video \"per vendere\" ti infastidisce", text: "Non sopporti l'idea di fare video solo per vendere: ti aiuterò a vedere un altro angolo." },
];

const testimonials = [
  { name: "Veronica Veneziani", role: "Operatore Olistico", title: "Partire da sé stessi", quote: "Questo corso è illuminante, aiuta a fare marketing partendo da sé stessi, utilizzando il proprio potenziale per presentarsi al meglio di ciò che si è." },
  { name: "Maria Cristina Andreoni", role: "Health & Life Coach", title: "Non ci si sente mai pronti", quote: "Il percorso con Marco è stato il mio primo passo concreto per uscire allo scoperto come coach, grazie al suo modo di accompagnarmi attraverso i dubbi di chi non si sente mai sufficientemente pronto." },
  { name: "Daniela Capraro", role: "Operatore Olistico", title: "Metterci la faccia", quote: "Questo corso mi sta stimolando a usare la mia creatività. Ho acquisito una struttura per costruire al meglio i miei contenuti: risulto molto più chiara e professionale." },
];
---

<BaseLayout
  title="Come parlare in Video restando sé stessi - Marco Munich"
  description="3 Video Lezioni per iniziare a produrre contenuti video superando il timore del giudizio, in modo autentico e senza stress."
  currentPath="/corso-come-parlare-in-video/"
>

<style is:global>
  :root {
    --red: #DC2626;
    --red-dark: #991B1B;
    --red-light: #FEF2F2;
    --dark: #0D0404;
    --dark2: #1A0808;
  }

  .video-page .btn-red {
    display: inline-block;
    background: var(--red);
    color: #fff;
    padding: 16px 36px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    letter-spacing: .5px;
    transition: background .2s;
  }
  .video-page .btn-red:hover { background: var(--red-dark); opacity: 1; }

  .video-page .btn-outline-red {
    display: inline-block;
    background: transparent;
    color: var(--red);
    padding: 14px 32px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    border: 2px solid var(--red);
    transition: all .2s;
  }
  .video-page .btn-outline-red:hover { background: var(--red); color: #fff; opacity: 1; }

  .rec-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(220,38,38,.15);
    border: 1px solid rgba(220,38,38,.4);
    color: #fca5a5;
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
  }
  .rec-dot {
    width: 10px; height: 10px;
    background: #DC2626;
    border-radius: 50%;
    animation: rec-blink 1.2s ease-in-out infinite;
  }
  @keyframes rec-blink { 0%,100%{opacity:1} 50%{opacity:.3} }

  /* Camera frame UI element */
  .cam-frame {
    border: 3px solid rgba(220,38,38,.5);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }
  .cam-frame::before {
    content: '';
    position: absolute; top: 12px; right: 12px;
    width: 12px; height: 12px;
    background: #DC2626;
    border-radius: 50%;
    z-index: 2;
    box-shadow: 0 0 0 3px rgba(220,38,38,.3);
    animation: rec-blink 1.2s ease-in-out infinite;
  }
  .cam-frame::after {
    content: '⬤ REC';
    position: absolute; top: 10px; left: 14px;
    font-size: 11px; font-weight: 800;
    color: #DC2626; letter-spacing: 2px;
    z-index: 2;
  }

  .feature-icon svg { width: 36px; height: 36px; color: var(--red); }
  .topic-item { display: flex; gap: 12px; align-items: flex-start; padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .topic-item:last-child { border: none; }

  .video-page { overflow-x: hidden; }

  @media (max-width: 768px) {
    /* Grid 2-col → 1 col */
    .video-page .vp-grid {
      display: block !important;
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    .video-page .vp-grid > * {
      width: 100% !important;
      max-width: 100% !important;
      margin-bottom: 32px;
    }
    .video-page .vp-grid > *:last-child { margin-bottom: 0; }

    /* Nasconde immagine hero */
    .video-page .vp-hero-img {
      display: none !important;
      visibility: hidden !important;
    }

    /* Sezione "Parlerò anche di" */
    .video-page .vp-talk {
      display: block !important;
      grid-template-columns: 1fr !important;
    }

    /* Pricing */
    .video-page .vp-costs {
      display: block !important;
      grid-template-columns: 1fr !important;
      max-width: 520px !important;
      margin-left: auto !important;
      margin-right: auto !important;
    }
    .video-page .vp-costs > * {
      width: 100% !important;
      margin-bottom: 24px;
    }
    .video-page .vp-costs > *:last-child { margin-bottom: 0; }
    .video-page .vp-cost-featured { margin-top: 20px !important; }

    /* Padding sezioni */
    .video-page section {
      padding-top: 48px !important;
      padding-bottom: 48px !important;
    }
  }
</style>

<div class="video-page">

<!-- ── HERO ──────────────────────────────────────────────────────────────── -->
<section style="background: #0D0404; color: #fff; padding: 80px 24px 0;">
  <div class="vp-grid" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">

    <!-- Testo -->
    <div>
      <div class="rec-badge" style="margin-bottom: 24px;">
        <span class="rec-dot"></span> VIDEO CORSO
      </div>
      <h1 style="font-size: clamp(34px, 4.5vw, 54px); font-weight: 800; line-height: 1.1; color: #fff; margin-bottom: 20px;">
        Come parlare in Video<br><span style="color: #DC2626;">restando sé stessi</span>
      </h1>
      <p style="font-size: 17px; line-height: 1.7; color: #bbb; margin-bottom: 36px;">
        3 Video Lezioni per chi vuole iniziare a fare video superando il timore
        del giudizio — in modo autentico, senza perfezione.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <a href="https://www.youtube.com/playlist?list=PLKgzAWOyM8xvs-UytKUtY4wsgjbHxU4Ge" target="_blank" rel="noopener" class="btn-red">Guarda il corso gratuitamente →</a>
        <a href="#costi" class="btn-outline-red">Vuoi farlo con me?</a>
      </div>
    </div>

    <!-- Camera frame con immagine -->
    <div class="vp-hero-img" style="padding-bottom: 48px;">
      <div class="cam-frame" style="aspect-ratio: 4/3; background: #1a0808;">
        <img
          src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=700&q=80&fit=crop"
          alt="Professionista olistica che registra un video"
          style="width:100%; height:100%; object-fit:cover; display:block; opacity:.75;"
          loading="eager"
        />
        <!-- HUD overlay -->
        <div style="position:absolute; bottom:0; left:0; right:0; padding:14px 16px; background:linear-gradient(transparent,rgba(0,0,0,.7)); display:flex; justify-content:space-between; align-items:flex-end;">
          <span style="color:#fff; font-size:12px; font-family:monospace;">00:03:24</span>
          <span style="color:#DC2626; font-size:11px; font-weight:700; letter-spacing:1px;">● LIVE</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Striscia decorativa -->
  <div style="max-width:1100px; margin:48px auto 0; display:flex; gap:24px; flex-wrap:wrap; padding-bottom:40px; border-top:1px solid rgba(255,255,255,.07); padding-top:32px;">
    {[
      { n: "3", label: "Video lezioni" },
      { n: "3h+", label: "di contenuto" },
      { n: "1", label: "Gruppo Telegram privato" },
    ].map(s => (
      <div>
        <p style="font-size:32px; font-weight:800; color:#DC2626; margin:0; line-height:1;">{s.n}</p>
        <p style="font-size:13px; color:#888; margin:4px 0 0; letter-spacing:.5px;">{s.label}</p>
      </div>
    ))}
  </div>
</section>

<!-- ── FARE IL PRIMO VIDEO ─────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div style="max-width: 1080px; margin: 0 auto;">
    <div class="vp-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center; margin-bottom:60px;">
      <div>
        <p style="color:#DC2626; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Il percorso</p>
        <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:16px;">Fare il tuo Primo Video e Divertirti</h2>
        <p style="color:#555; font-size:16px; line-height:1.8;">
          Creare video semplici per condividere il tuo messaggio autentico,
          rispettando chi sei veramente — perché metterci la faccia è molto meglio
          di qualsiasi altra forma di marketing.
        </p>
      </div>
      <div style="border-radius:12px; overflow:hidden; aspect-ratio:16/10; background:#111;">
        <img
          src="https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?w=700&q=80&fit=crop"
          alt="Coach olistica che registra una sessione per i suoi clienti"
          style="width:100%; height:100%; object-fit:cover; display:block;"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Feature grid -->
    <h3 style="text-align:center; font-size:18px; font-weight:600; color:#555; margin-bottom:36px;">Nel corso imparerai a:</h3>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(260px,1fr)); gap:20px;">
      {features.map(f => (
        <div style="border:1px solid #f0f0f0; border-top:3px solid #DC2626; border-radius:8px; padding:24px;">
          <div class="feature-icon" style="margin-bottom:12px;" set:html={f.icon} />
          <h4 style="font-size:15px; font-weight:700; text-transform:uppercase; letter-spacing:.5px; margin-bottom:8px;">{f.title}</h4>
          <p style="color:#555; font-size:14px; line-height:1.6; margin:0;">{f.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TI RISUONA ─────────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #FEF2F2;">
  <div class="vp-grid" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
    <div style="border-radius:12px; overflow:hidden; aspect-ratio:4/5; background:#111; position:relative;">
      <img
        src="https://images.unsplash.com/photo-1545389336-cf090694435e?w=600&q=80&fit=crop"
        alt="Operatrice olistica in meditazione, ambiente sereno"
        style="width:100%; height:100%; object-fit:cover; display:block;"
        loading="lazy"
      />
      <!-- Quote decorativa -->
      <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent,rgba(13,4,4,.85)); padding:28px 24px;">
        <p style="color:#fff; font-size:16px; font-style:italic; margin:0; line-height:1.5;">
          "Sono me stesso al 100% — questo è il traguardo."
        </p>
        <p style="color:#fca5a5; font-size:13px; margin:8px 0 0;">— Marco Munich</p>
      </div>
    </div>
    <div>
      <p style="color:#DC2626; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Perché il video?</p>
      <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:20px;">Ti risuona?</h2>
      <p style="font-size:16px; line-height:1.8; color:#333; margin-bottom:16px;">
        Se sei in questa pagina, probabilmente hai già visto un mio video.
        Non saranno perfetti, non avranno luci professionali — ma sono me stesso al 100%.
      </p>
      <p style="font-size:16px; line-height:1.8; color:#333; margin-bottom:24px;">
        Il video è il miglior mezzo per ottenere credibilità e fiducia: trasmette mimica,
        tonalità di voce, modo di essere — cose impossibili da comunicare solo con il testo.
      </p>
      <div style="background:#fff; border-left:4px solid #DC2626; padding:16px 20px; border-radius:0 8px 8px 0;">
        <p style="margin:0; font-size:15px; color:#333; font-weight:500;">
          Il problema è il <strong>perfezionismo</strong> — anche per me lo è stato.
          Nel tempo ho imparato che la spontaneità vale più della perfezione.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ── ARGOMENTI ──────────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #1A0808;">
  <div style="max-width:1000px; margin:0 auto;">
    <p style="color:#fca5a5; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Il programma</p>
    <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; color:#fff; margin-bottom:12px;">Ecco di cosa parleremo</h2>
    <p style="color:#999; margin-bottom:44px; font-size:16px;">Un elenco completo degli argomenti che affronteremo nel percorso.</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px,1fr)); gap:0;">
      {topics.map(item => (
        <div class="topic-item">
          <span style="color:#DC2626; font-weight:700; flex-shrink:0; font-size:16px; margin-top:1px;">▸</span>
          <span style="color:#ddd; font-size:15px; line-height:1.5;">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── TELEGRAM ───────────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div class="vp-grid" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
    <div>
      <p style="color:#DC2626; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Community</p>
      <h2 style="font-size:clamp(24px,2.5vw,34px); font-weight:800; margin-bottom:20px;">Un gruppo Telegram Privato dove fare i primi video senza vergogna</h2>
      <p style="font-size:16px; line-height:1.8; color:#333; margin-bottom:16px;">
        Già dalla prima sessione sarai chiamato a creare il tuo primo video con quello che hai.
        Pubblicherai nel gruppo dove riceverai feedback — anche da me.
      </p>
      <p style="font-size:16px; line-height:1.8; color:#333;">
        Il vero "click interiore" lo farai con la pratica, confrontandoti con gli altri corsisti
        in un luogo sicuro e protetto.
      </p>
    </div>
    <div style="border-radius:12px; overflow:hidden; aspect-ratio:4/3; background:#111;">
      <img
        src="https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=700&q=80&fit=crop"
        alt="Counselor che si registra con lo smartphone per condividere il suo messaggio"
        style="width:100%; height:100%; object-fit:cover; display:block;"
        loading="lazy"
      />
    </div>
  </div>
</section>

<!-- ── È IDEALE PER TE SE ─────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #FEF2F2;">
  <div style="max-width:1000px; margin:0 auto;">
    <h2 style="text-align:center; font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:48px;">È ideale per te <span style="color:#DC2626;">se:</span></h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:20px;">
      {ideals.map((item, i) => (
        <div style="background:#fff; border-radius:8px; padding:28px; position:relative; overflow:hidden;">
          <div style="font-size:42px; font-weight:900; color:rgba(220,38,38,.08); position:absolute; top:8px; right:16px; line-height:1;">{i+1}</div>
          <h4 style="font-size:15px; font-weight:700; margin-bottom:10px; padding-right:20px;">{item.title}</h4>
          <p style="color:#555; font-size:14px; line-height:1.6; margin:0;">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── PARLERÒ ANCHE DI ────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div style="max-width:800px; margin:0 auto;">
    <h3 style="font-size:24px; font-weight:800; margin-bottom:32px; border-bottom:3px solid #DC2626; display:inline-block; padding-bottom:8px;">Parlerò anche di…</h3>
    <div class="vp-talk" style="display:grid; grid-template-columns:1fr 1fr; gap:0;">
      {[
        "Come superare la paura dei primi video in pubblico",
        "Come convertire il tuo video in un post scritto",
        "Come catturare l'attenzione nei primi 15 secondi",
        "Come ricordare cosa dire (metodo infallibile)",
        "Come gestire il nervosismo iniziale",
        "Come fare video in movimento",
        "Quali sfondi professionali utilizzare",
        "Come restare al centro dell'inquadratura",
      ].map(item => (
        <div style="display:flex; gap:12px; align-items:flex-start; padding:14px 12px; border-bottom:1px solid #f0f0f0;">
          <span style="color:#DC2626; font-weight:700; flex-shrink:0; font-size:16px;">›</span>
          <span style="font-size:15px; color:#333; line-height:1.5;">{item}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── COSTI ───────────────────────────────────────────────────────────── -->
<section id="costi" style="padding: 80px 24px; background: #f7f7f7;">
  <div style="max-width:1000px; margin:0 auto;">
    <p style="color:#DC2626; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:12px;">Costi</p>
    <h2 style="text-align:center; font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:12px;">Scegli come vuoi iniziare</h2>
    <p style="text-align:center; color:#555; margin-bottom:48px; font-size:16px;">Il corso è gratuito su YouTube. Se preferisci farlo con me, c'è un percorso privato.</p>

    <div class="vp-costs" style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">

      <!-- Card gratuita -->
      <div style="background:#fff; border-radius:12px; padding:36px; border:2px solid #eee;">
        <p style="font-size:13px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">Autonomamente</p>
        <div style="margin-bottom:20px;">
          <span style="font-size:48px; font-weight:900; color:#0D0404;">Gratis</span>
        </div>
        <p style="color:#555; font-size:15px; line-height:1.7; margin-bottom:24px;">
          Guarda le 3 video lezioni su YouTube, ai tuoi ritmi, quante volte vuoi.
        </p>
        <ul style="list-style:none; padding:0; margin-bottom:32px;">
          {["3 Video Lezioni complete su YouTube", "Risorsa con tutti i link e gli strumenti", "Gruppo Telegram per confrontarsi"].map(i => (
            <li style="display:flex; gap:10px; align-items:flex-start; padding:8px 0; border-bottom:1px solid #f0f0f0; font-size:15px; color:#333;">
              <span style="color:#DC2626; font-weight:700; flex-shrink:0;">✓</span> {i}
            </li>
          ))}
        </ul>
