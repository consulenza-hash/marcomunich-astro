---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Servizi — Marco Munich"
  description="Personal branding olistico e sviluppo siti web per coach, counselor e operatori olistici. Scopri i percorsi disponibili."
  currentPath="/servizi/"
>

<div class="mm-page">

  <!-- HERO -->
  <section class="sv-hero">
    <div class="sv-hero__inner mm-container">
      <p class="mm-tag" style="margin-bottom:1.2rem">Cosa faccio</p>
      <h1 class="mm-h1" style="margin-bottom:2rem">Servizi.</h1>
      <p style="font-size:1.05rem;line-height:1.75;color:rgba(255,255,255,0.65);max-width:520px;font-weight:300">
        Lavoro con coach, counselor e operatori olistici che vogliono costruire una presenza online riconoscibile. Ogni percorso parte da quello che hai già, dal tuo modo di lavorare, dal tipo di clienti che vuoi attirare.
      </p>
    </div>
  </section>

  <!-- SERVIZI PRINCIPALI -->
  <section class="mm-section-light sv-services">
    <div class="mm-container">

      <div class="sv-service">
        <div class="sv-service__num">01</div>
        <div class="sv-service__body">
          <p class="mm-tag mm-tag-dark" style="margin-bottom:0.8rem">Consulenza</p>
          <h2 class="mm-h2" style="color:#0d0d0d;margin-bottom:1.2rem">Personal Branding Olistico</h2>
          <p style="font-size:0.9rem;line-height:1.85;color:#444;max-width:560px;margin-bottom:1.5rem">
            Il percorso partenza-arrivo per chi vuole costruire una presenza online che rifletta davvero chi è. Lavoriamo insieme sul posizionamento, sul messaggio, sui contenuti e sulla strategia. Il risultato è una presenza riconoscibile che attira le persone giuste senza richiedere di recitare un personaggio.
          </p>
          <div class="sv-service__tags">
            <span>Posizionamento</span>
            <span>Messaggio</span>
            <span>Contenuti</span>
            <span>Strategia</span>
          </div>
          <a href="/contatti/" class="mm-btn mm-btn-orange" style="margin-top:1.8rem">Parliamo →</a>
        </div>
      </div>

      <hr class="mm-rule-light" style="margin:0" />

      <div class="sv-service">
        <div class="sv-service__num">02</div>
        <div class="sv-service__body">
          <p class="mm-tag mm-tag-dark" style="margin-bottom:0.8rem">Siti web</p>
          <h2 class="mm-h2" style="color:#0d0d0d;margin-bottom:1.2rem">Sviluppo Sito Web</h2>
          <p style="font-size:0.9rem;line-height:1.85;color:#444;max-width:560px;margin-bottom:1.5rem">
            Siti pensati per il settore olistico, costruiti su misura del professionista. Ogni sito ha una struttura precisa: chi sei, cosa fai, perché contattarti. Lavoro su WordPress, con testi, grafica e ottimizzazione SEO inclusi nel percorso.
          </p>
          <div class="sv-service__tags">
            <span>WordPress</span>
            <span>SEO</span>
            <span>Copywriting</span>
            <span>Design</span>
          </div>
          <a href="/sviluppo-siti-web/" class="mm-btn" style="margin-top:1.8rem;background:transparent;color:#0d0d0d;border:1.5px solid #0d0d0d;">Scopri i siti web →</a>
          <a href="/contatti/" class="mm-btn mm-btn-orange" style="margin-top:1rem">Parliamo →</a>
        </div>
      </div>

    </div>
  </section>

  <!-- PERCORSI ONLINE -->
  <section class="mm-section-dark sv-corsi">
    <div class="mm-container">
      <p class="mm-tag" style="margin-bottom:1rem">Formazione</p>
      <h2 class="mm-h2" style="margin-bottom:0.5rem">Percorsi online.</h2>
      <p style="font-size:0.85rem;color:rgba(255,255,255,0.45);margin-bottom:3.5rem;line-height:1.7;max-width:480px">
        Materiale gratuito e a pagamento pensato per chi vuole costruire il proprio personal branding in autonomia, passo dopo passo.
      </p>
      <div class="sv-corsi__grid">

        <a href="/metterci-la-faccia-online/" class="sv-corso">
          <div class="sv-corso__n">01</div>
          <p class="sv-corso__tag">Se sei all'inizio</p>
          <h3 class="sv-corso__title">Metterci la faccia online</h3>
          <p class="sv-corso__desc">Il punto di partenza per chiunque voglia promuoversi online senza fingere di essere qualcun altro.</p>
          <span class="sv-corso__badge">Video-Corso Gratuito</span>
        </a>

        <a href="/creazione-messaggio-autentico/" class="sv-corso">
          <div class="sv-corso__n">02</div>
          <p class="sv-corso__tag">Il corso fondamentale</p>
          <h3 class="sv-corso__title">Creazione del Messaggio Autentico</h3>
          <p class="sv-corso__desc">Trovare il tuo punto di vista unico e strutturare un messaggio che rispecchi chi sei davvero.</p>
          <span class="sv-corso__badge">Corso</span>
        </a>

        <a href="/creazione-video-autentici/" class="sv-corso">
          <div class="sv-corso__n">03</div>
          <p class="sv-corso__tag">Dopo aver iniziato a scrivere</p>
          <h3 class="sv-corso__title">Creazione Video Autentici</h3>
          <p class="sv-corso__desc">Parlare davanti alla camera in modo naturale, senza vergogna e senza preparare script.</p>
          <span class="sv-corso__badge">Video-Corso Gratuito</span>
        </a>

        <a href="/lavorare-senzasito/" class="sv-corso">
          <div class="sv-corso__n">04</div>
          <p class="sv-corso__tag">Dopo almeno 30 video</p>
          <h3 class="sv-corso__title">Lavorare Senza Sito Web</h3>
          <p class="sv-corso__desc">Costruire un sistema di acquisizione clienti che funziona anche senza dipendere da un sito.</p>
          <span class="sv-corso__badge">Corso</span>
        </a>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="home-cta">
    <div class="mm-container home-cta__inner">
      <div>
        <h2 class="mm-h2">Non sai da dove iniziare?</h2>
        <p style="color:rgba(255,255,255,0.75);font-size:0.9rem;margin-top:0.5rem">Una chiamata gratuita. Ti dico esattamente cosa farei al posto tuo.</p>
      </div>
      <a href="/contatti/" class="mm-btn mm-btn-white">Parliamo →</a>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .sv-hero {
    background: #0d0d0d;
    padding: 9rem 0 5rem;
    min-height: 55vh;
    display: flex;
    align-items: center;
  }
  .sv-services { padding: 5rem 0; }
  .sv-service {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 3rem;
    padding: 4rem 0;
    align-items: start;
  }
  .sv-service__num {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem,6vw,5rem);
    color: #eee;
    line-height: 1;
    letter-spacing: -0.04em;
    padding-top: 0.2rem;
  }
  .sv-service__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .sv-service__tags span {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #777;
    border: 1px solid #ddd;
    padding: 0.25rem 0.75rem;
    border-radius: 40px;
  }
  .sv-corsi { padding: 5rem 0; }
  .sv-corsi__grid {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 1px;
    background: #1a1a1a;
    border: 1px solid #1a1a1a;
  }
  .sv-corso {
    background: #0d0d0d;
    padding: 2.5rem 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.15s;
  }
  .sv-corso:hover { background: #141414; opacity: 1; }
  .sv-corso__n {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 2.5rem;
    color: #222;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 0.3rem;
  }
  .sv-corso__tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #e85d00;
  }
  .sv-corso__title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.25;
    margin-top: 0.2rem;
  }
  .sv-corso__desc {
    font-size: 0.8rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.4);
    flex: 1;
  }
  .sv-corso__badge {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    border: 1px solid #2a2a2a;
    padding: 0.2rem 0.6rem;
    border-radius: 40px;
    align-self: flex-start;
    margin-top: 0.5rem;
  }
  .home-cta { background: #e85d00; padding: 4.5rem 0; }
  .home-cta__inner { display: flex; justify-content: space-between; align-items: center; gap: 2rem; }
  @media (max-width: 768px) {
    .sv-service { grid-template-columns: 1fr; gap: 1rem; }
    .sv-service__num { font-size: 3rem; }
    .sv-corsi__grid { grid-template-columns: 1fr; }
    .home-cta__inner { flex-direction: column; align-items: flex-start; }
  }
</style>
