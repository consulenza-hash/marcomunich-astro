---
import BaseLayout from '@layouts/BaseLayout.astro';

const corsi = [
  {
    n: '01', tag: "Se sei all'inizio",
    titolo: 'Metterci la faccia online',
    desc: 'Il punto di partenza per promuoverti online in modo autentico, senza vergogna e senza fingere di essere qualcun altro.',
    href: '/metterci-la-faccia-online/', cta: 'Video-Corso Gratuito',
    color: '#D4840A', bg: '#FEF6EC', border: '#F0A040',
  },
  {
    n: '02', tag: 'Il corso fondamentale',
    titolo: 'Creazione del Messaggio Autentico',
    desc: 'Trova il tuo punto di vista unico e struttura un messaggio che rispecchi chi sei davvero.',
    href: '/creazione-messaggio-autentico/', cta: 'Scopri il Corso',
    color: '#5551D3', bg: '#EEEEFF', border: '#5551D3',
  },
  {
    n: '03', tag: 'Dopo aver iniziato a scrivere',
    titolo: 'Creazione Video Autentici',
    desc: 'Supera la vergogna di fare video e impara a parlare davanti alla camera in modo naturale.',
    href: '/creazione-video-autentici/', cta: 'Video-Corso Gratuito',
    color: '#C0292A', bg: '#FEF0F0', border: '#C0292A',
  },
  {
    n: '04', tag: 'Dopo almeno 30 video',
    titolo: 'Lavorare Senza Sito Web',
    desc: 'Costruisci un sistema di acquisizione clienti parlando dal tuo centro, senza dipendere da un sito.',
    href: '/lavorare-senzasito/', cta: 'Guarda il Corso',
    color: '#1A7A4E', bg: '#EBF7EF', border: '#1A7A4E',
  },
];
---

<BaseLayout
  title="Servizi - Marco Munich"
  description="Servizi di Personal Branding Olistico e Sviluppo Siti Web di Marco Munich per coach, counselor e operatori olistici."
  currentPath="/servizi/"
>

<!-- ══ HERO ═══════════════════════════════════════════════════════════════ -->
<section class="sv-hero">
  <div class="sv-hero__inner">
    <span class="sv-label sv-label--gold">Di cosa mi occupo</span>
    <h1 class="sv-hero__title">
      <span class="sv-hl-plain">Servizi</span>
      <em class="sv-hl-gold">e offerte.</em>
    </h1>
    <p class="sv-hero__sub">
      Cerco sempre di mettere le persone nelle condizioni ideali per operare da soli.
      Non mi piace rendere i clienti dipendenti dal proprio sistema — non lo trovo naturale.
    </p>
  </div>
</section>

<!-- ══ SERVIZI ════════════════════════════════════════════════════════════ -->
<section class="sv-services">
  <div class="sv-services__inner">

    <!-- Personal Branding -->
    <article class="sv-service">
      <div class="sv-service__bar" aria-hidden="true"></div>
      <div class="sv-service__content">
        <span class="sv-label sv-label--gold">01</span>
        <h2 class="sv-service__title">
          Personal Branding<br /><em>Olistico</em>
        </h2>
        <p class="sv-service__desc">
          Per coach, counselor e operatori olistici che vogliono promuoversi
          online in modo autentico, senza funnel aggressivi e senza maschere.
          Sviluppiamo insieme il tuo punto di vista unico e la tua voce.
        </p>
        <div class="sv-service__tags">
          <span>Messaggio Autentico</span>
          <span>Contenuti</span>
          <span>Strategia</span>
          <span>Personal Branding</span>
        </div>
        <a href="/servizi/#percorsi" class="sv-service__link">Scopri i percorsi online →</a>
      </div>
    </article>

    <div class="sv-divider" aria-hidden="true"></div>

    <!-- Siti Web -->
    <article class="sv-service">
      <div class="sv-service__bar" aria-hidden="true"></div>
      <div class="sv-service__content">
        <span class="sv-label sv-label--gold">02</span>
        <h2 class="sv-service__title">
          Siti Web<br /><em>ad Alte Prestazioni</em>
        </h2>
        <p class="sv-service__desc">
          Siti veloci, accessibili e ottimizzati per la ricerca semantica.
          Progettati per riflettere davvero chi sei — non template generici
          ma identità digitali costruite su misura.
        </p>
        <div class="sv-service__tags">
          <span>Astro + Vercel</span>
          <span>SEO Tecnico</span>
          <span>AEO / GEO</span>
          <span>Design Editoriale</span>
        </div>
        <a href="/sviluppo-siti-web/" class="sv-service__link">Come lavoro →</a>
      </div>
    </article>

  </div>
</section>

<!-- ══ PERCORSI ═══════════════════════════════════════════════════════════ -->
<section class="sv-corsi" id="percorsi">
  <div class="sv-corsi__inner">
    <div class="sv-corsi__header">
      <span class="sv-label sv-label--muted">Formazione</span>
      <h2 class="sv-corsi__title">I miei <em>percorsi online</em></h2>
      <p class="sv-corsi__sub">
        Lezioni video per imparare a creare un messaggio autentico,
        promuoverti senza dipendere da un sito e fare video senza vergogna.
      </p>
    </div>
    <div class="sv-steps">
      {corsi.map((c) => (
        <div class="sv-step" style={`background:${c.bg};border-top:3px solid ${c.border};`}>
          <span class="sv-step__n" style={`color:${c.color};`}>{c.n}</span>
          <div class="sv-step__content">
            <span class="sv-step__tag" style={`color:${c.color};`}>{c.tag}</span>
            <h3 class="sv-step__title">{c.titolo}</h3>
            <p class="sv-step__desc">{c.desc}</p>
            <a href={c.href} class="sv-btn" style={`background:${c.color};color:#fff;`}>{c.cta} →</a>
          </div>
        </div>
      ))}
    </div>
    <a href="/risorse/" class="sv-btn sv-btn--ghost" style="margin-top:1.5rem;">
      Tutte le risorse gratuite →
    </a>
  </div>
</section>

<!-- ══ CTA ════════════════════════════════════════════════════════════════ -->
<section class="sv-cta">
  <div class="sv-cta__inner">
    <p class="sv-cta__eyebrow">Hai domande?</p>
    <h2 class="sv-cta__title">Inizia con una <em>chiacchierata gratuita.</em></h2>
    <a href="https://wa.link/zva8dp" class="sv-btn sv-btn--gold sv-btn--lg">
      <svg viewBox="0 0 448 512" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
      </svg>
      Scrivimi su WhatsApp
    </a>
  </div>
</section>

</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Labels ─────────────────────────────────────────────────────────────── */
.sv-label {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 1.5rem;
}
.sv-label--gold  { color: var(--gold); }
.sv-label--muted { color: var(--muted); }

/* ══ HERO ══════════════════════════════════════════════════════════════════ */
.sv-hero {
  background: var(--black);
  padding: 7rem var(--pad) 6rem;
}
.sv-hero__inner {
  max-width: var(--max);
  margin: 0 auto;
  max-width: 800px;
}
.sv-hero__title {
  display: flex;
  flex-direction: column;
  line-height: 0.92;
  margin-bottom: 2.5rem;
}
.sv-hl-plain {
  font: 800 clamp(3.2rem, 6vw, 6.5rem)/1 var(--display);
  color: var(--white);
  display: block;
  letter-spacing: -0.03em;
}
.sv-hl-gold {
  font: 300 clamp(3.6rem, 7vw, 7.5rem)/1 var(--serif);
  font-style: italic;
  color: var(--gold);
  display: block;
  letter-spacing: -0.02em;
  margin-top: 0.05em;
}
.sv-hero__sub {
  font: 300 1rem/1.75 var(--sans);
  color: rgba(255,255,255,0.45);
  max-width: 520px;
}

/* ══ SERVIZI ════════════════════════════════════════════════════════════════ */
.sv-services {
  background: var(--ink);
  padding: 6rem var(--pad);
}
.sv-services__inner {
  max-width: var(--max);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  gap: 0;
  align-items: start;
}
.sv-service {
  padding: 2rem 3.5rem 2rem 0;
}
.sv-services__inner > .sv-service:last-child {
  padding: 2rem 0 2rem 3.5rem;
}
.sv-service__bar {
  width: 2rem;
  height: 2px;
  background: var(--gold);
  margin-bottom: 2rem;
}
.sv-service__title {
  font: 300 clamp(1.8rem, 3vw, 2.6rem)/1.1 var(--serif);
  color: var(--white);
  margin-bottom: 1.25rem;
  letter-spacing: -0.01em;
}
.sv-service__title em { font-style: italic; color: var(--gold); }
.sv-service__desc {
  font: 300 0.92rem/1.75 var(--sans);
  color: rgba(255,255,255,0.45);
  margin-bottom: 1.5rem;
}
.sv-service__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2rem;
}
.sv-service__tags span {
  font: 700 0.6rem/1 var(--sans);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(197,138,55,0.7);
  border: 1px solid rgba(197,138,55,0.25);
  padding: 0.35rem 0.65rem;
  border-radius: 1px;
}
.sv-service__link {
  font: 600 0.8rem/1 var(--sans);
  color: rgba(255,255,255,0.35);
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 0.15s;
}
.sv-service__link:hover { color: var(--gold); opacity: 1; }
.sv-divider {
  background: rgba(255,255,255,0.06);
  align-self: stretch;
}

/* ══ CORSI ══════════════════════════════════════════════════════════════════ */
.sv-corsi {
  background: var(--paper);
  padding: 6rem var(--pad);
}
.sv-corsi__inner {
  max-width: var(--max);
  margin: 0 auto;
  max-width: 700px;
}
.sv-corsi__title {
  font: 300 clamp(2rem, 3.5vw, 3rem)/1.15 var(--serif);
  color: var(--black);
  margin-bottom: 1rem;
  letter-spacing: -0.01em;
}
.sv-corsi__title em { font-style: italic; color: var(--gold); }
.sv-corsi__sub {
  font: 300 0.95rem/1.7 var(--sans);
  color: var(--muted);
  margin-bottom: 2rem;
}
.sv-steps { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 0; }
.sv-step {
  display: grid;
  grid-template-columns: 3rem 1fr;
  gap: 0 1.75rem;
  padding: 2rem 1.5rem;
  border-radius: 8px;
  align-items: start;
}
.sv-step__n {
  font: 300 2.2rem/0.9 var(--serif);
  font-style: italic;
  opacity: 0.6;
  letter-spacing: -0.04em;
  padding-top: 0.2rem;
}
.sv-step__tag {
  display: block;
  font: 700 0.58rem/1 var(--sans);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: 0.6rem;
}
.sv-step__title {
  font: 700 1.1rem/1.25 var(--sans);
  color: var(--black);
  margin-bottom: 0.5rem;
}
.sv-step__desc {
  font: 300 0.88rem/1.65 var(--sans);
  color: rgba(10,10,10,0.6);
  margin-bottom: 1.1rem;
  max-width: 480px;
}

/* ══ CTA ════════════════════════════════════════════════════════════════════ */
.sv-cta {
  background: var(--black);
  padding: 7rem var(--pad);
  text-align: center;
}
.sv-cta__inner {
  max-width: 600px;
  margin: 0 auto;
}
.sv-cta__eyebrow {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 1.5rem;
}
.sv-cta__title {
  font: 300 clamp(2rem, 4vw, 3.2rem)/1.2 var(--serif);
  color: var(--white);
  margin-bottom: 3rem;
}
.sv-cta__title em { font-style: italic; color: var(--gold); }

/* ── Buttons ─────────────────────────────────────────────────────────────── */
.sv-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font: 700 0.78rem/1 var(--sans);
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.9rem 1.75rem;
  border-radius: 1px;
  transition: background 0.15s, color 0.15s, transform 0.12s;
  white-space: nowrap;
  margin-right: 1rem;
  margin-bottom: 0.75rem;
}
.sv-btn--gold { background: #25D366; color: #fff; }
.sv-btn--gold:hover { background: #1da851; transform: translateY(-1px); opacity: 1; }
.sv-btn--ghost { background: transparent; color: var(--muted); padding-left: 0; }
.sv-btn--ghost:hover { color: var(--black); opacity: 1; }
.sv-btn--lg { padding: 1.1rem 2.25rem; font-size: 0.85rem; }

/* ── Responsive ─────────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .sv-services__inner {
    grid-template-columns: 1fr;
  }
  .sv-divider { display: none; }
  .sv-service,
  .sv-services__inner > .sv-service:last-child {
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
}
</style>
