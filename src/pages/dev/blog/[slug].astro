---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';

interface PostData {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
  readTime: string;
  htmlContent: string;
}

export async function getStaticPaths() {
  const jsYaml = (await import('js-yaml')).default;
  const Markdoc = (await import('@markdoc/markdoc')).default;

  const rawFiles = import.meta.glob('/src/content/dev-blog/*.md', {
    eager: true,
    as: 'raw',
  }) as Record<string, string>;

  return Object.entries(rawFiles).map(([filePath, content]) => {
    const slug = filePath.match(/\/([^/]+)\.md$/)?.[1] ?? '';
    const fmMatch = content.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n([\s\S]*)$/);
    if (!fmMatch) {
      return { params: { slug }, props: { post: { slug, title: slug, description: '', date: '', tags: [], readTime: '', htmlContent: `<pre>${content}</pre>` } as PostData } };
    }
    const fm = (jsYaml.load(fmMatch[1]) as Record<string, any>) ?? {};
    const body = fmMatch[2];
    let htmlContent = '';
    try {
      const ast = Markdoc.parse(body);
      const tree = Markdoc.transform(ast, {});
      htmlContent = Markdoc.renderers.html(tree) as string;
    } catch {
      htmlContent = `<pre>${body.replace(/</g, '&lt;')}</pre>`;
    }
    const post: PostData = {
      slug,
      title: (fm.title as string) ?? slug,
      description: (fm.description as string) ?? '',
      date: fm.date ? String(fm.date) : '',
      tags: (fm.tags as string[]) ?? [],
      readTime: (fm.readTime as string) ?? '',
      htmlContent,
    };
    return { params: { slug }, props: { post } };
  });
}

const { post } = Astro.props as { post: PostData };

function formatDate(d: string): string {
  if (!d) return '';
  return new Date(d).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}

const siteUrl = 'https://marcomunich.com';
const canonicalUrl = `${siteUrl}/dev/blog/${post.slug}/`;

const articleSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  author: { '@type': 'Person', name: 'Marco Munich', url: `${siteUrl}/dev/` },
  publisher: { '@type': 'Person', name: 'Marco Munich' },
  datePublished: post.date,
  dateModified: post.date,
  url: canonicalUrl,
});
---

<BaseLayout
  title={`${post.title} · Marco Munich Dev`}
  description={post.description}
  currentPath={`/dev/blog/${post.slug}`}
>

<Fragment slot="head">
  <link rel="canonical" href={canonicalUrl} />
  <script type="application/ld+json" set:html={articleSchema} />
</Fragment>

<div class="mm-dev mm-page">

  <header class="art-header">
    <nav class="art-breadcrumb" aria-label="Breadcrumb">
      <a href="/dev/">Dev</a>
      <span>/</span>
      <a href="/dev/blog/">Blog</a>
      <span>/</span>
      <span>{post.title}</span>
    </nav>
    {post.tags.length > 0 && (
      <div class="art-tags">
        {post.tags.map(tag => <span class="art-tag">{tag}</span>)}
      </div>
    )}
    <h1 class="art-title">{post.title}</h1>
    <div class="art-meta">
      {post.date && <time datetime={post.date}>{formatDate(post.date)}</time>}
      {post.date && post.readTime && <span class="art-meta-sep"></span>}
      {post.readTime && <span>{post.readTime} di lettura</span>}
    </div>
  </header>

  <hr class="art-divider" />

  <div class="art-body">
    <div class="prose">
      <Fragment set:html={post.htmlContent} />
    </div>
  </div>

  <div class="art-cta">
    <div class="art-cta-box">
      <h3>Costruisco siti che si fanno trovare anche dai motori AI</h3>
      <p>Se vuoi un sito veloce, strutturato per Google e per i modelli AI, scrivimi. Ti dico subito cosa ti serve e cosa no.</p>
      <a href="/dev/contatti" class="mm-btn mm-btn-orange">Parliamo del tuo progetto &rarr;</a>
    </div>
  </div>

  <footer class="art-footer">
    <a href="/dev/blog/">&larr; Tutti gli articoli</a>
  </footer>

</div>

</BaseLayout>

<style>
  /* Article header */
  .art-header {
    max-width: 760px; margin: 0 auto;
    padding: 120px 1.5rem 40px;
  }
  .art-breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; color: #6B7B7F; margin-bottom: 1.5rem;
  }
  .art-breadcrumb a { color: #8A9699; transition: color 0.2s; }
  .art-breadcrumb a:hover { color: #3B82F6; }
  .art-breadcrumb span { color: #333; }
  .art-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .art-tag {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
    color: #3B82F6; background: rgba(59,130,246,0.1); padding: 3px 10px; border-radius: 100px;
  }
  .art-title {
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800; color: #fff; letter-spacing: -0.03em;
    line-height: 1.2; margin-bottom: 1rem;
  }
  .art-meta {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.825rem; color: #6B7B7F;
  }
  .art-meta-sep { width: 3px; height: 3px; border-radius: 50%; background: #333; }

  /* Divider */
  .art-divider {
    max-width: 760px; margin: 0 auto; padding: 0 1.5rem;
    border: none; border-top: 1px solid rgba(255,255,255,0.07);
  }

  /* Article content */
  .art-body {
    max-width: 760px; margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }
  .prose :global(h2) {
    font-size: 1.5rem; font-weight: 700; color: #fff;
    letter-spacing: -0.02em; margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }
  .prose :global(h3) {
    font-size: 1.15rem; font-weight: 600; color: #E2DED6;
    margin: 2rem 0 0.75rem; line-height: 1.4;
  }
  .prose :global(p) { color: #c5c5c5; font-size: 1.05rem; line-height: 1.8; margin-bottom: 1.25rem; }
  .prose :global(strong) { color: #E2DED6; font-weight: 600; }
  .prose :global(a) { color: #3B82F6; border-bottom: 1px solid rgba(59,130,246,0.3); transition: border-color 0.2s; }
  .prose :global(a:hover) { border-color: #3B82F6; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1.25rem; }
  .prose :global(li) { color: #c5c5c5; font-size: 1.05rem; line-height: 1.8; margin-bottom: 0.4rem; }
  .prose :global(blockquote) {
    border-left: 3px solid #3B82F6; padding: 0.75rem 1.25rem;
    background: rgba(59,130,246,0.05); border-radius: 0 8px 8px 0;
    margin: 1.5rem 0; font-style: italic; color: #8A9699;
  }
  .prose :global(code) {
    background: rgba(255,255,255,0.07); color: #3B82F6;
    font-family: 'Fira Code', monospace; font-size: 0.875em;
    padding: 2px 6px; border-radius: 4px;
  }
  .prose :global(pre) { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; padding: 1.25rem; overflow-x: auto; margin-bottom: 1.25rem; }
  .prose :global(pre code) { background: none; padding: 0; color: #E2DED6; }
  .prose :global(img) { width: 100%; border-radius: 10px; margin: 1.5rem 0; display: block; }

  /* CTA box */
  .art-cta {
    max-width: 760px; margin: 0 auto; padding: 0 1.5rem 5rem;
  }
  .art-cta-box {
    background: rgba(59,130,246,0.05);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 12px; padding: 2rem;
  }
  .art-cta-box h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 0.5rem; }
  .art-cta-box p { font-size: 0.9rem; color: #8A9699; margin-bottom: 1.25rem; }

  /* Footer link */
  .art-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem 1.5rem; text-align: center;
    font-size: 0.875rem; color: #6B7B7F;
  }
  .art-footer a { color: #8A9699; transition: color 0.2s; }
  .art-footer a:hover { color: #3B82F6; }

  @media (max-width: 768px) {
    .art-header { padding: 100px 1.25rem 32px; }
    .art-body { padding: 2rem 1.25rem 4rem; }
    .art-cta { padding: 0 1.25rem 4rem; }
  }
</style>
