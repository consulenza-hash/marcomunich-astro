---
export const prerender = true;

import jsYaml from 'js-yaml';

const rawFiles = import.meta.glob('/src/content/dev-blog/*.md', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

interface Post {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
  readTime: string;
}

const posts: Post[] = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug = filePath.match(/\/([^/]+)\.md$/)?.[1] ?? '';
  const fmStr = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    title: (fm.title as string) ?? slug,
    description: (fm.description as string) ?? '',
    date: fm.date ? String(fm.date) : '',
    tags: (fm.tags as string[]) ?? [],
    readTime: (fm.readTime as string) ?? '',
  };
}).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(d: string): string {
  if (!d) return '';
  return new Date(d).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog · Marco Munich Dev</title>
  <meta name="description" content="Articoli su SEO, intelligenza artificiale, performance web e visibilità digitale per aziende italiane." />
  <link rel="canonical" href="https://marcomunich.com/dev/blog/" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #050505;
      color: #e5e5e5;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }

    /* Navbar */
    .navbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(5,5,5,0.85); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(245,158,11,0.1);
    }
    .navbar-inner {
      max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;
      height: 64px; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { font-weight: 700; font-size: 1.1rem; color: #fff; letter-spacing: -0.02em; }
    .nav-logo span { color: #f59e0b; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { font-size: 0.875rem; font-weight: 500; color: #a3a3a3; transition: color 0.2s; }
    .nav-links a:hover, .nav-links a.active { color: #f59e0b; }
    .nav-toggle { display: none; background: none; border: none; cursor: pointer; padding: 0.5rem; }
    .nav-toggle span { display: block; width: 22px; height: 2px; background: #e5e5e5; margin: 5px 0; transition: all 0.3s; }

    /* Hero */
    .hero {
      padding: 120px 1.5rem 60px;
      max-width: 1200px; margin: 0 auto;
    }
    .hero-label {
      font-size: 0.8rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.1em; color: #f59e0b; margin-bottom: 1rem;
    }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 800; color: #fff; letter-spacing: -0.04em;
      line-height: 1.15; margin-bottom: 1rem;
    }
    .hero p {
      font-size: 1.1rem; color: #a3a3a3; max-width: 560px; line-height: 1.7;
    }

    /* Posts grid */
    .posts-section { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem 6rem; }
    .posts-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 1.5rem;
    }
    .post-card {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px; padding: 1.75rem;
      transition: border-color 0.2s, background 0.2s;
      display: flex; flex-direction: column;
    }
    .post-card:hover {
      border-color: rgba(245,158,11,0.3);
      background: rgba(245,158,11,0.03);
    }
    .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
    .post-tag {
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em;
      text-transform: uppercase; color: #f59e0b;
      background: rgba(245,158,11,0.1); padding: 3px 10px; border-radius: 100px;
    }
    .post-title {
      font-size: 1.2rem; font-weight: 700; color: #fff;
      letter-spacing: -0.02em; line-height: 1.35; margin-bottom: 0.75rem;
    }
    .post-desc { font-size: 0.9rem; color: #a3a3a3; line-height: 1.65; flex: 1; margin-bottom: 1.25rem; }
    .post-meta {
      display: flex; align-items: center; gap: 0.75rem;
      font-size: 0.78rem; color: #525252;
    }
    .post-meta-sep { width: 3px; height: 3px; border-radius: 50%; background: #404040; }
    .post-link {
      margin-top: 1.25rem; font-size: 0.875rem; font-weight: 600;
      color: #f59e0b; display: inline-flex; align-items: center; gap: 0.375rem;
      transition: gap 0.2s;
    }
    .post-card:hover .post-link { gap: 0.625rem; }

    /* Footer */
    .footer {
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 2rem 1.5rem; text-align: center;
      font-size: 0.875rem; color: #525252;
    }
    .footer a { color: #a3a3a3; transition: color 0.2s; }
    .footer a:hover { color: #f59e0b; }

    @media (max-width: 768px) {
      .nav-links {
        display: none; position: absolute; top: 64px; left: 0; right: 0;
        background: rgba(5,5,5,0.97); backdrop-filter: blur(12px);
        padding: 1rem 1.5rem 1.5rem; flex-direction: column; gap: 0;
        border-bottom: 1px solid rgba(255,255,255,0.06);
      }
      .nav-links.open { display: flex; }
      .nav-links li { border-bottom: 1px solid rgba(255,255,255,0.04); }
      .nav-links a { display: block; padding: 0.875rem 0; font-size: 1rem; }
      .nav-toggle { display: block; }
      .posts-grid { grid-template-columns: 1fr; }
      .hero { padding: 100px 1.25rem 48px; }
    }
  </style>
</head>
<body>

  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/dev/" class="nav-logo">Marco Munich <span>· Dev</span></a>
      <button class="nav-toggle" aria-label="Menu" id="navToggle">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="navLinks">
        <li><a href="/dev/come-lavoro">Come Lavoro</a></li>
        <li><a href="/dev/vibe-coding">Vibe Coding</a></li>
        <li><a href="/dev/portfolio">Portfolio</a></li>
        <li><a href="/dev/prezzi">Prezzi</a></li>
        <li><a href="/dev/blog/" class="active">Blog</a></li>
        <li><a href="/dev/contatti">Contatti</a></li>
      </ul>
    </div>
  </nav>

  <header class="hero">
    <p class="hero-label">Risorse</p>
    <h1>SEO, AI e performance web</h1>
    <p>Articoli pratici su come farsi trovare online nel 2025, quando Google non è più l'unico motore che conta.</p>
  </header>

  <section class="posts-section">
    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/dev/blog/${post.slug}`} class="post-card">
          {post.tags.length > 0 && (
            <div class="post-tags">
              {post.tags.map(tag => <span class="post-tag">{tag}</span>)}
            </div>
          )}
          <h2 class="post-title">{post.title}</h2>
          <p class="post-desc">{post.description}</p>
          <div class="post-meta">
            {post.date && <span>{formatDate(post.date)}</span>}
            {post.date && post.readTime && <span class="post-meta-sep"></span>}
            {post.readTime && <span>{post.readTime} di lettura</span>}
          </div>
          <span class="post-link">Leggi l'articolo &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <footer class="footer">
    <a href="/dev/">&larr; Torna alla sezione Dev</a>
  </footer>

  <script is:inline>
    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });
  </script>

</body>
</html>
