---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import jsYaml from 'js-yaml';

const rawFiles = import.meta.glob('/src/content/dev-blog/*.md', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

interface Post {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
  readTime: string;
}

const posts: Post[] = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug = filePath.match(/\/([^/]+)\.md$/)?.[1] ?? '';
  const fmStr = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    title: (fm.title as string) ?? slug,
    description: (fm.description as string) ?? '',
    date: fm.date ? String(fm.date) : '',
    tags: (fm.tags as string[]) ?? [],
    readTime: (fm.readTime as string) ?? '',
  };
}).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

function formatDate(d: string): string {
  if (!d) return '';
  return new Date(d).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog · Marco Munich Dev"
  description="Articoli su SEO, intelligenza artificiale, performance web e visibilità digitale per aziende italiane."
  currentPath="/dev/blog"
>

<div class="mm-dev mm-page">

  <header class="blog-hero">
    <p class="mm-tag" style="display:inline-block;margin-bottom:1rem;background:rgba(59,130,246,.1);padding:4px 14px;border-radius:100px;font-size:0.8rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;">Risorse</p>
    <h1 class="mm-h1">SEO, AI e performance web</h1>
    <p class="mm-body" style="max-width:560px;line-height:1.7;">Articoli pratici su come farsi trovare online nel 2025, quando Google non è più l'unico motore che conta.</p>
  </header>

  <section class="posts-section">
    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/dev/blog/${post.slug}`} class="post-card">
          {post.tags.length > 0 && (
            <div class="post-tags">
              {post.tags.map(tag => <span class="post-tag">{tag}</span>)}
            </div>
          )}
          <h2 class="post-title">{post.title}</h2>
          <p class="post-desc">{post.description}</p>
          <div class="post-meta">
            {post.date && <span>{formatDate(post.date)}</span>}
            {post.date && post.readTime && <span class="post-meta-sep"></span>}
            {post.readTime && <span>{post.readTime} di lettura</span>}
          </div>
          <span class="post-link">Leggi l'articolo &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <footer class="blog-footer">
    <a href="/dev/">&larr; Torna alla sezione Dev</a>
  </footer>

</div>

</BaseLayout>

<style>
  /* ── Blog Hero ── */
  .blog-hero {
    padding: 120px 1.5rem 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Posts grid ── */
  .posts-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }
  .post-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 1.75rem;
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover {
    border-color: rgba(59,130,246,0.3);
    background: rgba(59,130,246,0.03);
  }
  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .post-tag {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #3B82F6;
    background: rgba(59,130,246,0.1);
    padding: 3px 10px;
    border-radius: 100px;
  }
  .post-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.35;
    margin-bottom: 0.75rem;
  }
  .post-desc {
    font-size: 0.9rem;
    color: #8A9699;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    color: #6B7B7F;
  }
  .post-meta-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #404040;
  }
  .post-link {
    margin-top: 1.25rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #3B82F6;
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    transition: gap 0.2s;
  }
  .post-card:hover .post-link {
    gap: 0.625rem;
  }

  /* ── Blog Footer ── */
  .blog-footer {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 2rem 1.5rem;
    text-align: center;
    font-size: 0.875rem;
    color: #6B7B7F;
  }
  .blog-footer a {
    color: #8A9699;
    transition: color 0.2s;
  }
  .blog-footer a:hover {
    color: #3B82F6;
  }

  @media (max-width: 768px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
    .blog-hero {
      padding: 100px 1.25rem 48px;
    }
  }
</style>
