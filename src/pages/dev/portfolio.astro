---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio — Marco Munich Dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #050505;
      color: #e5e5e5;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }

    /* Navbar */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 2rem;
      border-bottom: 1px solid #1a1a1a;
      position: sticky;
      top: 0;
      background: rgba(5, 5, 5, 0.95);
      backdrop-filter: blur(10px);
      z-index: 100;
    }
    .nav-brand { font-weight: 700; font-size: 1.05rem; color: #fff; }
    .nav-links {
      display: flex;
      gap: 1.5rem;
      list-style: none;
      align-items: center;
    }
    .nav-links a { font-size: 0.9rem; color: #999; transition: color 0.2s; }
    .nav-links a:hover { color: #fff; }
    .nav-links a.active { color: #f59e0b; font-weight: 600; }
    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      color: #fff;
      font-size: 1.5rem;
      cursor: pointer;
    }

    /* Hero */
    .hero {
      text-align: center;
      padding: 5rem 2rem 3rem;
      max-width: 700px;
      margin: 0 auto;
    }
    .hero h1 {
      font-size: 2.8rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 1rem;
    }
    .hero p { font-size: 1.15rem; color: #999; max-width: 550px; margin: 0 auto; }

    /* Portfolio grid */
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.2rem;
      max-width: 1050px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }
    .project-card {
      background: #111;
      border: 1px solid #1a1a1a;
      border-radius: 12px;
      padding: 1.8rem 1.5rem;
      transition: border-color 0.2s, transform 0.2s;
      display: flex;
      flex-direction: column;
    }
    .project-card:hover {
      border-color: #333;
      transform: translateY(-2px);
    }
    .project-icon {
      font-size: 2rem;
      margin-bottom: 0.8rem;
    }
    .project-card h3 {
      font-size: 1.05rem;
      color: #fff;
      font-weight: 600;
      margin-bottom: 0.4rem;
    }
    .project-card p {
      font-size: 0.88rem;
      color: #999;
      flex: 1;
      margin-bottom: 1rem;
    }
    .project-link {
      font-size: 0.88rem;
      font-weight: 600;
      color: #f59e0b;
      transition: color 0.2s;
    }
    .project-link:hover { color: #d97706; }

    /* CTA */
    .cta-section {
      text-align: center;
      padding: 0 2rem 5rem;
    }
    .cta-section p {
      font-size: 1.15rem;
      color: #999;
      margin-bottom: 1.5rem;
    }
    .cta-btn {
      display: inline-block;
      background: #f59e0b;
      color: #050505;
      font-weight: 700;
      font-size: 1.05rem;
      padding: 0.9rem 2.2rem;
      border-radius: 8px;
      transition: background 0.2s, transform 0.2s;
    }
    .cta-btn:hover {
      background: #d97706;
      transform: translateY(-1px);
    }

    /* Footer */
    footer {
      border-top: 1px solid #1a1a1a;
      text-align: center;
      padding: 2rem;
    }
    footer a { color: #999; font-size: 0.9rem; transition: color 0.2s; }
    footer a:hover { color: #f59e0b; }

    /* Mobile */
    @media (max-width: 768px) {
      .mobile-toggle { display: block; }
      .nav-links {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: rgba(5, 5, 5, 0.98);
        flex-direction: column;
        padding: 1.5rem 2rem;
        gap: 1rem;
        border-bottom: 1px solid #1a1a1a;
      }
      .nav-links.open { display: flex; }
      .hero { padding: 3rem 1.5rem 2rem; }
      .hero h1 { font-size: 2rem; }
      .portfolio-grid {
        grid-template-columns: 1fr;
        padding: 0 1.5rem 3rem;
      }
    }
  </style>
</head>
<body>
  <nav>
    <span class="nav-brand">Marco Munich &middot; Dev</span>
    <button class="mobile-toggle" aria-label="Menu">&#9776;</button>
    <ul class="nav-links">
      <li><a href="/dev/come-lavoro">Come Lavoro</a></li>
      <li><a href="/dev/vibe-coding">Vibe Coding</a></li>
      <li><a href="/dev/portfolio" class="active">Portfolio</a></li>
      <li><a href="/dev/prezzi">Prezzi</a></li>
      <li><a href="/dev/contatti">Contatti</a></li>
    </ul>
  </nav>

  <section class="hero">
    <h1>12 demo navigabili.</h1>
    <p>Ogni progetto è diverso. Esplora le demo per farti un'idea concreta.</p>
  </section>

  <div class="portfolio-grid">
    <a href="/portfolio/ecommerce" class="project-card">
      <div class="project-icon">&#128722;</div>
      <h3>E-commerce</h3>
      <p>Negozio online completo con carrello, pagamenti e gestione prodotti.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/corso-online" class="project-card">
      <div class="project-icon">&#127891;</div>
      <h3>Corso Online</h3>
      <p>Piattaforma per vendere e gestire corsi digitali con area studenti.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/sito-vetrina" class="project-card">
      <div class="project-icon">&#128100;</div>
      <h3>Sito Vetrina</h3>
      <p>Presenza professionale online per liberi professionisti e piccole imprese.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/landing-page" class="project-card">
      <div class="project-icon">&#128640;</div>
      <h3>Landing Page</h3>
      <p>Pagina singola ottimizzata per conversioni e campagne marketing.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/blog" class="project-card">
      <div class="project-icon">&#128240;</div>
      <h3>Blog &amp; Magazine</h3>
      <p>Piattaforma editoriale con categorie, ricerca e layout articoli.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/booking" class="project-card">
      <div class="project-icon">&#128197;</div>
      <h3>Booking</h3>
      <p>Sistema di prenotazione online con calendario e conferma automatica.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/portfolio-creativo" class="project-card">
      <div class="project-icon">&#127912;</div>
      <h3>Portfolio Creativo</h3>
      <p>Vetrina visuale per designer, fotografi e creativi.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/ristorante" class="project-card">
      <div class="project-icon">&#127869;</div>
      <h3>Ristorante</h3>
      <p>Menu digitale, prenotazione tavoli e gallery per locali.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/saas" class="project-card">
      <div class="project-icon">&#9889;</div>
      <h3>SaaS Dashboard</h3>
      <p>Dashboard moderna per prodotti software con grafici e gestione utenti.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/non-profit" class="project-card">
      <div class="project-icon">&#128155;</div>
      <h3>Non-Profit</h3>
      <p>Sito per associazioni con donazioni, eventi e raccolta fondi.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/immobiliare" class="project-card">
      <div class="project-icon">&#127968;</div>
      <h3>Immobiliare</h3>
      <p>Catalogo immobili con filtri, mappa e schede dettagliate.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/wedding" class="project-card">
      <div class="project-icon">&#128141;</div>
      <h3>Wedding &amp; Eventi</h3>
      <p>Inviti digitali, RSVP, countdown e gallery per eventi speciali.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>
  </div>

  <section class="cta-section">
    <p>Hai visto qualcosa che ti piace? Parliamone.</p>
    <a href="/dev/contatti" class="cta-btn">Contattami &rarr;</a>
  </section>

  <footer>
    <a href="/">&larr; Torna a marcomunich.com</a>
  </footer>

  <script>
    document.querySelector('.mobile-toggle')?.addEventListener('click', () => {
      document.querySelector('.nav-links')?.classList.toggle('open');
    });
  </script>
</body>
</html>
