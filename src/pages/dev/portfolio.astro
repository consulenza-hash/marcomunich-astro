---
export const prerender = true;
---

<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portfolio · Marco Munich Dev</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <style>
    [data-theme="dark"] {
      --bg: #141C1F;
      --bg-card: #1A2225;
      --border: #243035;
      --text: #E2DED6;
      --text-muted: #8A9699;
      --primary: #C17F3A;
      --primary-hover: #D4944D;
      --accent: #C17F3A;
      --navbar-bg: rgba(20, 28, 31, 0.8);
    }
    [data-theme="light"] {
      --bg: #F5F0E8;
      --bg-card: #FFFFFF;
      --border: #EDE8DF;
      --text: #1E2B2F;
      --text-muted: #6B7B7F;
      --primary: #A0614A;
      --primary-hover: #8A5240;
      --accent: #A0614A;
      --navbar-bg: rgba(245, 240, 232, 0.8);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      transition: background 0.3s, color 0.3s;
    }
    a { color: inherit; text-decoration: none; }

    /* ── Navbar ── */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: var(--navbar-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      transition: background 0.3s, border-color 0.3s;
    }
    .navbar-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 700;
      font-size: 1.05rem;
      color: var(--text);
      letter-spacing: -0.02em;
      transition: color 0.3s;
    }
    .nav-logo span { color: var(--primary); }
    .nav-right { display: flex; align-items: center; gap: 2rem; }
    .nav-links { display: flex; gap: 1.75rem; list-style: none; }
    .nav-links a {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--text-muted);
      transition: color 0.2s;
      position: relative;
      padding-bottom: 4px;
    }
    .nav-links a:hover { color: var(--primary); }
    .nav-links a.active { color: var(--primary); }
    .nav-links a.active::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--primary);
      border-radius: 1px;
    }
    .theme-toggle {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      width: 36px; height: 36px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 1.1rem;
      transition: background 0.3s, border-color 0.3s;
      color: var(--text-muted);
      flex-shrink: 0;
    }
    .theme-toggle:hover { border-color: var(--primary); color: var(--primary); }
    [data-theme="dark"] .theme-toggle .icon-sun { display: none; }
    [data-theme="dark"] .theme-toggle .icon-moon { display: inline; }
    [data-theme="light"] .theme-toggle .icon-sun { display: inline; }
    [data-theme="light"] .theme-toggle .icon-moon { display: none; }
    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.5rem;
    }
    .nav-toggle span {
      display: block;
      width: 22px; height: 2px;
      background: var(--text);
      margin: 5px 0;
      transition: all 0.3s;
    }

    /* ── Hero ── */
    .hero {
      text-align: center;
      padding: 10rem 2rem 4rem;
      max-width: 700px;
      margin: 0 auto;
    }
    .hero h1 {
      font-family: 'Lora', Georgia, serif;
      font-size: 2.8rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 1rem;
      transition: color 0.3s;
    }
    .hero p {
      font-size: 1.15rem;
      color: var(--text-muted);
      max-width: 550px;
      margin: 0 auto;
      transition: color 0.3s;
    }

    /* ── Portfolio grid ── */
    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.2rem;
      max-width: 1050px;
      margin: 0 auto;
      padding: 0 2rem 4rem;
    }
    .project-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.8rem 1.5rem;
      transition: border-color 0.2s, transform 0.2s, background 0.3s;
      display: flex;
      flex-direction: column;
    }
    .project-card:hover {
      border-color: var(--primary);
      transform: translateY(-2px);
    }
    .project-icon {
      font-size: 2rem;
      margin-bottom: 0.8rem;
    }
    .project-card h3 {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.05rem;
      color: var(--text);
      font-weight: 600;
      margin-bottom: 0.4rem;
      transition: color 0.3s;
    }
    .project-card p {
      font-size: 0.88rem;
      color: var(--text-muted);
      flex: 1;
      margin-bottom: 1rem;
      transition: color 0.3s;
    }
    .project-link {
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--primary);
      transition: color 0.2s;
    }
    .project-link:hover { color: var(--primary-hover); }

    /* ── CTA ── */
    .cta-section {
      text-align: center;
      padding: 0 2rem 5rem;
    }
    .cta-section p {
      font-size: 1.15rem;
      color: var(--text-muted);
      margin-bottom: 1.5rem;
      transition: color 0.3s;
    }
    .cta-btn {
      display: inline-block;
      background: var(--primary);
      color: #fff;
      font-weight: 700;
      font-size: 1.05rem;
      padding: 0.9rem 2.2rem;
      border-radius: 8px;
      transition: background 0.2s, transform 0.2s;
    }
    .cta-btn:hover {
      background: var(--primary-hover);
      transform: translateY(-1px);
    }

    /* ── Footer ── */
    .footer {
      border-top: 1px solid var(--border);
      text-align: center;
      padding: 2.5rem;
      transition: border-color 0.3s;
    }
    .footer a {
      color: var(--text-muted);
      font-size: 0.9rem;
      transition: color 0.2s;
    }
    .footer a:hover { color: var(--primary); }

    /* ── Mobile ── */
    @media (max-width: 768px) {
      .nav-links {
        display: none;
        position: absolute;
        top: 64px; left: 0; right: 0;
        background: var(--navbar-bg);
        backdrop-filter: blur(12px);
        flex-direction: column;
        padding: 1.5rem;
        gap: 1rem;
        border-bottom: 1px solid var(--border);
      }
      .nav-links.open { display: flex; }
      .nav-toggle { display: block; }
      .hero { padding: 7rem 1.5rem 2rem; }
      .hero h1 { font-size: 2rem; }
      .portfolio-grid {
        grid-template-columns: 1fr;
        padding: 0 1.5rem 3rem;
      }
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/dev/" class="nav-logo">Marco Munich <span>&middot; Dev</span></a>
      <div class="nav-right">
        <ul class="nav-links" id="navLinks">
          <li><a href="/dev/come-lavoro">Come Lavoro</a></li>
          <li><a href="/dev/vibe-coding">Vibe Coding</a></li>
          <li><a href="/dev/portfolio" class="active">Portfolio</a></li>
          <li><a href="/dev/prezzi">Prezzi</a></li>
          <li><a href="/dev/blog/">Blog</a></li>
          <li><a href="/dev/contatti">Contatti</a></li>
        </ul>
        <button class="theme-toggle" id="theme-toggle" aria-label="Cambia tema">
          <span class="icon-sun">&#9728;</span>
          <span class="icon-moon">&#127769;</span>
        </button>
        <button class="nav-toggle" aria-label="Menu" id="navToggle">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <section class="hero">
    <h1>12 demo navigabili.</h1>
    <p>Ogni progetto è diverso, e puoi esplorare le demo per farti un'idea concreta del risultato.</p>
  </section>

  <div class="portfolio-grid">
    <a href="/portfolio/ecommerce" class="project-card">
      <div class="project-icon">&#128722;</div>
      <h3>E-commerce</h3>
      <p>Negozio online completo con carrello, pagamenti e gestione prodotti.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/corso-online" class="project-card">
      <div class="project-icon">&#127891;</div>
      <h3>Corso Online</h3>
      <p>Piattaforma per vendere e gestire corsi digitali con area studenti.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/sito-vetrina" class="project-card">
      <div class="project-icon">&#128100;</div>
      <h3>Sito Vetrina</h3>
      <p>Presenza professionale online per liberi professionisti e piccole imprese.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/landing-page" class="project-card">
      <div class="project-icon">&#128640;</div>
      <h3>Landing Page</h3>
      <p>Pagina singola ottimizzata per conversioni e campagne marketing.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/blog" class="project-card">
      <div class="project-icon">&#128240;</div>
      <h3>Blog &amp; Magazine</h3>
      <p>Piattaforma editoriale con categorie, ricerca e layout articoli.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/booking" class="project-card">
      <div class="project-icon">&#128197;</div>
      <h3>Booking</h3>
      <p>Sistema di prenotazione online con calendario e conferma automatica.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/portfolio-creativo" class="project-card">
      <div class="project-icon">&#127912;</div>
      <h3>Portfolio Creativo</h3>
      <p>Vetrina visuale per designer, fotografi e creativi.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/ristorante" class="project-card">
      <div class="project-icon">&#127869;</div>
      <h3>Ristorante</h3>
      <p>Menu digitale, prenotazione tavoli e gallery per locali.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/saas" class="project-card">
      <div class="project-icon">&#9889;</div>
      <h3>SaaS Dashboard</h3>
      <p>Dashboard moderna per prodotti software con grafici e gestione utenti.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/non-profit" class="project-card">
      <div class="project-icon">&#128155;</div>
      <h3>Non-Profit</h3>
      <p>Sito per associazioni con donazioni, eventi e raccolta fondi.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/immobiliare" class="project-card">
      <div class="project-icon">&#127968;</div>
      <h3>Immobiliare</h3>
      <p>Catalogo immobili con filtri, mappa e schede dettagliate.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/bed-and-breakfast" class="project-card">
      <div class="project-icon">&#127969;</div>
      <h3>Bed &amp; Breakfast</h3>
      <p>Sito per agriturismi e B&amp;B con camere, prenotazioni e gallery.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/yoga-studio" class="project-card">
      <div class="project-icon">&#129339;</div>
      <h3>Yoga &amp; Benessere</h3>
      <p>Studio yoga con classi, orari, abbonamenti e prenotazione online.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>

    <a href="/portfolio/studio-medico" class="project-card">
      <div class="project-icon">&#129338;</div>
      <h3>Studio Medico</h3>
      <p>Sito per medici e specialisti con servizi, prenotazione e teleconsulto.</p>
      <span class="project-link">Naviga la demo &rarr;</span>
    </a>
  </div>

  <section class="cta-section">
    <p>Hai visto qualcosa che ti piace? Parliamone.</p>
    <a href="/dev/contatti" class="cta-btn">Contattami &rarr;</a>
  </section>

  <footer class="footer">
    <a href="/">&larr; Torna a marcomunich.com</a>
  </footer>

  <script is:inline>
    const toggle = document.getElementById('theme-toggle');
    const html = document.documentElement;
    const saved = localStorage.getItem('dev-theme') || 'dark';
    html.setAttribute('data-theme', saved);
    toggle.addEventListener('click', () => {
      const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('dev-theme', next);
    });

    document.getElementById('navToggle')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });
  </script>
</body>
</html>
