---
import BaseLayout from '@layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout
  title="Marco Munich · Sviluppo Web"
  description="Costruisco siti web veloci, sicuri e ottimizzati. Progettati su misura per la tua attività."
  currentPath="/dev"
>

<div class="mm-dev mm-page">

  <!-- ── HERO ── -->
  <section class="hero mm-section-dark">
    <div class="hero-bg"></div>
    <div class="hero-glow"></div>
    <div class="hero-content">
      <h1 class="mm-h1" data-text="Costruisco siti web che funzionano." style="font-family:'Lora',Georgia,serif;font-size:clamp(2.5rem,6vw,4.5rem);letter-spacing:-0.04em;line-height:1.1;">Costruisco siti web<br/>che <span class="accent">funzionano.</span></h1>
      <p class="mm-body" style="font-size:1.25rem;max-width:550px;margin:0 auto 2.5rem;line-height:1.7;">Veloci, sicuri, ottimizzati. Progettati su misura per la tua attivit&agrave;.</p>
      <div class="hero-code"><span class="code-line" id="typed-line"></span><span class="cursor"></span></div>
      <div class="hero-ctas">
        <a href="/dev/portfolio" class="mm-btn mm-btn-orange">Vedi i progetti &rarr;</a>
        <a href="/dev/come-lavoro" class="mm-btn mm-btn-outline">Come lavoro</a>
      </div>
    </div>
  </section>

  <!-- ── COSA COSTRUISCO ── -->
  <section class="mm-section-dark section">
    <div class="container">
      <p class="mm-tag">Cosa costruisco</p>
      <h2 class="mm-h2">Soluzioni web per ogni esigenza</h2>
      <div class="build-grid">
        <div class="build-card">
          <div class="build-icon">
            <svg width="24" height="24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <h3 class="mm-h3">Siti Vetrina</h3>
          <p class="mm-body">Presenza online professionale che comunica chi sei e cosa fai.</p>
        </div>
        <div class="build-card">
          <div class="build-icon">
            <svg width="24" height="24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </div>
          <h3 class="mm-h3">E-commerce</h3>
          <p class="mm-body">Negozi online veloci con pagamenti sicuri e gestione prodotti.</p>
        </div>
        <div class="build-card">
          <div class="build-icon">
            <svg width="24" height="24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M15 3h6v6"/><path d="M10 14L21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </div>
          <h3 class="mm-h3">Landing Page</h3>
          <p class="mm-body">Pagine singole ad alta conversione per campagne e lanci.</p>
        </div>
        <div class="build-card">
          <div class="build-icon">
            <svg width="24" height="24" fill="none" stroke="#3B82F6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><line x1="14" y1="4" x2="10" y2="20"/></svg>
          </div>
          <h3 class="mm-h3">Web App</h3>
          <p class="mm-body">Applicazioni web su misura con funzionalit&agrave; avanzate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PERCHE' SCEGLIERMI ── -->
  <section class="mm-section-dark section" style="background:rgba(255,255,255,0.01);">
    <div class="container">
      <p class="mm-tag">Perch&eacute; scegliermi</p>
      <h2 class="mm-h2">Non il solito freelancer</h2>
      <div class="diff-grid">
        <div class="diff-card">
          <div class="diff-num">01</div>
          <h3 class="mm-h3">Velocit&agrave;</h3>
          <p class="mm-body">Un sito completo in giorni, non mesi. Grazie a un processo guidato dall'intelligenza artificiale.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">02</div>
          <h3 class="mm-h3">Trasparenza</h3>
          <p class="mm-body">Sai sempre a che punto siamo. Nessun gergo tecnico, nessuna sorpresa.</p>
        </div>
        <div class="diff-card">
          <div class="diff-num">03</div>
          <h3 class="mm-h3">Risultato</h3>
          <p class="mm-body">Il sito &egrave; tuo, il codice &egrave; pulito, le performance sono misurabili.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── VIBE CODING ── -->
  <section class="mm-section-dark section">
    <div class="container" style="text-align:center;">
      <p class="mm-tag">Il metodo</p>
      <h2 class="mm-h2">Come costruisco i tuoi progetti</h2>
      <div class="vibe-card">
        <h3 class="mm-h3" style="font-size:1.5rem;margin-bottom:1rem;">Vibe Coding: il mio metodo</h3>
        <p class="mm-body" style="font-size:1rem;line-height:1.7;margin-bottom:1.5rem;">Non scrivo codice riga per riga. Guido l'intelligenza artificiale per costruire siti che funzionano. Il risultato &egrave; lo stesso — anzi, pi&ugrave; veloce e pi&ugrave; pulito.</p>
        <a href="/dev/vibe-coding" class="link-arrow">Scopri come funziona &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ── PORTFOLIO ── -->
  <section class="mm-section-dark section" style="background:rgba(255,255,255,0.01);">
    <div class="container">
      <p class="mm-tag">Portfolio</p>
      <h2 class="mm-h2">12 demo navigabili</h2>
      <p class="mm-body" style="max-width:600px;">Progetti reali che puoi esplorare. Clicca per navigare ogni demo.</p>
      <div class="portfolio-grid">
        <a href="/portfolio/ecommerce" class="portfolio-card">
          <span class="portfolio-card-name">E-commerce</span>
          <span class="portfolio-card-link">Naviga &rarr;</span>
        </a>
        <a href="/portfolio/corso-online" class="portfolio-card">
          <span class="portfolio-card-name">Corso Online</span>
          <span class="portfolio-card-link">Naviga &rarr;</span>
        </a>
        <a href="/portfolio/sito-vetrina" class="portfolio-card">
          <span class="portfolio-card-name">Sito Vetrina</span>
          <span class="portfolio-card-link">Naviga &rarr;</span>
        </a>
        <a href="/portfolio/landing-page" class="portfolio-card">
          <span class="portfolio-card-name">Landing Page</span>
          <span class="portfolio-card-link">Naviga &rarr;</span>
        </a>
        <a href="/portfolio/blog" class="portfolio-card">
          <span class="portfolio-card-name">Blog</span>
          <span class="portfolio-card-link">Naviga &rarr;</span>
        </a>
        <a href="/portfolio/booking" class="portfolio-card">
          <span class="portfolio-card-name">Booking</span>
          <span class="portfolio-card-link">Naviga &rarr;</span>
        </a>
      </div>
      <div class="portfolio-all">
        <a href="/dev/portfolio">Vedi tutti i 12 progetti &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section mm-section-dark">
    <div class="container">
      <h2 class="mm-h2" style="font-size:2.5rem;">Parliamo del tuo progetto</h2>
      <p class="mm-body" style="font-size:1.1rem;margin-bottom:2rem;">Raccontami cosa ti serve. Ti dico subito se posso aiutarti.</p>
      <a href="/dev/contatti" class="mm-btn mm-btn-orange">Contattami &rarr;</a>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 1.5rem 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, rgba(59,130,246,0.08) 1px, transparent 0);
    background-size: 40px 40px;
    pointer-events: none;
  }

  .hero-glow {
    position: absolute;
    top: 20%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(59,130,246,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .hero h1 .accent {
    color: #3B82F6;
  }

  /* Glitch effect on H1 hover */
  .hero h1 {
    position: relative;
  }
  .hero h1::before,
  .hero h1::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    opacity: 0;
    pointer-events: none;
  }
  .hero h1::before {
    color: #3B82F6;
    clip-path: inset(30% 0 40% 0);
    transform: translateX(-3px);
  }
  .hero h1::after {
    color: #5B8FA8;
    clip-path: inset(60% 0 10% 0);
    transform: translateX(3px);
  }
  .hero h1:hover::before {
    opacity: 0.7;
    animation: glitch-top 0.4s steps(2) infinite;
  }
  .hero h1:hover::after {
    opacity: 0.7;
    animation: glitch-bot 0.4s steps(2) infinite;
  }
  @keyframes glitch-top {
    0%   { clip-path: inset(10% 0 60% 0); transform: translateX(-3px); }
    25%  { clip-path: inset(40% 0 20% 0); transform: translateX(3px); }
    50%  { clip-path: inset(20% 0 50% 0); transform: translateX(-2px); }
    75%  { clip-path: inset(50% 0 10% 0); transform: translateX(2px); }
    100% { clip-path: inset(10% 0 60% 0); transform: translateX(-3px); }
  }
  @keyframes glitch-bot {
    0%   { clip-path: inset(60% 0 10% 0); transform: translateX(3px); }
    25%  { clip-path: inset(20% 0 50% 0); transform: translateX(-3px); }
    50%  { clip-path: inset(70% 0 5% 0);  transform: translateX(2px); }
    75%  { clip-path: inset(45% 0 30% 0); transform: translateX(-2px); }
    100% { clip-path: inset(60% 0 10% 0); transform: translateX(3px); }
  }

  /* Typed code snippet */
  .hero-code {
    display: inline-block;
    background: rgba(13,13,13,0.85);
    border: 1px solid rgba(59,130,246,0.25);
    border-radius: 8px;
    padding: 0.75rem 1.25rem;
    margin-bottom: 2rem;
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.85rem;
    color: #3B82F6;
    text-align: left;
    min-width: 320px;
    max-width: 480px;
  }
  .hero-code .code-line {
    display: block;
    white-space: pre;
  }
  .cursor {
    display: inline-block;
    width: 2px;
    height: 1em;
    background: #3B82F6;
    vertical-align: text-bottom;
    margin-left: 1px;
    animation: blink 0.8s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Section base ── */
  .section {
    padding: 6rem 1.5rem;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── What I Build ── */
  .build-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .build-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    transition: border-color 0.3s, transform 0.2s;
  }

  .build-card:hover {
    border-color: rgba(59, 130, 246, 0.3);
    transform: translateY(-2px);
  }

  .build-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    background: rgba(59, 130, 246, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    font-size: 1.5rem;
  }

  /* ── Why Different ── */
  .diff-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .diff-card {
    padding: 2rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .diff-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(59, 130, 246, 0.12);
    color: #3B82F6;
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
  }

  /* ── Vibe Coding ── */
  .vibe-card {
    background: rgba(59, 130, 246, 0.04);
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: 16px;
    padding: 3rem;
    max-width: 800px;
    margin: 3rem auto 0;
  }

  .vibe-card .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #3B82F6;
    font-weight: 600;
    font-size: 0.95rem;
    transition: gap 0.2s;
  }

  .vibe-card .link-arrow:hover {
    gap: 0.75rem;
  }

  /* ── Portfolio Preview ── */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 3rem;
  }

  .portfolio-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: border-color 0.3s, transform 0.2s;
  }

  .portfolio-card:hover {
    border-color: rgba(59, 130, 246, 0.3);
    transform: translateY(-2px);
  }

  .portfolio-card-name {
    font-weight: 600;
    font-size: 1rem;
    color: #fff;
  }

  .portfolio-card-link {
    font-size: 0.85rem;
    color: #3B82F6;
    font-weight: 500;
    white-space: nowrap;
  }

  .portfolio-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  .portfolio-all a {
    color: #3B82F6;
    font-weight: 600;
    font-size: 1rem;
    transition: opacity 0.2s;
  }

  .portfolio-all a:hover {
    opacity: 0.8;
  }

  /* ── CTA Section ── */
  .cta-section {
    text-align: center;
    padding: 6rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .build-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: 7rem 1.5rem 4rem;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .build-grid {
      grid-template-columns: 1fr;
      display: block !important;
    }

    .build-card {
      width: 100% !important;
      margin-bottom: 1rem;
    }

    .diff-grid {
      grid-template-columns: 1fr;
      display: block !important;
    }

    .diff-card {
      width: 100% !important;
      margin-bottom: 1rem;
    }

    .vibe-card {
      padding: 2rem 1.5rem;
    }

    .portfolio-grid {
      grid-template-columns: 1fr;
      display: block !important;
    }

    .portfolio-card {
      width: 100% !important;
      margin-bottom: 1rem;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: center;
    }
  }
</style>

<script>
  // Typed code snippet
  const snippets = [
    'const perf = await lighthouse(url);\nreturn perf.score >= 95;',
    'await db.transaction(async (trx) => {\n  await trx.insert(orders).values(data);\n});',
    'export const prerender = true;\n// 0ms TTFB. Static. Fast.',
    'const res = await fetch(api, {\n  next: { revalidate: 3600 }\n});',
    'git push origin main\n# Deploy: ✓ Build passed (8.3s)',
  ];
  const colors = ['#3B82F6', '#7EAA92', '#2563EB', '#8BA5B5', '#3B82F6'];
  let si = 0, ci = 0, deleting = false;
  const el = document.getElementById('typed-line');

  function type() {
    if (!el) return;
    const full = snippets[si];
    el.style.color = colors[si];
    if (!deleting) {
      el.textContent = full.slice(0, ci + 1);
      ci++;
      if (ci === full.length) { deleting = true; setTimeout(type, 2200); return; }
      setTimeout(type, 38 + Math.random() * 30);
    } else {
      el.textContent = full.slice(0, ci - 1);
      ci--;
      if (ci === 0) {
        deleting = false;
        si = (si + 1) % snippets.length;
        setTimeout(type, 400);
        return;
      }
      setTimeout(type, 18);
    }
  }
  setTimeout(type, 900);
</script>
