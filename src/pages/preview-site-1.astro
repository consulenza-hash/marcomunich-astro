---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Preview Sito 1 — Studio Editoriale" description="Sito completo, mood studio italiano." currentPath="/preview-site-1/">

<div class="ps1-page">
  <!-- ── NAV ─────────────────────────────────────────────────────── -->
  <header class="ps1-nav">
    <div class="ps1-nav__inner">
      <a href="#" class="ps1-logo">M.M.<span>—Studio</span></a>
      <nav class="ps1-menu">
        <a href="#lavori">Lavori</a>
        <a href="#processo">Processo</a>
        <a href="#chi">Chi sono</a>
        <a href="/contatti/" class="ps1-menu__cta">Parliamone</a>
      </nav>
    </div>
  </header>

  <!-- ── HERO ────────────────────────────────────────────────────── -->
  <section class="ps1-hero">
    <div class="ps1-container">
      <p class="ps1-eyebrow">Studio indipendente · Vicenza · 2026</p>
      <h1 class="ps1-h1">
        Sviluppo siti<br>
        <em>e applicazioni web</em><br>
        per chi vende se stesso.
      </h1>
      <div class="ps1-hero__bottom">
        <p class="ps1-hero__sub">
          Ogni progetto è costruito da zero, su misura, con codice pulito e piena proprietà dei file alla consegna. Niente template, niente abbonamenti mensili a piattaforme che cambiano regole ogni anno.
        </p>
        <a href="#lavori" class="ps1-arrow-link">Vedi i lavori ↓</a>
      </div>
    </div>
  </section>

  <!-- ── LAVORI ──────────────────────────────────────────────── -->
  <section class="ps1-section ps1-works" id="lavori">
    <div class="ps1-container">
      <div class="ps1-section__head">
        <p class="ps1-eyebrow">— Lavori selezionati</p>
        <h2 class="ps1-h2">Demo navigabili.</h2>
        <p class="ps1-section__lead">
          Una selezione di siti che ho progettato e costruito come dimostrazioni del tipo di lavoro che faccio. Sono <em>demo</em>, non clienti reali. Ognuna è completamente navigabile.
        </p>
      </div>

      <ul class="ps1-works__list">
        <li>
          <a href="/portfolio/yoga-studio" class="ps1-work">
            <span class="ps1-work__num">01</span>
            <div class="ps1-work__meta">
              <h3>Studio yoga</h3>
              <p>Sito vetrina · prenotazioni · listino corsi</p>
            </div>
            <span class="ps1-work__year">2026</span>
            <span class="ps1-work__arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/portfolio/ristorante" class="ps1-work">
            <span class="ps1-work__num">02</span>
            <div class="ps1-work__meta">
              <h3>Ristorante</h3>
              <p>Vetrina + menu + storia + galleria</p>
            </div>
            <span class="ps1-work__year">2026</span>
            <span class="ps1-work__arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/portfolio/ecommerce" class="ps1-work">
            <span class="ps1-work__num">03</span>
            <div class="ps1-work__meta">
              <h3>E-commerce</h3>
              <p>Catalogo · scheda prodotto · carrello</p>
            </div>
            <span class="ps1-work__year">2026</span>
            <span class="ps1-work__arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/portfolio/booking" class="ps1-work">
            <span class="ps1-work__num">04</span>
            <div class="ps1-work__meta">
              <h3>Studio professionale</h3>
              <p>Booking online · area cliente · pagamenti</p>
            </div>
            <span class="ps1-work__year">2026</span>
            <span class="ps1-work__arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/portfolio/non-profit" class="ps1-work">
            <span class="ps1-work__num">05</span>
            <div class="ps1-work__meta">
              <h3>Organizzazione non-profit</h3>
              <p>Storia · progetti · donazioni</p>
            </div>
            <span class="ps1-work__year">2026</span>
            <span class="ps1-work__arrow">→</span>
          </a>
        </li>
        <li>
          <a href="/portfolio/" class="ps1-work ps1-work--all">
            <span class="ps1-work__num">+</span>
            <div class="ps1-work__meta">
              <h3>Vedi tutti i lavori →</h3>
            </div>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- ── COSA COSTRUISCO ─────────────────────────────────────── -->
  <section class="ps1-section ps1-services">
    <div class="ps1-container">
      <div class="ps1-section__head">
        <p class="ps1-eyebrow">— Servizi</p>
        <h2 class="ps1-h2">Cosa costruisco.</h2>
      </div>

      <div class="ps1-srv-grid">
        <div class="ps1-srv">
          <h3>Siti vetrina</h3>
          <p>Per professionisti, studi, attività locali. Ogni pagina è scritta e strutturata sul tuo modo di lavorare e sul cliente che vuoi attirare.</p>
        </div>
        <div class="ps1-srv">
          <h3>Landing page</h3>
          <p>Una pagina sola, costruita per convertire. Per lanci di prodotto, campagne pubblicitarie, raccolta contatti.</p>
        </div>
        <div class="ps1-srv">
          <h3>E-commerce</h3>
          <p>Negozi online con pagamenti sicuri e gestione prodotti. Stripe o PayPal a seconda del caso.</p>
        </div>
        <div class="ps1-srv">
          <h3>Web application</h3>
          <p>Quando il sito non basta più. Dashboard, area riservata, automazioni, integrazione con API esterne. FastAPI o Node a seconda del progetto.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROCESSO ─────────────────────────────────────────── -->
  <section class="ps1-section ps1-process" id="processo">
    <div class="ps1-container">
      <div class="ps1-section__head">
        <p class="ps1-eyebrow">— Come lavoro</p>
        <h2 class="ps1-h2">Quattro fasi.</h2>
      </div>

      <ol class="ps1-process__list">
        <li>
          <span class="ps1-process__num">I.</span>
          <div>
            <h3>Capisco il progetto.</h3>
            <p>Una chiamata di trenta minuti per inquadrare cosa serve, a chi parla, come deve funzionare. Se non sono la persona giusta te lo dico subito.</p>
          </div>
        </li>
        <li>
          <span class="ps1-process__num">II.</span>
          <div>
            <h3>Disegno la struttura.</h3>
            <p>Pagine, contenuti, logica. Lavoriamo prima sulle parole e sulla gerarchia, poi sul design. Tu approvi tutto prima che io scriva una riga di codice.</p>
          </div>
        </li>
        <li>
          <span class="ps1-process__num">III.</span>
          <div>
            <h3>Costruisco.</h3>
            <p>Sviluppo iterativo con anteprime live. Ogni passaggio lo vedi sul tuo telefono e mi dici cosa cambiare. Niente sorprese alla fine.</p>
          </div>
        </li>
        <li>
          <span class="ps1-process__num">IV.</span>
          <div>
            <h3>Consegno.</h3>
            <p>Sito online, codice nel tuo repository, documentazione scritta in italiano semplice, formazione di un'ora se ti serve gestirlo da solo.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ── CHI SONO ─────────────────────────────────────────── -->
  <section class="ps1-section ps1-about" id="chi">
    <div class="ps1-container ps1-about__inner">
      <div class="ps1-about__text">
        <p class="ps1-eyebrow">— Chi sono</p>
        <h2 class="ps1-h2">Marco Munich.</h2>
        <p>
          Da sette anni lavoro su come ci si presenta online. Ho seguito coach, counselor, operatori olistici e professionisti di vario tipo nel costruire la loro presenza online.
        </p>
        <p>
          A un certo punto ho cominciato a costruire io stesso i loro siti, perché vedere coach con siti tutti uguali aveva stancato anche me. Oggi è quello che faccio principalmente: <em>siti e applicazioni costruiti su misura</em>, con uno sguardo che viene da anni di lavoro sul brand di chi li commissiona.
        </p>
        <a href="/chi-sono/" class="ps1-arrow-link">Storia completa →</a>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────── -->
  <section class="ps1-cta">
    <div class="ps1-container">
      <p class="ps1-eyebrow ps1-eyebrow--light">— Lavoriamo insieme</p>
      <h2 class="ps1-cta__title">
        Hai un progetto<br>
        <em>in mente?</em>
      </h2>
      <p class="ps1-cta__sub">
        Una chiamata gratuita di trenta minuti. Capisco la tua situazione, ti dico cosa farei al tuo posto e se posso esserti utile davvero. Se non posso, te lo dico e ti indirizzo verso qualcun altro.
      </p>
      <a href="/contatti/" class="ps1-cta__btn">Fissa una chiamata →</a>
    </div>
  </section>

  <!-- ── FOOTER ────────────────────────────────────────────── -->
  <footer class="ps1-foot">
    <div class="ps1-container ps1-foot__inner">
      <div>
        <p class="ps1-logo ps1-logo--foot">M.M.<span>—Studio</span></p>
        <p class="ps1-foot__tag">Sviluppo web · Vicenza, IT</p>
      </div>
      <div class="ps1-foot__cols">
        <div>
          <p class="ps1-foot__col-title">Lavori</p>
          <a href="/portfolio/">Tutti i progetti</a>
          <a href="/servizi/posizionamento-online/">Posizionamento</a>
          <a href="/vibe-coding/">Vibe coding</a>
        </div>
        <div>
          <p class="ps1-foot__col-title">Studio</p>
          <a href="/chi-sono/">Chi sono</a>
          <a href="/blog/">Blog</a>
          <a href="/contatti/">Contatti</a>
        </div>
      </div>
    </div>
    <div class="ps1-container">
      <p class="ps1-foot__credit">— Marco Munich · 2019—2026 · Vicenza</p>
    </div>
  </footer>
</div>

</BaseLayout>

<style>
  .ps1-page {
    background: #f7f4ee;
    color: #1a1814;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 400;
    overflow-x: hidden;
  }
  .ps1-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 2.5rem;
    width: 100%;
  }

  /* ─── NAV ─── */
  .ps1-nav {
    border-bottom: 1px solid rgba(26,24,20,0.1);
    padding: 1.4rem 0;
    background: rgba(247,244,238,0.92);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .ps1-nav__inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .ps1-logo {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: 1.5rem;
    color: #1a1814;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .ps1-logo span { color: #b86a3e; }
  .ps1-menu { display: flex; gap: 2rem; align-items: center; }
  .ps1-menu a {
    color: #1a1814;
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
  }
  .ps1-menu a:hover { color: #b86a3e; }
  .ps1-menu__cta {
    background: #1a1814;
    color: #f7f4ee !important;
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
  }
  .ps1-menu__cta:hover { background: #b86a3e; }

  /* ─── HERO ─── */
  .ps1-hero {
    padding: 7rem 0 6rem;
  }
  .ps1-eyebrow {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6e6358;
    margin: 0 0 2rem;
  }
  .ps1-eyebrow--light { color: rgba(247,244,238,0.6); }
  .ps1-h1 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
    font-size: clamp(2.6rem, 6.5vw, 6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #1a1814;
    margin: 0 0 3rem;
  }
  .ps1-h1 em { font-style: italic; color: #b86a3e; }
  .ps1-hero__bottom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: end;
    border-top: 1px solid rgba(26,24,20,0.15);
    padding-top: 2rem;
  }
  .ps1-hero__sub {
    font-size: 1.05rem;
    line-height: 1.75;
    color: #4a4438;
    max-width: 580px;
    margin: 0;
  }
  .ps1-arrow-link {
    color: #b86a3e;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    border-bottom: 1px solid #b86a3e;
    padding-bottom: 0.2rem;
    white-space: nowrap;
  }
  .ps1-arrow-link:hover { color: #1a1814; border-bottom-color: #1a1814; }

  /* ─── SECTIONS ─── */
  .ps1-section { padding: 7rem 0; border-top: 1px solid rgba(26,24,20,0.1); }
  .ps1-section__head { margin-bottom: 4rem; max-width: 720px; }
  .ps1-h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 400;
    font-style: italic;
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    line-height: 1.05;
    color: #1a1814;
    margin: 0 0 1.2rem;
    letter-spacing: -0.015em;
  }
  .ps1-section__lead {
    font-size: 1rem;
    line-height: 1.75;
    color: #4a4438;
    margin: 0;
    max-width: 580px;
  }
  .ps1-section__lead em { font-style: italic; color: #b86a3e; }

  /* ─── WORKS ─── */
  .ps1-works__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(26,24,20,0.15);
  }
  .ps1-works__list li { border-bottom: 1px solid rgba(26,24,20,0.15); }
  .ps1-work {
    display: grid;
    grid-template-columns: 80px 1fr 100px 40px;
    gap: 2rem;
    padding: 2rem 0;
    color: #1a1814;
    text-decoration: none;
    align-items: center;
    transition: padding 0.25s ease, color 0.2s ease;
  }
  .ps1-work:hover { padding-left: 1.5rem; color: #b86a3e; }
  .ps1-work__num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.4rem;
    color: #b86a3e;
  }
  .ps1-work__meta h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.5rem, 2.4vw, 2rem);
    margin: 0 0 0.3rem;
    color: inherit;
    letter-spacing: -0.02em;
  }
  .ps1-work__meta p {
    font-size: 0.92rem;
    color: #6e6358;
    margin: 0;
  }
  .ps1-work__year { color: #8a8170; font-size: 0.92rem; text-align: right; }
  .ps1-work__arrow { color: #b86a3e; text-align: right; font-size: 1.3rem; }
  .ps1-work--all .ps1-work__meta h3 { color: #b86a3e; }

  /* ─── SERVICES ─── */
  .ps1-srv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem 4rem;
  }
  .ps1-srv {
    border-top: 2px solid #b86a3e;
    padding-top: 1.5rem;
  }
  .ps1-srv h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: 1.8rem;
    color: #1a1814;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }
  .ps1-srv p {
    font-size: 0.98rem;
    line-height: 1.75;
    color: #4a4438;
    margin: 0;
  }

  /* ─── PROCESS ─── */
  .ps1-process__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .ps1-process__list li {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 2.5rem;
    padding: 2.5rem 0;
    border-top: 1px solid rgba(26,24,20,0.15);
    align-items: start;
  }
  .ps1-process__list li:last-child { border-bottom: 1px solid rgba(26,24,20,0.15); }
  .ps1-process__num {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 2.2rem;
    color: #b86a3e;
  }
  .ps1-process__list h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: 1.8rem;
    color: #1a1814;
    margin: 0 0 0.8rem;
    letter-spacing: -0.02em;
  }
  .ps1-process__list p {
    font-size: 0.98rem;
    line-height: 1.75;
    color: #4a4438;
    margin: 0;
    max-width: 620px;
  }

  /* ─── ABOUT ─── */
  .ps1-about__inner { max-width: 760px; }
  .ps1-about__text p {
    font-size: 1.05rem;
    line-height: 1.85;
    color: #1a1814;
    margin: 0 0 1.5rem;
  }
  .ps1-about__text p em { font-style: italic; color: #b86a3e; }

  /* ─── CTA ─── */
  .ps1-cta {
    padding: 8rem 0;
    background: #1a1814;
    color: #f7f4ee;
    text-align: center;
  }
  .ps1-cta__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    color: #f7f4ee;
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
  }
  .ps1-cta__title em { font-style: italic; color: #d6884a; }
  .ps1-cta__sub {
    font-size: 1rem;
    line-height: 1.75;
    color: rgba(247,244,238,0.7);
    max-width: 560px;
    margin: 0 auto 3rem;
  }
  .ps1-cta__btn {
    display: inline-block;
    background: #d6884a;
    color: #1a1814;
    padding: 1.1rem 2.4rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
  }
  .ps1-cta__btn:hover { background: #f7f4ee; }

  /* ─── FOOTER ─── */
  .ps1-foot {
    background: #f0ece2;
    padding: 4rem 0 2rem;
    color: #4a4438;
  }
  .ps1-foot__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }
  .ps1-logo--foot { margin: 0 0 0.5rem; }
  .ps1-foot__tag { font-size: 0.85rem; color: #6e6358; margin: 0; }
  .ps1-foot__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .ps1-foot__col-title {
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1a1814;
    margin: 0 0 1rem;
  }
  .ps1-foot__cols a {
    display: block;
    color: #4a4438;
    text-decoration: none;
    font-size: 0.92rem;
    padding: 0.3rem 0;
  }
  .ps1-foot__cols a:hover { color: #b86a3e; }
  .ps1-foot__credit {
    text-align: center;
    font-size: 0.78rem;
    color: #8a8170;
    letter-spacing: 0.1em;
    border-top: 1px solid rgba(26,24,20,0.1);
    padding-top: 1.5rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .ps1-menu { gap: 1rem; }
    .ps1-menu a:not(.ps1-menu__cta) { display: none; }
    .ps1-hero__bottom { grid-template-columns: 1fr; gap: 1.5rem; }
    .ps1-srv-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .ps1-work { grid-template-columns: 50px 1fr 30px; gap: 1rem; padding: 1.5rem 0; }
    .ps1-work__year { display: none; }
    .ps1-process__list li { grid-template-columns: 1fr; gap: 0.6rem; }
    .ps1-foot__inner { grid-template-columns: 1fr; }
    .ps1-foot__cols { grid-template-columns: 1fr 1fr; }
  }
</style>
<script>
  if (!document.querySelector('link[href*="Cormorant+Garamond"]')) {
    const l = document.createElement('link'); l.rel = 'stylesheet';
    l.href = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap';
    document.head.appendChild(l);
  }
</script>
