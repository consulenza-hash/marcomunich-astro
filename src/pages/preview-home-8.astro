---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Preview Home 8 — Risograph"
  description="Mockup direzione Risograph print."
  currentPath="/preview-home-8/"
>

<div class="r8-page">

  <span class="r8-grain" aria-hidden="true"></span>

  <!-- ── HERO RISO ────────────────────────────────────────────────────── -->
  <section class="r8-hero">
    <div class="r8-container">
      <div class="r8-hero__top">
        <span class="r8-hero__date">26 / 04 / 2026 — N. 001</span>
        <span class="r8-hero__loc">VICENZA · IT</span>
      </div>

      <div class="r8-hero__compose">
        <div class="r8-blob r8-blob--coral"></div>
        <div class="r8-blob r8-blob--navy"></div>

        <h1 class="r8-h1">
          <span class="r8-h1__line">Sviluppo siti</span>
          <span class="r8-h1__line r8-h1__line--accent">e applicazioni</span>
          <span class="r8-h1__line">per chi vende</span>
          <span class="r8-h1__line r8-h1__line--accent r8-h1__line--big">se stesso.</span>
        </h1>
      </div>

      <div class="r8-hero__bottom">
        <p class="r8-hero__sub">
          Marco Munich, studio indipendente di Vicenza. Sette anni di consulenza sul personal branding per coach, counselor e operatori olistici. Oggi traduco quell'esperienza in codice.
        </p>
        <a href="/contatti/" class="r8-btn">→ Lavoriamo insieme</a>
      </div>
    </div>
  </section>

  <!-- ── CHAPTER 01 - SERVIZI ────────────────────────────────────────── -->
  <section class="r8-section">
    <div class="r8-container">
      <div class="r8-section__head">
        <span class="r8-section__num">N. 001</span>
        <h2 class="r8-section__title">Servizi.</h2>
      </div>

      <div class="r8-srv-grid">
        <article class="r8-srv">
          <div class="r8-srv__visual r8-srv__visual--coral">
            <span class="r8-stamp">★ DEV</span>
          </div>
          <h3 class="r8-srv__name">Sviluppo siti<br>e applicazioni.</h3>
          <p>
            Costruisco da zero, codice pulito, performance verificabili. Astro per i siti, FastAPI per le applicazioni. Niente plugin obbligatori, niente abbonamenti mensili.
          </p>
          <a href="/portfolio/" class="r8-link">Progetti recenti →</a>
        </article>

        <article class="r8-srv">
          <div class="r8-srv__visual r8-srv__visual--navy">
            <span class="r8-stamp">● POSIZIONAMENTO</span>
          </div>
          <h3 class="r8-srv__name">Posizionamento<br>online.</h3>
          <p>
            Per chi vende se stesso e vuole una presenza che corrisponda davvero a chi è. Sette anni di lavoro nel settore olistico, oltre duecento articoli pubblicati.
          </p>
          <a href="/servizi/posizionamento-online/" class="r8-link">Scopri il metodo →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ── CHAPTER 02 - NUMERI ─────────────────────────────────────── -->
  <section class="r8-section r8-section--alt">
    <div class="r8-container">
      <div class="r8-section__head">
        <span class="r8-section__num">N. 002</span>
        <h2 class="r8-section__title">In numeri.</h2>
      </div>

      <div class="r8-stats">
        <div class="r8-stat">
          <span class="r8-stat__big">218</span>
          <span class="r8-stat__lbl">articoli pubblicati</span>
        </div>
        <span class="r8-stat__divider"></span>
        <div class="r8-stat">
          <span class="r8-stat__big">07</span>
          <span class="r8-stat__lbl">anni di lavoro</span>
        </div>
        <span class="r8-stat__divider"></span>
        <div class="r8-stat">
          <span class="r8-stat__big">100<small>/100</small></span>
          <span class="r8-stat__lbl">google pagespeed</span>
        </div>
        <span class="r8-stat__divider"></span>
        <div class="r8-stat">
          <span class="r8-stat__big r8-stat__big--coral">00</span>
          <span class="r8-stat__lbl">template usati</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CHAPTER 03 - PROGETTI ──────────────────────────────────── -->
  <section class="r8-section">
    <div class="r8-container">
      <div class="r8-section__head">
        <span class="r8-section__num">N. 003</span>
        <h2 class="r8-section__title">Progetti.</h2>
      </div>

      <ul class="r8-projects">
        <li>
          <a href="/portfolio/" class="r8-project">
            <span class="r8-project__visual r8-project__visual--01"></span>
            <div>
              <span class="r8-project__year">— 2026</span>
              <h3 class="r8-project__name">marcomunich.com</h3>
              <p>Sito vetrina con CMS custom e 277 articoli migrati da WordPress a Ghost.</p>
            </div>
          </a>
        </li>
        <li>
          <a href="/portfolio/" class="r8-project">
            <span class="r8-project__visual r8-project__visual--02"></span>
            <div>
              <span class="r8-project__year">— 2026</span>
              <h3 class="r8-project__name">vela</h3>
              <p>Web application per gestione social media. FastAPI + instagrapi.</p>
            </div>
          </a>
        </li>
        <li>
          <a href="/portfolio/" class="r8-project">
            <span class="r8-project__visual r8-project__visual--03"></span>
            <div>
              <span class="r8-project__year">— 2026</span>
              <h3 class="r8-project__name">cms.marcomunich.com</h3>
              <p>Migrazione Ghost CMS con integrazione Admin API custom in PHP.</p>
            </div>
          </a>
        </li>
      </ul>
    </div>
  </section>

  <!-- ── COLOPHON / CTA ────────────────────────────────────────── -->
  <section class="r8-colophon">
    <div class="r8-container">
      <p class="r8-colophon__kicker">— ULTIMA PAGINA —</p>
      <h2 class="r8-colophon__title">
        Hai un progetto<br>
        <span class="r8-colophon__title--accent">in mente?</span>
      </h2>
      <p class="r8-colophon__sub">
        Una chiamata gratuita di trenta minuti. Capisco la tua situazione, ti dico se posso aiutarti davvero. Se non posso, te lo dico subito e ti indirizzo verso qualcun altro.
      </p>
      <a href="/contatti/" class="r8-btn r8-btn--lg">→ Fissa una chiamata</a>

      <div class="r8-colophon__credit">
        <span>★</span>
        <span>Stampato a Vicenza, 2026</span>
        <span>●</span>
      </div>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  :root {
    --r-cream: #fbf6e9;
    --r-coral: #e85a4b;
    --r-navy: #1d2956;
    --r-mustard: #d6a544;
    --r-ink: #1a1814;
  }
  .r8-page {
    background: var(--r-cream);
    color: var(--r-ink);
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
    position: relative;
  }
  .r8-grain {
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="240" height="240"><filter id="g"><feTurbulence type="fractalNoise" baseFrequency="0.92" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23g)" opacity="0.7"/></svg>');
    opacity: 0.18;
    mix-blend-mode: multiply;
    z-index: 50;
  }

  .r8-container {
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 2.5rem;
    width: 100%;
  }

  /* ─── HERO ─── */
  .r8-hero {
    padding: 4rem 0 6rem;
    border-bottom: 2px dashed rgba(26,24,20,0.3);
  }
  .r8-hero__top {
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--r-navy);
    border-bottom: 1px solid rgba(26,24,20,0.25);
    padding-bottom: 1rem;
    margin-bottom: 4rem;
  }
  .r8-hero__compose {
    position: relative;
    margin-bottom: 4rem;
  }
  .r8-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(2px);
    z-index: 0;
    mix-blend-mode: multiply;
  }
  .r8-blob--coral {
    background: var(--r-coral);
    width: 320px;
    height: 280px;
    top: -50px;
    left: -40px;
    border-radius: 60% 40% 50% 50% / 50% 60% 40% 50%;
    opacity: 0.85;
  }
  .r8-blob--navy {
    background: var(--r-navy);
    width: 220px;
    height: 220px;
    top: 100px;
    right: 15%;
    border-radius: 45% 55% 60% 40% / 55% 45% 55% 45%;
    opacity: 0.78;
  }
  .r8-h1 {
    position: relative;
    z-index: 1;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 7vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .r8-h1__line { display: block; }
  .r8-h1__line--accent {
    color: var(--r-coral);
    font-style: italic;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 500;
    letter-spacing: -0.025em;
  }
  .r8-h1__line--big {
    font-size: 1.15em;
  }
  .r8-hero__bottom {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: end;
    border-top: 1px solid rgba(26,24,20,0.25);
    padding-top: 2.5rem;
  }
  .r8-hero__sub {
    font-size: 1.05rem;
    line-height: 1.75;
    max-width: 580px;
    margin: 0;
    color: #3a352c;
  }
  .r8-btn {
    display: inline-block;
    padding: 1rem 1.8rem;
    background: var(--r-navy);
    color: var(--r-cream);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 4px;
    transition: background 0.2s ease;
    white-space: nowrap;
  }
  .r8-btn:hover { background: var(--r-coral); }
  .r8-btn--lg {
    padding: 1.3rem 2.6rem;
    font-size: 1rem;
  }

  /* ─── SECTIONS ─── */
  .r8-section { padding: 6rem 0; }
  .r8-section--alt { background: rgba(214,165,68,0.1); }
  .r8-section__head {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    margin-bottom: 4rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(26,24,20,0.2);
  }
  .r8-section__num {
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    color: var(--r-coral);
  }
  .r8-section__title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    color: var(--r-navy);
    margin: 0;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  /* ─── SERVICES ─── */
  .r8-srv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  .r8-srv__visual {
    aspect-ratio: 4/3;
    margin-bottom: 1.6rem;
    border-radius: 4px;
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1.5rem;
    overflow: hidden;
  }
  .r8-srv__visual::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 25% 30%, rgba(0,0,0,0.18) 0%, transparent 35%),
      radial-gradient(circle at 75% 70%, rgba(255,255,255,0.15) 0%, transparent 40%);
    mix-blend-mode: multiply;
  }
  .r8-srv__visual--coral { background: var(--r-coral); }
  .r8-srv__visual--navy { background: var(--r-navy); }
  .r8-stamp {
    background: var(--r-cream);
    color: var(--r-ink);
    padding: 0.4rem 0.9rem;
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    border: 2px solid var(--r-ink);
    border-radius: 999px;
    transform: rotate(-3deg);
    position: relative;
    z-index: 1;
  }
  .r8-srv__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.8rem, 3.2vw, 2.6rem);
    line-height: 1.05;
    color: var(--r-navy);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }
  .r8-srv p {
    font-size: 0.98rem;
    line-height: 1.7;
    color: #3a352c;
    margin: 0 0 1.5rem;
  }
  .r8-link {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--r-coral);
    text-decoration: none;
    border-bottom: 2px solid var(--r-coral);
    padding-bottom: 0.2rem;
  }
  .r8-link:hover { color: var(--r-navy); border-bottom-color: var(--r-navy); }

  /* ─── STATS ─── */
  .r8-stats {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }
  .r8-stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .r8-stat__big {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(3.5rem, 7vw, 6rem);
    color: var(--r-navy);
    letter-spacing: -0.04em;
    line-height: 0.9;
  }
  .r8-stat__big--coral { color: var(--r-coral); }
  .r8-stat__big small {
    font-size: 0.4em;
    color: rgba(29,41,86,0.55);
    font-weight: 500;
  }
  .r8-stat__lbl {
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #3a352c;
  }
  .r8-stat__divider {
    width: 1px;
    height: 60%;
    background: rgba(26,24,20,0.25);
  }

  /* ─── PROJECTS ─── */
  .r8-projects {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid rgba(26,24,20,0.2);
  }
  .r8-projects li {
    border-bottom: 1px solid rgba(26,24,20,0.2);
  }
  .r8-project {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2.5rem;
    padding: 2.2rem 0;
    text-decoration: none;
    color: var(--r-ink);
    align-items: start;
    transition: padding 0.2s ease;
  }
  .r8-project:hover { padding-left: 1.5rem; }
  .r8-project__visual {
    width: 200px;
    height: 130px;
    border-radius: 4px;
    position: relative;
    overflow: hidden;
  }
  .r8-project__visual--01 {
    background:
      radial-gradient(circle at 30% 40%, var(--r-coral) 0%, var(--r-coral) 30%, transparent 31%),
      radial-gradient(circle at 70% 60%, var(--r-navy) 0%, var(--r-navy) 35%, transparent 36%),
      var(--r-mustard);
  }
  .r8-project__visual--02 {
    background:
      linear-gradient(45deg, transparent 49%, var(--r-coral) 49%, var(--r-coral) 51%, transparent 51%) 0 0/30px 30px,
      var(--r-navy);
  }
  .r8-project__visual--03 {
    background:
      radial-gradient(circle, var(--r-cream) 3px, transparent 3px) 0 0/20px 20px,
      var(--r-coral);
  }
  .r8-project__year {
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.15em;
    color: var(--r-coral);
  }
  .r8-project__name {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.5rem, 2.6vw, 2.2rem);
    color: var(--r-navy);
    margin: 0.4rem 0 0.6rem;
    letter-spacing: -0.02em;
  }
  .r8-project p {
    font-size: 0.95rem;
    line-height: 1.65;
    color: #3a352c;
    margin: 0;
    max-width: 540px;
  }

  /* ─── COLOPHON ─── */
  .r8-colophon {
    padding: 7rem 0 5rem;
    text-align: center;
    background: var(--r-navy);
    color: var(--r-cream);
  }
  .r8-colophon__kicker {
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.25em;
    color: var(--r-coral);
    margin: 0 0 2rem;
  }
  .r8-colophon__title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-style: italic;
    font-size: clamp(2.5rem, 5.5vw, 5rem);
    line-height: 1.05;
    color: var(--r-cream);
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
  }
  .r8-colophon__title--accent { color: var(--r-coral); }
  .r8-colophon__sub {
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(251,246,233,0.75);
    max-width: 540px;
    margin: 0 auto 3rem;
  }
  .r8-colophon .r8-btn {
    background: var(--r-coral);
    color: var(--r-cream);
  }
  .r8-colophon .r8-btn:hover { background: var(--r-cream); color: var(--r-navy); }
  .r8-colophon__credit {
    margin-top: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    color: rgba(251,246,233,0.5);
  }
  .r8-colophon__credit span:nth-child(odd) { color: var(--r-coral); }

  @media (max-width: 768px) {
    .r8-hero__bottom { grid-template-columns: 1fr; gap: 2rem; }
    .r8-srv-grid { grid-template-columns: 1fr; gap: 3rem; }
    .r8-stats { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
    .r8-stat__divider { display: none; }
    .r8-project { grid-template-columns: 1fr; gap: 1rem; }
    .r8-project__visual { width: 100%; height: 180px; }
    .r8-section__head { flex-direction: column; gap: 0.8rem; align-items: flex-start; }
  }
</style>

<script>
if (!document.querySelector('link[href*="Cormorant+Garamond"]')) {
  const link = document.createElement('link');
  link.rel = 'stylesheet';
  link.href = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap';
  document.head.appendChild(link);
}
</script>
