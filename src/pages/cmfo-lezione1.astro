---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Come Metterci la Faccia Online – Lezione 1"
  description="Prima lezione gratuita del corso Come Metterci la Faccia Online: impara a costruire la tua presenza online in modo autentico."
  currentPath="/cmfo-lezione1/"
>

<style>
  .lz-wrap {
    background: var(--black, #1E2B2F);
    min-height: 100vh;
    color: var(--white, #fff);
    font-family: var(--sans, 'Syne', sans-serif);
  }
  .lz-header {
    background: rgba(255,255,255,.04);
    border-bottom: 1px solid rgba(255,255,255,.08);
    padding: 18px 24px;
  }
  .lz-header-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .lz-course-label {
    font-family: var(--sans, 'Syne', sans-serif);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #D4840A;
  }
  .lz-course-sub {
    font-size: 12px;
    color: rgba(255,255,255,.35);
    margin-top: 3px;
  }
  .lz-badge {
    display: inline-flex;
    align-items: center;
    background: rgba(212,132,10,.12);
    border: 1px solid rgba(212,132,10,.35);
    color: #D4840A;
    padding: 5px 16px;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    font-family: var(--sans, 'Syne', sans-serif);
  }
  .lz-video-section {
    padding: 52px 24px 36px;
    max-width: 900px;
    margin: 0 auto;
  }
  .lz-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(255,255,255,.4);
    font-size: 13px;
    text-decoration: none;
    margin-bottom: 36px;
    transition: color .2s;
    font-family: var(--sans, 'Syne', sans-serif);
  }
  .lz-back:hover { color: #D4840A; opacity: 1; }
  .lz-title {
    font-family: var(--display, 'Bricolage Grotesque', sans-serif);
    font-size: clamp(22px, 3.5vw, 36px);
    font-weight: 800;
    margin-bottom: 28px;
    line-height: 1.15;
    color: var(--white, #fff);
  }
  .lz-title em {
    font-style: italic;
    font-family: var(--serif, 'Cormorant', serif);
    font-size: 1.15em;
    color: #D4840A;
    font-weight: 600;
  }
  .lz-video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 4px;
    background: #000;
    box-shadow: 0 12px 60px rgba(0,0,0,.7);
  }
  .lz-video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: 0;
  }
  .lz-content {
    padding: 44px 24px 100px;
    max-width: 900px;
    margin: 0 auto;
  }
  .lz-divider {
    border: none;
    border-top: 1px solid rgba(255,255,255,.08);
    margin: 44px 0;
  }
  .lz-next {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-left: 3px solid #D4840A;
    border-radius: 0 4px 4px 0;
    padding: 28px 32px;
    text-decoration: none;
    color: inherit;
    transition: background .2s;
  }
  .lz-next:hover { background: rgba(255,255,255,.07); opacity: 1; }
  .lz-next-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #D4840A;
    margin-bottom: 8px;
    font-family: var(--sans, 'Syne', sans-serif);
  }
  .lz-next-title {
    font-family: var(--display, 'Bricolage Grotesque', sans-serif);
    font-size: 17px;
    font-weight: 700;
    color: var(--white, #fff);
    margin-bottom: 6px;
  }
  .lz-next-desc {
    font-size: 14px;
    color: rgba(255,255,255,.45);
    line-height: 1.5;
  }
  .lz-next-arrow {
    color: #D4840A;
    font-size: 26px;
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .lz-next { flex-direction: column; align-items: flex-start; }
    .lz-next-arrow { display: none; }
  }
</style>

<div class="lz-wrap">

  <div class="lz-header">
    <div class="lz-header-inner">
      <div>
        <div class="lz-course-label">Come Metterci la Faccia Online</div>
        <div class="lz-course-sub">Guida gratuita · Marco Munich</div>
      </div>
      <div class="lz-badge">Lezione 1 di 2</div>
    </div>
  </div>

  <div class="lz-video-section">
    <a href="/metterci-la-faccia-online/" class="lz-back">← Torna alla guida</a>
    <h1 class="lz-title">Lezione 1 — <em>Come iniziare a metterci la faccia</em></h1>
    <div class="lz-video-wrapper">
      <iframe
        src="https://www.youtube-nocookie.com/embed/SHOnybFwvlc?rel=0&modestbranding=1"
        title="Come Metterci la Faccia Online – Lezione 1"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <div class="lz-content">
    <hr class="lz-divider" />
    <a href="/cmfo-lezione2/" class="lz-next">
      <div>
        <div class="lz-next-label">Prossima lezione →</div>
        <div class="lz-next-title">Lezione 2 — Le 3 azioni specifiche nel dettaglio</div>
        <div class="lz-next-desc">Parleremo delle 3 azioni specifiche, viste nel dettaglio.</div>
      </div>
      <div class="lz-next-arrow">→</div>
    </a>
  </div>

</div>

</BaseLayout>
