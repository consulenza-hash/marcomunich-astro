---
/**
 * tag/[slug].astro — Y2K Chrome
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import { getAllTags, getPostsByTag, ghostPostToArticolo } from '@lib/ghost';

export async function getStaticPaths() {
  const tags = await getAllTags();
  const paths = await Promise.all(tags.map(async (tag) => {
    const ghostPosts = await getPostsByTag(tag.slug);
    const posts = ghostPosts.map(p => ghostPostToArticolo(p));
    return { params: { slug: tag.slug }, props: { tag, posts } };
  }));
  return paths;
}

const { tag, posts } = Astro.props;
const tagName = tag.name ?? '';
const tagDesc = tag.description ?? '';
---

<BaseLayout
  title={`#${tagName} — Marco Munich`}
  description={tagDesc || `Articoli con tag ${tagName} di Marco Munich.`}
  currentPath={`/tag/${tag.slug}/`}
>

<div class="tag-page">

  <section class="tag-hero">
    <div class="tag-container">
      <div class="tag-status-bar">
        <span class="tag-pill">SYS · tag</span>
        <span class="tag-pill">{posts.length} articoli</span>
      </div>
      <h1 class="tag-h1">
        <span class="tag-h1__prefix">▸</span>
        <span class="tag-h1__chrome">#{tagName}</span>
      </h1>
      {tagDesc && <p class="tag-hero__desc">{tagDesc}</p>}
    </div>
  </section>

  <section class="tag-section">
    <div class="tag-container">
      <h2 class="tag-section__title"><span class="tag-arrow">▸</span> ARTICOLI · #{tagName.toUpperCase()}</h2>

      {posts.length > 0 ? (
        <div class="tag-grid">
          {posts.map(post => <PostCard post={post} />)}
        </div>
      ) : (
        <p class="tag-empty">// nessun articolo con questo tag.</p>
      )}

      <div class="tag-back">
        <a href="/blog/" class="tag-back__link">← tutti gli articoli</a>
      </div>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .tag-page { color: #f0e9ff; font-family: 'Inter', system-ui, sans-serif; min-height: 100vh; }
  .tag-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; }

  .tag-hero { padding: 5rem 0 3.5rem; }
  .tag-status-bar { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
  .tag-pill { display: inline-flex; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; color: #ff2d92; background: rgba(255,45,146,0.08); border: 1px solid rgba(255,45,146,0.4); padding: 0.35rem 0.8rem; border-radius: 999px; }
  .tag-h1 { font-family: 'Inter', sans-serif; font-weight: 900; font-size: clamp(2.5rem, 9vw, 7rem); line-height: 0.92; letter-spacing: -0.04em; margin: 0 0 1.5rem; display: flex; align-items: baseline; gap: 0.4rem; }
  .tag-h1__prefix { color: #00e5ff; font-family: 'JetBrains Mono', monospace; font-size: 0.5em; }
  .tag-h1__chrome { background: linear-gradient(180deg, #ff2d92 0%, #ffe2f0 30%, #8a3aff 70%, #4a0066 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent; }
  .tag-hero__desc { font-size: 1.05rem; line-height: 1.7; color: rgba(240,233,255,0.7); max-width: 600px; margin: 0; }

  .tag-section { padding: 3rem 0 6rem; }
  .tag-section__title { font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: 700; letter-spacing: 0.2em; color: #ff2d92; margin: 0 0 3rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,45,146,0.3); }
  .tag-arrow { color: #00e5ff; }
  .tag-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .tag-empty { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: rgba(240,233,255,0.4); padding: 3rem 0; text-align: center; }
  .tag-back { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px dashed rgba(240,233,255,0.1); }
  .tag-back__link { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: rgba(240,233,255,0.5); text-decoration: none; transition: color 0.15s; }
  .tag-back__link:hover { color: #00e5ff; }

  @media (max-width: 1024px) { .tag-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .tag-grid { grid-template-columns: 1fr; } }
</style>
