---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Come Metterci la Faccia Online – Lezione 2"
  description="Seconda lezione gratuita del corso Come Metterci la Faccia Online: le 3 azioni specifiche per costruire la tua presenza online in modo autentico."
  currentPath="/cmfo-lezione2/"
>

<style>
  .lesson-wrap {
    background: #0f0f0f;
    min-height: 100vh;
    color: #fff;
  }
  .lesson-header {
    background: #111;
    border-bottom: 1px solid #222;
    padding: 20px 24px;
  }
  .lesson-header-inner {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .course-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9DFF20;
  }
  .lesson-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(157,255,32,.12);
    border: 1px solid rgba(157,255,32,.3);
    color: #9DFF20;
    padding: 5px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
  }
  .video-section {
    padding: 48px 24px 32px;
    max-width: 900px;
    margin: 0 auto;
  }
  .lesson-title {
    font-size: clamp(22px, 3vw, 32px);
    font-weight: 800;
    margin-bottom: 24px;
    line-height: 1.2;
    color: #fff;
  }
  .lesson-title span {
    color: #9DFF20;
  }
  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
    box-shadow: 0 8px 40px rgba(0,0,0,.6);
  }
  .video-wrapper iframe {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    border: 0;
  }
  .lesson-content {
    padding: 40px 24px 80px;
    max-width: 900px;
    margin: 0 auto;
  }
  .lesson-divider {
    border: none;
    border-top: 1px solid #222;
    margin: 40px 0;
  }
  .completed-box {
    background: #1a1a1a;
    border: 1px solid #333;
    border-left: 4px solid #9DFF20;
    border-radius: 0 12px 12px 0;
    padding: 28px 32px;
    margin-bottom: 32px;
  }
  .completed-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #9DFF20;
    margin-bottom: 8px;
  }
  .completed-text {
    font-size: 15px;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
  }
  .cta-section {
    background: linear-gradient(135deg, #111 0%, #1a2a00 100%);
    border: 1px solid rgba(157,255,32,.2);
    border-radius: 12px;
    padding: 36px 32px;
    text-align: center;
  }
  .cta-title {
    font-size: 22px;
    font-weight: 800;
    margin-bottom: 12px;
    color: #fff;
  }
  .cta-desc {
    font-size: 15px;
    color: #999;
    margin-bottom: 24px;
    line-height: 1.6;
  }
  .cta-btn {
    display: inline-block;
    background: #9DFF20;
    color: #0f0f0f;
    padding: 14px 32px;
    font-weight: 800;
    font-size: 15px;
    text-decoration: none;
    border-radius: 6px;
    transition: opacity .2s;
  }
  .cta-btn:hover { opacity: .85; }
  .prev-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #666;
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 40px;
    transition: color .2s;
  }
  .prev-link:hover {
    color: #9DFF20;
    opacity: 1;
  }
</style>

<div class="lesson-wrap">

  <!-- Header corso -->
  <div class="lesson-header">
    <div class="lesson-header-inner">
      <div>
        <div class="course-label">Come Metterci la Faccia Online</div>
        <div style="font-size:13px; color:#555; margin-top:2px;">Guida gratuita · Marco Munich</div>
      </div>
      <div class="lesson-badge">Lezione 2 di 2</div>
    </div>
  </div>

  <!-- Video -->
  <div class="video-section">
    <a href="/cmfo-lezione1/" class="prev-link">
      ← Torna alla Lezione 1
    </a>
    <h1 class="lesson-title">
      Lezione 2 — <span>Le 3 azioni specifiche nel dettaglio</span>
    </h1>
    <div class="video-wrapper">
      <iframe
        src="https://www.youtube-nocookie.com/embed/lxXmigUqAM8?rel=0&modestbranding=1"
        title="Come Metterci la Faccia Online – Lezione 2"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <!-- Contenuto + CTA -->
  <div class="lesson-content">

    <hr class="lesson-divider" />

    <!-- Completato -->
    <div class="completed-box">
      <div class="completed-label">✓ Corso completato</div>
      <p class="completed-text">Hai visto entrambe le lezioni di "Come Metterci la Faccia Online". Ora sai da dove iniziare per costruire la tua presenza online in modo autentico.</p>
    </div>

    <!-- CTA -->
    <div class="cta-section">
      <div class="cta-title">Vuoi approfondire?</div>
      <p class="cta-desc">
        Scopri il percorso completo per imparare a fare video e costruire la tua presenza online restando te stesso.
      </p>
      <a href="/metterci-la-faccia-online/" class="cta-btn">
        Torna alla guida completa →
      </a>
    </div>

  </div>

</div>

</BaseLayout>
