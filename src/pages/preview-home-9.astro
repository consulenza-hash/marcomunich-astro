---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Preview Home 9 — Y2K Chrome"
  description="Mockup direzione Y2K/chrome futurista."
  currentPath="/preview-home-9/"
>

<div class="y9-page">

  <!-- bg gradient mesh -->
  <div class="y9-bg" aria-hidden="true">
    <span class="y9-bg__blob y9-bg__blob--magenta"></span>
    <span class="y9-bg__blob y9-bg__blob--cyan"></span>
    <span class="y9-bg__blob y9-bg__blob--violet"></span>
  </div>

  <!-- ── HERO Y2K ─────────────────────────────────────────────────────── -->
  <section class="y9-hero">
    <div class="y9-container">
      <div class="y9-status-bar">
        <span class="y9-status-bar__pill">▸ ONLINE</span>
        <span class="y9-status-bar__pill">SYS: marco.dev</span>
        <span class="y9-status-bar__pill">v.2026.4</span>
      </div>

      <h1 class="y9-h1">
        <span class="y9-h1__chrome">SITI.</span>
        <span class="y9-h1__chrome y9-h1__chrome--violet">APP.</span>
        <span class="y9-h1__chrome y9-h1__chrome--cyan">BRAND.</span>
      </h1>

      <p class="y9-hero__tag">
        Sviluppo siti e applicazioni per chi vende se stesso. Vengo da sette anni di personal branding olistico, oggi traduco quell'esperienza in codice. ✦
      </p>

      <div class="y9-hero__ctas">
        <a href="/contatti/" class="y9-btn y9-btn--chrome">[ INIZIA UN PROGETTO ]</a>
        <a href="#cosa" class="y9-btn y9-btn--ghost">↓ Cosa faccio</a>
      </div>

      <div class="y9-hero__windows">
        <div class="y9-window">
          <div class="y9-window__bar">
            <span></span><span></span><span></span>
            <span class="y9-window__title">marcomunich.com / index</span>
          </div>
          <div class="y9-window__body">
            <div class="y9-cmd">$ cat hero.txt</div>
            <div class="y9-output">Sviluppo siti veloci, sicuri, costruiti da zero.</div>
            <div class="y9-cmd">$ ls projects/</div>
            <div class="y9-output">marcomunich.com  vela  cms.marcomunich  inspiration-bot</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── COSA FACCIO ────────────────────────────────────────────────── -->
  <section class="y9-section" id="cosa">
    <div class="y9-container">
      <h2 class="y9-section__title"><span class="y9-arrow">▸</span> COSA FACCIO</h2>

      <div class="y9-services">
        <div class="y9-card">
          <div class="y9-card__head">
            <span class="y9-card__num">[ 01 ]</span>
            <span class="y9-card__type">DEVELOPMENT</span>
          </div>
          <h3 class="y9-card__title">Sviluppo siti<br>e applicazioni.</h3>
          <p>
            Astro, FastAPI, codice pulito. Niente template, niente plugin obbligatori, niente abbonamenti mensili. Performance verificabili e file tutti tuoi alla consegna.
          </p>
          <ul class="y9-tags">
            <li>● Siti vetrina</li>
            <li>● Landing page</li>
            <li>● E-commerce</li>
            <li>● Web app custom</li>
          </ul>
          <a href="/portfolio/" class="y9-card__link">→ Vedi i progetti</a>
        </div>

        <div class="y9-card y9-card--alt">
          <div class="y9-card__head">
            <span class="y9-card__num">[ 02 ]</span>
            <span class="y9-card__type">CONSULTING</span>
          </div>
          <h3 class="y9-card__title">Posizionamento<br>online.</h3>
          <p>
            Per chi vende se stesso. Sette anni nel personal branding, oltre duecento articoli, un metodo che non si compra in un corso. Lavoriamo sul tuo punto di vista, non sulla tua immagine.
          </p>
          <ul class="y9-tags">
            <li>● Punto di vista</li>
            <li>● Voce autentica</li>
            <li>● Strategia contenuti</li>
            <li>● Differenziazione</li>
          </ul>
          <a href="/servizi/posizionamento-online/" class="y9-card__link">→ Scopri il metodo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── STATS NEON ─────────────────────────────────────────────── -->
  <section class="y9-section y9-stats-section">
    <div class="y9-container">
      <h2 class="y9-section__title"><span class="y9-arrow">▸</span> NUMERI</h2>

      <div class="y9-stats">
        <div class="y9-stat">
          <span class="y9-stat__big">218</span>
          <span class="y9-stat__hash">// articoli</span>
          <span class="y9-stat__lbl">pubblicati sul blog</span>
        </div>
        <div class="y9-stat">
          <span class="y9-stat__big">07</span>
          <span class="y9-stat__hash">// anni</span>
          <span class="y9-stat__lbl">di consulenza online</span>
        </div>
        <div class="y9-stat">
          <span class="y9-stat__big">100<i>/100</i></span>
          <span class="y9-stat__hash">// pagespeed</span>
          <span class="y9-stat__lbl">verificato su tutti i siti</span>
        </div>
        <div class="y9-stat">
          <span class="y9-stat__big">00</span>
          <span class="y9-stat__hash">// template</span>
          <span class="y9-stat__lbl">progetti costruiti da zero</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PROJECTS GRID ───────────────────────────────────────── -->
  <section class="y9-section">
    <div class="y9-container">
      <h2 class="y9-section__title"><span class="y9-arrow">▸</span> PROGETTI</h2>

      <div class="y9-projects">
        <a href="/portfolio/" class="y9-pgrid">
          <span class="y9-pgrid__year">[2026]</span>
          <h3>marcomunich.com</h3>
          <p>Sito + CMS custom · Astro 5 + Ghost + 277 articoli migrati</p>
          <span class="y9-pgrid__arrow">→</span>
        </a>
        <a href="/portfolio/" class="y9-pgrid">
          <span class="y9-pgrid__year">[2026]</span>
          <h3>vela</h3>
          <p>Web application · FastAPI + instagrapi · Railway deploy</p>
          <span class="y9-pgrid__arrow">→</span>
        </a>
        <a href="/portfolio/" class="y9-pgrid">
          <span class="y9-pgrid__year">[2026]</span>
          <h3>cms.marcomunich.com</h3>
          <p>Migrazione Ghost CMS · Admin API custom in PHP</p>
          <span class="y9-pgrid__arrow">→</span>
        </a>
        <a href="/portfolio/" class="y9-pgrid">
          <span class="y9-pgrid__year">[2026]</span>
          <h3>inspiration bot</h3>
          <p>Pipeline contenuti automatica · Telegram + PM2 daemon</p>
          <span class="y9-pgrid__arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA HOLOGRAPHIC ──────────────────────────────────────── -->
  <section class="y9-cta">
    <div class="y9-container">
      <div class="y9-cta__box">
        <p class="y9-cta__kicker">// LAVORIAMO INSIEME</p>
        <h2 class="y9-cta__title">
          <span class="y9-h1__chrome">PARLIAMONE.</span>
        </h2>
        <p class="y9-cta__sub">
          Una chiamata gratuita di 30 minuti. Ti dico cosa farei al tuo posto, e se posso aiutarti davvero. ✦
        </p>
        <a href="/contatti/" class="y9-btn y9-btn--big">[ FISSA UNA CHIAMATA → ]</a>
      </div>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .y9-page {
    background: #0a0512;
    color: #f0e9ff;
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
    position: relative;
    min-height: 100vh;
  }
  .y9-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  /* ─── BG MESH GRADIENT ─── */
  .y9-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
    z-index: 0;
  }
  .y9-bg__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.45;
  }
  .y9-bg__blob--magenta {
    background: #ff2d92;
    width: 600px; height: 600px;
    top: 10%; left: -10%;
    animation: y9float 18s ease-in-out infinite;
  }
  .y9-bg__blob--cyan {
    background: #00e5ff;
    width: 500px; height: 500px;
    top: 50%; right: -8%;
    animation: y9float 22s ease-in-out infinite reverse;
  }
  .y9-bg__blob--violet {
    background: #8a3aff;
    width: 700px; height: 700px;
    bottom: -20%; left: 30%;
    animation: y9float 25s ease-in-out infinite;
  }
  @keyframes y9float {
    0%, 100% { transform: translate(0,0) scale(1); }
    50% { transform: translate(40px, -60px) scale(1.1); }
  }

  /* ─── HERO ─── */
  .y9-hero {
    padding: 5rem 0 7rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }
  .y9-status-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 4rem;
  }
  .y9-status-bar__pill {
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #00e5ff;
    background: rgba(0,229,255,0.08);
    border: 1px solid rgba(0,229,255,0.4);
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
  }
  .y9-h1 {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 11vw, 10rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    margin: 0 0 2.5rem;
  }
  .y9-h1__chrome {
    display: block;
    background: linear-gradient(180deg,
      #ffffff 0%,
      #d8d8d8 25%,
      #909090 45%,
      #ffffff 55%,
      #f5f5f5 75%,
      #b5b5b5 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-shadow: 0 4px 30px rgba(255,255,255,0.15);
    filter: drop-shadow(0 0 20px rgba(255,45,146,0.3));
  }
  .y9-h1__chrome--violet {
    background: linear-gradient(180deg, #ff2d92 0%, #ffe2f0 30%, #8a3aff 70%, #4a0066 100%);
    -webkit-background-clip: text;
    background-clip: text;
    filter: drop-shadow(0 0 25px rgba(138,58,255,0.4));
  }
  .y9-h1__chrome--cyan {
    background: linear-gradient(180deg, #00e5ff 0%, #b8faff 35%, #007a99 70%, #002a33 100%);
    -webkit-background-clip: text;
    background-clip: text;
    filter: drop-shadow(0 0 25px rgba(0,229,255,0.4));
  }
  .y9-hero__tag {
    font-size: 1.1rem;
    line-height: 1.65;
    color: rgba(240,233,255,0.78);
    max-width: 600px;
    margin: 0 0 3rem;
  }
  .y9-hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 4rem;
  }

  /* Buttons */
  .y9-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 1rem 1.8rem;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.2s ease;
    display: inline-block;
  }
  .y9-btn--chrome {
    background: linear-gradient(180deg, #ffffff 0%, #b5b5b5 100%);
    color: #0a0512;
    box-shadow: 0 0 30px rgba(255,255,255,0.4), inset 0 -3px 0 rgba(0,0,0,0.2);
    border: 1px solid #fff;
  }
  .y9-btn--chrome:hover {
    box-shadow: 0 0 50px rgba(255,255,255,0.7);
    transform: translateY(-2px);
  }
  .y9-btn--ghost {
    background: transparent;
    color: #f0e9ff;
    border: 1px solid rgba(240,233,255,0.4);
  }
  .y9-btn--ghost:hover {
    border-color: #00e5ff;
    color: #00e5ff;
  }
  .y9-btn--big {
    padding: 1.4rem 2.6rem;
    font-size: 1.05rem;
    background: linear-gradient(180deg, #ffffff 0%, #cccccc 100%);
    color: #0a0512;
    box-shadow: 0 0 40px rgba(255,45,146,0.4);
  }
  .y9-btn--big:hover { box-shadow: 0 0 60px rgba(255,45,146,0.7); }

  /* Window mock */
  .y9-hero__windows {
    margin-top: 2rem;
  }
  .y9-window {
    background: rgba(10,5,18,0.6);
    border: 1px solid rgba(240,233,255,0.15);
    border-radius: 8px;
    overflow: hidden;
    backdrop-filter: blur(20px);
    max-width: 600px;
    box-shadow: 0 0 40px rgba(138,58,255,0.25);
  }
  .y9-window__bar {
    background: rgba(255,255,255,0.05);
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border-bottom: 1px solid rgba(240,233,255,0.1);
  }
  .y9-window__bar > span:nth-child(1),
  .y9-window__bar > span:nth-child(2),
  .y9-window__bar > span:nth-child(3) {
    width: 11px; height: 11px; border-radius: 50%;
  }
  .y9-window__bar > span:nth-child(1) { background: #ff5f57; }
  .y9-window__bar > span:nth-child(2) { background: #febc2e; }
  .y9-window__bar > span:nth-child(3) { background: #28c840; }
  .y9-window__title {
    margin-left: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: rgba(240,233,255,0.55);
  }
  .y9-window__body {
    padding: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    line-height: 1.8;
  }
  .y9-cmd { color: #00e5ff; }
  .y9-output { color: rgba(240,233,255,0.75); margin-left: 1rem; margin-bottom: 0.6rem; }

  /* ─── SECTIONS ─── */
  .y9-section {
    padding: 6rem 0;
  }
  .y9-section__title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #ff2d92;
    margin: 0 0 3.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,45,146,0.3);
  }
  .y9-arrow { color: #00e5ff; }

  /* ─── SERVICES ─── */
  .y9-services {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .y9-card {
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,45,146,0.04) 100%);
    border: 1px solid rgba(240,233,255,0.18);
    border-radius: 16px;
    padding: 2.5rem;
    backdrop-filter: blur(15px);
    box-shadow: 0 0 50px rgba(0,229,255,0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .y9-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 0 70px rgba(255,45,146,0.25);
  }
  .y9-card--alt {
    background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(0,229,255,0.04) 100%);
  }
  .y9-card__head {
    display: flex;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    color: rgba(240,233,255,0.55);
  }
  .y9-card__num { color: #ff2d92; }
  .y9-card__title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.2rem;
    color: #fff;
  }
  .y9-card p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(240,233,255,0.7);
    margin: 0 0 1.5rem;
  }
  .y9-tags {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1rem;
  }
  .y9-tags li {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    color: rgba(240,233,255,0.65);
  }
  .y9-card:nth-child(1) .y9-tags li::first-letter { color: #ff2d92; }
  .y9-card:nth-child(2) .y9-tags li::first-letter { color: #00e5ff; }
  .y9-card__link {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    color: #00e5ff;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,229,255,0.5);
    padding-bottom: 0.2rem;
  }

  /* ─── STATS ─── */
  .y9-stats-section { padding: 4rem 0 6rem; }
  .y9-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .y9-stat {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(240,233,255,0.12);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    backdrop-filter: blur(10px);
  }
  .y9-stat__big {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.8rem, 5vw, 4.2rem);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(180deg, #fff 0%, #00e5ff 60%, #007a99 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.8rem;
  }
  .y9-stat__big i {
    font-size: 0.4em;
    color: rgba(240,233,255,0.4);
    font-style: normal;
  }
  .y9-stat__hash {
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #ff2d92;
    margin-bottom: 0.3rem;
  }
  .y9-stat__lbl {
    font-size: 0.82rem;
    color: rgba(240,233,255,0.6);
  }

  /* ─── PROJECTS GRID ─── */
  .y9-projects {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .y9-pgrid {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(240,233,255,0.15);
    border-radius: 12px;
    padding: 2rem;
    text-decoration: none;
    color: #f0e9ff;
    display: grid;
    grid-template-columns: 1fr 30px;
    grid-template-rows: auto auto auto;
    gap: 0.4rem 1rem;
    backdrop-filter: blur(10px);
    transition: all 0.2s ease;
  }
  .y9-pgrid:hover {
    border-color: #00e5ff;
    box-shadow: 0 0 40px rgba(0,229,255,0.2);
  }
  .y9-pgrid__year {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #ff2d92;
    grid-column: 1;
  }
  .y9-pgrid h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    margin: 0;
    grid-column: 1;
    color: #fff;
  }
  .y9-pgrid p {
    font-size: 0.9rem;
    color: rgba(240,233,255,0.65);
    margin: 0;
    grid-column: 1;
    line-height: 1.55;
  }
  .y9-pgrid__arrow {
    grid-row: 1 / 4;
    grid-column: 2;
    align-self: center;
    color: #00e5ff;
    font-size: 1.4rem;
  }

  /* ─── CTA ─── */
  .y9-cta { padding: 7rem 0 9rem; }
  .y9-cta__box {
    text-align: center;
    background: linear-gradient(135deg, rgba(138,58,255,0.1) 0%, rgba(0,229,255,0.08) 100%);
    border: 1px solid rgba(240,233,255,0.2);
    border-radius: 24px;
    padding: 5rem 3rem;
    backdrop-filter: blur(20px);
    box-shadow: 0 0 80px rgba(255,45,146,0.15);
  }
  .y9-cta__kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: #00e5ff;
    margin: 0 0 2rem;
    letter-spacing: 0.2em;
  }
  .y9-cta__title {
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.9;
    margin: 0 0 2rem;
  }
  .y9-cta__sub {
    font-size: 1.05rem;
    color: rgba(240,233,255,0.75);
    max-width: 500px;
    margin: 0 auto 3rem;
    line-height: 1.65;
  }

  @media (max-width: 768px) {
    .y9-services, .y9-projects { grid-template-columns: 1fr; }
    .y9-stats { grid-template-columns: 1fr 1fr; }
    .y9-tags { grid-template-columns: 1fr; }
    .y9-cta__box { padding: 3.5rem 2rem; }
  }
</style>
