---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Preview 12 — Glassmorphic" description="Glass / Vision OS." currentPath="/preview-home-12/">

<div class="gl-page">
  <div class="gl-bg">
    <span class="gl-orb gl-orb--1"></span>
    <span class="gl-orb gl-orb--2"></span>
    <span class="gl-orb gl-orb--3"></span>
  </div>

  <section class="gl-hero">
    <div class="gl-pill">
      <span class="gl-pulse"></span>
      Disponibile · Maggio 2026
    </div>
    <h1>
      Sviluppo siti<br>
      e applicazioni<br>
      <span class="gl-h1__accent">su misura.</span>
    </h1>
    <p class="gl-hero__sub">
      Per chi vende se stesso. Costruiti da zero, codice pulito, performance verificabili. Niente template, niente abbonamenti mensili.
    </p>
    <div class="gl-hero__ctas">
      <a href="/contatti/" class="gl-btn gl-btn--primary">Lavoriamo insieme →</a>
      <a href="/portfolio/" class="gl-btn gl-btn--ghost">Vedi i progetti</a>
    </div>
  </section>

  <section class="gl-services">
    <div class="gl-glass">
      <span class="gl-glass__num">01</span>
      <h3>Sviluppo</h3>
      <p>Siti, landing, e-commerce, web app. Astro + FastAPI. File tutti tuoi alla consegna.</p>
      <a href="/portfolio/" class="gl-link">Vedi progetti →</a>
    </div>
    <div class="gl-glass">
      <span class="gl-glass__num">02</span>
      <h3>Posizionamento</h3>
      <p>Per chi vende se stesso. 7 anni di consulenza, 218 articoli, un metodo che non si compra in un corso.</p>
      <a href="/servizi/posizionamento-online/" class="gl-link">Scopri il metodo →</a>
    </div>
    <div class="gl-glass">
      <span class="gl-glass__num">03</span>
      <h3>Vibe Coding</h3>
      <p>Guido l'AI per costruire più velocemente, con codice migliore. Risultato: stesso output di sviluppo tradizionale.</p>
      <a href="/vibe-coding/" class="gl-link">Come funziona →</a>
    </div>
  </section>

  <section class="gl-stats">
    <div class="gl-stat-glass">
      <span class="gl-stat__big">218</span>
      <span class="gl-stat__lbl">Articoli<br>pubblicati</span>
    </div>
    <div class="gl-stat-glass">
      <span class="gl-stat__big">07</span>
      <span class="gl-stat__lbl">Anni<br>di lavoro</span>
    </div>
    <div class="gl-stat-glass">
      <span class="gl-stat__big">100<small>/100</small></span>
      <span class="gl-stat__lbl">Google<br>PageSpeed</span>
    </div>
    <div class="gl-stat-glass">
      <span class="gl-stat__big">00</span>
      <span class="gl-stat__lbl">Template<br>usati</span>
    </div>
  </section>

  <section class="gl-cta">
    <div class="gl-glass gl-glass--cta">
      <h2>Hai un progetto<br>in mente?</h2>
      <p>Una chiamata gratuita di trenta minuti. Capisco la situazione, ti dico cosa farei al tuo posto.</p>
      <a href="/contatti/" class="gl-btn gl-btn--primary">Fissa una chiamata →</a>
    </div>
  </section>
</div>

</BaseLayout>

<style>
  .gl-page {
    background: #f0eaff;
    color: #1a1428;
    font-family: 'Inter', system-ui, sans-serif;
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    padding-bottom: 6rem;
  }
  .gl-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .gl-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
  }
  .gl-orb--1 { background: #ff9eb1; width: 500px; height: 500px; top: 5%; left: -8%; }
  .gl-orb--2 { background: #a8c8ff; width: 600px; height: 600px; top: 30%; right: -10%; }
  .gl-orb--3 { background: #c3a3ff; width: 500px; height: 500px; bottom: -10%; left: 30%; }

  /* HERO */
  .gl-hero {
    max-width: 900px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .gl-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.6);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #5a3a8a;
    margin-bottom: 2.5rem;
  }
  .gl-pulse {
    width: 8px; height: 8px;
    background: #4ade80;
    border-radius: 50%;
    box-shadow: 0 0 0 0 rgba(74,222,128,0.6);
    animation: glpulse 2s infinite;
  }
  @keyframes glpulse {
    0% { box-shadow: 0 0 0 0 rgba(74,222,128,0.6); }
    70% { box-shadow: 0 0 0 10px rgba(74,222,128,0); }
  }
  .gl-hero h1 {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(3rem, 7vw, 6.5rem);
    line-height: 0.95;
    letter-spacing: -0.045em;
    margin: 0 0 2rem;
    color: #1a1428;
  }
  .gl-h1__accent {
    background: linear-gradient(120deg, #ff7a8a 0%, #a06bff 50%, #5a8eff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .gl-hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: rgba(26,20,40,0.7);
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }
  .gl-hero__ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .gl-btn {
    padding: 1rem 1.8rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }
  .gl-btn--primary {
    background: rgba(26,20,40,0.85);
    color: #fff;
    backdrop-filter: blur(15px);
    box-shadow: 0 8px 30px rgba(160,107,255,0.25);
  }
  .gl-btn--primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(160,107,255,0.4); }
  .gl-btn--ghost {
    background: rgba(255,255,255,0.4);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 1px solid rgba(255,255,255,0.7);
    color: #1a1428;
  }
  .gl-btn--ghost:hover { background: rgba(255,255,255,0.6); }

  /* SERVICES */
  .gl-services {
    max-width: 1200px;
    margin: 4rem auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .gl-glass {
    background: rgba(255,255,255,0.4);
    backdrop-filter: blur(25px) saturate(180%);
    -webkit-backdrop-filter: blur(25px) saturate(180%);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 24px;
    padding: 2rem;
    transition: all 0.25s ease;
    box-shadow: 0 8px 32px rgba(160,107,255,0.08);
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .gl-glass:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 50px rgba(160,107,255,0.18);
  }
  .gl-glass__num {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: #a06bff;
    letter-spacing: 0.05em;
  }
  .gl-glass h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .gl-glass p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(26,20,40,0.7);
    margin: 0;
  }
  .gl-link {
    margin-top: auto;
    color: #a06bff;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
  }

  /* STATS */
  .gl-stats {
    max-width: 1200px;
    margin: 4rem auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }
  .gl-stat-glass {
    background: rgba(255,255,255,0.45);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    text-align: center;
  }
  .gl-stat__big {
    display: block;
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.6rem, 4vw, 3.6rem);
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(120deg, #ff7a8a 0%, #a06bff 60%, #5a8eff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    margin-bottom: 0.6rem;
  }
  .gl-stat__big small {
    font-size: 0.4em;
    color: rgba(26,20,40,0.4);
    font-weight: 500;
    -webkit-text-fill-color: rgba(26,20,40,0.4);
  }
  .gl-stat__lbl {
    font-size: 0.85rem;
    color: rgba(26,20,40,0.7);
    font-weight: 500;
    line-height: 1.4;
  }

  /* CTA */
  .gl-cta {
    max-width: 900px;
    margin: 4rem auto 0;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }
  .gl-glass--cta {
    text-align: center;
    padding: 4rem 2rem;
    align-items: center;
  }
  .gl-glass--cta h2 {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.04em;
    line-height: 1;
    margin: 0 0 1rem;
  }
  .gl-glass--cta p {
    max-width: 460px;
    margin: 0 0 2rem;
  }

  @media (max-width: 768px) {
    .gl-services, .gl-stats { grid-template-columns: 1fr 1fr; }
    .gl-services { grid-template-columns: 1fr; }
  }
</style>
