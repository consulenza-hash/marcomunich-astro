---
import BaseLayout from '@layouts/BaseLayout.astro';

const punti = [
  {
    n: "1",
    title: "La domanda esistenziale che cambia tutto",
    text: "Scopri la domanda fondamentale che ti permette di capire come aiutare i tuoi potenziali clienti partendo da ciò che ami, non da ciò che \"dovresti\" fare."
  },
  {
    n: "2",
    title: "Cosa significa creare da uno spazio di Servizio",
    text: "La differenza tra un prodotto gratuito creato dalla paura di non avere clienti e uno creato da un genuino desiderio di aiutare. Il pubblico sente questa differenza."
  },
  {
    n: "3",
    title: "Come trasformare la tua competenza in una gratuità utile",
    text: "Imparerai a estrarre da te stesso il valore che già possiedi e trasformarlo in qualcosa che le persone sentono come un regalo autentico."
  },
  {
    n: "4",
    title: "Restare nel tuo centro mentre offri qualcosa gratis",
    text: "Come fare in modo che la tua gratuità attiri persone a cui risuoni veramente, senza sentirti sfruttato o fuori dal tuo asse."
  },
];

const ideals = [
  { title: "Sei coach, counselor o operatore olistico", text: "Vuoi creare qualcosa da offrire gratuitamente ma non sai da dove iniziare, o non vuoi farlo 'solo per avere la mail' delle persone." },
  { title: "Hai già un messaggio ma non sai come comunicarlo", text: "Senti di avere qualcosa di valore da condividere ma ti blocchi quando si tratta di creare contenuto gratuito in modo autentico." },
  { title: "Non vuoi sentirti falso", text: "Vuoi che il tuo prodotto gratuito rispecchi chi sei davvero e non una versione di marketing di te stesso." },
  { title: "Vuoi attrarre le persone giuste", text: "Stai cercando di costruire un pubblico che risuoni con i tuoi valori, non semplicemente raccogliere contatti." },
];

const VIDEO_URL = "https://youtu.be/vzTqnpFhALE?list=PLKgzAWOyM8xv6uBoRyB28N5fpxtbcepz9";
---

<BaseLayout
  title="Come Creare Prodotti Gratuiti da uno Spazio di Servizio - Marco Munich"
  description="Video lezione di 50 minuti: la domanda esistenziale che ti permette di creare contenuto gratuito autentico restando in uno spazio di passione per ciò che fai."
  currentPath="/creare-prodotti-gratuiti/"
>

<div class="orange-page">

  <!-- Hero -->
  <section style="background: #1a0500; color: #fff; padding: 80px 24px 64px;">
    <div style="max-width: 760px; margin: 0 auto; text-align: center;">
      <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(234,88,12,.15); border: 1px solid rgba(234,88,12,.4); color: #fdba74; padding: 6px 14px; border-radius: 100px; font-size: 13px; font-weight: 700; letter-spacing: 2px; margin-bottom: 24px;">
        VIDEO LEZIONE · 50 MINUTI
      </div>
      <h1 style="font-size: clamp(30px, 5vw, 50px); font-weight: 800; line-height: 1.1; color: #fff; margin-bottom: 20px;">
        Come Creare Prodotti Gratuiti<br><span style="color: #EA580C;">da uno Spazio di Servizio</span>
      </h1>
      <p style="font-size: 17px; line-height: 1.7; color: #bbb; margin-bottom: 36px;">
        Una video lezione dove ti mostro la <strong style="color:#fff;">domanda esistenziale</strong> che ti permette
        di capire come aiutare i tuoi potenziali clienti attraverso una gratuità
        restando in uno spazio di <strong style="color:#fff;">passione e amore</strong> per ciò che fai.
      </p>
      <a href={VIDEO_URL} target="_blank" rel="noopener noreferrer" class="btn-orange">
        Guarda la lezione gratuita →
      </a>
    </div>
  </section>

  <!-- Cosa trovi -->
  <section style="padding: 72px 24px; background: #fff;">
    <div style="max-width: 760px; margin: 0 auto;">
      <h2 style="font-size: clamp(20px, 3vw, 28px); font-weight: 700; color: #0A0A0A; margin-bottom: 40px; text-align: center;">
        Cosa trovi in questa lezione
      </h2>
      <div style="display: flex; flex-direction: column; gap: 28px;">
        {punti.map((p) => (
          <div style="display: flex; gap: 20px; align-items: flex-start;">
            <span style="flex-shrink: 0; width: 40px; height: 40px; background: #EA580C; color: #fff; font-size: 16px; font-weight: 700; display: flex; align-items: center; justify-content: center; border-radius: 4px;">
              {p.n}
            </span>
            <div>
              <strong style="display: block; font-size: 17px; font-weight: 700; color: #0A0A0A; margin-bottom: 6px;">{p.title}</strong>
              <p style="font-size: 15px; line-height: 1.65; color: rgba(10,10,10,0.68); margin: 0;">{p.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Per chi è -->
  <section style="padding: 0 24px 72px; background: #fff;">
    <div style="max-width: 900px; margin: 0 auto;">
      <h2 style="font-size: clamp(20px, 3vw, 28px); font-weight: 700; color: #0A0A0A; margin-bottom: 36px; text-align: center;">
        Questo percorso fa per te se…
      </h2>
      <div class="cpg-grid">
        {ideals.map((item) => (
          <div style="border: 1.5px solid #E5E5E5; border-top: 3px solid #EA580C; padding: 24px;">
            <strong style="display: block; font-size: 16px; font-weight: 700; color: #0A0A0A; margin-bottom: 8px;">{item.title}</strong>
            <p style="font-size: 14px; line-height: 1.65; color: rgba(10,10,10,0.68); margin: 0;">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA finale -->
  <section style="background: #1a0500; color: #fff; padding: 72px 24px; text-align: center;">
    <div style="max-width: 560px; margin: 0 auto;">
      <h2 style="font-size: clamp(22px, 4vw, 34px); font-weight: 800; color: #fff; margin-bottom: 14px;">
        Pronto a guardare?
      </h2>
      <p style="font-size: 17px; color: rgba(255,255,255,0.7); margin-bottom: 32px;">
        La lezione è gratuita e disponibile su YouTube.
      </p>
      <a href={VIDEO_URL} target="_blank" rel="noopener noreferrer" class="btn-orange">
        Guarda la lezione gratuita →
      </a>
    </div>
  </section>

</div>
</BaseLayout>

<style>
  .btn-orange {
    display: inline-block;
    background: #EA580C;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 36px;
    border-radius: 2px;
    transition: background 0.15s;
  }
  .btn-orange:hover { background: #C2410C; }

  .cpg-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  @media (max-width: 640px) {
    .cpg-grid { grid-template-columns: minmax(0, 1fr); }
  }
</style>
