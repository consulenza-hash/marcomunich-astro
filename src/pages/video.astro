---
/**
 * video.astro
 * Pagina "Video Marketing Olistico" — contenuto dalla pagina WP slug "video".
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import { getPageBySlug } from '@lib/wordpress';

const page = await getPageBySlug('video');

const title   = page?.title?.rendered   ?? 'Video Marketing Olistico';
const content = page?.content?.rendered ?? '';

const seoTitle = `${title} - Marco Munich`;
const seoDesc  = 'Guarda i video di Marco Munich sul Personal Branding Olistico e il Marketing Autentico.';
---

<BaseLayout title={seoTitle} description={seoDesc} currentPath="/video/">

  <div class="video-page">

    <div class="video-page__hero">
      <h1 class="video-page__title">Video Marketing Olistico</h1>
      <p class="video-page__subtitle">
        Guarda i miei video sul Personal Branding e Marketing Autentico.
      </p>
      <a
        href="https://www.youtube.com/channel/UCh9LH2mnDSJ2l3jfDVsGSIA?sub_confirmation=1"
        target="_blank"
        rel="noopener noreferrer"
        class="video-page__subscribe"
      >
        ▶ Iscriviti al canale YouTube
      </a>
    </div>

    <div class="video-page__content">
      <Fragment set:html={content} />
    </div>

  </div>

</BaseLayout>

<script>
  function setupVideoGallery() {
    const gallery = document.querySelector('.epyt-gallery');
    if (!gallery) return;

    const mainIframe = gallery.querySelector('.epyt-video-wrapper iframe') as HTMLIFrameElement;
    const thumbs = gallery.querySelectorAll('.epyt-gallery-thumb');
    if (!mainIframe || !thumbs.length) return;

    // ── Fix embed iniziale ───────────────────────────────────────────────
    // EPYT imposta come src il Channel ID (UCx-g4qtAtQ) invece di un Video ID.
    // Il Channel ID produce un embed "canale split" di YouTube — visivamente errato.
    // Sostituiamo con il primo vero Video ID trovato nei thumb (non inizia con "UC").
    const firstRealVideoId = Array.from(thumbs)
      .map(t => t.getAttribute('data-videoid') || '')
      .find(id => id.length === 11 && !id.startsWith('UC'));

    if (firstRealVideoId) {
      const params = new URLSearchParams({
        enablejsapi: '1',
        autoplay: '0',
        rel: '0',
        modestbranding: '1',
        fs: '1',
        controls: '1',
      });
      mainIframe.src = `https://www.youtube.com/embed/${firstRealVideoId}?${params}`;
      mainIframe.title = 'Video principale';
    }

    // ── Click sui thumbnail → aggiorna player principale ─────────────────
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', (e) => {
        e.preventDefault();
        const videoId = thumb.getAttribute('data-videoid');
        if (!videoId || videoId.startsWith('UC')) return;

        const params = new URLSearchParams({
          enablejsapi: '1',
          autoplay: '1',
          rel: '0',
          modestbranding: '1',
          fs: '1',
          controls: '1',
        });
        mainIframe.src = `https://www.youtube.com/embed/${videoId}?${params}`;
        mainIframe.scrollIntoView({ behavior: 'smooth', block: 'center' });

        // Evidenzia il thumb attivo
        thumbs.forEach(t => t.classList.remove('is-active'));
        thumb.classList.add('is-active');
      });
    });
  }

  setupVideoGallery();
  document.addEventListener('astro:page-load', setupVideoGallery);
</script>

<style>
  .video-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 56px 24px 80px;
  }

  .video-page__hero {
    text-align: center;
    margin-bottom: 56px;
    padding-bottom: 40px;
    border-bottom: 2px solid #0A0A0A;
  }

  .video-page__title {
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.1;
    color: #0A0A0A;
    margin-bottom: 16px;
  }

  .video-page__subtitle {
    font-size: 18px;
    color: rgba(10,10,10,0.6);
    margin-bottom: 24px;
  }

  .video-page__subscribe {
    display: inline-block;
    background: #FF0000;
    color: white;
    padding: 12px 28px;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: background 0.15s;
  }
  .video-page__subscribe:hover {
    background: #cc0000;
  }

  /* ── Griglia video (EPYT Plugin Overrides) ───────────────────────────────── */
  
  .video-page__content :global(.epyt-gallery-rowbreak),
  .video-page__content :global(.epyt-gallery-clear) {
    display: none !important;
  }

  .video-page__content :global(.epyt-gallery) {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
  }

  /* Wrapper video principale */
  .video-page__content :global(.epyt-video-wrapper) {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #000;
    margin-bottom: 32px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    order: 1;
  }

  .video-page__content :global(.epyt-video-wrapper iframe) {
    position: absolute;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    border: none;
  }

  /* Subscribe button inside gallery */
  .video-page__content :global(.epyt-gallery-subscribe) {
    display: none !important;
  }

  /* Miniature container */
  .video-page__content :global(.epyt-gallery-list) {
    order: 3;
  }

  .video-page__content :global(.epyt-gallery-allthumbs) {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    gap: 32px 24px !important;
    width: 100% !important;
    margin: 0 !important;
  }

  .video-page__content :global(.epyt-gallery-thumb) {
    cursor: pointer !important;
    display: flex !important;
    flex-direction: column !important;
    transition: transform 0.2s ease;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    position: relative;
  }
  
  /* Assicuriamoci che i figli non blocchino il click */
  .video-page__content :global(.epyt-gallery-thumb *) {
    pointer-events: none;
  }

  .video-page__content :global(.epyt-gallery-thumb:hover) {
    transform: translateY(-4px);
  }

  .video-page__content :global(.epyt-gallery-thumb.is-active) {
    outline: 3px solid #0c83fb;
    outline-offset: 3px;
  }

  .video-page__content :global(.epyt-gallery-img-box) {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background: #eee;
    margin-bottom: 12px;
  }

  .video-page__content :global(.epyt-gallery-img) {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .video-page__content :global(.epyt-gallery-title) {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    color: #0A0A0A;
  }

  /* ── Paginazione ─────────────────────────────────────────────────────── */

  /* Riga contenitore: « Prev  1 / 13  Next » */
  .video-page__content :global(.epyt-pagination) {
    display: flex !important;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin: 28px 0 36px;
    order: 2;
  }

  /* Nascondi il loading-spinner che appare accanto ai pulsanti */
  .video-page__content :global(.epyt-loader),
  .video-page__content :global(.epyt-pagination > img) {
    display: none !important;
  }

  /* Pulsanti Prev / Next: flex orizzontale per «Prev e Next» */
  .video-page__content :global(.epyt-pagebutton) {
    display: flex !important;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    background: #0A0A0A;
    color: #fff !important;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: none;
    border-radius: 4px;
    transition: background 0.15s;
    user-select: none;
  }
  .video-page__content :global(.epyt-pagebutton:hover) {
    background: #333;
  }
  .video-page__content :global(.epyt-pagebutton.hide) {
    display: none !important;
  }

  /* Frecce dentro il pulsante */
  .video-page__content :global(.epyt-pagebutton .epyt-arrow) {
    font-size: 15px;
    line-height: 1;
  }

  /* Contatore "1 / 13" — tre div inline */
  .video-page__content :global(.epyt-pagenumbers) {
    display: flex !important;
    align-items: center;
    gap: 4px;
    font-size: 14px;
    font-weight: 600;
    color: #0A0A0A;
    min-width: 60px;
    justify-content: center;
  }
  .video-page__content :global(.epyt-current),
  .video-page__content :global(.epyt-pageseparator),
  .video-page__content :global(.epyt-totalpages) {
    display: inline !important;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .video-page__content :global(.epyt-gallery-allthumbs) {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    }
  }

  @media (max-width: 560px) {
    .video-page__content :global(.epyt-gallery-allthumbs) {
      grid-template-columns: minmax(0, 1fr) !important;
    }
    .video-page { padding-top: 32px; }
  }
</style>
