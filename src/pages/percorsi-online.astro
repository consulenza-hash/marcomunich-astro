---
import BaseLayout from '@layouts/BaseLayout.astro';

const courses = [
  {
    title: "Creazione del Messaggio Autentico",
    badge: "5 Video Lezioni",
    description:
      "Un percorso per aiutarti a promuovere la tua attività restando autentico, scoprendo la tua firma energetica (unica al mondo), che ti permetterà di creare contenuto fedele a chi sei veramente, attirando solo persone a cui risuona la tua vera essenza.",
    tag: "VERSIONE AGGIORNATA E RIVISTA",
    href: "/creazione-messaggio-autentico/",
    cta: "Scopri di più",
    color: "#5551D3",
    hoverColor: "#3730A3",
  },
  {
    title: "Come parlare in Video restando sé stessi",
    badge: "3 Video Lezioni",
    description:
      "Per chi desidera iniziare a produrre contenuti video continuativi, trovando il proprio tono di voce, in un mercato che ci vuole tutti \"perfezionisti\".",
    tag: "",
    href: "/corso-come-parlare-in-video/",
    cta: "Scopri di più",
    color: "#DC2626",
    hoverColor: "#991b1b",
  },
  {
    title: "Come Lavorare Senza Sito Web",
    badge: "2 ore di Video Lezione",
    description:
      "Scopri tutto ciò che ti serve sapere per iniziare a lavorare subito e preoccuparti solo di creare contenuti e gestire il tuo lavoro.",
    tag: "",
    href: "/lavorare-senzasito/",
    cta: "Scopri di più",
    color: "#16A34A",
    hoverColor: "#166534",
  },
  {
    title: "Come Creare Prodotti Gratuiti da uno spazio di Servizio",
    badge: "Video Lezione 50 min",
    description:
      "La domanda esistenziale che ti permette di capire come aiutare i tuoi potenziali clienti attraverso una gratuità restando in uno spazio di passione e amore per ciò che fai.",
    tag: "",
    href: "/creare-prodotti-gratuiti/",
    cta: "Scopri di più",
    color: "#EA580C",
    hoverColor: "#C2410C",
  },
  {
    title: "Sito Web Premium per Coach e Operatori Olistici",
    badge: "Servizio",
    description:
      "Una casa digitale professionale, veloce e senza manutenzione. Pensata per chi vuole uno spazio online che risuoni con la propria essenza, senza stress tecnico. Pagabile a rate.",
    tag: "NUOVO",
    href: "/sviluppo-siti-web/",
    cta: "Scopri il servizio",
    color: "#0D0404",
    hoverColor: "#DC2626",
  },
];
---

<BaseLayout
  title="Servizi - Marco Munich"
  description="Scopri i percorsi Online pensati per Coach, Operatori Olistici e Terapeuti o Consulenti che desiderano un Marketing Autentico"
  currentPath="/percorsi-online/"
>

  <!-- Hero -->
  <section class="po-hero">
    <div class="po-hero__inner">
      <h1 class="po-hero__title">Servizi</h1>
      <p class="po-hero__label">Percorsi Online</p>
      <p class="po-hero__sub">
        Tutto quello a cui punto è metterti nelle condizioni per poter creare
        contenuto da uno spazio autentico di servizio, qualcosa di realmente tuo.
      </p>
    </div>
  </section>

  <!-- Griglia corsi -->
  <section class="po-courses site-wrapper">
    <h2 class="po-courses__heading">Lavoriamo insieme — Percorsi Online</h2>

    <div class="po-grid">
      {courses.map((c) => (
        <article class="po-card" style={`--accent: ${c.color}; --accent-hover: ${c.hoverColor}`}>
          <div class="po-card__body">
            <span class="po-card__badge">{c.badge}</span>
            <h3 class="po-card__title">{c.title}</h3>
            {c.tag && <p class="po-card__tag">{c.tag}</p>}
            <p class="po-card__desc">{c.description}</p>
          </div>
          <a href={c.href} class="po-card__cta">
            {c.cta} →
          </a>
        </article>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────────── */
  .po-hero {
    background: #0A0A0A;
    color: #fff;
    padding: 72px 24px 60px;
    text-align: center;
  }
  .po-hero__inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .po-hero__title {
    font-size: clamp(32px, 6vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 8px;
    color: #fff;
  }
  .po-hero__label {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 20px;
  }
  .po-hero__sub {
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,255,255,0.72);
  }

  /* ── Corsi ────────────────────────────────────────────────────────────── */
  .po-courses {
    padding: 64px 24px 80px;
  }
  .po-courses__heading {
    font-size: clamp(22px, 3.5vw, 32px);
    font-weight: 700;
    text-align: center;
    color: #0A0A0A;
    margin-bottom: 48px;
  }

  .po-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px;
  }

  /* ── Card ─────────────────────────────────────────────────────────────── */
  .po-card {
    border: 1.5px solid #E5E5E5;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s;
  }
  .po-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .po-card__body {
    padding: 32px 28px 24px;
    flex: 1;
  }
  .po-card__badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    background: var(--accent);
    padding: 4px 12px;
    margin-bottom: 16px;
  }
  .po-card__title {
    font-size: 20px;
    font-weight: 700;
    color: #0A0A0A;
    line-height: 1.3;
    margin-bottom: 12px;
  }
  .po-card__tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    color: #555;
    margin-bottom: 12px;
  }
  .po-card__desc {
    font-size: 15px;
    line-height: 1.65;
    color: rgba(10,10,10,0.72);
  }
  .po-card__cta {
    display: block;
    text-align: center;
    background: var(--accent);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 24px;
    transition: background 0.15s;
  }
  .po-card__cta:hover {
    background: var(--accent-hover);
  }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 700px) {
    .po-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
