---
import BaseLayout from '@layouts/BaseLayout.astro';

const courses = [
  {
    n: '01',
    title: "Creazione del Messaggio Autentico",
    badge: "5 Video Lezioni",
    tag: "VERSIONE AGGIORNATA",
    description:
      "Un percorso per aiutarti a promuovere la tua attività restando autentico, scoprendo la tua firma energetica (unica al mondo), che ti permetterà di creare contenuto fedele a chi sei veramente, attirando solo persone a cui risuona la tua vera essenza.",
    href: "/creazione-messaggio-autentico/",
    cta: "Scopri il percorso",
  },
  {
    n: '02',
    title: "Come parlare in Video restando sé stessi",
    badge: "3 Video Lezioni",
    tag: "",
    description:
      "Per chi desidera iniziare a produrre contenuti video continuativi, trovando il proprio tono di voce, in un mercato che ci vuole tutti «perfezionisti».",
    href: "/corso-come-parlare-in-video/",
    cta: "Scopri il percorso",
  },
  {
    n: '03',
    title: "Come Lavorare Senza Sito Web",
    badge: "2 ore di Video Lezione",
    tag: "",
    description:
      "Scopri tutto ciò che ti serve sapere per iniziare a lavorare subito e preoccuparti solo di creare contenuti e gestire il tuo lavoro.",
    href: "/lavorare-senzasito/",
    cta: "Scopri il percorso",
  },
  {
    n: '04',
    title: "Come Creare Prodotti Gratuiti da uno spazio di Servizio",
    badge: "Video Lezione 50 min",
    tag: "",
    description:
      "La domanda esistenziale che ti permette di capire come aiutare i tuoi potenziali clienti attraverso una gratuità restando in uno spazio di passione e amore per ciò che fai.",
    href: "/creare-prodotti-gratuiti/",
    cta: "Scopri il percorso",
  },
  {
    n: '05',
    title: "Sito Web Premium per Coach e Operatori Olistici",
    badge: "Servizio",
    tag: "NUOVO",
    description:
      "Una casa digitale professionale, veloce e senza manutenzione. Pensata per chi vuole uno spazio online che risuoni con la propria essenza, senza stress tecnico. Pagabile a rate.",
    href: "/sviluppo-siti-web/",
    cta: "Scopri il servizio",
  },
];
---

<BaseLayout
  title="Percorsi Online - Marco Munich"
  description="Scopri i percorsi Online pensati per Coach, Operatori Olistici e Terapeuti o Consulenti che desiderano un Marketing Autentico"
  currentPath="/percorsi-online/"
>

<!-- ══ HERO ═══════════════════════════════════════════════════════════════ -->
<section class="po-hero">
  <div class="po-hero__inner">
    <span class="po-label po-label--gold">Percorsi Online</span>
    <h1 class="po-hero__title">
      <span class="po-hl-plain">Servizi</span>
      <em class="po-hl-gold">e percorsi.</em>
    </h1>
    <p class="po-hero__sub">
      Tutto quello a cui punto è metterti nelle condizioni per poter creare
      contenuto da uno spazio autentico di servizio, qualcosa di realmente tuo.
    </p>
  </div>
</section>

<!-- ══ COURSES ════════════════════════════════════════════════════════════ -->
<section class="po-courses">
  <div class="po-courses__inner">
    <div class="po-courses__header">
      <span class="po-label po-label--muted">Lavoriamo insieme</span>
      <h2 class="po-courses__title">I miei <em>percorsi</em></h2>
    </div>

    <div class="po-list">
      {courses.map((c) => (
        <article class="po-item">
          <div class="po-item__bar" aria-hidden="true"></div>
          <div class="po-item__content">
            <div class="po-item__top">
              <span class="po-item__n">{c.n}</span>
              <div class="po-item__meta">
                <span class="po-item__badge">{c.badge}</span>
                {c.tag && <span class="po-item__tag">{c.tag}</span>}
              </div>
            </div>
            <h3 class="po-item__title">{c.title}</h3>
            <p class="po-item__desc">{c.description}</p>
            <a href={c.href} class="po-item__link">{c.cta} →</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ══ CTA ════════════════════════════════════════════════════════════════ -->
<section class="po-cta">
  <div class="po-cta__inner">
    <p class="po-cta__eyebrow">Hai domande?</p>
    <h2 class="po-cta__title">Parliamoci <em>liberamente.</em></h2>
    <a href="https://wa.link/zva8dp" class="po-btn po-btn--lg">
      <svg viewBox="0 0 448 512" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
      </svg>
      Scrivimi su WhatsApp
    </a>
  </div>
</section>

</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Labels ─────────────────────────────────────────────────────────────── */
.po-label {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 1.5rem;
}
.po-label--gold  { color: var(--gold); }
.po-label--muted { color: var(--muted); }

/* ══ HERO ══════════════════════════════════════════════════════════════════ */
.po-hero {
  background: var(--black);
  padding: 7rem var(--pad) 6rem;
}
.po-hero__inner {
  max-width: var(--max);
  margin: 0 auto;
  max-width: 800px;
}
.po-hero__title {
  display: flex;
  flex-direction: column;
  line-height: 0.92;
  margin-bottom: 2.5rem;
}
.po-hl-plain {
  font: 800 clamp(3.2rem, 6vw, 6.5rem)/1 var(--display);
  color: var(--white);
  display: block;
  letter-spacing: -0.03em;
}
.po-hl-gold {
  font: 300 clamp(3.6rem, 7vw, 7.5rem)/1 var(--serif);
  font-style: italic;
  color: var(--gold);
  display: block;
  letter-spacing: -0.02em;
  margin-top: 0.05em;
}
.po-hero__sub {
  font: 300 1rem/1.75 var(--sans);
  color: rgba(255,255,255,0.45);
  max-width: 540px;
}

/* ══ COURSES ════════════════════════════════════════════════════════════════ */
.po-courses {
  background: var(--white);
  padding: 6rem var(--pad) 7rem;
}
.po-courses__inner {
  max-width: var(--max);
  margin: 0 auto;
}
.po-courses__header {
  margin-bottom: 3.5rem;
}
.po-courses__title {
  font: 300 clamp(2rem, 3.5vw, 3rem)/1.15 var(--serif);
  color: var(--black);
  letter-spacing: -0.01em;
}
.po-courses__title em { font-style: italic; color: var(--gold); }

/* ── List ─────────────────────────────────────────────────────────────── */
.po-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.po-item {
  display: grid;
  grid-template-columns: 2px 1fr;
  gap: 0;
  border-bottom: 1px solid rgba(10,10,10,0.07);
  padding: 2.75rem 0;
}
.po-item:first-child { border-top: 1px solid rgba(10,10,10,0.07); }
.po-item__bar {
  background: var(--gold);
  width: 2px;
  align-self: stretch;
  margin-right: 2.5rem;
}
.po-item__content {
  padding-left: 2.5rem;
}
.po-item__top {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1rem;
}
.po-item__n {
  font: 700 0.6rem/1 var(--sans);
  letter-spacing: 0.15em;
  color: var(--gold);
}
.po-item__meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.po-item__badge {
  font: 700 0.58rem/1 var(--sans);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(197,138,55,0.75);
  border: 1px solid rgba(197,138,55,0.3);
  padding: 0.3rem 0.6rem;
  border-radius: 1px;
}
.po-item__tag {
  font: 700 0.58rem/1 var(--sans);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--white);
  background: var(--black);
  padding: 0.3rem 0.65rem;
  border-radius: 1px;
}
.po-item__title {
  font: 300 clamp(1.4rem, 2.5vw, 1.9rem)/1.2 var(--serif);
  color: var(--black);
  letter-spacing: -0.01em;
  margin-bottom: 0.9rem;
}
.po-item__desc {
  font: 300 0.92rem/1.75 var(--sans);
  color: rgba(10,10,10,0.6);
  max-width: 640px;
  margin-bottom: 1.5rem;
}
.po-item__link {
  font: 600 0.8rem/1 var(--sans);
  color: rgba(10,10,10,0.4);
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 0.15s;
}
.po-item__link:hover { color: var(--gold); opacity: 1; }

/* ══ CTA ════════════════════════════════════════════════════════════════════ */
.po-cta {
  background: var(--black);
  padding: 7rem var(--pad);
  text-align: center;
}
.po-cta__inner {
  max-width: 600px;
  margin: 0 auto;
}
.po-cta__eyebrow {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 1.5rem;
}
.po-cta__title {
  font: 300 clamp(2rem, 4vw, 3.2rem)/1.2 var(--serif);
  color: var(--white);
  margin-bottom: 3rem;
}
.po-cta__title em { font-style: italic; color: var(--gold); }

/* ── Button ──────────────────────────────────────────────────────────── */
.po-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font: 700 0.78rem/1 var(--sans);
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.9rem 1.75rem;
  border-radius: 1px;
  background: var(--gold);
  color: var(--white);
  transition: background 0.15s, transform 0.12s;
  white-space: nowrap;
}
.po-btn:hover { background: var(--gold-d); transform: translateY(-1px); opacity: 1; }
.po-btn--lg { padding: 1.1rem 2.25rem; font-size: 0.85rem; }

/* ── Responsive ─────────────────────────────────────────────────────── */
@media (max-width: 768px) {
  .po-item {
    grid-template-columns: 1fr;
  }
  .po-item__bar {
    display: none;
  }
  .po-item__content {
    padding-left: 0;
  }
}
</style>
