---
export const prerender = true;

// Genera stub per ogni articolo esistente
export async function getStaticPaths() {
  const files = import.meta.glob('/src/content/articoli/*/index.mdoc', { eager: false });
  return Object.keys(files).map((filePath) => {
    const slug = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
    return { params: { slug } };
  });
}

const { slug } = Astro.params;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Redirect…</title>
  <script define:vars={{ slug }}>
    // Redirect verso la nuova SPA, con supporto ?ai=1
    const ai = new URLSearchParams(window.location.search).get('ai');
    const hash = '#edit/' + encodeURIComponent(slug);
    const url  = '/admin/app.html' + hash;
    window.location.replace(url);
    // Se ?ai=1, apri panel AI dopo il redirect (gestito dalla SPA via sessionStorage)
    if (ai === '1') {
      try { sessionStorage.setItem('mm_open_ai', '1'); } catch(e) {}
    }
  </script>
</head>
<body style="background:#0f0f1a;color:#64748b;font-family:system-ui,sans-serif;display:flex;align-items:center;justify-content:center;height:100vh;margin:0">
  <p>Reindirizzamento alla nuova admin…</p>
</body>
</html>
