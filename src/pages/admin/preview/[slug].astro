---
export const prerender = true;

import AdminGuard from '@components/AdminGuard.astro';
import { getAllPosts, getPostBySlug, ghostPostToArticolo } from '@lib/ghost';

/**
 * Preview page for admin — rendered from Ghost HTML.
 * Shows published articles with a preview bar.
 * For drafts: use the Ghost Admin editor's built-in preview (cms.marcomunich.com/ghost).
 */
export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((p) => ({
    params: { slug: p.slug },
    props:  { slug: p.slug },
  }));
}

const { slug } = Astro.props;

const ghostPost = await getPostBySlug(slug!);
const art       = ghostPostToArticolo(ghostPost);

const title    = art.titolo ?? slug;
const htmlContent = art.htmlContent ?? '';
const imageUrl = art.immagine ?? null;
const rawDate  = ghostPost.published_at?.slice(0, 10) ?? null;
const dateLabel = rawDate
  ? new Date(rawDate + 'T12:00:00').toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Anteprima Admin</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="stylesheet" href="/styles/global.css" />
  <style>
    .preview-bar {
      position: sticky;
      top: 0;
      z-index: 999;
      background: #059669;
      color: #fff;
      padding: .6rem 1.2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: system-ui, sans-serif;
      font-size: .85rem;
      gap: 1rem;
    }
    .preview-bar__label {
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      font-size: .75rem;
    }
    .preview-bar__title {
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      opacity: .85;
    }
    .preview-bar__back,
    .preview-bar__live {
      background: rgba(255,255,255,.15);
      color: #fff;
      text-decoration: none;
      padding: .35rem .85rem;
      border-radius: 6px;
      font-weight: 600;
      white-space: nowrap;
      font-size: .82rem;
    }
    .preview-bar__back:hover,
    .preview-bar__live:hover { background: rgba(255,255,255,.25); }
  </style>
</head>
<body>
  <AdminGuard />

  <div class="preview-bar">
    <span class="preview-bar__label">● Pubblicato</span>
    <span class="preview-bar__title">{title}</span>
    <a href={`/${slug}/`} target="_blank" class="preview-bar__live">Vedi live ↗</a>
    <a href="/admin/articoli/" class="preview-bar__back">← Admin</a>
  </div>

  <header class="art-hero">
    <div class="art-hero__inner">
      <nav class="art-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{title}</span>
      </nav>
      <h1 class="art-hero__title">{title}</h1>
      {dateLabel && <time class="art-hero__date" datetime={rawDate ?? ''}>{dateLabel}</time>}
    </div>
  </header>

  <div class="art-layout">
    <main class="art-main">

      {imageUrl && (
        <figure class="art-cover">
          <img src={imageUrl} alt={title} width="780" height="440" loading="eager" decoding="async" />
        </figure>
      )}

      <div class="prose-marcomunich art-content">
        <Fragment set:html={htmlContent} />
      </div>

    </main>
  </div>

</body>
</html>
