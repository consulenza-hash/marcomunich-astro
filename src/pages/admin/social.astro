---
export const prerender = true;
import AdminGuard from '@components/AdminGuard.astro';
---
<html lang="it">
<head>
  <meta charset="utf-8"/>
  <AdminGuard />
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Social Media — Admin</title>
  <meta name="robots" content="noindex,nofollow" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{font-family:system-ui,-apple-system,sans-serif;background:#0f172a;color:#e2e8f0;padding:20px;max-width:1200px;margin:0 auto}
    h1{font-size:1.6rem;margin-bottom:20px;color:#f8fafc}
    a.back{color:#60a5fa;text-decoration:none;font-size:.9rem;display:inline-block;margin-bottom:16px}
    .section{background:#1e293b;border-radius:12px;padding:20px;margin-bottom:20px}
    label{display:block;margin-bottom:6px;font-size:.85rem;color:#94a3b8}
    select,button{padding:10px 16px;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#e2e8f0;font-size:.95rem}
    select{width:100%;max-width:500px}
    button{cursor:pointer;font-weight:600}
    button:disabled{opacity:.4;cursor:not-allowed}
    .btn-primary{background:#3b82f6;border-color:#3b82f6;color:#fff}
    .btn-primary:hover:not(:disabled){background:#2563eb}
    .btn-success{background:#10b981;border-color:#10b981;color:#fff;display:inline-block;padding:8px 16px;border-radius:6px}
    .btn-success:hover:not(:disabled){background:#059669}
    .btn-copy{background:#6366f1;border:1px solid #6366f1;color:#fff;padding:8px 16px;border-radius:6px;cursor:pointer;font-size:.85rem}
    .btn-copy:hover{background:#4f46e5}
    .btn-danger{background:#ef4444;border-color:#ef4444;color:#fff}
    .status-msg{margin-top:12px;padding:10px;border-radius:8px;font-size:.9rem}
    .status-ok{background:#064e3b;color:#6ee7b7}
    .status-err{background:#7f1d1d;color:#fca5a5}
    .status-info{background:#1e3a5f;color:#93c5fd}
    .cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:16px}
    @media(max-width:900px){.cards{grid-template-columns:1fr}}
    .card{background:#0f172a;border:1px solid #334155;border-radius:10px;padding:16px;display:flex;flex-direction:column}
    .card-header{display:flex;align-items:center;gap:8px;margin-bottom:12px;font-weight:600;font-size:1rem}
    .card-header svg{width:20px;height:20px;flex-shrink:0}
    .card textarea{width:100%;min-height:140px;resize:vertical;padding:10px;border-radius:8px;border:1px solid #334155;background:#1e293b;color:#e2e8f0;font-size:.9rem;font-family:inherit;line-height:1.5}
    .card-footer{display:flex;justify-content:space-between;align-items:center;margin-top:12px;gap:8px}
    .char-count{font-size:.8rem;color:#64748b}
    .card-status{font-size:.85rem;margin-top:8px;padding:6px 10px;border-radius:6px}
    .hashtags{font-size:.85rem;color:#60a5fa;margin-top:8px}
    .actions{display:flex;gap:10px;margin-top:16px;flex-wrap:wrap}
    #gen-status{display:none}
    .spinner{display:inline-block;width:16px;height:16px;border:2px solid #60a5fa;border-top-color:transparent;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-right:6px}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* Login */
    .login-wrap{display:flex;align-items:center;justify-content:center;min-height:100vh;position:fixed;inset:0;background:#0f172a;z-index:100}
    .login-box{background:#1e293b;border:1px solid #334155;border-radius:12px;padding:2.5rem;width:320px;text-align:center}
    .login-box h2{color:#f1f5f9;margin-bottom:1.5rem;font-size:1.2rem}
    .login-box input{width:100%;padding:.75rem 1rem;background:#0f172a;border:1px solid #334155;border-radius:8px;color:#f1f5f9;font-size:1rem;margin-bottom:.75rem;box-sizing:border-box}
    .login-box button{width:100%;padding:.75rem;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:1rem;cursor:pointer}
  </style>
</head>
<body>
  <div id="login-wrap" class="login-wrap" style="display:none">
    <div class="login-box">
      <h2>Social Media — Accesso</h2>
      <form id="login-form">
        <input type="password" id="pwd" placeholder="Password" autofocus />
        <button type="submit">Accedi</button>
      </form>
    </div>
  </div>
  <div id="content-wrap" style="display:none">
    <a href="/admin" class="back">&larr; Admin</a>
    <h1>Social Media</h1>

    <!-- STEP 1: Seleziona articolo -->
    <div class="section">
      <label for="article-select">Articolo</label>
      <select id="article-select">
        <option value="">Caricamento...</option>
      </select>
      <div style="margin-top:12px">
        <button class="btn-primary" id="btn-genera" disabled>Genera Post</button>
      </div>
      <div id="gen-status" class="status-msg status-info"></div>
    </div>

    <!-- STEP 2: Preview cards -->
    <div class="section" id="preview-section" style="display:none">
      <h2 style="font-size:1.2rem;margin-bottom:4px">Preview Post</h2>
      <p style="font-size:.85rem;color:#94a3b8;margin-bottom:12px" id="article-title"></p>
      <div class="cards">
        <!-- X Card -->
        <div class="card" id="card-x">
          <div class="card-header">
            <svg viewBox="0 0 24 24" fill="#fff"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            <span>X (Twitter)</span>
          </div>
          <textarea id="text-x"></textarea>
          <div class="hashtags" id="hashtags-x"></div>
          <div class="card-footer">
            <span class="char-count" id="count-x">0 / 280</span>
            <button class="btn-copy" onclick="var t=document.getElementById('text-x');t.select();document.execCommand('copy');this.textContent='Copiato!';setTimeout(()=>this.textContent='Copia testo',2000)">Copia testo</button>
            <a href="https://x.com/compose/post" target="_blank" class="btn-success" style="text-decoration:none;text-align:center">Apri X e incolla</a>
          </div>
          <div class="card-status" id="status-x" style="display:none"></div>
          <div style="margin-top:8px;text-align:center"><a href="https://x.com/marcomunich_" target="_blank" style="color:#999;font-size:13px">Il tuo profilo → @marcomunich_</a></div>
        </div>

        <!-- LinkedIn Card -->
        <div class="card" id="card-linkedin">
          <div class="card-header">
            <svg viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            <span>LinkedIn</span>
          </div>
          <textarea id="text-linkedin"></textarea>
          <div class="card-footer">
            <span class="char-count" id="count-linkedin">0 / 3000</span>
            <button class="btn-success btn-pub" data-platform="linkedin">Pubblica</button>
          </div>
          <div class="card-status" id="status-linkedin" style="display:none"></div>
        </div>

        <!-- Facebook Card -->
        <div class="card" id="card-facebook">
          <div class="card-header">
            <svg viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
            <span>Facebook</span>
          </div>
          <textarea id="text-facebook"></textarea>
          <div class="card-footer">
            <span class="char-count" id="count-facebook">0 / 63206</span>
            <button class="btn-success btn-pub" data-platform="facebook">Pubblica</button>
          </div>
          <div class="card-status" id="status-facebook" style="display:none"></div>
        </div>
      </div>

      <div class="actions">
        <button class="btn-primary" id="btn-pub-all">Pubblica Tutti</button>
        <button class="btn-primary" id="btn-rigenera" style="background:#6366f1;border-color:#6366f1">Rigenera</button>
      </div>
    </div>
  </div>

  <script is:inline>
  (function(){
    // Auth check
    var cookie = document.cookie;
    var auth = cookie.split(';').find(function(c){return c.trim().startsWith('stats_auth=')});
    if(auth){
      document.getElementById('content-wrap').style.display='block';
    } else {
      document.getElementById('login-wrap').style.display='flex';
    }
    var loginForm = document.getElementById('login-form');
    if(loginForm) loginForm.addEventListener('submit', function(e){
      e.preventDefault();
      var pwd = document.getElementById('pwd').value;
      fetch('/api/admin-auth.php', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password:pwd})})
      .then(function(r){return r.json()})
      .then(function(d){
        if(d.success) { crypto.subtle.digest('SHA-256',new TextEncoder().encode(pwd)).then(function(buf){var h=Array.from(new Uint8Array(buf)).map(function(b){return b.toString(16).padStart(2,'0')}).join('');document.cookie='stats_auth='+h+';path=/;max-age=604800';location.reload();}); }
        else alert('Password errata');
      })
      .catch(function(){ alert('Errore di connessione'); });
    });

    if(!auth) return;

    var currentSlug="",currentLink="",articles=[];

    // Carica lista articoli
    (async function(){
      try{
        var r=await fetch("/api/lista-articoli.php");
        if(!r.ok)throw new Error(r.status);
        var data=await r.json();
        articles=data;
        var sel=document.getElementById("article-select");
        sel.innerHTML='<option value="">— Seleziona articolo —</option>';
        data.forEach(function(a){
          var o=document.createElement("option");
          o.value=a.slug;o.textContent=a.titolo||a.slug;
          sel.appendChild(o);
        });
        document.getElementById("btn-genera").disabled=false;
      }catch(e){
        document.getElementById("article-select").innerHTML='<option>Errore caricamento</option>';
      }
    })();

    // Conta caratteri
    ["x","linkedin","facebook"].forEach(function(p){
      var ta=document.getElementById("text-"+p);
      var lim=p==="x"?280:p==="linkedin"?3000:63206;
      ta.addEventListener("input",function(){
        document.getElementById("count-"+p).textContent=ta.value.length+" / "+lim;
      });
    });

    // Genera
    document.getElementById("btn-genera").addEventListener("click",async function(){
      var slug=document.getElementById("article-select").value;
      if(!slug){alert("Seleziona un articolo");return;}
      currentSlug=slug;
      var gs=document.getElementById("gen-status");
      gs.style.display="block";gs.className="status-msg status-info";
      gs.innerHTML='<span class="spinner"></span> Generazione in corso con Claude...';
      document.getElementById("btn-genera").disabled=true;
      document.getElementById("preview-section").style.display="none";
      try{
        var r=await fetch("/api/social/genera.php",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({slug:slug})});
        if(!r.ok){var e=await r.json();throw new Error(e.error||r.status);}
        var d=await r.json();
        currentLink=d.articleUrl;
        document.getElementById("article-title").textContent=d.titolo+" — "+d.articleUrl;
        // X
        document.getElementById("text-x").value=d.posts.x_post.testo;
        document.getElementById("count-x").textContent=d.posts.x_post.testo.length+" / 280";
        var ht=d.posts.x_post.hashtags||[];
        document.getElementById("hashtags-x").textContent=ht.length?ht.map(function(h){return"#"+h}).join(" "):"";
        // LinkedIn
        document.getElementById("text-linkedin").value=d.posts.linkedin_post.testo;
        document.getElementById("count-linkedin").textContent=d.posts.linkedin_post.testo.length+" / 3000";
        // Facebook
        document.getElementById("text-facebook").value=d.posts.facebook_post.testo;
        document.getElementById("count-facebook").textContent=d.posts.facebook_post.testo.length+" / 63206";
        // Reset status
        ["x","linkedin","facebook"].forEach(function(p){
          document.getElementById("status-"+p).style.display="none";
        });
        document.getElementById("preview-section").style.display="block";
        gs.className="status-msg status-ok";gs.textContent="Post generati con successo!";
      }catch(e){
        gs.className="status-msg status-err";gs.textContent="Errore: "+e.message;
      }
      document.getElementById("btn-genera").disabled=false;
    });

    // Pubblica singola piattaforma
    document.querySelectorAll(".btn-pub").forEach(function(btn){
      btn.addEventListener("click",async function(){
        var p=btn.dataset.platform;
        await pubblicaPiattaforma(p);
      });
    });

    async function pubblicaPiattaforma(p){
      var text=document.getElementById("text-"+p).value;
      if(!text){alert("Testo vuoto per "+p);return;}
      var statusEl=document.getElementById("status-"+p);
      var btn=document.querySelector('.btn-pub[data-platform="'+p+'"]');
      btn.disabled=true;
      statusEl.style.display="block";
      statusEl.className="card-status status-info";
      statusEl.innerHTML='<span class="spinner"></span> Pubblicazione...';
      try{
        var r=await fetch("/api/social/pubblica.php",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({platform:p,text:text,link:currentLink})});
        var d=await r.json();
        if(!r.ok)throw new Error(d.error||r.status);
        statusEl.className="card-status status-ok";
        statusEl.innerHTML='Pubblicato! <a href="'+d.postUrl+'" target="_blank" style="color:#6ee7b7">Vedi post</a>';
      }catch(e){
        statusEl.className="card-status status-err";
        statusEl.textContent="Errore: "+e.message;
        btn.disabled=false;
      }
    }

    // Pubblica tutti
    document.getElementById("btn-pub-all").addEventListener("click",async function(){
      var btn=document.getElementById("btn-pub-all");
      btn.disabled=true;
      for(var i=0;i<["x","linkedin","facebook"].length;i++){
        var p=["x","linkedin","facebook"][i];
        var statusEl=document.getElementById("status-"+p);
        if(statusEl.className.indexOf("status-ok")===-1){
          await pubblicaPiattaforma(p);
        }
      }
      btn.disabled=false;
    });

    // Rigenera
    document.getElementById("btn-rigenera").addEventListener("click",function(){
      document.getElementById("btn-genera").click();
    });
  })();
  </script>
</body>
</html>
