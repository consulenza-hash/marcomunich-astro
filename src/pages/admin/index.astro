---
export const prerender = false;
const expectedPwd = (import.meta.env.STATS_PASSWORD || 'stats2024').trim();
const isAuth = (Astro.cookies.get('stats_auth')?.value ?? '') === expectedPwd;
if (!isAuth) {
  if (Astro.request.method === 'POST') {
    const form = await Astro.request.formData();
    if ((form.get('password')?.toString() ?? '').trim() === expectedPwd) {
      Astro.cookies.set('stats_auth', expectedPwd, { path: '/', maxAge: 86400 * 7 });
      return Astro.redirect('/admin', 302);
    }
  }
  return new Response(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Admin</title></head><body style="background:#0f172a;display:flex;align-items:center;justify-content:center;height:100vh;margin:0;font-family:sans-serif"><div style="background:#1e293b;padding:2rem;border-radius:12px;width:320px;text-align:center"><p style="color:#94a3b8;margin:0 0 .5rem;font-size:.85rem">marcomunich.com</p><h2 style="color:#f1f5f9;margin:0 0 1.5rem;font-size:1.2rem">Area admin</h2><form method="POST"><input type="password" name="password" placeholder="Password" autofocus style="width:100%;box-sizing:border-box;padding:.75rem 1rem;border-radius:8px;border:1px solid #334155;background:#0f172a;color:#f1f5f9;font-size:1rem;margin-bottom:.75rem"><button style="width:100%;padding:.75rem;background:#6366f1;color:#fff;border:none;border-radius:8px;font-size:1rem;cursor:pointer">Accedi</button></form></div></body></html>`, { status: 401, headers: { 'Content-Type': 'text/html' } });
}
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — marcomunich.com</title>
  <meta name="robots" content="noindex,nofollow" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f0f1a; color: #e2e8f0; font-family: system-ui, sans-serif;
           display: flex; align-items: center; justify-content: center; min-height: 100vh; }
    .hub { text-align: center; }
    h1 { font-size: 1.2rem; color: #64748b; margin-bottom: 2rem; letter-spacing: .1em; text-transform: uppercase; }
    .links { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
    a { display: flex; flex-direction: column; align-items: center; gap: .5rem;
        padding: 2rem 2.5rem; border-radius: 14px; text-decoration: none;
        border: 1px solid #2d2d3d; transition: all .2s; }
    a:hover { transform: translateY(-2px); border-color: #6366f1; }
    .icon { font-size: 2.5rem; }
    .label { font-size: 1rem; font-weight: 600; color: #fff; }
    .sub { font-size: .75rem; color: #64748b; }
    .cms { background: #1e1e2e; }
    .stats { background: #1a1a2e; }
    .ai { background: #1a1a2e; border-color: #3d2d4e; }
    .ai:hover { border-color: #8b5cf6; }
  </style>

</head>
<body>
  <div class="hub">
    <h1>marcomunich.com — Admin</h1>
    <div class="links">
      <a href="/admin/articoli" class="cms">
        <span class="icon">📄</span>
        <span class="label">Articoli</span>
        <span class="sub">Modifica & AI editor</span>
      </a>
      <a href="/admin/genera" class="ai">
        <span class="icon">🤖</span>
        <span class="label">Genera con AI</span>
        <span class="sub">Crea articoli con Claude</span>
      </a>
      <a href="/admin/statistiche" class="stats">
        <span class="icon">📊</span>
        <span class="label">Statistiche</span>
        <span class="sub">GA4 + Search Console</span>
      </a>
      <a href="/admin/acquirenti" class="stats">
        <span class="icon">🛒</span>
        <span class="label">Acquirenti</span>
        <span class="sub">Prompt Pack · newsletter</span>
      </a>
      <a href="/admin/aggiornamenti" class="ai">
        <span class="icon">📦</span>
        <span class="label">Aggiornamenti</span>
        <span class="sub">Prompt Pack · roadmap v2 v3 v4</span>
      </a>
      <a href="/admin/social" class="ai">
        <span class="icon">📱</span>
        <span class="label">Social Media</span>
        <span class="sub">Genera e pubblica su X, LinkedIn, Facebook</span>
      </a>
      <a href="/admin/batch" class="cms">
        <span class="icon">⚡</span>
        <span class="label">Batch Rewrite</span>
        <span class="sub">Riscrivi articoli in blocco con AI</span>
      </a>
    </div>
  </div>
</body>
</html>
