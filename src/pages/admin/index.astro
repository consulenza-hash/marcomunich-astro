---
export const prerender = true;
import AdminGuard from '@components/AdminGuard.astro';
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <AdminGuard />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — marcomunich.com</title>
  <meta name="robots" content="noindex,nofollow" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0a0a0f;
      color: #e2e8f0;
      font-family: system-ui, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .hub { width: 100%; max-width: 680px; }
    .hub-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 2rem;
    }
    .hub-title { font-size: .72rem; letter-spacing: .12em; text-transform: uppercase; color: #475569; }
    .hub-ghost-link {
      font-size: .75rem;
      color: #64748b;
      text-decoration: none;
      padding: .3rem .7rem;
      border: 1px solid #2d2d3d;
      border-radius: 6px;
      transition: all .15s;
    }
    .hub-ghost-link:hover { color: #e2e8f0; border-color: #475569; }

    /* primary — Ghost CMS */
    .card-ghost {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding: 1.4rem 1.6rem;
      border-radius: 14px;
      border: 1px solid #2d3a50;
      background: linear-gradient(135deg, #0f1e38 0%, #0a1525 100%);
      text-decoration: none;
      margin-bottom: 1rem;
      transition: all .2s;
    }
    .card-ghost:hover { border-color: #3b82f6; transform: translateY(-1px); }
    .card-ghost .icon { font-size: 2rem; flex-shrink: 0; }
    .card-ghost .text {}
    .card-ghost .label { font-size: 1.05rem; font-weight: 700; color: #fff; display: block; }
    .card-ghost .sub { font-size: .78rem; color: #64748b; margin-top: .2rem; display: block; }
    .card-ghost .badge {
      margin-left: auto;
      font-size: .65rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #3b82f6;
      border: 1px solid rgba(59,130,246,.3);
      padding: .25rem .6rem;
      border-radius: 20px;
      white-space: nowrap;
    }

    /* grid — tool secondari */
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; }
    .card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.1rem 1.3rem;
      border-radius: 12px;
      border: 1px solid #2d2d3d;
      background: #111118;
      text-decoration: none;
      transition: all .2s;
    }
    .card:hover { border-color: #6366f1; transform: translateY(-1px); background: #16161f; }
    .card .icon { font-size: 1.5rem; flex-shrink: 0; }
    .card .label { font-size: .9rem; font-weight: 600; color: #e2e8f0; display: block; }
    .card .sub { font-size: .72rem; color: #475569; margin-top: .15rem; display: block; }

    @media (max-width: 480px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="hub">

    <div class="hub-header">
      <span class="hub-title">marcomunich.com — Admin</span>
      <a href="https://cms.marcomunich.com/ghost" class="hub-ghost-link" target="_blank">
        cms.marcomunich.com ↗
      </a>
    </div>

    <!-- Ghost CMS — primary -->
    <a href="https://cms.marcomunich.com/ghost" target="_blank" class="card-ghost">
      <span class="icon">👻</span>
      <span class="text">
        <span class="label">Ghost CMS — Articoli</span>
        <span class="sub">Scrivi, modifica, pubblica e programma gli articoli</span>
      </span>
      <span class="badge">Editor principale</span>
    </a>

    <!-- Tool secondari -->
    <div class="grid">
      <a href="/admin/genera" class="card">
        <span class="icon">🤖</span>
        <span class="text">
          <span class="label">Genera con AI</span>
          <span class="sub">Crea articoli con Claude</span>
        </span>
      </a>
      <a href="/admin/batch" class="card">
        <span class="icon">⚡</span>
        <span class="text">
          <span class="label">Batch rewrite</span>
          <span class="sub">Riscrivi più articoli in serie</span>
        </span>
      </a>
      <a href="/admin/statistiche" class="card">
        <span class="icon">📊</span>
        <span class="text">
          <span class="label">Statistiche</span>
          <span class="sub">GA4 + Search Console</span>
        </span>
      </a>
      <a href="/admin/social" class="card">
        <span class="icon">📱</span>
        <span class="text">
          <span class="label">Social</span>
          <span class="sub">Piano editoriale + caroselli</span>
        </span>
      </a>
      <a href="/admin/acquirenti" class="card">
        <span class="icon">🛒</span>
        <span class="text">
          <span class="label">Acquirenti</span>
          <span class="sub">Prompt Pack · newsletter</span>
        </span>
      </a>
      <a href="/admin/aggiornamenti" class="card">
        <span class="icon">📦</span>
        <span class="text">
          <span class="label">Aggiornamenti</span>
          <span class="sub">Prompt Pack · roadmap</span>
        </span>
      </a>
    </div>

  </div>
</body>
</html>
