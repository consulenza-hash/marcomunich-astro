---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Acquirenti — Admin</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0f0f1a; color: #e2e8f0; font-family: system-ui, sans-serif; min-height: 100vh; }
    .login-wrap { display: flex; align-items: center; justify-content: center; min-height: 100vh; position: fixed; inset: 0; background: #0f0f1a; z-index: 100; }
    .login-box { background: #1a1a2e; border: 1px solid #2d2d3d; border-radius: 14px; padding: 2.5rem; width: 320px; text-align: center; }
    .login-box h1 { font-size: 1rem; color: #64748b; margin-bottom: 1.5rem; text-transform: uppercase; letter-spacing: .1em; }
    input[type=password] { width: 100%; padding: .75rem 1rem; background: #0f0f1a; border: 1px solid #2d2d3d; border-radius: 8px; color: #e2e8f0; font-size: .95rem; margin-bottom: .75rem; box-sizing: border-box; }
    button[type=submit] { width: 100%; padding: .75rem; background: #6366f1; border: none; border-radius: 8px; color: #fff; font-weight: 600; cursor: pointer; }
    .page { max-width: 960px; margin: 0 auto; padding: 2.5rem 1.5rem; }
    .top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
    h1 { font-size: 1.25rem; font-weight: 700; }
    .back { font-size: .85rem; color: #64748b; text-decoration: none; }
    .back:hover { color: #e2e8f0; }
    .stats { display: flex; gap: 1rem; margin-bottom: 2rem; flex-wrap: wrap; }
    .stat { background: #1a1a2e; border: 1px solid #2d2d3d; border-radius: 10px; padding: 1rem 1.5rem; flex: 1; min-width: 140px; }
    .stat-val { font-size: 2rem; font-weight: 800; color: #fff; line-height: 1; }
    .stat-label { font-size: .75rem; color: #64748b; margin-top: .3rem; text-transform: uppercase; letter-spacing: .08em; }
    .stat--green .stat-val { color: #4ade80; }
    .filter { display: flex; gap: .5rem; margin-bottom: 1.25rem; }
    .filter-btn { padding: .4rem .9rem; border-radius: 20px; border: 1px solid #2d2d3d; background: transparent; color: #94a3b8; font-size: .8rem; cursor: pointer; transition: all .15s; }
    .filter-btn.active, .filter-btn:hover { background: #6366f1; border-color: #6366f1; color: #fff; }
    table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    th { text-align: left; padding: .5rem .75rem; color: #64748b; font-weight: 500; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid #2d2d3d; }
    td { padding: .65rem .75rem; border-bottom: 1px solid #1a1a2a; color: #cbd5e1; vertical-align: middle; }
    tr:hover td { background: #1a1a2e; }
    .badge { display: inline-flex; align-items: center; gap: .3rem; font-size: .72rem; font-weight: 600; border-radius: 20px; padding: .2rem .6rem; }
    .badge--yes { background: rgba(74,222,128,.12); color: #4ade80; border: 1px solid rgba(74,222,128,.25); }
    .badge--no  { background: rgba(100,116,139,.1); color: #64748b; border: 1px solid rgba(100,116,139,.2); }
    .name { font-weight: 500; color: #f1f5f9; }
    .email-cell { color: #94a3b8; font-size: .82rem; }
    .date-cell { color: #64748b; font-size: .8rem; white-space: nowrap; }
    .empty { color: #64748b; text-align: center; padding: 3rem; }
    .loading-msg { text-align: center; padding: 3rem; color: #64748b; }
  </style>
</head>
<body>

<div id="login-wrap" class="login-wrap" style="display:none">
  <div class="login-box">
    <h1>Acquirenti — Admin</h1>
    <form id="login-form">
      <input type="password" id="pwd" placeholder="Password" autofocus />
      <button type="submit">Accedi</button>
    </form>
  </div>
</div>

<div id="content-wrap" style="display:none">
  <div class="page">
    <div class="top">
      <h1>🛒 Acquirenti Prompt Pack</h1>
      <a href="/admin" class="back">← Admin</a>
    </div>

    <div class="stats">
      <div class="stat"><div class="stat-val" id="stat-total">—</div><div class="stat-label">Acquirenti totali</div></div>
      <div class="stat stat--green"><div class="stat-val" id="stat-newsletter">—</div><div class="stat-label">Newsletter sì</div></div>
      <div class="stat"><div class="stat-val" id="stat-no-newsletter">—</div><div class="stat-label">Newsletter no</div></div>
    </div>

    <div class="filter">
      <button class="filter-btn active" data-filter="all">Tutti</button>
      <button class="filter-btn" data-filter="yes">Newsletter ✓</button>
      <button class="filter-btn" data-filter="no">Solo transaz.</button>
      <button id="btn-grant" style="margin-left:auto;background:#C58A37;color:#0A0A0A;border:none;padding:0.45rem 1rem;border-radius:6px;font-weight:600;cursor:pointer;font-size:0.85rem;">+ Accesso manuale</button>
    </div>

    <div id="grant-form" style="display:none;background:#1C1C1C;border:1px solid rgba(197,138,55,0.3);border-radius:8px;padding:1.2rem;margin-bottom:1rem;">
      <p style="margin:0 0 0.75rem;font-size:0.9rem;color:#94a3b8;">Aggiungi accesso manualmente e invia email con link</p>
      <div style="display:flex;gap:0.6rem;flex-wrap:wrap;">
        <input id="grant-email" type="email" placeholder="email@cliente.it" style="flex:1;min-width:200px;padding:0.5rem 0.75rem;background:#0A0A0A;border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#f1f5f9;font-size:0.9rem;" />
        <input id="grant-name" type="text" placeholder="Nome (opzionale)" style="flex:1;min-width:160px;padding:0.5rem 0.75rem;background:#0A0A0A;border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#f1f5f9;font-size:0.9rem;" />
        <button id="btn-grant-send" style="background:#C58A37;color:#0A0A0A;border:none;padding:0.5rem 1rem;border-radius:6px;font-weight:600;cursor:pointer;">Invia</button>
      </div>
      <p id="grant-msg" style="margin:0.6rem 0 0;font-size:0.82rem;display:none;"></p>
    </div>

    <div id="table-wrap">
      <div class="loading-msg">Caricamento...</div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  var cookie = document.cookie;
  var auth = cookie.split(';').find(function(c){return c.trim().startsWith('stats_auth=')});
  if(auth){
    document.getElementById('content-wrap').style.display='block';
    loadData();
  } else {
    document.getElementById('login-wrap').style.display='flex';
  }
  var form = document.getElementById('login-form');
  if(form) form.addEventListener('submit', function(e){
    e.preventDefault();
    var pwd = document.getElementById('pwd').value;
    fetch('/api/admin-auth.php', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password:pwd})})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.success) { document.cookie='stats_auth='+encodeURIComponent(pwd)+';path=/;max-age=604800'; location.reload(); }
      else alert('Password errata');
    })
    .catch(function(){ alert('Errore di connessione'); });
  });

  function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  function fmtDate(iso){return new Date(iso).toLocaleDateString('it-IT',{day:'2-digit',month:'short',year:'numeric'});}

  function loadData(){
    fetch('/api/admin/pp-list.php')
      .then(function(r){return r.json()})
      .then(function(purchasers){
        var total=purchasers.length;
        var newsletter=purchasers.filter(function(p){return p.newsletterConsent}).length;
        document.getElementById('stat-total').textContent=total;
        document.getElementById('stat-newsletter').textContent=newsletter;
        document.getElementById('stat-no-newsletter').textContent=total-newsletter;

        var wrap=document.getElementById('table-wrap');
        if(!total){wrap.innerHTML='<p class="empty">Nessun acquirente ancora.</p>';return;}

        var h='<table id="purchasers-table"><thead><tr><th>Nome</th><th>Email</th><th>Newsletter</th><th>Data acquisto</th></tr></thead><tbody>';
        purchasers.forEach(function(p){
          h+='<tr data-newsletter="'+(p.newsletterConsent?'yes':'no')+'">';
          h+='<td class="name">'+esc(p.name||'—')+'</td>';
          h+='<td class="email-cell">'+esc(p.email)+'</td>';
          h+='<td>'+(p.newsletterConsent?'<span class="badge badge--yes">✓ Sì</span>':'<span class="badge badge--no">No</span>')+'</td>';
          h+='<td class="date-cell">'+fmtDate(p.createdAt)+'</td>';
          h+='</tr>';
        });
        h+='</tbody></table>';
        wrap.innerHTML=h;
        bindFilters();
      })
      .catch(function(err){
        document.getElementById('table-wrap').innerHTML='<p class="empty">Errore: '+esc(err.message)+'</p>';
      });
  }

  // Grant manual access
  document.getElementById('btn-grant').addEventListener('click', function(){
    var f=document.getElementById('grant-form');
    f.style.display = f.style.display==='none' ? 'block' : 'none';
  });
  document.getElementById('btn-grant-send').addEventListener('click', function(){
    var email=document.getElementById('grant-email').value.trim();
    var name=document.getElementById('grant-name').value.trim();
    var msg=document.getElementById('grant-msg');
    if(!email){document.getElementById('grant-email').focus();return;}
    document.getElementById('btn-grant-send').disabled=true;
    document.getElementById('btn-grant-send').textContent='Invio...';
    fetch('/api/admin/pp-grant.php',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({email:email,name:name})
    }).then(function(r){return r.json()}).then(function(d){
      if(d.ok){
        msg.style.color='#4ade80';
        msg.textContent='✓ Accesso creato' + (d.emailSent ? ' ed email inviata a '+email : ' (email non inviata — controlla RESEND_API_KEY)');
        msg.style.display='block';
        document.getElementById('grant-email').value='';
        document.getElementById('grant-name').value='';
        loadData();
      } else {
        msg.style.color='#f87171';
        msg.textContent='Errore: '+(d.error||'sconosciuto');
        msg.style.display='block';
      }
    }).catch(function(err){
      msg.style.color='#f87171';
      msg.textContent='Errore: '+err.message;
      msg.style.display='block';
    }).finally(function(){
      document.getElementById('btn-grant-send').disabled=false;
      document.getElementById('btn-grant-send').textContent='Invia';
    });
  });

  function bindFilters(){
    document.querySelectorAll('.filter-btn').forEach(function(btn){
      btn.addEventListener('click',function(){
        document.querySelectorAll('.filter-btn').forEach(function(b){b.classList.remove('active')});
        btn.classList.add('active');
        var filter=btn.dataset.filter;
        document.querySelectorAll('#purchasers-table tbody tr').forEach(function(row){
          if(filter==='all') row.style.display='';
          else row.style.display=row.dataset.newsletter===filter?'':'none';
        });
      });
    });
  }
})();
</script>

</body>
</html>
