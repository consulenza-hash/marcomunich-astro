---
export const prerender = false;

// ── Auth ──────────────────────────────────────────────────────────────────────
const cookie      = Astro.cookies.get('stats_auth')?.value ?? '';
const expectedPwd = import.meta.env.STATS_PASSWORD || 'stats2024';
const isAuth      = cookie === expectedPwd;

if (Astro.request.method === 'POST' && !isAuth) {
  const form = await Astro.request.formData();
  const pwd  = form.get('password')?.toString() ?? '';
  if (pwd === expectedPwd) {
    Astro.cookies.set('stats_auth', pwd, { path: '/', maxAge: 86400 * 7 });
    return Astro.redirect('/admin/genera');
  }
}

// ── Params da URL (?slug=...&modo=...&autostart=1) ────────────────────────────
const MODI_VALIDI = ['solo-articolo', 'solo-metadati', 'tutto-completo'];
const paramSlug      = isAuth ? (Astro.url.searchParams.get('slug') ?? '') : '';
const paramModoRaw   = isAuth ? (Astro.url.searchParams.get('modo')  ?? '') : '';
const paramModo      = MODI_VALIDI.includes(paramModoRaw) ? paramModoRaw : 'solo-articolo';
const paramAutostart = isAuth && Astro.url.searchParams.get('autostart') === '1';

// ── Lista articoli da GitHub ──────────────────────────────────────────────────
type ArticoloItem = { slug: string; label: string };
let articoli: ArticoloItem[] = [];

if (isAuth) {
  try {
    const token   = import.meta.env.GITHUB_TOKEN ?? '';
    const ghHeaders: Record<string, string> = { Accept: 'application/vnd.github.v3+json' };
    if (token) ghHeaders['Authorization'] = `token ${token}`;

    const res = await fetch(
      'https://api.github.com/repos/consulenza-hash/marcomunich-astro/contents/src/content/articoli?ref=main',
      { headers: ghHeaders }
    );
    if (res.ok) {
      const list = (await res.json()) as { name: string; type: string }[];
      articoli = list
        .filter(f => f.type === 'dir')
        .map(f => ({ slug: f.name, label: f.name.replace(/-/g, ' ') }))
        .sort((a, b) => a.label.localeCompare(b.label, 'it'));
    }
  } catch { /* silenzioso */ }
}
