---
export const prerender = true;
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Statistiche — marcomunich.com</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
           background: #0f0f0f; color: #e2e8f0; min-height: 100vh; }

    /* ── Login ── */
    .login-wrap { display:flex; align-items:center; justify-content:center; min-height:100vh; position:fixed; inset:0; background:#0f0f0f; z-index:100; }
    .login-box  { background:#1e1e2e; border:1px solid #2d2d3d; border-radius:12px;
                  padding:2.5rem; width:360px; }
    .login-box h1 { font-size:1.25rem; margin-bottom:1.5rem; color:#fff; }
    .login-box input { width:100%; padding:.75rem 1rem; background:#111; border:1px solid #333;
                       border-radius:8px; color:#fff; font-size:1rem; margin-bottom:1rem; box-sizing:border-box; }
    .login-box button { width:100%; padding:.75rem; background:#6366f1; color:#fff;
                        border:none; border-radius:8px; font-size:1rem; font-weight:600; cursor:pointer; }

    /* ── Layout ── */
    .wrap  { max-width:1280px; margin:0 auto; padding:1.5rem 1.5rem 4rem; }
    header { display:flex; align-items:center; justify-content:space-between;
             flex-wrap:wrap; gap:1rem; margin-bottom:2rem; border-bottom:1px solid #222; padding-bottom:1.25rem; }
    header h1 { font-size:1.4rem; font-weight:700; }
    header h1 span { color:#6366f1; }

    .days-tabs { display:flex; gap:.4rem; flex-wrap:wrap; }
    .days-tabs a { padding:.3rem .65rem; border-radius:6px; text-decoration:none; font-size:.8rem;
                   color:#94a3b8; border:1px solid #2d2d3d; transition:all .15s; white-space:nowrap; cursor:pointer; }
    .days-tabs a.active, .days-tabs a:hover { background:#6366f1; color:#fff; border-color:#6366f1; }

    /* ── Cards overview ── */
    .cards { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-bottom:2rem; }
    .card  { background:#1e1e2e; border:1px solid #2d2d3d; border-radius:10px; padding:1.25rem; }
    .card-label { font-size:.75rem; text-transform:uppercase; letter-spacing:.08em; color:#64748b; margin-bottom:.5rem; }
    .card-value { font-size:2rem; font-weight:700; line-height:1; color:#fff; }
    .card-delta { font-size:.8rem; margin-top:.35rem; }
    .delta-up   { color:#22c55e; }
    .delta-down { color:#f87171; }
    .delta-neutral { color:#64748b; }

    /* ── Sezioni ── */
    .section { background:#1e1e2e; border:1px solid #2d2d3d; border-radius:10px;
               padding:1.5rem; margin-bottom:1.25rem; }
    .section-title { font-size:.9rem; font-weight:600; text-transform:uppercase;
                     letter-spacing:.06em; color:#94a3b8; margin-bottom:1.25rem; }

    .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
    @media (max-width:900px) { .grid2 { grid-template-columns:1fr; } }

    /* ── Tabelle ── */
    table { width:100%; border-collapse:collapse; font-size:.875rem; }
    th    { text-align:left; padding:.5rem .75rem; color:#64748b; font-weight:500;
            font-size:.75rem; text-transform:uppercase; border-bottom:1px solid #2d2d3d; }
    td    { padding:.6rem .75rem; border-bottom:1px solid #1a1a2a; color:#cbd5e1; }
    tr:last-child td { border-bottom:none; }
    tr:hover td { background:#252535; }
    .num  { text-align:right; font-variant-numeric:tabular-nums; }

    /* ── Source bars ── */
    .src-row  { display:flex; align-items:center; gap:.75rem; margin-bottom:.65rem; }
    .src-label{ width:160px; font-size:.85rem; color:#cbd5e1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex-shrink:0; }
    .src-bar  { flex:1; background:#1a1a2a; border-radius:4px; height:8px; overflow:hidden; }
    .src-fill { height:100%; border-radius:4px; }
    .src-num  { width:80px; text-align:right; font-size:.8rem; color:#94a3b8; flex-shrink:0; }

    .empty { color:#475569; font-size:.875rem; padding:1rem 0; }
    .loading-msg { text-align:center; padding:3rem; color:#64748b; font-size:1rem; }
    .error-box { background:#2d1a1a; border:1px solid #7f1d1d; border-radius:10px; padding:1.5rem; color:#fca5a5; font-size:.9rem; }
    .badge { display:inline-block; padding:.15rem .5rem; border-radius:4px; font-size:.75rem; font-weight:600; }
    .badge-green { background:#14532d; color:#86efac; }
    .badge-blue  { background:#1e3a5f; color:#93c5fd; }
  </style>
</head>
<body>

<div id="login-wrap" class="login-wrap" style="display:none">
  <div class="login-box">
    <h1>📊 Statistiche Sito</h1>
    <form id="login-form">
      <input type="password" id="pwd" placeholder="Password" autofocus />
      <button type="submit">Accedi</button>
    </form>
  </div>
</div>

<div id="content-wrap" style="display:none">
  <div class="wrap">
    <header>
      <div>
        <h1>📊 <span>Statistiche</span> marcomunich.com</h1>
        <p id="period-note" style="font-size:.8rem;color:#64748b"></p>
      </div>
      <div>
        <nav class="days-tabs" id="days-tabs">
          <a data-days="7">7gg</a>
          <a data-days="14">14gg</a>
          <a data-days="30" class="active">30gg</a>
          <a data-days="90">90gg</a>
          <a data-days="180">180gg</a>
          <a data-days="0">Sempre</a>
        </nav>
        <a href="/admin" style="font-size:.8rem;color:#64748b;text-decoration:none;margin-left:.5rem;">← Admin</a>
      </div>
    </header>

    <div id="stats-content">
      <div class="loading-msg">⏳ Caricamento dati...</div>
    </div>
  </div>
</div>

<script is:inline>
(function(){
  // Auth check
  var cookie = document.cookie;
  var auth = cookie.split(';').find(function(c){return c.trim().startsWith('stats_auth=')});
  if(auth){
    document.getElementById('content-wrap').style.display='block';
    loadStats(30);
  } else {
    document.getElementById('login-wrap').style.display='flex';
  }
  var form = document.getElementById('login-form');
  if(form) form.addEventListener('submit', function(e){
    e.preventDefault();
    var pwd = document.getElementById('pwd').value;
    fetch('/api/admin-auth.php', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({password:pwd})})
    .then(function(r){return r.json()})
    .then(function(d){
      if(d.success) { document.cookie='stats_auth='+encodeURIComponent(pwd)+';path=/;max-age=604800'; location.reload(); }
      else alert('Password errata');
    })
    .catch(function(){ alert('Errore di connessione'); });
  });

  // Days tabs
  document.querySelectorAll('.days-tabs a').forEach(function(a){
    a.addEventListener('click', function(){
      document.querySelectorAll('.days-tabs a').forEach(function(b){ b.classList.remove('active'); });
      a.classList.add('active');
      loadStats(parseInt(a.dataset.days));
    });
  });

  function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function srcColor(ch) {
    var map = { 'Organic Search':'#22c55e', 'Direct':'#6366f1', 'Organic Social':'#f59e0b',
      'Referral':'#3b82f6', 'Email':'#ec4899', 'Paid Search':'#f97316', 'Unassigned':'#94a3b8' };
    return map[ch] || '#94a3b8';
  }

  function fmtDur(sec) { var m=Math.floor(sec/60); var s=Math.round(sec%60); return m+':'+String(s).padStart(2,'0'); }
  function deltaClass(n) { return n>0?'delta-up':n<0?'delta-down':'delta-neutral'; }
  function deltaLabel(n) { return n===0?'—':n>0?'+'+n+'%':n+'%'; }

  function loadStats(days) {
    var content = document.getElementById('stats-content');
    content.innerHTML = '<div class="loading-msg">⏳ Caricamento dati...</div>';

    fetch('/api/statistiche.php?days=' + days)
      .then(function(r){
        if(!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(data){ renderStats(data, days); })
      .catch(function(err){
        content.innerHTML = '<div class="error-box">❌ Errore nel caricamento dei dati: ' + esc(err.message) + '</div>';
      });
  }

  function renderStats(data, days) {
    var content = document.getElementById('stats-content');
    var note = document.getElementById('period-note');
    note.textContent = 'GA4: ' + data.period.start + ' → ' + data.period.end +
      ' | GSC: ' + data.gscPeriod.start + ' → ' + data.gscPeriod.end;

    var h = '';

    // Overview cards
    h += '<div class="cards">';
    h += card('Sessioni', data.overview.sessions.toLocaleString('it-IT'), data.overview.sessionsDelta);
    h += card('Utenti', data.overview.users.toLocaleString('it-IT'), data.overview.usersDelta);
    h += card('Pagine viste', data.overview.pageviews.toLocaleString('it-IT'), data.overview.pageviewsDelta);
    h += '<div class="card"><div class="card-label">Durata media</div><div class="card-value">' + fmtDur(data.overview.avgDuration) + '</div><div class="card-delta delta-neutral">min:sec per sessione</div></div>';
    h += '<div class="card"><div class="card-label">Bounce Rate</div><div class="card-value">' + data.overview.bounceRate + '%</div><div class="card-delta ' + deltaClass(data.overview.bounceRate<40?1:data.overview.bounceRate<60?0:-1) + '">' + (data.overview.bounceRate<40?'✓ Ottimo':data.overview.bounceRate<60?'Nella media':'Da migliorare') + '</div></div>';
    h += '</div>';

    // Sparkline
    h += '<div class="section"><div class="section-title">Andamento sessioni — ' + (days===0?'tutto il periodo':'ultimi '+days+' giorni') + '</div>';
    h += sparklineSvg(data.daily);
    h += '</div>';

    // Grid 2 col
    h += '<div class="grid2">';
    // Sources
    h += '<div class="section"><div class="section-title">Sorgenti di traffico</div>';
    if(!data.sources.length) h += '<p class="empty">Nessun dato.</p>';
    else data.sources.forEach(function(s){
      h += '<div class="src-row"><span class="src-label">' + esc(s.channel) + '</span>';
      h += '<div class="src-bar"><div class="src-fill" style="width:'+s.pct+'%;background:'+srcColor(s.channel)+'"></div></div>';
      h += '<span class="src-num">' + s.sessions.toLocaleString('it-IT') + ' (' + s.pct + '%)</span></div>';
    });
    h += '</div>';

    // Top pages
    h += '<div class="section"><div class="section-title">Pagine più visitate (GA4)</div>';
    if(!data.topPages.length) h += '<p class="empty">Nessun dato.</p>';
    else {
      h += '<table><thead><tr><th>Pagina</th><th class="num">Visualizz.</th><th class="num">Utenti</th></tr></thead><tbody>';
      data.topPages.slice(0,12).forEach(function(p){
        h += '<tr><td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><a href="'+esc(p.path)+'" target="_blank" style="color:#93c5fd;text-decoration:none">'+esc(p.path)+'</a></td>';
        h += '<td class="num">'+p.pageviews.toLocaleString('it-IT')+'</td>';
        h += '<td class="num">'+p.users.toLocaleString('it-IT')+'</td></tr>';
      });
      h += '</tbody></table>';
    }
    h += '</div></div>';

    // Keywords
    h += '<div class="section"><div class="section-title">Parole chiave su Google (Search Console)</div>';
    if(!data.keywords.length) h += '<p class="empty">' + (data.gscError ? '⚠️ Errore GSC: '+esc(data.gscError) : '⏳ I dati keyword appaiono entro 2-3 giorni.') + '</p>';
    else {
      h += '<table><thead><tr><th>Query</th><th class="num">Click</th><th class="num">Impressioni</th><th class="num">CTR</th><th class="num">Posiz. media</th></tr></thead><tbody>';
      data.keywords.forEach(function(k){
        h += '<tr><td>'+esc(k.query)+'</td><td class="num">'+k.clicks.toLocaleString('it-IT')+'</td><td class="num">'+k.impressions.toLocaleString('it-IT')+'</td>';
        h += '<td class="num"><span class="badge badge-green">'+k.ctr+'%</span></td>';
        h += '<td class="num"><span class="badge badge-blue">#'+k.position+'</span></td></tr>';
      });
      h += '</tbody></table>';
    }
    h += '</div>';

    // GSC Pages
    h += '<div class="section"><div class="section-title">Pagine più cliccate su Google (Search Console)</div>';
    if(!data.gscPages.length) h += '<p class="empty">Nessun dato.</p>';
    else {
      h += '<table><thead><tr><th>Pagina</th><th class="num">Click</th><th class="num">Impressioni</th></tr></thead><tbody>';
      data.gscPages.forEach(function(p){
        h += '<tr><td style="max-width:280px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><a href="'+esc(p.page)+'" target="_blank" style="color:#93c5fd;text-decoration:none">'+esc(p.page.replace('https://marcomunich.com',''))+'</a></td>';
        h += '<td class="num">'+p.clicks.toLocaleString('it-IT')+'</td><td class="num">'+p.impressions.toLocaleString('it-IT')+'</td></tr>';
      });
      h += '</tbody></table>';
    }
    h += '</div>';

    content.innerHTML = h;
  }

  function card(label, value, delta) {
    return '<div class="card"><div class="card-label">'+label+'</div><div class="card-value">'+value+'</div><div class="card-delta '+deltaClass(delta)+'">'+deltaLabel(delta)+' vs periodo precedente</div></div>';
  }

  function sparklineSvg(points) {
    if(!points||!points.length) return '<p class="empty">Nessun dato disponibile.</p>';
    var w=700,h=80;
    var vals=points.map(function(p){return p.sessions;});
    var max=Math.max.apply(null,vals.concat([1]));
    var step=w/(vals.length-1||1);
    var coords=vals.map(function(v,i){return (i*step)+','+(h-(v/max)*(h-4)-2);});
    var fill=coords.map(function(c,i){return (i===0?'M':'L')+c;}).join(' ');
    var area=fill+' L'+w+','+h+' L0,'+h+' Z';
    return '<div style="overflow:hidden;border-radius:6px"><svg viewBox="0 0 '+w+' '+h+'" preserveAspectRatio="none" style="width:100%;height:80px">' +
      '<defs><linearGradient id="sg" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#6366f1" stop-opacity=".3"/><stop offset="100%" stop-color="#6366f1" stop-opacity="0"/></linearGradient></defs>' +
      '<path d="'+area+'" fill="url(#sg)"/><path d="'+fill+'" fill="none" stroke="#6366f1" stroke-width="2" stroke-linejoin="round"/></svg></div>';
  }
})();
</script>

</body>
</html>
