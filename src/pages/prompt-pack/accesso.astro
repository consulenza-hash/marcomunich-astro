import { aggiornamenti } from '../../data/prompt-updates';

// Data is rendered at build time; auth is handled client-side
// The login form HTML is embedded below as a hidden div
// The old inline Response login form has been removed

const loginFormHtml = `<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Accesso al Prompt Pack — Marco Munich</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #0C0B09;
      color: #F0EBE3;
      font-family: Georgia, serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }
    .wrap {
      max-width: 460px;
      width: 100%;
      text-align: center;
    }
    .logo {
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #C58A37;
      margin-bottom: 2.5rem;
    }
    h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #F0EBE3;
      margin-bottom: 0.75rem;
      line-height: 1.3;
    }
    .desc {
      font-size: 0.95rem;
      color: rgba(240,235,227,0.6);
      line-height: 1.6;
      margin-bottom: 2rem;
    }
    .card {
      background: #181612;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }
    label {
      display: block;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(240,235,227,0.5);
      margin-bottom: 0.5rem;
      text-align: left;
    }
    input[type=email] {
      width: 100%;
      padding: 0.85rem 1rem;
      background: #0C0B09;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 8px;
      color: #F0EBE3;
      font-size: 1rem;
      font-family: Georgia, serif;
      margin-bottom: 1rem;
      transition: border-color 0.2s;
    }
    input[type=email]:focus {
      outline: none;
      border-color: #C58A37;
    }
    button {
      width: 100%;
      padding: 0.9rem;
      background: #C58A37;
      color: #0A0A0A;
      border: none;
      border-radius: 8px;
      font-size: 0.95rem;
      font-weight: 700;
      font-family: Georgia, serif;
      letter-spacing: 0.03em;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    button:hover { opacity: 0.88; }
    button:disabled { opacity: 0.5; cursor: not-allowed; }
    .msg {
      margin-top: 1rem;
      font-size: 0.88rem;
      line-height: 1.5;
      display: none;
    }
    .msg--ok { color: #4ade80; }
    .msg--err { color: #f87171; }
    .back {
      font-size: 0.82rem;
      color: rgba(240,235,227,0.35);
      text-decoration: none;
    }
    .back:hover { color: rgba(240,235,227,0.65); }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="logo">Marco Munich</div>
    <h1>Accedi al tuo Prompt Pack</h1>
    <p class="desc">
      Inserisci l'email con cui hai acquistato il pack.<br>
      Ti mandiamo subito un nuovo link di accesso.
    </p>
    <div class="card">
      <label for="email">La tua email</label>
      <input type="email" id="email" placeholder="nome@email.it" autocomplete="email" />
      <button id="btn">Invia il link di accesso</button>
      <p class="msg msg--ok" id="msg-ok">
        ✓ Controlla la tua casella — il link arriva in pochi secondi.<br>
        <small style="opacity:.7">Se non lo vedi, guarda nello spam.</small>
      </p>
      <p class="msg msg--err" id="msg-err">
        Qualcosa non ha funzionato. Riprova o scrivimi a <a href="mailto:marco@marcomunich.com" style="color:#C58A37">marco@marcomunich.com</a>.
      </p>
    </div>
    <a href="/prompt-pack" class="back">← Torna alla pagina del Prompt Pack</a>
  </div>
  <script>
    const btn = document.getElementById('btn');
    const emailInput = document.getElementById('email');
    const msgOk = document.getElementById('msg-ok');
    const msgErr = document.getElementById('msg-err');

    btn.addEventListener('click', async () => {
      const email = emailInput.value.trim();
      if (!email || !email.includes('@')) {
        emailInput.focus();
        return;
      }
      btn.disabled = true;
      btn.textContent = 'Invio in corso…';
      msgOk.style.display = 'none';
      msgErr.style.display = 'none';

      try {
        const res = await fetch('/api/prompt-pack/resend-access.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        if (res.ok) {
          msgOk.style.display = 'block';
          btn.textContent = 'Link inviato ✓';
        } else {
          throw new Error('ko');
        }
      } catch {
        msgErr.style.display = 'block';
        btn.disabled = false;
        btn.textContent = 'Invia il link di accesso';
      }
    });

    emailInput.addEventListener('keydown', e => {
      if (e.key === 'Enter') btn.click();
    });
  </script>
</body>
</html>`;

const categorie = [
