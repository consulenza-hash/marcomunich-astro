<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Il tuo Prompt Pack — Marco Munich</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..60,400;12..60,600;12..60,700&family=Host+Grotesk:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold: #C58A37;
      --gold-dim: rgba(197,138,55,0.12);
      --gold-mid: rgba(197,138,55,0.28);
      --ink: #0A0A0A;
      --bg: #0C0B09;
      --bg2: #141210;
      --bg3: #1C1A17;
      --cream: #F0EBE3;
      --muted: rgba(240,235,227,0.42);
      --border: rgba(255,255,255,0.065);
      --header-h: 56px;
      --sidebar-w: 272px;
    }

    html, body { height: 100%; overflow: hidden; background: var(--bg); color: var(--cream); font-family: 'Host Grotesk', system-ui, sans-serif; }

    /* ── HEADER ── */
    .topbar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      height: var(--header-h);
      background: rgba(12,11,9,0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(197,138,55,0.1);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 1.25rem 0 1rem;
      gap: 1rem;
    }
    .topbar__brand {
      display: flex; align-items: center; gap: 0.6rem;
      text-decoration: none; flex-shrink: 0;
    }
    .topbar__brand-name {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 0.95rem; font-weight: 700; color: var(--cream);
      letter-spacing: -0.01em;
    }
    .topbar__brand-dot { color: var(--gold); font-size: 1.1rem; line-height: 1; margin: 0 0.1rem; }
    .topbar__brand-tag {
      font-size: 0.7rem; color: var(--muted);
      letter-spacing: 0.04em; font-weight: 400;
      display: none;
    }
    @media (min-width: 640px) { .topbar__brand-tag { display: inline; } }
    .topbar__product {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 0.78rem; font-weight: 600;
      color: var(--gold); letter-spacing: 0.06em;
      text-transform: uppercase;
      background: var(--gold-dim); border: 1px solid var(--gold-mid);
      border-radius: 100px; padding: 0.2rem 0.75rem;
      flex-shrink: 0;
    }
    .topbar__count {
      font-size: 0.75rem; color: var(--muted);
      border: 1px solid var(--border); border-radius: 100px;
      padding: 0.2rem 0.7rem; flex-shrink: 0;
    }
    .topbar__count strong { color: var(--gold); font-weight: 600; }

    /* ── USER MENU ── */
    .user-menu {
      position: relative; flex-shrink: 0;
    }
    .user-menu__btn {
      display: flex; align-items: center; gap: 0.4rem;
      background: rgba(197,138,55,0.08); border: 1px solid rgba(197,138,55,0.2);
      border-radius: 100px; padding: 0.25rem 0.75rem 0.25rem 0.5rem;
      cursor: pointer; color: var(--gold);
      font-size: 0.75rem; font-weight: 600;
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      letter-spacing: 0.02em;
      transition: background 0.15s;
    }
    .user-menu__btn:hover { background: rgba(197,138,55,0.14); }
    .user-menu__avatar {
      width: 22px; height: 22px; border-radius: 50%;
      background: rgba(197,138,55,0.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; color: var(--gold); flex-shrink: 0;
    }
    .user-menu__dropdown {
      display: none; position: absolute; top: calc(100% + 8px); right: 0;
      min-width: 260px;
      background: #1C1A17; border: 1px solid rgba(255,255,255,0.1);
      border-radius: 10px; overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5);
      z-index: 200;
    }
    .user-menu__dropdown.open { display: block; }
    .user-menu__header {
      padding: 1rem 1.1rem 0.75rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .user-menu__name {
      font-size: 0.85rem; font-weight: 600; color: var(--cream);
      margin-bottom: 0.15rem;
    }
    .user-menu__email {
      font-size: 0.72rem; color: var(--muted);
    }
    .user-menu__date {
      font-size: 0.7rem; color: rgba(240,235,227,0.3);
      margin-top: 0.25rem;
    }
    .user-menu__items { padding: 0.4rem 0; }
    .user-menu__item {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.55rem 1.1rem;
      font-size: 0.8rem; color: rgba(240,235,227,0.65);
      text-decoration: none; cursor: pointer;
      transition: background 0.1s, color 0.1s;
    }
    .user-menu__item:hover { background: rgba(255,255,255,0.04); color: var(--cream); }
    .user-menu__item svg { width: 14px; height: 14px; flex-shrink: 0; }
    .user-menu__item--danger { color: rgba(240,100,80,0.7); }
    .user-menu__item--danger:hover { color: rgb(240,100,80); background: rgba(240,100,80,0.06); }
    .user-menu__divider { height: 1px; background: rgba(255,255,255,0.06); margin: 0.25rem 0; }
    .topbar__search {
      flex: 1; max-width: 380px;
      position: relative;
    }
    .topbar__search-icon {
      position: absolute; left: 0.75rem; top: 50%; transform: translateY(-50%);
      color: var(--muted); pointer-events: none;
      width: 15px; height: 15px;
    }
    .topbar__search input {
      width: 100%; background: var(--bg2); border: 1px solid var(--border);
      border-radius: 8px; color: var(--cream);
      font-family: 'Host Grotesk', system-ui, sans-serif;
      font-size: 0.875rem; padding: 0.45rem 0.75rem 0.45rem 2.25rem;
      outline: none; transition: border-color .2s;
    }
    .topbar__search input::placeholder { color: var(--muted); }
    .topbar__search input:focus { border-color: var(--gold-mid); }

    /* ── LAYOUT ── */
    .layout {
      display: flex;
      height: calc(100vh - var(--header-h));
      margin-top: var(--header-h);
    }

    /* ── SIDEBAR ── */
    .sidebar {
      width: var(--sidebar-w); flex-shrink: 0;
      background: #0F0D0B;
      border-right: 1px solid var(--border);
      overflow-y: auto; overflow-x: hidden;
      padding: 1rem 0;
    }
    .sidebar::-webkit-scrollbar { width: 4px; }
    .sidebar::-webkit-scrollbar-track { background: transparent; }
    .sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    .sidebar__label {
      font-size: 0.68rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--muted);
      padding: 0.5rem 1.25rem 0.4rem; margin-bottom: 0.25rem;
    }
    .sidebar__item {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.55rem 1.25rem; cursor: pointer;
      border-left: 2px solid transparent;
      transition: all .18s; text-decoration: none;
      border-radius: 0;
    }
    .sidebar__item:hover { background: rgba(197,138,55,0.06); border-left-color: var(--gold-mid); }
    .sidebar__item.active {
      background: linear-gradient(90deg, rgba(197,138,55,0.12), rgba(197,138,55,0.04));
      border-left-color: var(--gold);
    }
    .sidebar__num {
      font-size: 0.7rem; font-weight: 700; color: var(--gold);
      letter-spacing: 0.03em; flex-shrink: 0; width: 26px;
      opacity: 0.7;
    }
    .sidebar__item.active .sidebar__num { opacity: 1; }
    .sidebar__info { flex: 1; min-width: 0; }
    .sidebar__title {
      font-size: 0.8rem; font-weight: 600; color: var(--cream);
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .sidebar__item.active .sidebar__title { color: var(--cream); }
    .sidebar__count {
      font-size: 0.7rem; color: var(--muted);
    }
    .sidebar__badge {
      font-size: 0.65rem; font-weight: 700; color: var(--ink);
      background: var(--gold); border-radius: 100px;
      padding: 0.1rem 0.45rem; flex-shrink: 0;
    }

    /* ── MAIN ── */
    .main {
      flex: 1; overflow-y: auto; overflow-x: hidden;
      padding: 2rem 2.5rem 4rem;
      scroll-behavior: smooth;
    }
    .main::-webkit-scrollbar { width: 6px; }
    .main::-webkit-scrollbar-track { background: transparent; }
    .main::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

    /* ── PACK HERO ── */
    .pack-hero {
      padding: 0 0 2.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 2.5rem;
    }
    .pack-hero__eyebrow {
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--gold);
      margin-bottom: 0.6rem;
    }
    .pack-hero__title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: clamp(2.4rem, 4vw, 3.4rem);
      font-weight: 700; color: #fff;
      letter-spacing: -0.04em; line-height: 1.05;
      margin-bottom: 0.75rem;
    }
    .pack-hero__title em {
      font-style: normal;
      background: linear-gradient(90deg, var(--gold) 0%, #e8b76a 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .pack-hero__sub {
      font-size: 0.95rem; color: var(--muted); line-height: 1.5;
      max-width: 52ch;
    }
    .pack-hero__meta {
      display: flex; align-items: center; gap: 1rem;
      margin-top: 1.1rem; flex-wrap: wrap;
    }
    .pack-hero__pill {
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.05em;
      padding: 0.3rem 0.75rem; border-radius: 999px;
      background: var(--gold-dim); color: var(--gold);
      border: 1px solid var(--gold-mid);
    }
    .pack-hero__pill--gpt {
      background: rgba(109,40,217,0.1); color: #a78bfa;
      border-color: rgba(109,40,217,0.25);
    }
    @media (max-width: 768px) {
      .pack-hero { padding: 0 0 1.5rem; margin-bottom: 1.5rem; }
      .pack-hero__title { font-size: 2rem; }
    }

    /* ── CATEGORY SECTION ── */
    .cat-section { margin-bottom: 3.5rem; }
    .cat-section:first-child .cat-header { padding-top: 0; }
    .cat-header {
      display: flex; align-items: flex-start; gap: 1rem;
      padding: 0 0 1.5rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.5rem;
      position: relative; overflow: hidden;
    }
    .cat-header__bg-num {
      position: absolute; right: -0.25rem; top: 50%; transform: translateY(-50%);
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 6rem; font-weight: 700; color: rgba(197,138,55,0.05);
      letter-spacing: -0.05em; line-height: 1;
      pointer-events: none; user-select: none;
    }
    .cat-header__num {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
      color: var(--gold); text-transform: uppercase;
      background: var(--gold-dim); border: 1px solid var(--gold-mid);
      border-radius: 6px; padding: 0.3rem 0.65rem;
      flex-shrink: 0; margin-top: 0.15rem;
      position: relative; z-index: 1;
    }
    .cat-header__text { position: relative; z-index: 1; }
    .cat-header__title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 2rem; font-weight: 700; color: #fff;
      letter-spacing: -0.03em; line-height: 1.15;
    }
    .cat-header__sub {
      font-size: 0.9rem; color: var(--muted); margin-top: 0.4rem;
      line-height: 1.5;
    }
    .cat-header__image-badge {
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em;
      text-transform: uppercase; color: var(--ink);
      background: var(--gold); border-radius: 100px;
      padding: 0.15rem 0.6rem; margin-left: 0.5rem;
      vertical-align: middle;
    }
    .cat-header__gpt-badge {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em;
      text-transform: uppercase; color: #fff;
      background: #6d28d9; border-radius: 100px;
      padding: 0.15rem 0.6rem; margin-left: 0.5rem;
      vertical-align: middle;
    }

    /* ── GPT CARDS ── */
    .prompt-card.is-gpt {
      background: linear-gradient(160deg, #130F1E 0%, #0E0C16 100%);
      border-color: rgba(109,40,217,0.2);
      box-shadow: 0 2px 12px rgba(109,40,217,0.08);
    }
    .prompt-card.is-gpt:hover {
      border-color: rgba(109,40,217,0.4);
      box-shadow: 0 4px 20px rgba(109,40,217,0.15);
      transform: translateY(-1px);
    }
    .prompt-card__gpt-tag {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; color: #fff;
      background: #6d28d9; border-radius: 6px;
      padding: 0.2rem 0.55rem; flex-shrink: 0;
    }
    .prompt-card__gpt-title {
      font-family: 'Bricolage Grotesque', system-ui, sans-serif;
      font-size: 1.1rem; font-weight: 700; color: #e2d9f3;
      letter-spacing: -0.015em; line-height: 1.25;
      margin: 0;
    }
    .prompt-card__gpt-tagline {
      font-size: 0.84rem; color: rgba(196,181,253,0.6); line-height: 1.55;
      margin: 0;
    }
    .prompt-card__gpt-how {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.73rem; color: rgba(167,139,250,0.85);
      background: rgba(109,40,217,0.1);
      border: 1px solid rgba(109,40,217,0.2);
      border-radius: 8px; padding: 0.5rem 0.75rem;
      line-height: 1.4;
    }
    .prompt-card__gpt-how svg { flex-shrink: 0; opacity: 0.8; }
    .prompt-card__copy--gpt {
      background: rgba(109,40,217,0.1);
      border-color: rgba(109,40,217,0.25);
      color: #a78bfa;
    }
    .prompt-card__copy--gpt:hover {
      background: rgba(109,40,217,0.2);
      border-color: rgba(109,40,217,0.45);
      color: #c4b5fd;
    }
    .sidebar__badge--gpt {
      background: #6d28d9 !important;
    }
    .sidebar__badge--update {
      background: #1e3a5f !important;
      color: #60a5fa;
      border-color: rgba(96,165,250,0.3);
    }
    .update-subsection {
      margin-bottom: 2rem;
    }
    .update-subsection__title {
      font-size: .78rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: #64748b;
      margin-bottom: 1rem;
      padding-bottom: .5rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    /* ── GPT PREVIEW ── */
    .prompt-card__gpt-preview {
      max-height: 220px;
      overflow-y: auto;
      border: 1px solid rgba(109,40,217,0.2);
      border-radius: 8px;
      background: rgba(0,0,0,0.3);
      padding: 0.875rem 1rem;
      scrollbar-width: thin;
      scrollbar-color: rgba(109,40,217,0.3) transparent;
    }
    .prompt-card__gpt-preview::-webkit-scrollbar { width: 4px; }
    .prompt-card__gpt-preview::-webkit-scrollbar-thumb { background: rgba(109,40,217,0.3); border-radius: 4px; }
    .prompt-card__gpt-preview-text {
      font-family: 'Host Grotesk', system-ui, sans-serif;
      font-size: 0.78rem; line-height: 1.65;
      color: rgba(196,181,253,0.75);
      white-space: pre-wrap; word-break: break-word;
      margin: 0;
    }
    .prompt-card__preview-toggle {
      font-size: 0.78rem; font-weight: 500;
      background: rgba(109,40,217,0.08);
      border: 1px solid rgba(109,40,217,0.2);
      border-radius: 8px; padding: 0.45rem 0.9rem;
      color: rgba(167,139,250,0.8);
      display: flex; align-items: center; gap: 0.4rem;
      cursor: pointer; transition: all .15s;
    }
    .prompt-card__preview-toggle:hover {
      background: rgba(109,40,217,0.15);
      color: #c4b5fd;
    }
    .prompt-card__preview-toggle.open {
      background: rgba(109,40,217,0.2);
      color: #c4b5fd;
    }

    /* ── PROMPT GRID ── */
    .prompts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 1rem;
    }

    /* ── PROMPT CARD ── */
    .prompt-card {
      background: linear-gradient(160deg, var(--bg2) 0%, var(--bg3) 100%);
      border: 1px solid rgba(255,255,255,0.055);
      border-radius: 14px;
      padding: 1.35rem;
      display: flex; flex-direction: column; gap: 0.75rem;
      transition: border-color .2s, box-shadow .2s, transform .2s;
      position: relative;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }
    .prompt-card:hover {
      border-color: var(--gold-mid);
      box-shadow: 0 4px 20px rgba(0,0,0,0.4), 0 0 0 1px rgba(197,138,55,0.08);
      transform: translateY(-1px);
    }
    .prompt-card.copied { border-color: var(--gold); box-shadow: 0 4px 24px rgba(197,138,55,0.15); }

    .prompt-card__meta {
      display: flex; align-items: center; justify-content: space-between;
      gap: 0.5rem;
    }
    .prompt-card__num {
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em;
      color: var(--gold); background: var(--gold-dim);
      border: 1px solid rgba(197,138,55,0.2);
      border-radius: 6px; padding: 0.2rem 0.55rem;
      flex-shrink: 0;
    }
    .prompt-card__title {
      font-size: 0.78rem; font-weight: 600; color: var(--muted);
      flex: 1; text-align: right;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    .prompt-card__text {
      font-size: 0.9rem; line-height: 1.7; color: var(--cream);
      flex: 1;
    }
    .prompt-card__text mark.ph {
      background: rgba(197,138,55,0.18);
      color: var(--gold); border-radius: 3px;
      padding: 0.05em 0.3em;
      font-style: normal;
    }

    .prompt-card__footer {
      display: flex; justify-content: flex-end; gap: 0.5rem; align-items: center;
      border-top: 1px solid var(--border);
      padding-top: 0.75rem;
      margin-top: 0.25rem;
    }
    .prompt-card__copy {
      font-size: 0.78rem; font-weight: 500;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 8px; padding: 0.45rem 0.9rem;
      color: var(--muted);
      display: flex; align-items: center; gap: 0.4rem;
      cursor: pointer; transition: all .15s;
      font-family: 'Host Grotesk', system-ui, sans-serif;
    }
    .prompt-card__copy:hover {
      background: rgba(197,138,55,0.1);
      border-color: var(--gold-mid);
      color: var(--gold);
    }
    .prompt-card__copy.done {
      background: rgba(197,138,55,0.15);
      border-color: var(--gold);
      color: var(--gold);
    }
    .prompt-card__copy svg { width: 13px; height: 13px; flex-shrink: 0; }

    /* ── IMAGE CARD VARIANT ── */
    .prompt-card.is-image .prompt-card__text {
      font-family: 'Courier New', monospace;
      font-size: 0.82rem; color: rgba(197,138,55,0.85);
      background: rgba(197,138,55,0.05);
      border: 1px solid var(--gold-dim);
      border-radius: 8px; padding: 0.75rem 1rem;
      line-height: 1.6;
    }

    /* ── SEARCH EMPTY ── */
    .search-empty {
      display: none; text-align: center;
      padding: 4rem 2rem; color: var(--muted);
    }
    .search-empty.visible { display: block; }
    .search-empty h3 { font-size: 1.1rem; color: var(--cream); margin-bottom: 0.5rem; }

    /* ── NO RESULTS IN SECTION ── */
    .cat-section.hidden { display: none; }

    /* ── MOBILE ── */
    @media (max-width: 768px) {
      html, body { overflow: visible; }
      .layout { flex-direction: column; height: auto; margin-top: calc(var(--header-h) + 44px); }
      .sidebar {
        position: fixed; top: var(--header-h); left: 0; right: 0; z-index: 90;
        width: 100%; height: 44px; flex-direction: row;
        overflow-x: auto; overflow-y: hidden;
        padding: 0 0.5rem; border-right: none; border-bottom: 1px solid var(--border);
        white-space: nowrap; scrollbar-width: none; display: flex;
        background: #0F0D0B;
      }
      .sidebar::-webkit-scrollbar { display: none; }
      .sidebar__label { display: none; }
      .sidebar__item {
        flex-direction: row; align-items: center; padding: 0 0.9rem;
        height: 44px; border-left: none;
        border-bottom: 2px solid transparent; gap: 0.35rem;
        flex-shrink: 0; border-radius: 0;
      }
      .sidebar__item.active {
        border-bottom-color: var(--gold);
        background: rgba(197,138,55,0.08);
        border-left-color: transparent;
      }
      .sidebar__info { display: none; }
      .sidebar__badge { display: none; }
      .main { overflow-y: visible; height: auto; padding: 1.5rem 1rem 4rem; }
      .prompts-grid { grid-template-columns: 1fr !important; }
      .topbar__search { display: none; }
      .topbar__count { font-size: 0.68rem; padding: 0.15rem 0.5rem; }
      .cat-header { flex-direction: column; gap: 0.5rem; }
      .prompt-card__gpt-how { font-size: 0.7rem; }
    }

    /* ── UPSELL SECTION ── */
    .pp-upsell {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      padding: 3rem 2rem;
      max-width: 1100px;
      margin: 0 auto;
    }
    .pp-upsell__card {
      border-radius: 16px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .pp-upsell__card--book {
      background: linear-gradient(145deg, #1C1A17 0%, #221E18 100%);
      border: 1px solid rgba(197,138,55,0.25);
    }
    .pp-upsell__card--consulting {
      background: linear-gradient(145deg, #12100E 0%, #1E1A14 100%);
      border: 1px solid rgba(197,138,55,0.4);
      box-shadow: 0 0 32px rgba(197,138,55,0.06);
    }
    .pp-upsell__badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      background: var(--gold-dim);
      padding: 0.25rem 0.75rem;
      border-radius: 100px;
      width: fit-content;
    }
    .pp-upsell__title {
      font-family: 'Bricolage Grotesque', sans-serif;
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--cream);
      line-height: 1.35;
    }
    .pp-upsell__text {
      font-size: 0.9rem;
      line-height: 1.7;
      color: var(--muted);
    }
    .pp-upsell__list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }
    .pp-upsell__list li {
      font-size: 0.88rem;
      color: var(--muted);
      padding-left: 1.2rem;
      position: relative;
    }
    .pp-upsell__list li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--gold);
      font-weight: 700;
    }
    .pp-upsell__btn {
      display: inline-block;
      margin-top: auto;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      text-align: center;
      transition: opacity .2s, transform .15s;
    }
    .pp-upsell__btn:hover { opacity: 0.88; transform: translateY(-1px); }
    .pp-upsell__btn--book {
      background: transparent;
      border: 1.5px solid var(--gold);
      color: var(--gold);
    }
    .pp-upsell__btn--consulting {
      background: var(--gold);
      color: #0A0A0A;
    }
    .pp-upsell__price {
      font-size: 0.8rem;
      color: rgba(197,138,55,0.6);
      text-align: center;
    }
    @media (max-width: 768px) {
      .pp-upsell { grid-template-columns: 1fr; padding: 2rem 1rem; }
    }
  </style>
</head>
<body>

  <!-- Login form (shown if no pp_access cookie) -->
  <div id="pp-login-wrap" style="display:none" set:html={loginFormHtml}></div>

  <!-- Content (shown if pp_access cookie exists) -->
  <div id="pp-content-wrap" style="display:none">

  <!-- HEADER -->
  <header class="topbar">
    <a href="/" class="topbar__brand">
      <span class="topbar__brand-name">Marco Munich</span>
      <span class="topbar__brand-dot">✦</span>
      <span class="topbar__brand-tag">Personal Branding Olistico</span>
    </a>
    <span class="topbar__product">Prompt Pack</span>
    <div class="topbar__search">
      <svg class="topbar__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" id="search" placeholder="Cerca nei prompt…" autocomplete="off" />
    </div>
    <div class="topbar__count">
      <strong>{totalPrompts}</strong> prompt · <strong>{totalGPTs}</strong> GPT
    </div>

    <!-- User menu — populated client-side -->
    <div class="user-menu" id="user-menu">
      <button class="user-menu__btn" id="user-menu-btn" aria-expanded="false" aria-haspopup="true">
        <span class="user-menu__avatar" id="user-avatar">✦</span>
        <span class="user-menu__label" id="user-label">Account</span>
      </button>
      <div class="user-menu__dropdown" id="user-menu-dropdown" role="menu">
        <div class="user-menu__header">
          <div class="user-menu__name" id="user-name-display"></div>
          <div class="user-menu__email" id="user-email-display"></div>
          <div class="user-menu__date" id="user-date-display"></div>
        </div>
        <div class="user-menu__items">
          <a id="user-receipt-link" href="#" target="_blank" rel="noopener" class="user-menu__item" role="menuitem" style="display:none">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/>
              </svg>
              Visualizza ricevuta →
            </a>
          <a href="mailto:marco@marcomunich.com?subject=Supporto Prompt Pack" class="user-menu__item" role="menuitem">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/>
            </svg>
            Supporto via email
          </a>
          <div class="user-menu__divider"></div>
          <a href="#" onclick="document.cookie='pp_access=;path=/;max-age=0';location.reload();" class="user-menu__item user-menu__item--danger" role="menuitem">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
            Esci
          </a>
        </div>
      </div>
    </div>
  </header>

  <div class="layout">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
      <div class="sidebar__label">Categorie</div>
      {categorie.map((cat) => (
        <a class="sidebar__item" data-cat={cat.id} href={`#${cat.id}`}>
          <span class="sidebar__num">{cat.num}</span>
          <span class="sidebar__info">
            <span class="sidebar__title">{cat.title}</span>
            <span class="sidebar__count">{cat.isGPT ? `${cat.count} GPT` : `${cat.count} prompt`}</span>
          </span>
          {cat.isImage && <span class="sidebar__badge">IMG</span>}
          {cat.isGPT && <span class="sidebar__badge sidebar__badge--gpt">GPT</span>}
        </a>
      ))}
      {releasedUpdates.length > 0 && (
        <>
          <div class="sidebar__label" style="margin-top:1.5rem;">Aggiornamenti</div>
          {releasedUpdates.map((upd) => (
            <a class="sidebar__item sidebar__item--update" data-cat={upd.id} href={`#${upd.id}`}>
              <span class="sidebar__num">{upd.tag}</span>
              <span class="sidebar__info">
                <span class="sidebar__title">{upd.title}</span>
                <span class="sidebar__count">{upd.sections.reduce((s,sec)=>s+sec.prompts.length,0)} prompt</span>
              </span>
              <span class="sidebar__badge sidebar__badge--update">NEW</span>
            </a>
          ))}
        </>
      )}
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main" id="main">

      <div class="pack-hero">
        <p class="pack-hero__eyebrow">Marco Munich</p>
        <h1 class="pack-hero__title">Prompt Pack<br>per <em>Coach e Professionisti</em><br>dell'Olistico</h1>
        <p class="pack-hero__sub">Usa questi prompt partendo dalla tua esperienza concreta: quello che esce parla di te.</p>
        <div class="pack-hero__meta">
          <span class="pack-hero__pill">147 prompt · 11 categorie</span>
          <span class="pack-hero__pill pack-hero__pill--gpt">10 Custom GPT</span>
        </div>
      </div>

      <div class="search-empty" id="search-empty">
        <h3>Nessun prompt trovato</h3>
        <p>Prova con un termine diverso.</p>
      </div>

      {categorie.map((cat) => (
        <section class="cat-section" id={cat.id} data-cat-id={cat.id}>
          <div class="cat-header">
            <span class="cat-header__bg-num">{cat.num}</span>
            <div class="cat-header__num">Cat. {cat.num}</div>
            <div class="cat-header__text">
              <h2 class="cat-header__title">
                {cat.title}
                {cat.isImage && <span class="cat-header__image-badge">Gemini / Imagen 3</span>}
                {cat.isGPT && <span class="cat-header__gpt-badge">Custom GPT</span>}
              </h2>
              <p class="cat-header__sub">{cat.sub}</p>
            </div>
          </div>

          <div class={`prompts-grid${cat.isGPT ? ' prompts-grid--gpt' : ''}`}>
            {cat.prompts.map((p) => (
              cat.isGPT ? (
                <div class="prompt-card is-gpt" data-text={p.text} data-n={p.n}>
                  <div class="prompt-card__meta">
                    <span class="prompt-card__gpt-tag">GPT</span>
                    <span class="prompt-card__num" style="background:rgba(109,40,217,0.15);color:#a78bfa">#{p.n}</span>
                  </div>
                  <h3 class="prompt-card__gpt-title">{p.title}</h3>
                  {'tagline' in p && <p class="prompt-card__gpt-tagline">{p.tagline}</p>}
                  <div class="prompt-card__gpt-how">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    ChatGPT → Esplora GPT → Crea un GPT → Istruzioni → Incolla → Salva
                  </div>
                  <div class="prompt-card__gpt-preview" id={`preview-${p.n}`} style="display:none;">
                    <pre class="prompt-card__gpt-preview-text">{p.text}</pre>
                  </div>
                  <div class="prompt-card__footer">
                    <button class="prompt-card__preview-toggle" onclick={`togglePreview(${p.n})`}>
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                      Anteprima
                    </button>
                    <button class="prompt-card__copy prompt-card__copy--gpt" onclick="copyPrompt(this)">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                      </svg>
                      Copia system prompt
                    </button>
                  </div>
                </div>
              ) : (
                <div class={`prompt-card${cat.isImage ? ' is-image' : ''}`} data-text={p.text} data-n={p.n}>
                  <div class="prompt-card__meta">
                    <span class="prompt-card__num">#{p.n}</span>
                    {'title' in p && p.title && (
                      <span class="prompt-card__title">{p.title}</span>
                    )}
                  </div>
                  <div class="prompt-card__text" data-raw={p.text}></div>
                  <div class="prompt-card__footer">
                    <button class="prompt-card__copy" onclick="copyPrompt(this)">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                      </svg>
                      Copia
                    </button>
                  </div>
                </div>
              )
            ))}
          </div>
        </section>
      ))}

    <!-- ── AGGIORNAMENTI RILASCIATI ────────────────────────────────── -->
    {releasedUpdates.map((upd) => (
      <section class="cat-section update-section" id={upd.id} data-cat-id={upd.id}>
        <div class="cat-header">
          <span class="cat-header__bg-num">{upd.tag}</span>
          <div class="cat-header__num">{upd.tag.toUpperCase()}</div>
          <div class="cat-header__text">
            <h2 class="cat-header__title">
              {upd.title}
              <span class="cat-header__gpt-badge" style="background:rgba(99,102,241,0.15);color:#818cf8;border-color:rgba(99,102,241,0.3);">Nuovo</span>
            </h2>
            <p class="cat-header__sub">{upd.description}</p>
          </div>
        </div>
        {upd.sections.map((sec) => (
          <div class="update-subsection">
            <h3 class="update-subsection__title">{sec.title}</h3>
            <div class="prompts-grid">
              {sec.prompts.map((p) => (
                <div class="prompt-card" data-text={p.text}>
                  {p.title && <div class="prompt-card__title">{p.title}</div>}
                  <p class="prompt-card__text" data-raw={p.text}></p>
                  <div class="prompt-card__footer">
                    <span class="prompt-card__num">#{p.n}</span>
                    <button class="prompt-card__copy" onclick="copyPrompt(this)">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                      </svg>
                      Copia
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </section>
    ))}

    <!-- ── PROMO BOOK + CONSULENZA ─────────────────────────────────── -->
    <div class="pp-upsell">

      <!-- Libro -->
      <div class="pp-upsell__card pp-upsell__card--book">
        <div class="pp-upsell__badge">📖 Il libro</div>
        <h2 class="pp-upsell__title">Restare autentici scrivendo con l'intelligenza artificiale</h2>
        <p class="pp-upsell__text">
          Il Prompt Pack nasce da questo libro. Se vuoi capire il ragionamento dietro ogni categoria e come costruire un metodo di contenuti fondato sul tuo lavoro reale, è il posto da cui partire.
        </p>
        <a href="https://www.amazon.it/dp/B0FQ57R899" target="_blank" rel="noopener" class="pp-upsell__btn pp-upsell__btn--book">
          Leggilo su Amazon →
        </a>
      </div>

      <!-- Consulenza -->
      <div class="pp-upsell__card pp-upsell__card--consulting">
        <div class="pp-upsell__badge">🤝 Lavora con me</div>
        <h2 class="pp-upsell__title">Vuoi costruire il tuo messaggio con il mio supporto diretto?</h2>
        <p class="pp-upsell__text">
          Il Percorso Privato è 5 sessioni individuali in cui ti seguo mentre costruisci il tuo messaggio e strutturi come portarlo fuori. Ogni sessione parte da quello che è emerso nella precedente.
        </p>
        <ul class="pp-upsell__list">
          <li>5 sessioni individuali con Marco</li>
          <li>Facilitazione passo-passo del processo</li>
          <li>Video lezioni + PDF di supporto inclusi</li>
          <li>Accesso al Gruppo Telegram</li>
        </ul>
        <a href="https://wa.link/wjlw58" target="_blank" rel="noopener" class="pp-upsell__btn pp-upsell__btn--consulting">
          Scrivimi su WhatsApp →
        </a>
        <p class="pp-upsell__price">€500, oppure 3 rate da €167</p>
      </div>

    </div>

    </main>
  </div>

  <script>
    // ── Highlight placeholders [brackets] in prompt text
    document.querySelectorAll('.prompt-card__text[data-raw]').forEach(el => {
      const raw = el.getAttribute('data-raw') || '';
      el.innerHTML = raw.replace(/\[([^\]]+)\]/g,
        '<mark class="ph">[$1]</mark>');
    });

    // ── Toggle GPT preview
    window.togglePreview = function(n) {
      const preview = document.getElementById('preview-' + n);
      const btn = document.querySelector(`[onclick="togglePreview(${n})"]`);
      if (!preview) return;
      const isOpen = preview.style.display !== 'none';
      preview.style.display = isOpen ? 'none' : 'block';
      if (btn) btn.classList.toggle('open', !isOpen);
      if (btn) btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> ${!isOpen ? 'Nascondi' : 'Anteprima'}`;
    };

    // ── Copy to clipboard
    window.copyPrompt = function(btn) {
      const card = btn.closest('.prompt-card');
      const text = card.getAttribute('data-text') || '';
      navigator.clipboard.writeText(text).then(() => {
        btn.classList.add('done');
        btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Copiato`;
        card.classList.add('copied');
        setTimeout(() => {
          btn.classList.remove('done');
          btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg> Copia`;
          card.classList.remove('copied');
        }, 2000);
      });
    };

    // ── Sidebar active state on scroll (IntersectionObserver)
    const mainEl = document.getElementById('main');
    const sections = document.querySelectorAll('.cat-section');
    const sidebarItems = document.querySelectorAll('.sidebar__item');

    function setActive(catId) {
      sidebarItems.forEach(item => {
        item.classList.toggle('active', item.getAttribute('data-cat') === catId);
      });
    }

    // Set first as active initially
    if (sections.length) setActive(sections[0].id);

    const isMobile = () => window.innerWidth <= 768;

    const observerOptions = () => isMobile()
      ? { root: null, rootMargin: '-100px 0px -60% 0px', threshold: 0 }
      : { root: mainEl, rootMargin: '-10% 0px -70% 0px', threshold: 0 };

    let observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
          const activeItem = document.querySelector(`.sidebar__item[data-cat="${entry.target.id}"]`);
          if (activeItem) activeItem.scrollIntoView({ block: 'nearest', inline: 'nearest' });
        }
      });
    }, observerOptions());

    sections.forEach(s => observer.observe(s));

    // Re-init observer on resize (mobile ↔ desktop)
    window.addEventListener('resize', () => {
      observer.disconnect();
      observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            const activeItem = document.querySelector(`.sidebar__item[data-cat="${entry.target.id}"]`);
            if (activeItem) activeItem.scrollIntoView({ block: 'nearest', inline: 'nearest' });
          }
        });
      }, observerOptions());
      sections.forEach(s => observer.observe(s));
    }, { passive: true });

    // ── Sidebar click → scroll to section
    sidebarItems.forEach(item => {
      item.addEventListener('click', (e) => {
        e.preventDefault();
        const catId = item.getAttribute('data-cat');
        const section = document.getElementById(catId);
        if (section) {
          // Mobile: scroll window; Desktop: scroll main
          if (window.innerWidth <= 768) {
            const mobileOffset = section.getBoundingClientRect().top + window.scrollY - (56 + 44 + 12);
            window.scrollTo({ top: mobileOffset, behavior: 'smooth' });
          } else {
            const sectionTop = section.getBoundingClientRect().top - mainEl.getBoundingClientRect().top + mainEl.scrollTop;
            mainEl.scrollTo({ top: sectionTop - 24, behavior: 'smooth' });
          }
          setActive(catId);
        }
      });
    });

    // ── User menu dropdown
    const userMenuBtn = document.getElementById('user-menu-btn');
    const userMenuDropdown = document.getElementById('user-menu-dropdown');
    if (userMenuBtn && userMenuDropdown) {
      userMenuBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = userMenuDropdown.classList.contains('open');
        userMenuDropdown.classList.toggle('open', !isOpen);
        userMenuBtn.setAttribute('aria-expanded', String(!isOpen));
      });
      document.addEventListener('click', () => {
        userMenuDropdown.classList.remove('open');
        userMenuBtn.setAttribute('aria-expanded', 'false');
      });
      userMenuDropdown.addEventListener('click', (e) => e.stopPropagation());
    }

    // ── Search
    const searchInput = document.getElementById('search');
    const searchEmpty = document.getElementById('search-empty');

    searchInput.addEventListener('input', () => {
      const q = searchInput.value.toLowerCase().trim();
      let anyVisible = false;

      sections.forEach(section => {
        const cards = section.querySelectorAll('.prompt-card');
        let sectionVisible = false;

        cards.forEach(card => {
          const text = (card.getAttribute('data-text') || '').toLowerCase();
          const title = card.querySelector('.prompt-card__title')?.textContent?.toLowerCase() || '';
          const matches = !q || text.includes(q) || title.includes(q);
          card.style.display = matches ? '' : 'none';
          if (matches) sectionVisible = true;
        });

        section.classList.toggle('hidden', !sectionVisible);
        if (sectionVisible) anyVisible = true;
      });

      searchEmpty.classList.toggle('visible', !anyVisible && q.length > 0);
    });
  </script>

  </div><!-- /pp-content-wrap -->

  <script is:inline>
  (function(){
    // Check for pp_access cookie OR token in URL
    var cookie = document.cookie;
    var hasCookie = cookie.split(';').some(function(c){return c.trim().startsWith('pp_access=')});

    // Also check for ?token= in URL (first visit from email link)
    var urlParams = new URLSearchParams(window.location.search);
    var tokenFromUrl = urlParams.get('token');

    if (tokenFromUrl) {
      // Validate token server-side and set cookie
      fetch('/api/prompt-pack/validate-token.php?token=' + encodeURIComponent(tokenFromUrl))
        .then(function(r){ return r.json(); })
        .then(function(d){
          if (d.valid) {
            document.cookie = 'pp_access=' + encodeURIComponent(tokenFromUrl) + ';path=/;max-age=' + (86400*365) + ';SameSite=Lax';
            document.getElementById('pp-content-wrap').style.display = 'block';
          } else {
            document.getElementById('pp-login-wrap').style.display = 'block';
          }
        })
        .catch(function(){
          // Fallback: show content if we have cookie, otherwise login
          if (hasCookie) document.getElementById('pp-content-wrap').style.display = 'block';
          else document.getElementById('pp-login-wrap').style.display = 'block';
        });
    } else if (hasCookie) {
      document.getElementById('pp-content-wrap').style.display = 'block';
    } else {
      document.getElementById('pp-login-wrap').style.display = 'block';
    }
  })();
  </script>

</body>
</html>
