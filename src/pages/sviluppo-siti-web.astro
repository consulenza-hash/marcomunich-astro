---
import BaseLayout from '@layouts/BaseLayout.astro';

const stack = [
  {
    icon: "⚡",
    name: "Astro 5",
    desc: "Genera pagine HTML pure, senza JavaScript superfluo. Risultato: PageSpeed 95–100/100 e caricamento in meno di 1 secondo. Nessun database, nessun PHP."
  },
  {
    icon: "🔁",
    name: "CI/CD Automatizzato",
    desc: "Ogni aggiornamento va online in pochi minuti tramite GitHub Actions. Nessun FTP, nessun pannello di controllo da imparare. La tecnologia lavora da sola."
  },
  {
    icon: "🧠",
    name: "SEO + AEO Ready",
    desc: "Schema.org avanzato (Person, Service, FAQPage, LocalBusiness) che parla direttamente con Google, ChatGPT e Claude per farti trovare meglio oggi e domani."
  },
  {
    icon: "📬",
    name: "Forensic Mailer",
    desc: "Sistema email costruito su misura per aggirare i filtri spam dei server condivisi. Ogni richiesta di contatto arriva sempre a destinazione — zero messaggi persi."
  },
  {
    icon: "🎨",
    name: "Design System su Misura",
    desc: "Palette cromatica, tipografia e griglia matematica a 8pt progettate per la tua frequenza. Non scegli da un catalogo: è un vestito cucito addosso a te."
  },
  {
    icon: "🔒",
    name: "Zero Vulnerabilità",
    desc: "Senza database, senza PHP, senza plugin da aggiornare. Non esiste una superficie di attacco. È sicuro by design, non grazie a un plugin di sicurezza."
  },
];

const faq = [
  {
    q: "Non sono bravo a scrivere i testi, mi aiuti?",
    a: "Assolutamente sì. Ti guiderò con domande mirate per far emergere il tuo messaggio autentico, senza forzature. Non dovrai affrontare il foglio bianco da solo."
  },
  {
    q: "Dovrò pagare costi mensili per mantenere il sito?",
    a: "No. A parte il normale costo annuale del dominio e del server (poche decine di euro), la tecnologia che uso non richiede contratti di assistenza o manutenzione continua. Paghi una volta, funziona per anni."
  },
  {
    q: "Qual è la differenza rispetto a WordPress o Wix?",
    a: "WordPress e Wix generano le pagine al momento della visita (server-side). Astro le pre-genera una volta sola — questo significa velocità drasticamente superiore, zero aggiornamenti di plugin e un livello di sicurezza che i CMS tradizionali non possono eguagliare."
  },
  {
    q: "E se non capisco nulla di tecnologia?",
    a: "È esattamente per questo che ho creato questa soluzione. Il mio obiettivo è toglierti completamente il peso della tecnologia. Tu parli con le persone, al resto ci penso io."
  },
  {
    q: "In quanto tempo va online il sito?",
    a: "Dal momento in cui ho tutti i tuoi materiali, il sito è pronto in 2 settimane. Ti guido io nella raccolta di quello che serve."
  }
];
---

<BaseLayout
  title="Siti Web per Coach, Counselor e Operatori Olistici — Marco Munich"
  description="Sviluppo siti web ad alte prestazioni con Astro 5. Veloci, sicuri, senza manutenzione. Progettati su misura per Coach, Counselor e Operatori Olistici."
  currentPath="/sviluppo-siti-web/"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet" />

  <div class="sw-page">

    <!-- ── HERO ─────────────────────────────────────────────────────────── -->
    <section class="sw-hero">
      <div class="sw-hero-inner">
        <span class="sw-badge">Per Coach, Counselor e Operatori Olistici</span>
        <h1 class="sw-h1">
          Siti Web ad Alte Prestazioni.<br>
          <em>Costruiti per durare,<br class="sw-br-mobile"> progettati per te.</em>
        </h1>
        <p class="sw-hero-desc">
          Sviluppo siti web statici con <strong>Astro 5</strong> — veloci, sicuri, senza manutenzione.
          Non un template pre-fatto: ogni progetto è un design system su misura costruito
          intorno alla tua essenza e al tuo messaggio.
        </p>
        <div class="sw-hero-pills">
          <span>⚡ PageSpeed 95–100/100</span>
          <span>🔒 Zero vulnerabilità</span>
          <span>🛠 Zero manutenzione</span>
        </div>
        <a href="#offerta" class="sw-btn-primary">Scopri come funziona →</a>
      </div>
    </section>

    <!-- ── PROBLEMA ───────────────────────────────────────────────────── -->
    <section class="sw-section sw-warm">
      <div class="sw-container sw-narrow sw-center-text">
        <span class="sw-label">Il problema</span>
        <h2 class="sw-h2">La tecnologia non dovrebbe<br>prosciugarti l'energia</h2>
        <p class="sw-body-lg">
          Hai fatto un lavoro profondo su te stesso e sui tuoi talenti. Eppure, quando si tratta
          di metterti online, ti scontri con piattaforme lente, plugin da aggiornare e siti
          che non rispecchiano davvero chi sei.
        </p>
        <ul class="sw-list">
          {[
            "La tua presenza online non riflette l'anima del tuo lavoro",
            "Aggiornamenti continui e rischio di crash ti tolgono il focus",
            "Email di potenziali clienti che finiscono nello spam senza che tu lo sappia",
            "Un sito lento che allontana le persone prima ancora che leggano una riga",
          ].map(item => (
            <li><span class="sw-arrow">›</span>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── STACK TECNICO ──────────────────────────────────────────────── -->
    <section class="sw-section sw-sage">
      <div class="sw-container">
        <span class="sw-label sw-center-text" style="display:block;">Come è costruito</span>
        <h2 class="sw-h2 sw-center-text">Lo Stack Tecnico</h2>
        <p class="sw-body-lg sw-center-text" style="max-width:580px; margin-left:auto; margin-right:auto; margin-bottom:48px;">
          Non WordPress, non Wix. Un'architettura moderna costruita per performare,
          resistere e farti trovare — sia dagli utenti che dalle AI.
        </p>
        <div class="sw-tech-grid">
          {stack.map(s => (
            <div class="sw-tech-card">
              <div class="sw-tech-icon">{s.icon}</div>
              <h3 class="sw-tech-name">{s.name}</h3>
              <p class="sw-tech-desc">{s.desc}</p>
            </div>
          ))}
        </div>

        <!-- VS TABLE -->
        <div class="sw-vs-wrap">
          <div class="sw-vs-col sw-vs-bad">
            <p class="sw-vs-label">WordPress / Wix</p>
            {[
              "Plugin da aggiornare ogni settimana",
              "Vulnerabile agli attacchi hacker",
              "Lento: ogni pagina è generata al momento",
              "Costi mensili o annuali obbligatori",
              "Template uguali a migliaia di altri siti",
            ].map(i => <p class="sw-vs-row sw-vs-no">✗ {i}</p>)}
          </div>
          <div class="sw-vs-divider">vs</div>
          <div class="sw-vs-col sw-vs-good">
            <p class="sw-vs-label sw-vs-label-good">Sito con Astro 5</p>
            {[
              "Zero plugin, zero aggiornamenti",
              "HTML puro: non c'è nulla da attaccare",
              "Pre-renderizzato: si carica in &lt;1 secondo",
              "Una tantum — nessun canone mensile",
              "Design system unico, costruito su di te",
            ].map(i => <p class="sw-vs-row sw-vs-yes" set:html={"✓ " + i} />)}
          </div>
        </div>
      </div>
    </section>

    <!-- ── PROCESSO ───────────────────────────────────────────────────── -->
    <section class="sw-section" style="background:#fff;">
      <div class="sw-container sw-narrow">
        <span class="sw-label sw-center-text" style="display:block;">Il processo</span>
        <h2 class="sw-h2 sw-center-text">Dalla prima chiacchierata<br>al sito online</h2>
        <div class="sw-steps">
          {[
            {
              n: "01",
              t: "Intervista di Allineamento",
              d: "Partiamo da te. Ti faccio le domande giuste per estrarre il tuo messaggio autentico, capire il tuo cliente ideale e definire l'energia visiva del sito."
            },
            {
              n: "02",
              t: "Design System su Misura",
              d: "Creo una palette cromatica, una selezione tipografica e una griglia a 8pt progettate appositamente per la tua frequenza. Non scegli da un catalogo."
            },
            {
              n: "03",
              t: "Sviluppo & Deploy",
              d: "Il sito viene sviluppato con Astro 5 e deployato tramite GitHub Actions in automatico. Ti mostro ogni avanzamento e raccoglieremo i feedback insieme."
            },
            {
              n: "04",
              t: "Online & Libero",
              d: "Il sito va live. Ti consegno accessi, istruzioni e struttura. Da quel momento non hai bisogno di me per nulla — a meno che tu non voglia espanderlo."
            },
          ].map(s => (
            <div class="sw-step">
              <div class="sw-step-n">{s.n}</div>
              <div class="sw-step-body">
                <h3 class="sw-step-title">{s.t}</h3>
                <p class="sw-step-desc">{s.d}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── OFFERTA / PREZZO ──────────────────────────────────────────── -->
    <section id="offerta" class="sw-section sw-dark">
      <div class="sw-container sw-narrow">
        <span class="sw-label sw-label-sage sw-center-text" style="display:block;">L'investimento</span>
        <h2 class="sw-h2 sw-center-text" style="color:#fff;">Il tuo nuovo Spazio Digitale</h2>
        <p class="sw-center-text" style="color:#a09a90; font-size:16px; margin-bottom:48px;">Semplice, elegante, tuo. Senza costi nascosti.</p>

        <div class="sw-price-card">
          <div class="sw-price-header">
            <div class="sw-price-amount">1.300€</div>
            <p class="sw-price-sub">Una tantum · Nessun canone mensile</p>
          </div>

          <div class="sw-rate-box">
            <p class="sw-rate-title">Preferisci rateizzare?</p>
            <p class="sw-rate-desc">
              Inizia con un anticipo di <strong>400€</strong> per avviare i lavori,
              e salda il resto in <strong>3 rate mensili da 300€</strong>.
            </p>
          </div>

          <p class="sw-includes-title">Cosa creeremo insieme:</p>
          <ul class="sw-includes">
            {[
              "Intervista di allineamento per estrarre la tua vera essenza",
              "Design System su misura (Palette, Tipografia, Griglia 8pt)",
              "Sviluppo con Astro 5 — statico, velocissimo, zero manutenzione",
              "Fino a 5 pagine (Home, Chi Sono, Servizi, Contatti, Blog)",
              "Forensic Mailer — sistema email anti-spam costruito su misura",
              "SEO + AEO: Schema.org (Person, Service, FAQPage) per Google e AI",
              "Deploy automatizzato via GitHub Actions — nessun FTP",
            ].map(item => (
              <li><span class="sw-check">✓</span>{item}</li>
            ))}
          </ul>

          <a href="https://wa.me/393337498922?text=Ciao%20Marco,%20sono%20interessato%20al%20servizio%20Sito%20Web%20Premium"
            class="sw-btn-dark">
            Fissiamo una chiacchierata →
          </a>
          <p class="sw-cta-note">Nessun impegno. Solo per capire se siamo in sintonia.</p>
        </div>
      </div>
    </section>

    <!-- ── FAQ ───────────────────────────────────────────────────────── -->
    <section class="sw-section sw-warm">
      <div class="sw-container sw-narrow">
        <span class="sw-label sw-center-text" style="display:block;">Dubbi o domande?</span>
        <h2 class="sw-h2 sw-center-text">Sono qui</h2>
        <div class="sw-faq">
          {faq.map(item => (
            <div class="sw-faq-item">
              <p class="sw-faq-q">› {item.q}</p>
              <p class="sw-faq-a">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA FINALE ─────────────────────────────────────────────────── -->
    <section class="sw-section sw-dark sw-center-text">
      <div class="sw-container sw-narrow">
        <h2 class="sw-h2" style="color:#fff;">Pronto a costruire<br>il tuo spazio autentico?</h2>
        <p style="color:#a09a90; font-size:16px; line-height:1.7; margin-bottom:44px;">
          Prendo a cuore pochi progetti al mese per dedicare la giusta energia a ciascuno.
          Scrivimi per capire se siamo in sintonia.
        </p>
        <a href="https://wa.me/393337498922?text=Ciao%20Marco,%20sono%20interessato%20al%20servizio%20Sito%20Web%20Premium"
          class="sw-btn-primary">
          Scrivimi su WhatsApp →
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  :root {
    --sw-dark:        #1A1814;
    --sw-accent:      #5C7E60;
    --sw-accent-mid:  #8AAF8E;
    --sw-accent-lt:   #E8F0E6;
    --sw-warm:        #F6F2EB;
    --sw-warm-border: #E2DDD4;
    --sw-text:        #2C2820;
    --sw-muted:       #7A7268;
    --ff-display:     'Cormorant Garamond', Georgia, serif;
    --ff-body:        'DM Sans', system-ui, sans-serif;
  }

  .sw-page          { overflow-x: hidden; font-family: var(--ff-body); color: var(--sw-text); }

  /* ── LAYOUT ───────────────────────────────────────────────────────── */
  .sw-section       { padding: 80px 24px; }
  .sw-container     { max-width: 960px; margin: 0 auto; }
  .sw-narrow        { max-width: 700px; }
  .sw-center-text   { text-align: center; }
  .sw-warm          { background: var(--sw-warm); }
  .sw-sage          { background: var(--sw-accent-lt); }
  .sw-dark          { background: var(--sw-dark); }

  /* ── TYPOGRAPHY ───────────────────────────────────────────────────── */
  .sw-label         { color: var(--sw-accent); font-weight: 700; font-size: 12px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
  .sw-label-sage    { color: var(--sw-accent-mid); }
  .sw-h2            { font-family: var(--ff-display); font-size: clamp(28px, 4vw, 46px); font-weight: 700; line-height: 1.15; margin-bottom: 20px; color: var(--sw-text); }
  .sw-body-lg       { color: #555; font-size: 17px; line-height: 1.8; margin-bottom: 40px; }

  /* ── HERO ─────────────────────────────────────────────────────────── */
  .sw-hero          { background: var(--sw-dark); color: #fff; padding: 100px 24px 90px; text-align: center; }
  .sw-hero-inner    { max-width: 820px; margin: 0 auto; }
  .sw-badge         { display: inline-block; background: rgba(138,175,142,.12); color: var(--sw-accent-mid); font-size: 12px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; padding: 6px 18px; border-radius: 100px; border: 1px solid rgba(138,175,142,.25); margin-bottom: 28px; }
  .sw-h1            { font-family: var(--ff-display); font-size: clamp(36px, 5.5vw, 68px); font-weight: 700; line-height: 1.1; margin-bottom: 24px; color: #fff; }
  .sw-h1 em         { font-style: italic; color: var(--sw-accent-mid); }
  .sw-br-mobile     { display: none; }
  .sw-hero-desc     { font-size: clamp(16px, 2vw, 18px); color: #c8c4bc; line-height: 1.8; margin-bottom: 32px; max-width: 640px; margin-left: auto; margin-right: auto; }
  .sw-hero-desc strong { color: #fff; font-weight: 600; }
  .sw-hero-pills    { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 40px; }
  .sw-hero-pills span { background: rgba(255,255,255,.06); color: #d4d0c8; font-size: 13px; padding: 6px 14px; border-radius: 4px; border: 1px solid rgba(255,255,255,.1); }

  /* ── BUTTONS ──────────────────────────────────────────────────────── */
  .sw-btn-primary   { display: inline-block; background: var(--sw-accent); color: #fff; font-weight: 700; font-size: 16px; padding: 18px 40px; text-decoration: none; border-radius: 4px; transition: background .2s; }
  .sw-btn-primary:hover { background: #4A6B4E; }
  .sw-btn-dark      { display: block; text-align: center; background: var(--sw-accent); color: #fff; font-weight: 700; font-size: 17px; padding: 20px; text-decoration: none; border-radius: 8px; transition: background .2s; }
  .sw-btn-dark:hover { background: #4A6B4E; }

  /* ── PROBLEM LIST ─────────────────────────────────────────────────── */
  .sw-list          { list-style: none; padding: 0; text-align: left; }
  .sw-list li       { display: flex; gap: 14px; align-items: flex-start; padding: 14px 0; border-bottom: 1px solid var(--sw-warm-border); font-size: 16px; color: #333; line-height: 1.6; }
  .sw-arrow         { color: var(--sw-accent); font-weight: 800; flex-shrink: 0; margin-top: 2px; }

  /* ── TECH GRID ────────────────────────────────────────────────────── */
  .sw-tech-grid     { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
  .sw-tech-card     { background: #fff; padding: 32px 28px; border-radius: 12px; border: 1px solid rgba(92,126,96,.15); }
  .sw-tech-icon     { font-size: 32px; margin-bottom: 14px; }
  .sw-tech-name     { font-family: var(--ff-display); font-size: 20px; font-weight: 700; margin-bottom: 10px; color: var(--sw-text); }
  .sw-tech-desc     { color: #555; font-size: 14px; line-height: 1.75; }

  /* ── VS TABLE ─────────────────────────────────────────────────────── */
  .sw-vs-wrap       { display: grid; grid-template-columns: 1fr auto 1fr; background: #fff; border-radius: 16px; overflow: hidden; border: 1px solid rgba(92,126,96,.18); }
  .sw-vs-col        { padding: 36px 32px; }
  .sw-vs-divider    { display: flex; align-items: center; justify-content: center; background: var(--sw-accent-lt); padding: 0 24px; font-family: var(--ff-display); font-size: 26px; font-weight: 700; color: var(--sw-accent); border-left: 1px solid rgba(92,126,96,.15); border-right: 1px solid rgba(92,126,96,.15); }
  .sw-vs-label      { font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; color: #aaa; margin-bottom: 16px; }
  .sw-vs-label-good { color: var(--sw-accent); }
  .sw-vs-row        { font-size: 14px; padding: 7px 0; border-bottom: 1px solid #f5f5f5; display: flex; gap: 8px; align-items: flex-start; line-height: 1.5; }
  .sw-vs-no         { color: #bbb; }
  .sw-vs-yes        { color: var(--sw-text); font-weight: 500; border-bottom-color: #edf2ec; }

  /* ── STEPS ────────────────────────────────────────────────────────── */
  .sw-steps         { display: flex; flex-direction: column; }
  .sw-step          { display: flex; gap: 32px; align-items: flex-start; padding: 32px 0; border-bottom: 1px solid var(--sw-warm-border); }
  .sw-step:last-child { border-bottom: none; }
  .sw-step-n        { font-family: var(--ff-display); font-size: 52px; font-weight: 700; color: var(--sw-accent-mid); line-height: 1; flex-shrink: 0; width: 64px; }
  .sw-step-title    { font-family: var(--ff-display); font-size: 22px; font-weight: 700; margin-bottom: 8px; color: var(--sw-text); }
  .sw-step-desc     { color: #555; font-size: 15px; line-height: 1.75; }

  /* ── PRICE CARD ───────────────────────────────────────────────────── */
  .sw-price-card    { background: #fff; color: var(--sw-text); border-radius: 16px; padding: 48px 40px; border: 2px solid rgba(138,175,142,.35); }
  .sw-price-header  { text-align: center; margin-bottom: 32px; }
  .sw-price-amount  { font-family: var(--ff-display); font-size: clamp(52px, 7vw, 76px); font-weight: 700; line-height: 1; color: var(--sw-text); }
  .sw-price-sub     { color: #888; font-size: 15px; margin-top: 8px; }
  .sw-rate-box      { background: var(--sw-accent-lt); border-radius: 10px; padding: 24px; margin-bottom: 32px; border-left: 4px solid var(--sw-accent); }
  .sw-rate-title    { font-weight: 700; font-size: 15px; color: var(--sw-accent); margin-bottom: 8px; }
  .sw-rate-desc     { color: #333; font-size: 15px; line-height: 1.7; }
  .sw-includes-title { font-weight: 700; font-size: 15px; margin-bottom: 16px; color: #333; }
  .sw-includes      { list-style: none; padding: 0; margin-bottom: 40px; }
  .sw-includes li   { display: flex; gap: 12px; align-items: flex-start; padding: 10px 0; border-bottom: 1px solid #ede9e4; font-size: 15px; color: #333; line-height: 1.6; }
  .sw-check         { color: var(--sw-accent); font-weight: 800; flex-shrink: 0; }
  .sw-cta-note      { text-align: center; color: #888; font-size: 13px; margin-top: 12px; }

  /* ── FAQ ──────────────────────────────────────────────────────────── */
  .sw-faq-item      { border-bottom: 2px solid var(--sw-warm-border); padding: 24px 0; }
  .sw-faq-q         { font-family: var(--ff-display); font-weight: 600; font-size: 18px; color: var(--sw-text); margin-bottom: 10px; }
  .sw-faq-a         { color: #555; font-size: 15px; line-height: 1.75; }

  /* ── MOBILE ───────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .sw-tech-grid              { grid-template-columns: 1fr !important; }
    .sw-tech-grid > *          { width: 100% !important; }
    .sw-vs-wrap                { grid-template-columns: 1fr !important; }
    .sw-vs-divider             { padding: 14px; border-left: none; border-right: none; border-top: 1px solid rgba(92,126,96,.15); border-bottom: 1px solid rgba(92,126,96,.15); }
    .sw-step                   { flex-direction: column; gap: 8px; }
    .sw-step-n                 { font-size: 36px; width: auto; }
    .sw-price-card             { padding: 32px 20px !important; }
    .sw-br-mobile              { display: block; }
    .sw-h1                     { font-size: clamp(32px, 9vw, 48px); }
  }
</style>
