---
import BaseLayout from '@layouts/BaseLayout.astro';

const stack = [
  {
    icon: "⚡",
    name: "Astro 5",
    desc: "Genera pagine HTML pure, senza JavaScript superfluo. Risultato: PageSpeed 95–100/100 e caricamento in meno di 1 secondo. Nessun database, nessun PHP."
  },
  {
    icon: "🔁",
    name: "CI/CD Automatizzato",
    desc: "Ogni aggiornamento va online in pochi minuti tramite GitHub Actions. Nessun FTP, nessun pannello di controllo da imparare. La tecnologia lavora da sola."
  },
  {
    icon: "🧠",
    name: "SEO + AEO Ready",
    desc: "Schema.org avanzato (Person, Service, FAQPage, LocalBusiness) che parla direttamente con Google, ChatGPT e Claude per farti trovare meglio oggi e domani."
  },
  {
    icon: "📬",
    name: "Forensic Mailer",
    desc: "Sistema email costruito su misura per aggirare i filtri spam dei server condivisi. Ogni richiesta di contatto arriva sempre a destinazione — zero messaggi persi."
  },
  {
    icon: "🎨",
    name: "Design System su Misura",
    desc: "Palette cromatica, tipografia e griglia matematica a 8pt progettate per la tua frequenza. Non scegli da un catalogo: è un vestito cucito addosso a te."
  },
  {
    icon: "🔒",
    name: "Zero Vulnerabilità",
    desc: "Senza database, senza PHP, senza plugin da aggiornare. Non esiste una superficie di attacco. È sicuro by design, non grazie a un plugin di sicurezza."
  },
];

const problems = [
  {
    title: "Cosa ci metto dentro?",
    body: "Non sanno cosa scrivere nella pagina chi sono, nella pagina servizi, nell'about. Perché non hanno ancora chiarito il loro posizionamento. Il sito diventa lo specchio di quella confusione: pagine generiche, frasi vaghe, tono da depliant."
  },
  {
    title: "Un sito uguale a mille altri.",
    body: "Affidano il sito a qualcuno senza sapere cosa vogliono davvero. Il risultato è un sito che assomiglia a mille altri. Oppure usano un template bello graficamente ma che non dice nulla di specifico su di loro."
  },
  {
    title: "Il cantiere permanente.",
    body: "Il sito diventa un work in progress infinito. La palette non va bene, il font è da sistemare, la foto non convince. Passa un anno e il sito non è mai online — o è online ma non viene aggiornato perché «manca ancora qualcosa»."
  },
  {
    title: "Il cliente non capisce cosa vendi.",
    body: "Le pagine servizi elencano nomi di tecniche e approcci che il cliente non conosce: «sessioni di coaching sistemico», «percorsi di bioenergetica integrata». Il cliente cerca qualcuno che risolva il suo problema, non una nomenclatura di metodi."
  },
  {
    title: "SEO come pensiero magico.",
    body: "Credono che mettere su il sito faccia arrivare traffico automaticamente. Oppure si affidano a chi dice «ti posiziono su Google» senza capire che senza contenuti e senza traffico pregresso è una promessa vuota nel breve periodo."
  },
  {
    title: "Il sito non vende al posto tuo.",
    body: "Pensano che il sito «convinca» il cliente. Ma nel settore olistico funziona come conferma, non come primo contatto. Le persone arrivano al sito dopo aver già incontrato la persona da qualche altra parte — online o di persona."
  },
  {
    title: "L'investimento nel momento sbagliato.",
    body: "Spendono 3–5k in un sito prima di avere 30 contenuti scritti, una lista email, o anche solo una presenza social stabile. Il sito da solo non porta niente, e quando lo capiscono si sentono fregati."
  },
];

const faq = [
  {
    q: "Non sono bravo a scrivere i testi, mi aiuti?",
    a: "Assolutamente sì. Ti guiderò con domande mirate per far emergere il tuo messaggio autentico, senza forzature. Non dovrai affrontare il foglio bianco da solo."
  },
  {
    q: "Dovrò pagare costi mensili per mantenere il sito?",
    a: "No. A parte il normale costo annuale del dominio e del server (poche decine di euro), la tecnologia che uso non richiede contratti di assistenza o manutenzione continua. Paghi una volta, funziona per anni."
  },
  {
    q: "Qual è la differenza rispetto a WordPress o Wix?",
    a: "WordPress e Wix generano le pagine al momento della visita (server-side). Astro le pre-genera una volta sola — questo significa velocità drasticamente superiore, zero aggiornamenti di plugin e un livello di sicurezza che i CMS tradizionali non possono eguagliare."
  },
  {
    q: "E se non capisco nulla di tecnologia?",
    a: "È esattamente per questo che ho creato questa soluzione. Il mio obiettivo è toglierti completamente il peso della tecnologia. Tu parli con le persone, al resto ci penso io."
  },
  {
    q: "In quanto tempo va online il sito?",
    a: "Dal momento in cui ho tutti i tuoi materiali, il sito è pronto in 2 settimane. Ti guido io nella raccolta di quello che serve."
  }
];
---

<BaseLayout
  title="Siti Web per Coach, Counselor e Operatori Olistici — Marco Munich"
  description="Sviluppo siti web ad alte prestazioni con Astro 5. Veloci, sicuri, senza manutenzione. Progettati su misura per Coach, Counselor e Operatori Olistici."
  image="https://marcomunich.com/og/marco-munich.png"
  currentPath="/sviluppo-siti-web/"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&display=swap" rel="stylesheet" />

  <div class="sw-page">

    <!-- ── HERO ─────────────────────────────────────────────────────────── -->
    <section class="sw-hero">
      <div class="sw-hero-inner">
        <span class="sw-badge">Per Coach, Counselor e Operatori Olistici</span>
        <h1 class="sw-h1">
          Siti Web ad Alte Prestazioni.<br>
          <em>Costruiti per durare,<br class="sw-br-mobile"> progettati per te.</em>
        </h1>
        <p class="sw-hero-desc">
          Sviluppo siti web ad alte prestazioni — <strong>Astro 5</strong> per siti statici puri,
          <strong>Vite + CMS ibrido</strong> per chi vuole gestire i contenuti in autonomia.
          Non un template pre-fatto: ogni progetto è un design system su misura costruito
          intorno alla tua essenza e al tuo messaggio.
        </p>
        <div class="sw-hero-pills">
          <span>⚡ PageSpeed 95–100/100</span>
          <span>🔒 Zero vulnerabilità</span>
          <span>🛠 Zero manutenzione</span>
        </div>
        <a href="#offerta" class="sw-btn-primary">Scopri come funziona →</a>
      </div>
    </section>

    <!-- ── PROBLEMA ───────────────────────────────────────────────────── -->
    <section class="sw-section sw-prob-section">
      <div class="sw-container">
        <div class="sw-prob-header">
          <span class="sw-label">Il problema (vero)</span>
          <h2 class="sw-h2">Non è un problema tecnico.<br><em style="font-style:italic; color:var(--sw-accent);">È un problema di chiarezza.</em></h2>
          <p class="sw-body-lg sw-prob-intro">
            Quasi nessuno che lavora nel settore olistico ha un problema di tecnologia. Il problema è a monte — e il sito lo amplifica.
          </p>
        </div>
        <div class="sw-prob-grid">
          {problems.map((p, i) => (
            <div class="sw-prob-item">
              <span class="sw-prob-num">0{i + 1}</span>
              <h3 class="sw-prob-title">{p.title}</h3>
              <p class="sw-prob-body">{p.body}</p>
            </div>
          ))}
        </div>
        </div>
        
        <!-- TRANSIZIONE: Il ponte tra Problema e Soluzione Tecnica -->
        <div class="sw-prob-bridge">
          <p class="sw-bridge-text">
            <strong>La tecnologia serve solo a una cosa: proteggere il tuo messaggio.</strong><br>
            Proprio perché il tuo vero lavoro è scavare in profondità e connetterti con le persone, non puoi permetterti di sprecare energia dietro a plugin da aggiornare, siti hackerati o caricamenti lenti.
          </p>
          <p class="sw-bridge-text">
            Ho scelto uno stack tecnico estremo (senza database, senza CMS tradizionali) esattamente per questo motivo: costruire una casa digitale solida e silenziosa, che non ti chieda mai manutenzione. Tu lavori sul contenuto, il sito fa il resto.
          </p>
        </div>
      </div>
    </section>

    <!-- ── STACK TECNICO ──────────────────────────────────────────────── -->
    <section class="sw-section sw-sage">
      <div class="sw-container">
        <span class="sw-label sw-center-text" style="display:block;">Come è costruito</span>
        <h2 class="sw-h2 sw-center-text">Lo Stack Tecnico</h2>
        <p class="sw-body-lg sw-center-text" style="max-width:580px; margin-left:auto; margin-right:auto; margin-bottom:48px;">
          Non WordPress, non Wix. La tecnologia si adatta al progetto — ma sempre
          moderna, performante e costruita per durare nel tempo.
        </p>
        <div class="sw-tech-grid">
          {stack.map(s => (
            <div class="sw-tech-card">
              <div class="sw-tech-icon">{s.icon}</div>
              <h3 class="sw-tech-name">{s.name}</h3>
              <p class="sw-tech-desc">{s.desc}</p>
            </div>
          ))}
        </div>

        <!-- VS TABLE -->
        <div class="sw-vs-wrap">
          <div class="sw-vs-col sw-vs-bad">
            <p class="sw-vs-label">WordPress / Wix</p>
            {[
              "Plugin da aggiornare ogni settimana",
              "Vulnerabile agli attacchi hacker",
              "Lento: ogni pagina è generata al momento",
              "Costi mensili o annuali obbligatori",
              "Template uguali a migliaia di altri siti",
            ].map(i => <p class="sw-vs-row sw-vs-no">✗ {i}</p>)}
          </div>
          <div class="sw-vs-divider">vs</div>
          <div class="sw-vs-col sw-vs-good">
            <p class="sw-vs-label sw-vs-label-good">Sito con Astro 5</p>
            {[
              "Zero plugin, zero aggiornamenti",
              "HTML puro: non c'è nulla da attaccare",
              "Pre-renderizzato: si carica in &lt;1 secondo",
              "Una tantum — nessun canone mensile",
              "Design system unico, costruito su di te",
            ].map(i => <p class="sw-vs-row sw-vs-yes" set:html={"✓ " + i} />)}
          </div>
        </div>
      </div>
    </section>

    <!-- ── STILI / MOCKUP ────────────────────────────────────────────── -->
    <section class="sw-section" style="background:#fff;">
      <div class="sw-container">
        <span class="sw-label sw-center-text" style="display:block;">Stili e Progetti Reali</span>
        <h2 class="sw-h2 sw-center-text">Ogni progetto ha la sua frequenza</h2>
        <p class="sw-body-lg sw-center-text" style="max-width:560px; margin-left:auto; margin-right:auto; margin-bottom:56px;">
          Non ho uno stile fisso e non lavoro con un solo stack tecnologico.
          Un esempio reale, e quattro direzioni estetiche che posso realizzare.
        </p>

        <!-- CASO REALE: Valentina Russo BG5 -->
        <div class="mock-featured-wrap">
          <div class="mock-browser">
            <div class="mock-chrome">
              <span class="mock-dot" style="background:#ff5f57;"></span>
              <span class="mock-dot" style="background:#febc2e;"></span>
              <span class="mock-dot" style="background:#28c840;"></span>
              <div class="mock-url">valentinarussobg5.com</div>
            </div>
            <div class="mock-screen" style="background:#FBF5F0;">
              <div style="background:#fff; border-bottom:1px solid #ede8e4; padding:8px 14px; display:flex; align-items:center; gap:8px;">
                <span style="font-family:Georgia,serif; font-size:11px; font-weight:700; color:#2C1810; letter-spacing:.5px;">Valentina Russo</span>
                <span style="margin-left:auto; font-size:8px; color:#9B8EA6; font-weight:600; letter-spacing:.3px;">Privati · Aziende · Contatti</span>
              </div>
              <div style="display:grid; grid-template-columns:1fr 1fr;">
                <div style="background:#FBF5F0; padding:18px 14px 20px;">
                  <p style="color:#C77B8A; font-size:7px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:6px;">PERCORSO PRIVATI</p>
                  <p style="color:#2C1810; font-size:12px; font-weight:700; line-height:1.3; margin-bottom:10px; font-family:Georgia,serif; font-style:italic;">Scopri il tuo<br>Human Design</p>
                  <div style="display:inline-block; background:#C77B8A; color:#fff; font-size:7px; font-weight:700; padding:5px 10px; border-radius:20px;">Scopri →</div>
                </div>
                <div style="background:#1C2A4A; padding:18px 14px 20px;">
                  <p style="color:#2A9E9E; font-size:7px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:6px;">PERCORSO AZIENDE</p>
                  <p style="color:#fff; font-size:12px; font-weight:800; line-height:1.3; margin-bottom:10px;">Team<br>Engineering<br>BG5</p>
                  <div style="display:inline-block; background:#C9A84C; color:#1C2A4A; font-size:7px; font-weight:700; padding:5px 10px; border-radius:2px; letter-spacing:.5px;">PRENOTA</div>
                </div>
              </div>
              <div style="background:#fff; padding:8px 14px; display:flex; gap:8px; border-top:1px solid #ede8e4;">
                <div style="height:4px; background:#9B8EA6; border-radius:2px; width:50px; opacity:.35;"></div>
                <div style="height:4px; background:#C9A84C; border-radius:2px; width:35px; opacity:.35; margin-left:auto;"></div>
              </div>
            </div>
          </div>

          <div class="mock-featured-info">
            <span class="mock-case-badge">Caso Reale</span>
            <h3 class="mock-case-title">Valentina Russo BG5</h3>
            <p class="mock-case-desc">
              Human Design Coach &amp; Business Strategist. Due percorsi utente completamente separati —
              area <strong>Privati</strong> e area <strong>Corporate</strong>.
              <br><br>
              Integra l'<strong>AI Writing Assistant</strong>: può far scrivere articoli completi all'AI partendo da un'idea, oppure scrivere lei il testo e far autogenerare all'AI tutti i metadati tecnici (SEO, Geo, AEO) in automatico prima della pubblicazione.
            </p>
            <div class="mock-case-stack">
              <span>Grav CMS</span>
              <span>Vite MPA</span>
              <span>GitHub Actions CI/CD</span>
              <span>Schema.org AEO</span>
              <span>Forensic Mailer</span>
            </div>
            <p class="mock-case-budget">Budget finale: <strong>2.500€</strong></p>
            <a href="https://valentinarussobg5.com" target="_blank" rel="noopener" class="mock-case-link">
              Vedi il sito →
            </a>
          </div>
        </div>

        <!-- STILI PERSONALIZZABILI -->
        <p class="sw-label sw-center-text" style="display:block; margin-bottom:32px;">Stili personalizzabili</p>
        <div class="mock-grid">

          <!-- STILE 1: Olistica/Calore -->
          <div class="mock-wrap">
            <div class="mock-browser">
              <div class="mock-chrome">
                <span class="mock-dot" style="background:#ff5f57;"></span>
                <span class="mock-dot" style="background:#febc2e;"></span>
                <span class="mock-dot" style="background:#28c840;"></span>
                <div class="mock-url">iltuosito.com</div>
              </div>
              <div class="mock-screen" style="background:#F6F2EB;">
                <div class="mock-nav" style="background:#1A1814; color:#E8E4DC;">
                  <span style="font-weight:700; font-size:10px;">Chiara Bianchi</span>
                  <span style="font-size:9px; opacity:.6; margin-left:auto;">Chi sono · Servizi · Contatti</span>
                </div>
                <div class="mock-body" style="background:#1A1814; padding:18px 16px 20px;">
                  <p style="color:#8AAF8E; font-size:7px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:6px;">COACH OLISTICA</p>
                  <p style="color:#fff; font-size:13px; font-weight:700; line-height:1.25; font-style:italic; margin-bottom:10px; font-family:Georgia,serif;">Accompagno le persone<br>verso la propria luce</p>
                  <div style="display:inline-block; background:#8AAF8E; color:#fff; font-size:7px; font-weight:700; padding:5px 10px; border-radius:3px;">Scopri →</div>
                </div>
                <div style="padding:12px 14px; display:flex; gap:8px;">
                  <div style="flex:1; background:#fff; border-radius:6px; padding:10px 10px;">
                    <div style="width:16px; height:16px; background:#EEF3EC; border-radius:50%; margin-bottom:6px;"></div>
                    <div style="height:5px; background:#E2DDD4; border-radius:2px; margin-bottom:4px;"></div>
                    <div style="height:5px; background:#EDE9E2; border-radius:2px; width:70%;"></div>
                  </div>
                  <div style="flex:1; background:#fff; border-radius:6px; padding:10px 10px;">
                    <div style="width:16px; height:16px; background:#EEF3EC; border-radius:50%; margin-bottom:6px;"></div>
                    <div style="height:5px; background:#E2DDD4; border-radius:2px; margin-bottom:4px;"></div>
                    <div style="height:5px; background:#EDE9E2; border-radius:2px; width:70%;"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="mock-meta">
              <p class="mock-style">Olistica / Calore</p>
              <div class="mock-chips">
                <span style="background:#1A1814;" title="#1A1814"></span>
                <span style="background:#8AAF8E;" title="#8AAF8E"></span>
                <span style="background:#F6F2EB;" title="#F6F2EB"></span>
              </div>
              <p class="mock-kw">Caldo · Autentico · Organico</p>
            </div>
          </div>

          <!-- STILE 2: Premium/Corporate -->
          <div class="mock-wrap">
            <div class="mock-browser">
              <div class="mock-chrome">
                <span class="mock-dot" style="background:#ff5f57;"></span>
                <span class="mock-dot" style="background:#febc2e;"></span>
                <span class="mock-dot" style="background:#28c840;"></span>
                <div class="mock-url">iltuosito.com</div>
              </div>
              <div class="mock-screen" style="background:#F0EDE8;">
                <div class="mock-nav" style="background:#fff; border-bottom:1px solid #E8E4DC; color:#1A1814;">
                  <span style="font-weight:800; font-size:10px; letter-spacing:1px; text-transform:uppercase;">STUDIO VERDI</span>
                  <span style="font-size:9px; opacity:.5; margin-left:auto;">Servizi · Case Study · Contatti</span>
                </div>
                <div class="mock-body" style="background:#1C2030; padding:18px 16px 20px;">
                  <p style="color:#C9A84C; font-size:7px; font-weight:700; letter-spacing:2px; text-transform:uppercase; margin-bottom:6px;">BUSINESS COACHING</p>
                  <p style="color:#fff; font-size:13px; font-weight:800; line-height:1.25; margin-bottom:10px;">Strategia.<br>Leadership.<br>Risultati.</p>
                  <div style="display:inline-block; background:#C9A84C; color:#fff; font-size:7px; font-weight:700; padding:5px 10px; border-radius:2px; letter-spacing:.5px;">PRENOTA UNA CALL</div>
                </div>
                <div style="padding:12px 14px; display:flex; gap:8px;">
                  <div style="flex:1; background:#fff; border-radius:4px; padding:10px; border-top:3px solid #C9A84C;">
                    <div style="height:5px; background:#E8E4DC; border-radius:2px; margin-bottom:4px; width:40%;"></div>
                    <div style="height:4px; background:#F0EDE8; border-radius:2px;"></div>
                  </div>
                  <div style="flex:1; background:#fff; border-radius:4px; padding:10px; border-top:3px solid #1C2030;">
                    <div style="height:5px; background:#E8E4DC; border-radius:2px; margin-bottom:4px; width:40%;"></div>
                    <div style="height:4px; background:#F0EDE8; border-radius:2px;"></div>
                  </div>
                  <div style="flex:1; background:#fff; border-radius:4px; padding:10px; border-top:3px solid #C9A84C;">
                    <div style="height:5px; background:#E8E4DC; border-radius:2px; margin-bottom:4px; width:40%;"></div>
                    <div style="height:4px; background:#F0EDE8; border-radius:2px;"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="mock-meta">
              <p class="mock-style">Premium / Corporate</p>
              <div class="mock-chips">
                <span style="background:#1C2030;" title="#1C2030"></span>
                <span style="background:#C9A84C;" title="#C9A84C"></span>
                <span style="background:#F0EDE8;" title="#F0EDE8"></span>
              </div>
              <p class="mock-kw">Autorevole · Strutturato · Raffinato</p>
            </div>
          </div>

          <!-- STILE 3: Minimal/Editoriale -->
          <div class="mock-wrap">
            <div class="mock-browser">
              <div class="mock-chrome">
                <span class="mock-dot" style="background:#ff5f57;"></span>
                <span class="mock-dot" style="background:#febc2e;"></span>
                <span class="mock-dot" style="background:#28c840;"></span>
                <div class="mock-url">iltuosito.com</div>
              </div>
              <div class="mock-screen" style="background:#FAFAFA;">
                <div class="mock-nav" style="background:#FAFAFA; border-bottom:1px solid #111; color:#111; padding-top:6px; padding-bottom:6px;">
                  <span style="font-weight:900; font-size:10px; text-transform:uppercase; letter-spacing:2px;">LUCA M.</span>
                  <span style="font-size:9px; margin-left:auto; letter-spacing:1px;">LAVORO · BLOG · NOW</span>
                </div>
                <div class="mock-body" style="background:#FAFAFA; padding:14px 16px 10px;">
                  <p style="color:#ddd; font-size:28px; font-weight:900; line-height:1; margin-bottom:4px; letter-spacing:-1px;">WRITER.</p>
                  <p style="color:#111; font-size:11px; font-weight:700; line-height:1.3; margin-bottom:8px; border-bottom:2px solid #111; padding-bottom:8px;">Parole che lasciano<br>il segno.</p>
                  <div style="display:flex; align-items:center; gap:6px;">
                    <div style="width:18px; height:1px; background:#111;"></div>
                    <span style="font-size:7px; font-weight:700; letter-spacing:1px; text-transform:uppercase;">Leggi il mio lavoro</span>
                  </div>
                </div>
                <div style="padding:0 16px 12px; display:flex; gap:0; border-top:1px solid #eee; margin-top:4px;">
                  <div style="flex:1; padding:8px 0; border-right:1px solid #eee;">
                    <div style="height:4px; background:#eee; border-radius:1px; width:60%;"></div>
                  </div>
                  <div style="flex:1; padding:8px 8px;">
                    <div style="height:4px; background:#eee; border-radius:1px; width:80%;"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="mock-meta">
              <p class="mock-style">Minimal / Editoriale</p>
              <div class="mock-chips">
                <span style="background:#111;" title="#111"></span>
                <span style="background:#EBEBEB;" title="#EBEBEB"></span>
                <span style="background:#FAFAFA; border:1px solid #ddd;" title="#FAFAFA"></span>
