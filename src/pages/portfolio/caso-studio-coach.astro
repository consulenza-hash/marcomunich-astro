---
// Chiara Martini — caso studio life coach Milano
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Caso Studio — Coach | Chiara Martini</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #1a1a1a;
      --ink-soft: #4a4a4a;
      --cream: #faf8f5;
      --cream-dark: #ede9e3;
      --terra: #b85c38;
      --terra-light: #cc7050;
      --warm-gray: #8a8078;
      --white: #ffffff;
      --dark: #111111;
      --serif: 'Libre Baskerville', Georgia, serif;
      --sans: 'Inter', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--cream); color: var(--ink); line-height: 1.6; overflow-x: hidden; }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    /* Mockup bar */
    .mockup-bar {
      background: var(--dark); color: rgba(250,248,245,0.55);
      text-align: center; font-size: 0.75rem; padding: 0.6rem 1.5rem;
      font-family: var(--sans); letter-spacing: 0.03em;
    }

    /* BACK */
    .back-btn {
      position: fixed; bottom: 2rem; left: 1.5rem; z-index: 999;
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(10,10,10,0.85); backdrop-filter: blur(8px);
      color: rgba(250,248,245,0.8); text-decoration: none;
      font-size: 0.8rem; letter-spacing: 0.04em; padding: 0.5rem 1rem;
      border-radius: 2rem; transition: all 0.2s;
    }
    .back-btn:hover { color: var(--cream); }

    /* HERO */
    .hero {
      background: var(--dark); min-height: 480px;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; gap: 3rem; padding: 6rem 3rem 4rem;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background: url('/images/portfolio/coach-bg.jpg') center/cover no-repeat;
      opacity: 0.18;
    }
    .hero-left { position: relative; }
    .hero-tag {
      font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: var(--terra); margin-bottom: 1.2rem; display: block;
    }
    .hero h1 {
      font-family: var(--serif); font-size: clamp(2.2rem, 4vw, 3.4rem);
      font-weight: 400; color: var(--cream); line-height: 1.15; margin-bottom: 1.2rem;
    }
    .hero h1 em { font-style: italic; color: rgba(250,248,245,0.55); }
    .hero-sub { font-size: 0.88rem; color: rgba(250,248,245,0.5); line-height: 1.8; max-width: 380px; }
    .hero-meta { position: relative; display: flex; flex-direction: column; gap: 1.5rem; }
    .hero-meta-item { border-top: 1px solid rgba(250,248,245,0.1); padding-top: 1rem; }
    .hero-meta-label { font-size: 0.62rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--warm-gray); display: block; margin-bottom: 0.3rem; }
    .hero-meta-val { font-size: 0.85rem; color: rgba(250,248,245,0.7); }

    /* CONTAINER */
    .container { max-width: 860px; margin: 0 auto; padding: 0 2rem; }
    .main { max-width: 860px; margin: 0 auto; padding: 0 2rem; }

    /* STEP LABELS */
    .step-label {
      display: inline-flex; align-items: center; gap: 0.6rem;
      font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--warm-gray); margin-bottom: 2.5rem; padding-top: 3rem;
    }
    .step-num {
      width: 22px; height: 22px; border-radius: 50%;
      background: var(--terra); color: white;
      font-size: 0.6rem; display: inline-flex; align-items: center; justify-content: center;
    }

    /* STEP 1 — RIFERIMENTO */
    .step1 { padding: 3rem 0; }
    .insp-card {
      display: grid; grid-template-columns: 1.1fr 1fr;
      border: 1px solid var(--cream-dark); background: white; overflow: hidden;
    }
    .insp-site { border-right: 1px solid var(--cream-dark); overflow: hidden; }
    .insp-screenshot { grid-column: 1 / -1; border-bottom: 1px solid var(--cream-dark); position: relative; }
    .insp-screenshot img { width: 100%; display: block; max-height: 220px; object-fit: cover; object-position: top; }
    .screenshot-label {
      position: absolute; bottom: 0.6rem; left: 0.8rem;
      background: rgba(0,0,0,0.55); color: rgba(255,255,255,0.85);
      font-size: 0.68rem; padding: 0.25rem 0.6rem; border-radius: 4px;
      backdrop-filter: blur(4px);
    }
    .insp-info { padding: 2rem; }
    .site-tag { font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terra); margin-bottom: 0.5rem; }
    .site-name { font-family: var(--serif); font-size: 1.3rem; font-weight: 400; margin-bottom: 0.3rem; }
    .site-url { font-size: 0.72rem; color: var(--warm-gray); margin-bottom: 1.2rem; }
    .tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .tag { font-size: 0.68rem; letter-spacing: 0.08em; padding: 0.3rem 0.7rem; background: var(--cream); color: var(--warm-gray); }
    .insp-quote { margin-top: 1.5rem; padding: 1rem 1.2rem; background: var(--cream); border-left: 2px solid var(--terra); }
    .insp-quote p { font-size: 0.82rem; line-height: 1.75; color: var(--ink-soft); font-style: italic; }

    /* STEP 2 — ANALISI */
    .step2 { padding: 3rem 0; }
    .analisi-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; }
    .analisi-card { background: white; border: 1px solid var(--cream-dark); padding: 1.5rem; }
    .analisi-card-label { font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terra); margin-bottom: 1rem; display: block; }
    .palette { display: flex; gap: 0.5rem; margin-bottom: 0.8rem; }
    .swatch { width: 32px; height: 32px; border-radius: 2px; }
    .palette-names { font-size: 0.72rem; color: var(--warm-gray); line-height: 1.8; }
    .font-sample { font-family: var(--serif); font-size: 1.4rem; margin-bottom: 0.3rem; }
    .font-name { font-size: 0.72rem; color: var(--warm-gray); }
    .keyword-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
    .keyword-list li { font-size: 0.82rem; color: var(--ink-soft); display: flex; align-items: center; gap: 0.5rem; }
    .keyword-list li::before { content: '→'; color: var(--terra); font-size: 0.72rem; }

    /* STEP 3 — TRADUZIONE */
    .step3 { padding: 3rem 0; background: var(--cream-dark); margin: 0 -2rem; padding-left: 2rem; padding-right: 2rem; }
    .traduzione-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
    .trans-col h3 {
      font-family: var(--serif); font-size: 1.1rem; margin-bottom: 1.2rem;
      padding-bottom: 0.8rem; border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    .trans-col h3 span { color: var(--warm-gray); font-size: 0.72rem; font-weight: 400; font-family: var(--sans); letter-spacing: 0.08em; text-transform: uppercase; display: block; margin-bottom: 0.3rem; }
    .trans-list { list-style: none; }
    .trans-list li {
      display: flex; gap: 0.8rem; padding: 0.8rem 0;
      border-bottom: 1px solid rgba(0,0,0,0.05);
      font-size: 0.85rem; line-height: 1.5; color: var(--ink-soft); align-items: flex-start;
    }
    .trans-list li .icon { color: var(--terra); flex-shrink: 0; margin-top: 0.1rem; }

    /* STEP 4 — RISULTATO */
    .step4 { padding: 3rem 0; }
    .risultato-intro { max-width: 620px; margin-bottom: 2rem; }
    .risultato-intro h3 { font-family: var(--serif); font-size: 1.8rem; font-weight: 300; margin-bottom: 0.8rem; }
    .risultato-intro p { font-size: 0.9rem; line-height: 1.8; color: var(--warm-gray); }
    .demo-frame { background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 50px rgba(0,0,0,0.12); border: 1px solid var(--cream-dark); }
    .demo-bar { background: #f0eeea; padding: 0.7rem 1rem; display: flex; align-items: center; gap: 0.6rem; border-bottom: 1px solid rgba(0,0,0,0.08); }
    .demo-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .demo-dot.red { background: #ff5f57; }
    .demo-dot.yellow { background: #febc2e; }
    .demo-dot.green { background: #28c840; }
    .demo-url { font-size: 0.72rem; color: #8a8a8a; font-family: var(--sans); margin-left: 0.5rem; }

    /* ── Chiara Martini mini-site — BOLD personal brand ── */
    .cm-site { background: #fff; font-family: var(--sans); }

    /* Nav — bold uppercase sans */
    .cm-nav { display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 2.5rem; background: white; border-bottom: 2px solid var(--ink); }
    .cm-logo { font-family: var(--sans); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink); }
    .cm-nav-links { display: flex; gap: 2rem; font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: #8a8078; }
    .cm-nav-cta { font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; background: var(--terra); color: white; padding: 0.5rem 1.4rem; font-weight: 600; }

    /* Hero — dark full-bleed, portrait faded right, big headline left */
    .cm-hero { background: var(--ink); position: relative; overflow: hidden; padding: 3.5rem 2.5rem 3rem; min-height: 340px; display: flex; align-items: flex-end; }
    .cm-hero-bg-img { position: absolute; top: 0; right: 0; width: 44%; height: 100%; object-fit: cover; object-position: top; opacity: 0.28; display: block; }
    .cm-hero-content { position: relative; max-width: 54%; }
    .cm-hero-eyebrow { font-size: 0.6rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--terra); margin-bottom: 1rem; display: block; }
    .cm-hero h2 { font-family: var(--serif); font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 700; line-height: 1.05; color: white; margin-bottom: 1.5rem; }
    .cm-hero-cta { display: inline-block; font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; background: var(--terra); color: white; padding: 0.7rem 1.8rem; font-weight: 600; }

    /* Services — numbered horizontal rows (no cards) */
    .cm-servizi { background: white; padding: 2.5rem; }
    .cm-servizi-label { font-size: 0.6rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--terra); margin-bottom: 1.5rem; display: block; }
    .cm-row { display: grid; grid-template-columns: 64px 1fr 1fr; gap: 1.5rem; padding: 1.5rem 0; border-bottom: 1px solid rgba(0,0,0,0.07); align-items: start; }
    .cm-row:first-of-type { border-top: 1px solid rgba(0,0,0,0.07); }
    .cm-row-num { font-family: var(--serif); font-size: 2.8rem; font-weight: 700; color: var(--terra); opacity: 0.12; line-height: 1; }
    .cm-row-title { font-family: var(--serif); font-size: 1.05rem; color: var(--ink); padding-top: 0.3rem; }
    .cm-row-desc { font-size: 0.78rem; line-height: 1.8; color: #6a6058; }

    /* About — photo left panel, dark text right */
    .cm-about { display: grid; grid-template-columns: 1fr 1fr; }
    .cm-about-img { overflow: hidden; min-height: 280px; }
    .cm-about-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
    .cm-about-text { padding: 2.5rem; background: var(--ink); display: flex; flex-direction: column; justify-content: center; }
    .cm-about-label { font-size: 0.58rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--terra); margin-bottom: 0.8rem; }
    .cm-about-name { font-family: var(--serif); font-size: 1.4rem; font-weight: 400; color: white; font-style: italic; margin-bottom: 0.3rem; }
    .cm-about-title { font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(250,248,245,0.3); margin-bottom: 1.2rem; }
    .cm-about-bio { font-size: 0.78rem; line-height: 1.9; color: rgba(250,248,245,0.5); }

    /* Testimonial — cream, big quotemark, no strip */
    .cm-testi { background: var(--cream); padding: 2.5rem; }
    .cm-testi-mark { font-family: var(--serif); font-size: 5rem; color: var(--terra); opacity: 0.22; line-height: 0.6; margin-bottom: 1rem; display: block; }
    .cm-testi-quote { font-family: var(--serif); font-size: 1.15rem; font-weight: 400; color: var(--ink); font-style: italic; line-height: 1.65; max-width: 540px; margin-bottom: 1rem; }
    .cm-testi-author { font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--warm-gray); }

    /* CTA — split layout dark */
    .cm-cta { background: var(--ink); padding: 2.5rem; display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
    .cm-cta-text h3 { font-family: var(--serif); font-size: 1.3rem; font-weight: 400; color: white; font-style: italic; margin-bottom: 0.3rem; }
    .cm-cta-text p { font-size: 0.78rem; color: rgba(250,248,245,0.4); }
    .cm-cta-btn { flex-shrink: 0; font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; background: var(--terra); color: white; padding: 0.8rem 2rem; white-space: nowrap; display: block; }

    /* Footer */
    .cm-footer { background: #0a0a0a; padding: 1.2rem 2.5rem; display: flex; justify-content: space-between; align-items: center; }
    .cm-footer-name { font-family: var(--serif); font-size: 0.75rem; color: rgba(250,248,245,0.35); font-style: italic; }
    .cm-footer-addr { font-size: 0.6rem; letter-spacing: 0.08em; color: rgba(250,248,245,0.2); }

    /* CTA section */
    .cta-section {
      padding: 5rem 2rem; text-align: center;
      background: var(--dark); margin: 4rem -2rem 0;
    }
    .cta-section .label { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--terra); display: block; margin-bottom: 1rem; }
    .cta-section h2 { font-family: var(--serif); font-size: clamp(2rem,4vw,3rem); font-weight: 300; color: var(--cream); margin-bottom: 1rem; }
    .cta-section p { color: rgba(250,248,245,0.55); font-size: 0.9rem; max-width: 500px; margin: 0 auto 2.5rem; line-height: 1.8; }
    .btn-terra {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--terra); color: white; text-decoration: none;
      font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.9rem 2.2rem; transition: background 0.2s;
    }
    .btn-terra:hover { background: var(--terra-light); }

    /* Divider */
    .section-divider { border: none; border-top: 1px solid rgba(0,0,0,0.07); margin: 0; }

    /* Fade */
    .fade-in { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* Mobile */
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; padding: 4rem 1.5rem 3rem; gap: 2rem; min-height: auto; }
      .main { padding: 0 1.5rem; }
      .insp-card { grid-template-columns: 1fr; }
      .analisi-grid { grid-template-columns: 1fr; }
      .step3 { margin: 0 -1.5rem; padding-left: 1.5rem; padding-right: 1.5rem; }
      .traduzione-grid { grid-template-columns: 1fr; }
      .step4 .demo-frame { margin: 0 -1.5rem; border-radius: 8px; }
      .cm-nav-links { display: none; }
      .cm-hero { padding: 2.5rem 1.5rem; }
      .cm-hero-bg-img { opacity: 0.15; }
      .cm-hero-content { max-width: 100%; }
      .cm-servizi { padding: 2rem 1.5rem; }
      .cm-row { grid-template-columns: 44px 1fr; }
      .cm-row-desc { grid-column: 2; }
      .cm-about { grid-template-columns: 1fr; }
      .cm-about-img { min-height: 220px; }
      .cm-testi { padding: 2rem 1.5rem; }
      .cm-cta { flex-direction: column; gap: 1.5rem; padding: 2rem 1.5rem; }
      .cm-footer { flex-direction: column; gap: 0.4rem; text-align: center; padding: 1rem 1.5rem; }
      .cta-section { margin: 4rem -1.5rem 0; padding: 3.5rem 1.5rem; }
    }
  </style>
</head>
<body>
  <div class="mockup-bar">🎯 Mockup di caso studio — Chiara Martini è un personaggio di fantasia creato per illustrare il processo di lavoro</div>
  <a href="/dev/portfolio" class="back-btn">← Portfolio</a>

  <section class="hero">
    <div class="hero-left">
      <span class="hero-tag">Caso Studio</span>
      <h1>Dalla chiarezza<br />di <em>Marie Forleo</em><br />a Milano</h1>
      <p class="hero-sub">Come si costruisce un sito di personal brand per una coach che vuole autorevolezza senza freddezza.</p>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item"><span class="hero-meta-label">Cliente</span><span class="hero-meta-val">Chiara Martini — Milano</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Settore</span><span class="hero-meta-val">Life & Business Coaching</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Ispirazione</span><span class="hero-meta-val">marieforleo.com</span></div>
      <div class="hero-meta-item"><span class="hero-meta-label">Tempo</span><span class="hero-meta-val">Costruito in 2 giorni</span></div>
    </div>
  </section>

  <div class="main">

    <!-- STEP 1 -->
    <section class="step1">
      <div class="step-label fade-in"><span class="step-num">1</span>Il Riferimento</div>
      <div class="insp-card fade-in">
        <div class="insp-screenshot">
          <img src="/images/portfolio/coach-bg.jpg" alt="Ispirazione — sito di coaching premium" />
          <span class="screenshot-label">marieforleo.com — personal brand coaching</span>
        </div>
        <div class="insp-info">
          <div class="site-tag">Fonte di ispirazione</div>
          <div class="site-name">Marie Forleo</div>
          <div class="site-url">marieforleo.com</div>
          <div class="tags">
            <span class="tag">Personal brand forte</span>
            <span class="tag">Bianco dominante</span>
            <span class="tag">Serif editoriale</span>
            <span class="tag">Accento caldo</span>
            <span class="tag">CTA diretti</span>
          </div>
          <div class="insp-quote">
            <p>"Non voglio sembrare una coach qualunque con foto sorridenti e frasi motivazionali. Voglio che chi arriva sul sito capisca subito che sono seria, che ho metodo, che so quello che faccio."</p>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- STEP 2 -->
    <section class="step2">
      <div class="step-label fade-in"><span class="step-num">2</span>L'Analisi</div>
      <div class="analisi-grid fade-in">
        <div class="analisi-card">
          <span class="analisi-card-label">Palette colori</span>
          <div class="palette">
            <div class="swatch" style="background:#ffffff; border:1px solid #e0dbd4;"></div>
            <div class="swatch" style="background:#1a1a1a;"></div>
            <div class="swatch" style="background:#c96040;"></div>
            <div class="swatch" style="background:#faf8f5;"></div>
          </div>
          <div class="palette-names">Bianco puro · Nero profondo<br />Terracotta · Crema</div>
        </div>
        <div class="analisi-card">
          <span class="analisi-card-label">Tipografia</span>
          <div class="font-sample">Libre Baskerville</div>
          <div class="font-name">Serif editoriale — autorevolezza</div>
          <div style="margin-top:0.8rem; font-family:'Inter',sans-serif; font-size:0.85rem; letter-spacing:0.05em;">INTER CAPS</div>
          <div class="font-name">Sans uppercase — struttura</div>
        </div>
        <div class="analisi-card">
          <span class="analisi-card-label">Elementi chiave</span>
          <ul class="keyword-list">
            <li>Foto della persona in primo piano</li>
            <li>Headline diretta senza retorica</li>
            <li>Servizi chiari con numeri</li>
            <li>Testimonianza reale in evidenza</li>
            <li>CTA singola e decisa</li>
          </ul>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- STEP 3 -->
    <section class="step3">
      <div class="step-label fade-in"><span class="step-num">3</span>La Traduzione</div>
      <p class="fade-in" style="font-size:0.9rem; color:var(--ink-soft); line-height:1.8; max-width:600px; margin-bottom:2rem;">
        Da un brand americano noto a un'identità italiana autentica. Stessa struttura, stesso rigore visivo — ma il linguaggio, i servizi e la voce sono di Chiara.
      </p>
      <div class="traduzione-grid fade-in">
        <div class="trans-col">
          <h3><span>Ispirazione</span>Marie Forleo</h3>
          <ul class="trans-list">
            <li><span class="icon">→</span> Headline in inglese, energica e diretta</li>
            <li><span class="icon">→</span> Colore accento rosso-arancio</li>
            <li><span class="icon">→</span> Foto lifestyle americana</li>
            <li><span class="icon">→</span> Programmi con nomi di brand propri</li>
            <li><span class="icon">→</span> Community e newsletter come asset centrale</li>
          </ul>
        </div>
        <div class="trans-col">
          <h3><span>Risultato</span>Chiara Martini</h3>
          <ul class="trans-list">
            <li><span class="icon">→</span> Headline italiana, concreta, senza slogan vuoti</li>
            <li><span class="icon">→</span> Terracotta più sobrio, scala italiana</li>
            <li><span class="icon">→</span> Ritratto professionale a Milano</li>
            <li><span class="icon">→</span> Percorsi con descrizioni dirette e oneste</li>
