---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Come Raggiungerci — Podere del Sole</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <a href="/portfolio/bed-and-breakfast" class="back-btn" aria-label="Torna al B&amp;B">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    <span>Podere del Sole</span>
  </a>

  <!-- Hero -->
  <section class="hero reveal">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-tag">Raggiungerci</p>
      <h1>Come Raggiungerci</h1>
      <p class="hero-sub">Nel cuore del Chianti, tra Siena e Firenze</p>
    </div>
  </section>

  <div class="divider-wave">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>

  <!-- Map + Address -->
  <section class="section section--light">
    <div class="container">
      <div class="map-address-grid">
        <div class="map-area reveal" style="--delay:.1s">
          <div class="map-box">
            <div class="map-grid-bg"></div>
            <div class="map-pin-wrap">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="#c4956a" stroke="#2d2418" stroke-width="1"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3" fill="#2d2418"/></svg>
            </div>
          </div>
        </div>
        <div class="address-info reveal" style="--delay:.2s">
          <p class="section-tag">Indirizzo</p>
          <h2>Localit&agrave; Podere del Sole 5</h2>
          <p class="address-detail">53011 Castellina in Chianti (SI)<br/>Toscana, Italia</p>
          <div class="address-divider"></div>
          <p class="address-note">Nel cuore del Chianti Classico, il Podere del Sole &egrave; circondato da vigneti e uliveti. L'accesso &egrave; tramite una strada bianca di 800 metri, ben segnalata dalla strada provinciale.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Directions -->
  <div class="divider-wave divider-wave--dark">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,20 C240,70 480,0 720,40 C960,80 1200,10 1440,30 L1440,80 L0,80 Z" fill="#2d2418"/></svg>
  </div>
  <section class="section section--dark">
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag section-tag--light">Indicazioni Stradali</p>
        <h2>Come Arrivare</h2>
      </div>

      <div class="directions-grid">
        <!-- In Auto -->
        <div class="direction-card reveal" style="--delay:.1s">
          <div class="direction-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><rect x="1" y="6" width="22" height="12" rx="4"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><path d="M5 10h14"/></svg>
          </div>
          <h3>In Auto</h3>
          <div class="direction-routes">
            <div class="route">
              <strong>Da Firenze</strong> <span class="route-time">~1 ora</span>
              <p>Superstrada FI-SI (Firenze-Siena), uscita Poggibonsi Nord. Seguire indicazioni per Castellina in Chianti sulla SP101. Dopo 12 km, svoltare a sinistra al cartello "Podere del Sole".</p>
            </div>
            <div class="route">
              <strong>Da Siena</strong> <span class="route-time">~30 min</span>
              <p>Superstrada FI-SI direzione Firenze, uscita Monteriggioni. Seguire SP130 verso Castellina in Chianti. Dopo il centro abitato, proseguire per 2 km sulla SP101.</p>
            </div>
          </div>
        </div>

        <!-- In Treno -->
        <div class="direction-card reveal" style="--delay:.2s">
          <div class="direction-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><rect x="4" y="2" width="16" height="18" rx="3"/><path d="M4 14h16"/><circle cx="8" cy="18" r="1"/><circle cx="16" cy="18" r="1"/><path d="M8 22l-2-2"/><path d="M16 22l2-2"/></svg>
          </div>
          <h3>In Treno</h3>
          <p>Stazione pi&ugrave; vicina: <strong>Poggibonsi - San Gimignano</strong>, sulla linea Empoli-Siena.</p>
          <p>Dalla stazione, 20 minuti in taxi fino al Podere del Sole. Possiamo organizzare il trasferimento per voi su richiesta.</p>
        </div>

        <!-- Dall'Aeroporto -->
        <div class="direction-card reveal" style="--delay:.3s">
          <div class="direction-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><path d="M2 17l10-5 10 5"/><path d="M12 12V2"/><path d="M4.93 13.14L12 8l7.07 5.14"/></svg>
          </div>
          <h3>Dall'Aeroporto</h3>
          <div class="direction-routes">
            <div class="route">
              <strong>Firenze Peretola (FLR)</strong> <span class="route-time">65 km</span>
              <p>L'aeroporto pi&ugrave; comodo. Noleggio auto disponibile in aeroporto. Circa 1 ora di viaggio panoramico attraverso le colline toscane.</p>
            </div>
            <div class="route">
              <strong>Pisa Galilei (PSA)</strong> <span class="route-time">120 km</span>
              <p>Collegato con voli low-cost europei. Circa 1,5 ore in auto via la SGC FI-PI-LI e poi Superstrada FI-SI.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Parcheggio + Contatti -->
  <div class="divider-wave divider-wave--cream-up">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,60 C320,0 640,80 960,30 C1120,10 1320,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>
  <section class="section section--light">
    <div class="container">
      <div class="parking-contact-grid">
        <div class="parking-card reveal" style="--delay:.1s">
          <p class="section-tag">Comodo e Gratuito</p>
          <h2>Parcheggio</h2>
          <p>Disponiamo di un <strong>parcheggio privato gratuito</strong> all'interno della propriet&agrave;, con 10 posti auto a pochi passi dalle camere. Il parcheggio &egrave; su fondo sterrato, ombreggiato da cipressi e ulivi.</p>
          <p>Per chi arriva con un camper, abbiamo uno spazio dedicato con attacco elettrico (su richiesta).</p>
        </div>
        <div class="contact-card reveal" style="--delay:.2s">
          <p class="section-tag">Siamo a Disposizione</p>
          <h2>Contatti</h2>
          <div class="contact-list">
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
              <div>
                <strong>Telefono</strong>
                <p>+39 0577 123 456</p>
              </div>
            </div>
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <strong>Email</strong>
                <p>info@poderedelesole.it</p>
              </div>
            </div>
            <div class="contact-item">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="#c4956a"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <div>
                <strong>WhatsApp</strong>
                <p>+39 0577 123 456</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <h3>Podere del Sole</h3>
        <p>Agriturismo di Charme &mdash; Castellina in Chianti, Toscana</p>
        <p class="footer-copy">&copy; 2026 Podere del Sole S.r.l. Agricola &middot; P.IVA 03456789012</p>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family:'Nunito', sans-serif; color:#3a3028; background:#faf7f2; overflow-x:hidden; line-height:1.7; }
    ::-webkit-scrollbar { width:8px; }
    ::-webkit-scrollbar-track { background:#faf7f2; }
    ::-webkit-scrollbar-thumb { background:#c4956a; border-radius:4px; }

    h1, h2, h3, h4 { font-family:'Cormorant Garamond', serif; font-weight:500; line-height:1.2; }
    h2 { font-size:clamp(1.8rem,4vw,2.8rem); color:#2d2418; margin-bottom:.5em; }
    h3 { font-size:clamp(1.2rem,3vw,1.5rem); color:#2d2418; margin-bottom:.4em; }
    p { margin-bottom:1em; }
    a { text-decoration:none; color:inherit; }

    .container { max-width:1100px; margin:0 auto; padding:0 24px; }
    .section { padding:80px 0; position:relative; }
    .section--light { background:#faf7f2; }
    .section--dark { background:#2d2418; color:#ede6da; }
    .section--dark h2 { color:#ede6da; }
    .section--dark h3 { color:#ede6da; }

    .section-header { text-align:center; max-width:680px; margin:0 auto 60px; }
    .section-tag {
      font-family:'Cormorant Garamond', serif; font-size:.95rem; font-weight:600;
      letter-spacing:3px; text-transform:uppercase; color:#c4956a; margin-bottom:.4em; display:block;
    }
    .section-tag--light { color:#c4956a; }

    .noise-overlay {
      position:absolute; inset:0; pointer-events:none; z-index:0;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
      background-repeat:repeat;
    }
    .section--dark > .container { position:relative; z-index:1; }

    .reveal {
      opacity:0; transform:translateY(30px);
      transition:opacity .7s ease, transform .7s ease;
      transition-delay:var(--delay, 0s);
    }
    .reveal.visible { opacity:1; transform:translateY(0); }

    .back-btn {
      position:fixed; top:24px; left:24px; z-index:100;
      display:flex; align-items:center; gap:8px;
      background:rgba(45,36,24,.85); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
      color:#faf7f2; padding:10px 18px 10px 14px; border-radius:50px;
      font-size:.85rem; font-weight:600; letter-spacing:.5px;
      transition:all .3s ease; box-shadow:0 4px 20px rgba(0,0,0,.15);
    }
    .back-btn:hover { background:rgba(196,149,106,.9); transform:translateX(-3px); }
    .back-btn svg { flex-shrink:0; }

    .divider-wave { margin-top:-1px; line-height:0; position:relative; z-index:2; }
    .divider-wave svg { width:100%; height:auto; display:block; }
    .divider-wave--dark { background:#faf7f2; }
    .divider-wave--cream-up { background:#2d2418; }

    /* Hero */
    .hero {
      position:relative; padding:140px 24px 80px; text-align:center;
      background:linear-gradient(135deg, #2d2418 0%, #3a3028 50%, #2d2418 100%);
      overflow:hidden;
    }
    .hero-overlay {
      position:absolute; inset:0;
      background:radial-gradient(ellipse at center, rgba(196,149,106,.08) 0%, transparent 70%);
    }
    .hero-content { position:relative; z-index:2; color:#faf7f2; }
    .hero-tag {
      font-family:'Cormorant Garamond', serif; font-size:1rem; font-weight:500;
      letter-spacing:5px; text-transform:uppercase; color:#c4956a; margin-bottom:12px;
    }
    .hero h1 {
      font-size:clamp(2.5rem,7vw,4.5rem); font-weight:300;
      text-shadow:0 2px 40px rgba(0,0,0,.3); margin-bottom:16px; letter-spacing:2px;
    }
    .hero-sub { font-size:1.1rem; font-weight:300; opacity:.7; margin-bottom:0; }

    /* Map */
    .map-address-grid { display:grid; grid-template-columns:1.2fr 1fr; gap:48px; align-items:start; }
    .map-area { width:100%; }
    .map-box {
      position:relative; width:100%; aspect-ratio:16/10; border-radius:12px; overflow:hidden;
      background:linear-gradient(135deg, #e8e0d4, #d4c8b8);
    }
    .map-grid-bg {
      position:absolute; inset:0;
      background-image:
        linear-gradient(rgba(196,149,106,.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(196,149,106,.08) 1px, transparent 1px);
      background-size:30px 30px;
    }
    .map-pin-wrap {
      position:absolute; top:50%; left:50%; transform:translate(-50%, -70%);
      animation:pinBounce 2s ease-in-out infinite;
    }
    @keyframes pinBounce {
      0%,100% { transform:translate(-50%, -70%); }
      50% { transform:translate(-50%, -78%); }
    }
    .address-info p { color:#6b5e50; }
    .address-detail { font-size:1.1rem; font-weight:600; color:#2d2418; }
    .address-divider { width:60px; height:2px; background:#c4956a; margin:20px 0; }
    .address-note { font-size:.95rem; color:#6b5e50; }

    /* Directions */
    .directions-grid { display:grid; grid-template-columns:1fr; gap:32px; }
    .direction-card {
      background:rgba(250,247,242,.06); border:1px solid rgba(196,149,106,.15);
      border-radius:12px; padding:36px; transition:border-color .3s;
    }
    .direction-card:hover { border-color:rgba(196,149,106,.35); }
    .direction-icon { margin-bottom:16px; }
    .direction-card h3 { color:#c4956a; }
    .direction-card p { font-size:.9rem; color:#d4c8b8; }
    .direction-routes { margin-top:16px; }
    .route { margin-bottom:20px; padding-bottom:16px; border-bottom:1px solid rgba(196,149,106,.1); }
    .route:last-child { margin-bottom:0; border-bottom:none; padding-bottom:0; }
    .route strong { color:#ede6da; font-size:.95rem; }
    .route-time {
      display:inline-block; background:rgba(196,149,106,.15); color:#c4956a;
      padding:2px 10px; border-radius:20px; font-size:.75rem; font-weight:600;
      margin-left:8px;
    }
    .route p { margin-top:6px; margin-bottom:0; }

    /* Parking + Contact */
    .parking-contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:48px; }
    .parking-card p, .contact-card p { color:#6b5e50; }
    .parking-card strong { color:#2d2418; }

    .contact-list { display:flex; flex-direction:column; gap:20px; margin-top:12px; }
    .contact-item {
      display:flex; align-items:flex-start; gap:14px;
    }
    .contact-item svg { flex-shrink:0; margin-top:4px; }
    .contact-item strong { display:block; font-size:.85rem; color:#2d2418; margin-bottom:2px; }
    .contact-item p { font-size:.9rem; color:#6b5e50; margin-bottom:0; }

    /* Footer */
    .site-footer { background:#1e1810; padding:48px 0; }
    .footer-inner { text-align:center; }
    .footer-inner h3 {
      font-family:'Cormorant Garamond', serif; font-size:1.5rem; color:#c4956a; margin-bottom:8px;
    }
    .footer-inner p { font-size:.85rem; color:rgba(237,230,218,.5); margin-bottom:4px; }
    .footer-copy { font-size:.75rem !important; color:rgba(237,230,218,.3) !important; margin-top:12px !important; }

    @media (max-width: 768px) {
      .map-address-grid { grid-template-columns:1fr; }
      .parking-contact-grid { grid-template-columns:1fr; }
      .back-btn { top:12px; left:12px; bottom:auto; font-size:.8rem; padding:8px 14px 8px 10px; }
    }
  </style>
</body>
</html>
