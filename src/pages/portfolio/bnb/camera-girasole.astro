---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Camera Girasole — Podere del Sole</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <a href="/portfolio/bed-and-breakfast" class="back-btn" aria-label="Torna al B&amp;B">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    <span>Podere del Sole</span>
  </a>

  <!-- Hero Image Area -->
  <section class="hero-img">
    <div class="hero-gradient" style="background:linear-gradient(135deg, #c4956a 0%, #8b6b4a 30%, #6b5040 60%, #c4956a 100%);"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content reveal">
      <p class="hero-tag">Camera Matrimoniale</p>
      <h1>Camera Girasole</h1>
      <div class="hero-meta">
        <span class="hero-price">&euro;120<small>/notte</small></span>
        <span class="hero-sep">&middot;</span>
        <span>Max 2 ospiti</span>
      </div>
    </div>
  </section>

  <div class="divider-wave">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>

  <!-- Room Details -->
  <section class="section section--light">
    <div class="container">
      <div class="room-detail-grid">
        <div class="room-info reveal" style="--delay:.1s">
          <p class="section-tag">Vista sulla Vallata</p>
          <h2>Il tuo angolo di Toscana</h2>
          <p>La Camera Girasole &egrave; la nostra camera matrimoniale pi&ugrave; amata, con una vista mozzafiato sulla vallata del Chianti che si estende fino all'orizzonte. Al risveglio, la luce dorata del mattino inonda la stanza attraverso le grandi finestre, regalandovi ogni giorno un'alba indimenticabile.</p>
          <p>L'arredamento combina il fascino rustico toscano con il comfort moderno: letto matrimoniale con materasso ortopedico, biancheria in lino naturale, bagno privato con doccia ampia e prodotti da bagno biologici. Ogni dettaglio &egrave; pensato per il vostro relax.</p>

          <h3>Servizi inclusi</h3>
          <ul class="amenities-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              Wi-Fi gratuito ad alta velocit&agrave;
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              Aria condizionata
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              Asciugamani e biancheria
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              Kit cortesia biologico
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              Phon
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              Cassaforte in camera
            </li>
          </ul>
        </div>
        <div class="room-gallery reveal" style="--delay:.25s">
          <div class="gallery-grid">
            <div class="gallery-item" style="background:linear-gradient(135deg,#c4956a,#8b6b4a);"></div>
            <div class="gallery-item" style="background:linear-gradient(135deg,#8b6b4a,#6b5040);"></div>
            <div class="gallery-item" style="background:linear-gradient(135deg,#a0845e,#c4956a);"></div>
            <div class="gallery-item" style="background:linear-gradient(135deg,#6b5040,#8b6b4a);"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- La Colazione -->
  <div class="divider-wave divider-wave--dark">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,20 C240,70 480,0 720,40 C960,80 1200,10 1440,30 L1440,80 L0,80 Z" fill="#2d2418"/></svg>
  </div>
  <section class="section section--dark">
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag section-tag--light">Ogni Mattina</p>
        <h2>La Colazione</h2>
      </div>
      <div class="breakfast-grid">
        <div class="breakfast-item reveal" style="--delay:.1s">
          <div class="breakfast-icon">&#127874;</div>
          <h3>Prodotti del podere</h3>
          <p>Frutta fresca di stagione, miele del nostro apiario, olio extravergine d'oliva appena spremuto.</p>
        </div>
        <div class="breakfast-item reveal" style="--delay:.2s">
          <div class="breakfast-icon">&#127863;</div>
          <h3>Marmellate fatte in casa</h3>
          <p>Fichi, albicocche, arance amare e frutti di bosco. Preparate da Maria con la frutta dell'orto.</p>
        </div>
        <div class="breakfast-item reveal" style="--delay:.3s">
          <div class="breakfast-icon">&#127838;</div>
          <h3>Pane fresco</h3>
          <p>Pane toscano cotto nel forno a legna, focaccia al rosmarino, crostate e dolci del giorno.</p>
        </div>
        <div class="breakfast-item reveal" style="--delay:.4s">
          <div class="breakfast-icon">&#129370;</div>
          <h3>Uova del pollaio</h3>
          <p>Le nostre galline razzolano libere. Uova alla coque, strapazzate o in frittata con le erbe dell'orto.</p>
        </div>
        <div class="breakfast-item reveal" style="--delay:.5s">
          <div class="breakfast-icon">&#9749;</div>
          <h3>Caff&egrave; e cappuccino</h3>
          <p>Espresso italiano, cappuccino con latte fresco, t&egrave; e tisane. Succhi di frutta naturali.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Dintorni -->
  <div class="divider-wave divider-wave--cream-up">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,60 C320,0 640,80 960,30 C1120,10 1320,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>
  <section class="section section--light">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag">Esplorare il Chianti</p>
        <h2>Cosa c'&egrave; nei Dintorni</h2>
      </div>
      <div class="distances-grid">
        <div class="distance-card reveal" style="--delay:.1s">
          <span class="distance-km">2 km</span>
          <h3>Castellina in Chianti</h3>
          <p>Borgo medievale con botteghe artigiane, ristoranti tipici e la famosa Via delle Volte sotterranea.</p>
        </div>
        <div class="distance-card reveal" style="--delay:.2s">
          <span class="distance-km">25 km</span>
          <h3>Siena</h3>
          <p>Piazza del Campo, il Duomo, il Palio, i musei. Una delle citt&agrave; pi&ugrave; belle d'Italia, a soli 30 minuti.</p>
        </div>
        <div class="distance-card reveal" style="--delay:.3s">
          <span class="distance-km">65 km</span>
          <h3>Firenze</h3>
          <p>La culla del Rinascimento: gli Uffizi, il David di Michelangelo, Ponte Vecchio. Un'ora di viaggio panoramico.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="divider-wave divider-wave--dark">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,50 C200,10 400,70 600,30 C800,-10 1100,60 1440,20 L1440,80 L0,80 Z" fill="#2d2418"/></svg>
  </div>
  <section class="section section--dark section--cta">
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container" style="text-align:center;position:relative;z-index:1;">
      <div class="reveal">
        <h2>Prenota la Camera Girasole</h2>
        <p style="color:#d4c8b8;max-width:500px;margin:0 auto 32px;">Contattaci per verificare la disponibilit&agrave; e prenotare il tuo soggiorno nel cuore del Chianti.</p>
        <div class="cta-buttons">
          <a href="/portfolio/bed-and-breakfast#prenota" class="cta-btn">Prenota Questa Camera</a>
          <a href="/portfolio/bed-and-breakfast#camere" class="cta-link">Vedi le altre camere &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <h3>Podere del Sole</h3>
        <p>Agriturismo di Charme &mdash; Castellina in Chianti, Toscana</p>
        <p class="footer-copy">&copy; 2026 Podere del Sole S.r.l. Agricola &middot; P.IVA 03456789012</p>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

  <style>
    *, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body { font-family:'Nunito', sans-serif; color:#3a3028; background:#faf7f2; overflow-x:hidden; line-height:1.7; }
    ::-webkit-scrollbar { width:8px; }
    ::-webkit-scrollbar-track { background:#faf7f2; }
    ::-webkit-scrollbar-thumb { background:#c4956a; border-radius:4px; }

    h1, h2, h3, h4 { font-family:'Cormorant Garamond', serif; font-weight:500; line-height:1.2; }
    h2 { font-size:clamp(2rem,5vw,3.2rem); color:#2d2418; margin-bottom:.5em; }
    h3 { font-size:clamp(1.3rem,3vw,1.6rem); color:#2d2418; margin-bottom:.4em; }
    p { margin-bottom:1em; }
    a { text-decoration:none; color:inherit; }

    .container { max-width:1100px; margin:0 auto; padding:0 24px; }
    .section { padding:100px 0; position:relative; }
    .section--light { background:#faf7f2; }
    .section--dark { background:#2d2418; color:#ede6da; }
    .section--dark h2 { color:#ede6da; }
    .section--dark h3 { color:#ede6da; }

    .section-header { text-align:center; max-width:680px; margin:0 auto 60px; }
    .section-tag {
      font-family:'Cormorant Garamond', serif; font-size:.95rem; font-weight:600;
      letter-spacing:3px; text-transform:uppercase; color:#c4956a; margin-bottom:.4em; display:block;
    }
    .section-tag--light { color:#c4956a; }

    .noise-overlay {
      position:absolute; inset:0; pointer-events:none; z-index:0;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
      background-repeat:repeat;
    }
    .section--dark > .container { position:relative; z-index:1; }

    .reveal {
      opacity:0; transform:translateY(30px);
      transition:opacity .7s ease, transform .7s ease;
      transition-delay:var(--delay, 0s);
    }
    .reveal.visible { opacity:1; transform:translateY(0); }

    /* Back button */
    .back-btn {
      position:fixed; top:24px; left:24px; z-index:100;
      display:flex; align-items:center; gap:8px;
      background:rgba(45,36,24,.85); backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
      color:#faf7f2; padding:10px 18px 10px 14px; border-radius:50px;
      font-size:.85rem; font-weight:600; letter-spacing:.5px;
      transition:all .3s ease; box-shadow:0 4px 20px rgba(0,0,0,.15);
    }
    .back-btn:hover { background:rgba(196,149,106,.9); transform:translateX(-3px); }
    .back-btn svg { flex-shrink:0; }

    /* Dividers */
    .divider-wave { margin-top:-1px; line-height:0; position:relative; z-index:2; }
    .divider-wave svg { width:100%; height:auto; display:block; }
    .divider-wave--dark { background:#faf7f2; }
    .divider-wave--cream-up { background:#2d2418; }

    /* Hero */
    .hero-img {
      position:relative; height:60vh; min-height:400px;
      display:flex; align-items:center; justify-content:center;
      overflow:hidden;
    }
    .hero-gradient { position:absolute; inset:0; }
    .hero-overlay {
      position:absolute; inset:0;
      background:linear-gradient(180deg, rgba(45,36,24,.3) 0%, rgba(45,36,24,.6) 100%);
    }
    .hero-content { position:relative; z-index:2; text-align:center; color:#faf7f2; padding:0 24px; }
    .hero-tag {
      font-family:'Cormorant Garamond', serif; font-size:1rem; font-weight:500;
      letter-spacing:5px; text-transform:uppercase; color:#c4956a; margin-bottom:12px;
    }
    .hero-content h1 {
      font-size:clamp(3rem,8vw,5rem); font-weight:300;
      text-shadow:0 2px 40px rgba(0,0,0,.3); margin-bottom:20px; letter-spacing:2px;
    }
    .hero-meta {
      display:flex; align-items:center; justify-content:center; gap:16px;
      font-size:1.1rem; color:rgba(250,247,242,.8);
    }
    .hero-price {
      font-family:'Cormorant Garamond', serif; font-size:1.6rem; font-weight:600; color:#c4956a;
    }
    .hero-price small { font-size:0.7em; font-weight:400; opacity:0.7; }
    .hero-sep { opacity:0.4; }

    /* Room detail */
    .room-detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:start; }
    .room-info p { color:#6b5e50; }
    .room-info h3 { margin-top:32px; }

    .amenities-list { list-style:none; display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:12px; }
    .amenities-list li {
      display:flex; align-items:center; gap:8px;
      font-size:.9rem; color:#5a4d40;
    }

    .gallery-grid {
      display:grid; grid-template-columns:1fr 1fr; gap:12px;
    }
    .gallery-item {
      aspect-ratio:1; border-radius:8px;
      transition:transform .3s ease;
    }
    .gallery-item:hover { transform:scale(1.03); }

    /* Breakfast */
    .breakfast-grid {
      display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:28px;
    }
    .breakfast-item { text-align:center; }
    .breakfast-icon { font-size:2.5rem; margin-bottom:12px; }
    .breakfast-item h3 { font-size:1.1rem; }
    .breakfast-item p { font-size:.9rem; color:#d4c8b8; }

    /* Distances */
    .distances-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:28px; }
    .distance-card {
      background:#fff; border-radius:12px; padding:32px 24px; text-align:center;
      box-shadow:0 4px 20px rgba(45,36,24,.06);
      transition:transform .3s ease, box-shadow .3s ease;
    }
    .distance-card:hover { transform:translateY(-6px); box-shadow:0 12px 40px rgba(45,36,24,.1); }
    .distance-km {
      display:block; font-family:'Cormorant Garamond', serif;
      font-size:2.2rem; font-weight:600; color:#c4956a; margin-bottom:8px;
    }
    .distance-card p { font-size:.9rem; color:#6b5e50; margin-bottom:0; }

    /* CTA */
    .section--cta { padding:80px 0; }
    .cta-buttons { display:flex; flex-direction:column; align-items:center; gap:16px; }
    .cta-btn {
      display:inline-block; padding:14px 40px;
      border:1.5px solid #c4956a; color:#faf7f2;
      font-family:'Cormorant Garamond', serif; font-size:1.1rem; font-weight:500;
      letter-spacing:2px; text-transform:uppercase;
      transition:all .4s ease; border-radius:2px;
    }
    .cta-btn:hover { background:#c4956a; color:#2d2418; box-shadow:0 4px 25px rgba(196,149,106,.35); }
    .cta-link {
      font-size:.9rem; color:#c4956a; transition:opacity .3s;
    }
    .cta-link:hover { opacity:.7; }

    /* Footer */
    .site-footer { background:#1e1810; padding:48px 0; }
    .footer-inner { text-align:center; }
    .footer-inner h3 {
      font-family:'Cormorant Garamond', serif; font-size:1.5rem; color:#c4956a; margin-bottom:8px;
    }
    .footer-inner p { font-size:.85rem; color:rgba(237,230,218,.5); margin-bottom:4px; }
    .footer-copy { font-size:.75rem !important; color:rgba(237,230,218,.3) !important; margin-top:12px !important; }

    @media (max-width: 768px) {
      .room-detail-grid { grid-template-columns:1fr; }
      .amenities-list { grid-template-columns:1fr; }
      .distances-grid { grid-template-columns:1fr; }
      .hero-img { height:50vh; }
      .back-btn { top:12px; left:12px; bottom:auto; font-size:.8rem; padding:8px 14px 8px 10px; }
    }
  </style>
</body>
</html>
