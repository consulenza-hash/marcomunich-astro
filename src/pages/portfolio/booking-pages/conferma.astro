---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Prenotazione Confermata — Studio Rinascita</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Noise overlay -->
  <div class="noise"></div>

  <!-- Organic blob shapes -->
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <!-- Back button -->
  <a href="/portfolio/booking" class="back-btn">
    <span class="back-arrow">&larr;</span> Torna a Studio Rinascita
  </a>

  <!-- Main Content -->
  <main class="main">
    <div class="confirmation-card fade-in">
      <!-- Checkmark -->
      <div class="checkmark-wrap">
        <div class="checkmark-circle">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
      </div>

      <h1 class="confirm-title">Prenotazione Confermata!</h1>
      <p class="confirm-sub">Ti abbiamo inviato un'email di conferma con tutti i dettagli.</p>

      <!-- Booking Summary -->
      <div class="summary">
        <div class="summary-row">
          <div class="summary-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <div>
            <span class="summary-label">Servizio</span>
            <strong>Sessione Individuale</strong>
          </div>
        </div>
        <div class="summary-row">
          <div class="summary-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <span class="summary-label">Durata</span>
            <strong>60 minuti</strong>
          </div>
        </div>
        <div class="summary-row">
          <div class="summary-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <span class="summary-label">Professionista</span>
            <strong>Dott.ssa Elena Marchetti</strong>
          </div>
        </div>
        <div class="summary-row highlight">
          <div class="summary-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div>
            <span class="summary-label">Data e ora</span>
            <strong>Mercoled&igrave; 26 Marzo 2026, ore 10:00</strong>
          </div>
        </div>
        <div class="summary-row">
          <div class="summary-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <span class="summary-label">Luogo</span>
            <strong>Via Roma 18, Vicenza (VI)</strong>
            <span class="summary-note">Studio al primo piano, citofono "Marchetti"</span>
          </div>
        </div>
      </div>

      <!-- Calendar Button -->
      <button class="btn btn-primary btn-calendar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Aggiungi al Calendario
      </button>

      <!-- Info Sections -->
      <div class="info-sections">
        <div class="info-card fade-in">
          <div class="info-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <h3>Cosa portare</h3>
          <p>Niente di particolare, solo te stessa/o. Lo studio &egrave; dotato di tutto il necessario per il tuo comfort.</p>
        </div>

        <div class="info-card fade-in">
          <div class="info-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3>Prima della sessione</h3>
          <p>Ti invieremo un breve questionario via email 48 ore prima dell'appuntamento. Compilarlo ci aiuter&agrave; a personalizzare l'incontro.</p>
        </div>

        <div class="info-card fade-in">
          <div class="info-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          </div>
          <h3>Cancellazione</h3>
          <p>Puoi cancellare gratuitamente fino a 24 ore prima dell'appuntamento. Oltre tale termine verr&agrave; addebitato il 50% del costo della sessione.</p>
        </div>
      </div>

      <!-- Contact -->
      <div class="contact-box fade-in">
        <p>Per qualsiasi dubbio, scrivici a <a href="mailto:studio@studiorinascita.it">studio@studiorinascita.it</a> o chiama <a href="tel:0444123456">0444 123 456</a></p>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="footer fade-in">
    <div class="footer-inner">
      <h3 class="footer-brand">Studio Rinascita</h3>
      <p class="footer-sub">Dott.ssa Elena Marchetti — Counselor Professionista CNCP</p>
      <div class="footer-copy">&copy; 2026 Studio Rinascita di Elena Marchetti &middot; P.IVA 02345678901. Tutti i diritti riservati.</div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const delay = el.dataset.delay || 0;
          setTimeout(() => el.classList.add('visible'), Number(delay));
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach((el, i) => {
      el.dataset.delay = (i % 6) * 120;
      observer.observe(el);
    });
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: linear-gradient(180deg, #f0fdf4 0%, #ffffff 40%, #f0fdf4 100%);
      color: #1a1a1a; line-height: 1.7; overflow-x: hidden;
    }

    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f0fdf4; }
    ::-webkit-scrollbar-thumb { background: #059669; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #047857; }

    .noise {
      position: fixed; inset: 0; pointer-events: none; z-index: 9999; opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 256px;
    }

    .blob {
      position: fixed; border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
      pointer-events: none; z-index: -1; opacity: 0.08; background: #059669;
    }
    .blob-1 { width: 500px; height: 500px; top: -100px; right: -150px; animation: blobMorph1 20s ease-in-out infinite; }
    .blob-2 { width: 350px; height: 350px; bottom: 10%; left: -100px; background: #10b981; animation: blobMorph2 25s ease-in-out infinite; }
    .blob-3 { width: 200px; height: 200px; top: 50%; right: 5%; background: #34d399; animation: blobMorph1 18s ease-in-out infinite reverse; }
    @keyframes blobMorph1 {
      0%, 100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: translate(0,0) rotate(0deg); }
      33% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; transform: translate(20px,-20px) rotate(5deg); }
      66% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; transform: translate(-15px,15px) rotate(-3deg); }
    }
    @keyframes blobMorph2 {
      0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; transform: translate(0,0); }
      50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; transform: translate(30px,-25px); }
    }

    .fade-in {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* Back button */
    .back-btn {
      position: fixed; top: 20px; left: 20px; z-index: 1000;
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(5,150,105,0.15); border-radius: 50px;
      color: #1a1a1a; text-decoration: none;
      font-size: 0.85rem; font-weight: 600; transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }
    .back-btn:hover {
      background: #059669; color: #fff; border-color: #059669;
      transform: translateX(-4px);
      box-shadow: 0 4px 25px rgba(5,150,105,0.25);
    }
    .back-arrow { font-size: 1.1rem; transition: transform 0.3s; }
    .back-btn:hover .back-arrow { transform: translateX(-3px); }

    /* Main */
    .main {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      padding: 100px 24px 60px;
    }

    /* Confirmation Card */
    .confirmation-card {
      max-width: 640px; width: 100%;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1.5px solid rgba(5,150,105,0.12);
      border-radius: 24px; padding: 48px 40px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.06);
      text-align: center;
    }

    /* Checkmark */
    .checkmark-wrap { margin-bottom: 24px; }
    .checkmark-circle {
      width: 80px; height: 80px; border-radius: 50%;
      background: linear-gradient(135deg, #059669, #34d399);
      display: inline-flex; align-items: center; justify-content: center;
      animation: checkPop 0.6s cubic-bezier(0.16,1,0.3,1) 0.3s both;
      box-shadow: 0 8px 30px rgba(5,150,105,0.3);
    }
    @keyframes checkPop {
      0% { transform: scale(0); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }

    .confirm-title {
      font-family: 'Nunito', sans-serif;
      font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800;
      background: linear-gradient(135deg, #065f46, #059669);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 8px;
    }
    .confirm-sub { color: #666; font-size: 0.95rem; margin-bottom: 36px; }

    /* Summary */
    .summary {
      text-align: left; margin-bottom: 32px;
      border: 1px solid rgba(5,150,105,0.1); border-radius: 16px;
      overflow: hidden;
    }
    .summary-row {
      display: flex; align-items: flex-start; gap: 16px;
      padding: 16px 20px;
      border-bottom: 1px solid rgba(5,150,105,0.06);
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-row.highlight { background: rgba(5,150,105,0.04); }
    .summary-icon {
      width: 40px; height: 40px; border-radius: 10px;
      background: rgba(5,150,105,0.08); color: #059669;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .summary-label { display: block; font-size: 0.78rem; color: #888; margin-bottom: 2px; text-transform: uppercase; letter-spacing: 0.06em; }
    .summary-row strong { font-size: 0.95rem; color: #1a1a1a; }
    .summary-note { display: block; font-size: 0.82rem; color: #888; margin-top: 2px; }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px;
      border-radius: 50px; font-size: 0.9rem; font-weight: 700;
      text-decoration: none; transition: all 0.3s ease; border: 2px solid transparent;
      cursor: pointer; font-family: inherit;
    }
    .btn-primary {
      background: #059669; color: #fff; border-color: #059669;
    }
    .btn-primary:hover {
      background: #047857; transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(5,150,105,0.3);
    }
    .btn-calendar { margin-bottom: 36px; }

    /* Info Sections */
    .info-sections {
      display: grid; grid-template-columns: 1fr; gap: 16px;
      text-align: left; margin-bottom: 32px;
    }
    .info-card {
      display: flex; gap: 16px; align-items: flex-start;
      padding: 20px; border-radius: 14px;
      background: rgba(5,150,105,0.03);
      border: 1px solid rgba(5,150,105,0.08);
    }
    .info-icon {
      width: 44px; height: 44px; border-radius: 12px;
      background: rgba(5,150,105,0.08);
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .info-card h3 {
      font-family: 'Nunito', sans-serif; font-size: 0.95rem; font-weight: 700;
      margin-bottom: 4px; color: #065f46;
    }
    .info-card p { font-size: 0.88rem; color: #555; line-height: 1.6; }

    /* Contact box */
    .contact-box {
      padding: 20px; border-radius: 14px;
      background: linear-gradient(135deg, #f0fdf4, #fff);
      border: 1px solid rgba(5,150,105,0.12);
    }
    .contact-box p { font-size: 0.9rem; color: #555; }
    .contact-box a { color: #059669; font-weight: 600; text-decoration: none; }
    .contact-box a:hover { text-decoration: underline; }

    /* Footer */
    .footer { text-align: center; padding: 40px 24px; }
    .footer-inner { max-width: 600px; margin: 0 auto; }
    .footer-brand {
      font-family: 'Nunito', sans-serif; font-size: 1.2rem; font-weight: 800;
      background: linear-gradient(135deg, #065f46, #059669);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 4px;
    }
    .footer-sub { font-size: 0.82rem; color: #888; margin-bottom: 16px; }
    .footer-copy { font-size: 0.75rem; color: #aaa; }

    /* Responsive */
    @media (max-width: 768px) {
      .confirmation-card { padding: 36px 24px; }
      .back-btn { top: 12px; left: 12px; padding: 8px 14px; font-size: 0.78rem; }
      .main { padding: 80px 16px 40px; }
    }
    @media (max-width: 480px) {
      .confirm-title { font-size: 1.4rem; }
      .summary-row { padding: 14px 16px; }
    }
  </style>
</body>
</html>
