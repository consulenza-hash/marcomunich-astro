---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nome Cognome — Portfolio Creativo</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap');

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Space Grotesk', sans-serif;
      background: #000;
      color: #fff;
      line-height: 1.5;
      overflow-x: hidden;
    }

    .back-btn {
      position: fixed;
      top: 20px;
      left: 20px;
      z-index: 1000;
      background: #fff;
      color: #000;
      text-decoration: none;
      padding: 10px 18px;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 600;
      box-shadow: 0 4px 15px rgba(255,255,255,0.15);
      transition: transform 0.2s;
    }
    .back-btn:hover { transform: translateY(-2px); }

    /* NAVBAR */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 24px 60px;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent);
    }
    .nav-name {
      font-size: 1.2rem;
      font-weight: 600;
      letter-spacing: -0.5px;
    }
    .nav-links { display: flex; gap: 32px; list-style: none; }
    .nav-links a {
      text-decoration: none;
      color: rgba(255,255,255,0.6);
      font-size: 0.88rem;
      font-weight: 400;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #fff; }

    /* HERO */
    .hero {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 40px;
      position: relative;
    }
    .hero h1 {
      font-size: clamp(2.5rem, 7vw, 5.5rem);
      font-weight: 300;
      letter-spacing: -2px;
      line-height: 1.1;
      animation: fadeUp 1.2s ease-out;
    }
    .hero h1 span {
      display: inline-block;
      opacity: 0;
      animation: fadeUp 1s ease-out forwards;
    }
    .hero h1 span:nth-child(1) { animation-delay: 0.2s; }
    .hero h1 span:nth-child(2) { animation-delay: 0.5s; }
    .hero h1 span:nth-child(3) { animation-delay: 0.8s; }
    .hero-scroll {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(255,255,255,0.3);
      font-size: 0.75rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      animation: pulse 2s infinite;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 0.7; }
    }

    /* GALLERY */
    .gallery {
      padding: 40px 60px 100px;
    }
    .gallery-label {
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 40px;
    }
    .masonry {
      columns: 3;
      column-gap: 20px;
    }
    .masonry-item {
      break-inside: avoid;
      margin-bottom: 20px;
      border-radius: 8px;
      overflow: hidden;
      position: relative;
      cursor: pointer;
    }
    .masonry-item .placeholder {
      width: 100%;
      display: block;
    }
    .m1 .placeholder { height: 350px; background: #e8b4b8; }
    .m2 .placeholder { height: 240px; background: #b4d4e8; }
    .m3 .placeholder { height: 300px; background: #d4e8b4; }
    .m4 .placeholder { height: 200px; background: #e8d4b4; }
    .m5 .placeholder { height: 280px; background: #b4e8d4; }
    .m6 .placeholder { height: 320px; background: #d4b4e8; }
    .m7 .placeholder { height: 220px; background: #e8e4b4; }
    .m8 .placeholder { height: 260px; background: #b4b8e8; }

    .masonry-overlay {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .masonry-item:hover .masonry-overlay { opacity: 1; }
    .masonry-overlay span {
      font-size: 1.1rem;
      font-weight: 500;
      letter-spacing: -0.5px;
    }

    /* ABOUT */
    .about {
      padding: 100px 60px;
      display: grid;
      grid-template-columns: 400px 1fr;
      gap: 60px;
      align-items: center;
      max-width: 1100px;
      margin: 0 auto;
    }
    .about-photo {
      width: 100%;
      height: 500px;
      background: linear-gradient(135deg, #333 0%, #222 100%);
      border-radius: 12px;
    }
    .about-text h2 {
      font-size: 2.5rem;
      font-weight: 300;
      letter-spacing: -1px;
      margin-bottom: 24px;
    }
    .about-text p {
      color: rgba(255,255,255,0.6);
      font-size: 1rem;
      line-height: 1.8;
      margin-bottom: 16px;
    }

    /* CLIENTS */
    .clients {
      padding: 60px;
      border-top: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .clients-label {
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      text-align: center;
      margin-bottom: 40px;
    }
    .clients-row {
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
      align-items: center;
    }
    .client-logo {
      width: 120px;
      height: 44px;
      background: rgba(255,255,255,0.06);
      border-radius: 6px;
      transition: background 0.3s;
    }
    .client-logo:hover { background: rgba(255,255,255,0.12); }

    /* CONTACT */
    .contact-section {
      padding: 120px 60px;
      text-align: center;
    }
    .contact-label {
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: rgba(255,255,255,0.3);
      margin-bottom: 20px;
    }
    .contact-email {
      font-size: clamp(1.5rem, 4vw, 3rem);
      font-weight: 300;
      letter-spacing: -1px;
      color: #fff;
      text-decoration: none;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 4px;
      transition: border-color 0.3s;
    }
    .contact-email:hover { border-color: #fff; }

    /* FOOTER */
    footer {
      padding: 30px 60px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid rgba(255,255,255,0.06);
      font-size: 0.78rem;
      color: rgba(255,255,255,0.3);
    }
    .footer-social { display: flex; gap: 20px; }
    .footer-social a {
      color: rgba(255,255,255,0.3);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-social a:hover { color: #fff; }

    @media (max-width: 768px) {
      nav { padding: 20px; }
      .nav-links { display: none; }
      .hero h1 { font-size: 2.2rem; }
      .gallery { padding: 30px 20px 60px; }
      .masonry { columns: 2; column-gap: 12px; }
      .about {
        grid-template-columns: 1fr;
        padding: 60px 20px;
        gap: 30px;
      }
      .about-photo { height: 300px; }
      .clients { padding: 40px 20px; }
      .client-logo { width: 80px; height: 30px; }
      .contact-section { padding: 80px 20px; }
      footer { padding: 20px; flex-direction: column; gap: 10px; }
    }
  </style>
</head>
<body>
  <a href="/portfolio" class="back-btn">&larr; Torna al Portfolio</a>

  <nav>
    <div class="nav-name">Nome Cognome</div>
    <ul class="nav-links">
      <li><a href="#">Info</a></li>
      <li><a href="#">Lavori</a></li>
      <li><a href="#">Contatti</a></li>
    </ul>
  </nav>

  <section class="hero">
    <h1>
      <span>Fotografo /&nbsp;</span>
      <span>Designer /&nbsp;</span>
      <span>Creativo</span>
    </h1>
    <div class="hero-scroll">Scorri</div>
  </section>

  <section class="gallery">
    <div class="gallery-label">Lavori Selezionati</div>
    <div class="masonry">
      <div class="masonry-item m1">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Campagna Estiva 2026</span></div>
      </div>
      <div class="masonry-item m2">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Ritratti Urbani</span></div>
      </div>
      <div class="masonry-item m3">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Brand Identity — Alma</span></div>
      </div>
      <div class="masonry-item m4">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Editoriale Vogue</span></div>
      </div>
      <div class="masonry-item m5">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Architettura Minimalista</span></div>
      </div>
      <div class="masonry-item m6">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Food Photography</span></div>
      </div>
      <div class="masonry-item m7">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Packaging Design</span></div>
      </div>
      <div class="masonry-item m8">
        <div class="placeholder"></div>
        <div class="masonry-overlay"><span>Progetto Personale</span></div>
      </div>
    </div>
  </section>

  <section class="about">
    <div class="about-photo"></div>
    <div class="about-text">
      <h2>Ciao, sono Nome</h2>
      <p>Da oltre dieci anni lavoro nel campo della fotografia e del design visivo. Il mio approccio combina sensibilità estetica e attenzione al dettaglio per raccontare storie attraverso le immagini.</p>
      <p>Ho collaborato con brand nazionali e internazionali, agenzie creative e riviste di settore. Ogni progetto rappresenta una nuova sfida e una nuova occasione per esplorare la bellezza nelle sue forme più autentiche.</p>
      <p>Vivo e lavoro a Milano.</p>
    </div>
  </section>

  <section class="clients">
    <div class="clients-label">Clienti Selezionati</div>
    <div class="clients-row">
      <div class="client-logo"></div>
      <div class="client-logo"></div>
      <div class="client-logo"></div>
      <div class="client-logo"></div>
      <div class="client-logo"></div>
      <div class="client-logo"></div>
    </div>
  </section>

  <section class="contact-section">
    <div class="contact-label">Parliamo del tuo progetto</div>
    <a href="mailto:ciao@iltuosito.it" class="contact-email">ciao@iltuosito.it</a>
  </section>

  <footer>
    <span>&copy; 2026</span>
    <div class="footer-social">
      <a href="#">Instagram</a>
      <a href="#">Behance</a>
      <a href="#">LinkedIn</a>
    </div>
  </footer>
</body>
</html>
