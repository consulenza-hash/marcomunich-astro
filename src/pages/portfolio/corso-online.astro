      .hero-title { font-size: 2.2rem; }
      .hero-buttons { flex-direction: column; align-items: center; }
      .back-btn { font-size: 0.75rem; padding: 8px 14px; }
      .footer-grid { grid-template-columns: 1fr; }
      .cta-glass { padding: 48px 24px; }
      .faq-item summary { font-size: 0.88rem; padding: 14px 18px; }
      .faq-item p { padding: 0 18px 14px; }
    }
  </style>

  <!-- Enroll Modal -->
  <div style="position:fixed;inset:0;background:rgba(0,0,0,0.8);z-index:9998;opacity:0;pointer-events:none;transition:opacity 0.3s" id="coEnrollOverlay" onclick="closeCoEnroll()"></div>
  <div id="coEnrollModal" style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);width:min(420px,90vw);background:#0f0f1a;border:1px solid rgba(139,92,246,0.3);border-radius:20px;padding:40px 32px;z-index:9999;opacity:0;pointer-events:none;transition:all 0.35s cubic-bezier(0.4,0,0.2,1);text-align:center;">
    <div style="font-size:2.5rem;margin-bottom:12px">🎓</div>
    <h3 style="font-size:1.4rem;font-weight:700;color:#fff;margin-bottom:8px">Inizia la tua formazione</h3>
    <p style="font-size:0.88rem;color:rgba(255,255,255,0.5);margin-bottom:24px">Accesso illimitato a tutti i corsi. Cancella quando vuoi.</p>
    <input type="email" id="coEnrollEmail" placeholder="La tua email" style="width:100%;padding:14px 18px;background:#1a1a2e;border:1px solid rgba(139,92,246,0.3);border-radius:10px;color:#fff;font-size:0.9rem;margin-bottom:12px;box-sizing:border-box;">
    <button onclick="submitCoEnroll()" style="width:100%;background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;border:none;padding:16px;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;margin-bottom:12px;">Iscriviti Gratis</button>
    <p style="font-size:0.75rem;color:rgba(255,255,255,0.3);">30 giorni soddisfatti o rimborsati · Nessuna carta richiesta</p>
    <button onclick="closeCoEnroll()" style="background:none;border:none;color:rgba(255,255,255,0.3);cursor:pointer;font-size:0.8rem;margin-top:12px;">No grazie</button>
  </div>
  <div id="co-land-toast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#0f0f1a;border:1px solid rgba(139,92,246,0.4);color:#c4b5fd;padding:13px 26px;border-radius:50px;font-size:0.84rem;z-index:99999;opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);white-space:nowrap;pointer-events:none;"></div>
  <style>#coEnrollModal.open,#coEnrollOverlay.open{opacity:1!important;pointer-events:all!important;transform:translate(-50%,-50%) scale(1)!important}#co-land-toast.show{opacity:1!important;transform:translateX(-50%) translateY(0)!important}</style>
</body>
</html>
