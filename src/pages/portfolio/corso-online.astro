  <script is:inline>
    // Intersection Observer for fade-in
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // Animated counters
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelectorAll('.stat-number').forEach(counter => {
            const target = parseInt(counter.dataset.target);
            const duration = 2000;
            const start = performance.now();
            const animate = (now) => {
              const p = Math.min((now - start) / duration, 1);
              const eased = 1 - Math.pow(1 - p, 3);
              counter.textContent = Math.floor(target * eased).toLocaleString('it-IT');
              if (p < 1) requestAnimationFrame(animate);
              else counter.textContent = target.toLocaleString('it-IT');
            };
            requestAnimationFrame(animate);
          });
          counterObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.stats-bar').forEach(el => counterObserver.observe(el));

    // Progress bar animation
    const progressObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.querySelector('.course-progress-bar').style.width = entry.target.querySelector('.course-progress-bar').style.getPropertyValue('--progress');
          progressObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.course-progress-wrap').forEach(el => progressObserver.observe(el));

    // ===== COURSE CTAs =====
    document.querySelectorAll('.course-cta').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        document.getElementById('coEnrollModal').classList.add('open');
        document.getElementById('coEnrollOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });

    document.querySelectorAll('.btn-primary').forEach(btn => {
      if (btn.closest('.back-btn')) return;
      btn.addEventListener('click', (e) => {
        if (btn.getAttribute('href') === '#corsi' || btn.getAttribute('href') === '#') {
          e.preventDefault();
          document.getElementById('coEnrollModal').classList.add('open');
          document.getElementById('coEnrollOverlay').classList.add('open');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    function closeCoEnroll() {
      document.getElementById('coEnrollModal').classList.remove('open');
      document.getElementById('coEnrollOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }
    function submitCoEnroll() {
      const email = document.getElementById('coEnrollEmail').value;
      if (!email) { showCoLandToast('Inserisci la tua email'); return; }
      closeCoEnroll();
      showCoLandToast('✓ Iscrizione completata! Controlla la tua email.');
    }

    // Demo button
    document.querySelector('.btn-secondary')?.addEventListener('click', (e) => {
      e.preventDefault();
      window.location.href = '/portfolio/corso-online-dashboard';
    });

    // FAQ accordions (detail/summary already work natively)

    let coLandToastTimeout;
    function showCoLandToast(msg) {
      const t = document.getElementById('co-land-toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(coLandToastTimeout);
      coLandToastTimeout = setTimeout(() => t.classList.remove('show'), 3200);
    }
  </script>

