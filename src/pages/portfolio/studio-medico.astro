---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dott.ssa Elena Ferretti — Medicina Generale &amp; Preventiva, Milano</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --teal: #2a7b7c;
      --teal-light: #4a9fa0;
      --teal-pale: #e8f4f4;
      --slate: #4a5568;
      --cream: #f8faf9;
      --white: #ffffff;
      --charcoal: #1a2332;
      --warm-gray: #6b7280;
    }

    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--charcoal); overflow-x: hidden; }

    /* Back */
    .back-btn {
      position: fixed; top: 1rem; left: 1rem; z-index: 1000;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);
      color: var(--charcoal); text-decoration: none;
      padding: 0.5rem 1rem; border-radius: 50px;
      font-size: 0.8rem; font-weight: 500;
      border: 1px solid rgba(0,0,0,0.1);
      display: flex; align-items: center; gap: 0.4rem;
      transition: all 0.2s;
    }
    .back-btn:hover { background: var(--charcoal); color: var(--white); }

    /* Nav */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      padding: 1rem 2rem;
      display: flex; align-items: center; justify-content: space-between;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(42,123,124,0.12);
    }
    .nav-brand { display: flex; flex-direction: column; line-height: 1.2; }
    .nav-brand .doctor-name { font-family: 'Libre Baskerville', serif; font-size: 1rem; font-weight: 700; color: var(--charcoal); }
    .nav-brand .doctor-title { font-size: 0.68rem; color: var(--teal); font-weight: 500; letter-spacing: 0.04em; }
    .nav-links { display: flex; align-items: center; gap: 1.8rem; }
    .nav-links a { text-decoration: none; color: var(--warm-gray); font-size: 0.82rem; font-weight: 400; transition: color 0.2s; }
    .nav-links a:hover { color: var(--teal); }
    .nav-cta { background: var(--teal) !important; color: var(--white) !important; padding: 0.5rem 1.2rem !important; border-radius: 8px; font-weight: 500 !important; }
    .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 4px; }
    .hamburger span { display: block; width: 22px; height: 2px; background: var(--charcoal); transition: all 0.3s; }

    /* Hero */
    .hero {
      min-height: 100vh;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 0;
      padding-top: 64px;
    }
    .hero-content {
      display: flex; flex-direction: column; justify-content: center;
      padding: 5rem 4rem;
      background: var(--white);
    }
    .trust-badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--teal-pale); color: var(--teal);
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.4rem 0.9rem; border-radius: 50px;
      margin-bottom: 1.5rem; width: fit-content;
    }
    .hero h1 { font-family: 'Libre Baskerville', serif; font-size: clamp(2rem, 3.5vw, 3rem); font-weight: 400; line-height: 1.2; color: var(--charcoal); margin-bottom: 0.5rem; }
    .hero h1 strong { color: var(--teal); }
    .hero-subtitle { font-family: 'Libre Baskerville', serif; font-size: 1.05rem; font-style: italic; color: var(--warm-gray); margin-bottom: 1.5rem; }
    .hero-sub { font-size: 0.95rem; line-height: 1.8; color: var(--warm-gray); max-width: 440px; margin-bottom: 2rem; }
    .hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }
    .btn-primary { background: var(--teal); color: var(--white); text-decoration: none; padding: 0.85rem 1.8rem; border-radius: 8px; font-size: 0.88rem; font-weight: 600; transition: background 0.2s; display: inline-block; }
    .btn-primary:hover { background: #1e5f60; }
    .btn-outline { border: 1.5px solid var(--teal); color: var(--teal); text-decoration: none; padding: 0.85rem 1.8rem; border-radius: 8px; font-size: 0.88rem; font-weight: 500; transition: all 0.2s; display: inline-block; }
    .btn-outline:hover { background: var(--teal-pale); }
    .hero-credentials { display: flex; gap: 1.5rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid rgba(0,0,0,0.06); }
    .cred-item { text-align: center; }
    .cred-num { font-family: 'Libre Baskerville', serif; font-size: 1.8rem; font-weight: 700; color: var(--teal); line-height: 1; }
    .cred-label { font-size: 0.7rem; color: var(--warm-gray); margin-top: 0.2rem; }

    .hero-image { position: relative; overflow: hidden; }
    .hero-image img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; }
    .hero-image-overlay { position: absolute; inset: 0; background: linear-gradient(to right, rgba(255,255,255,0.08) 0%, transparent 40%); }

    /* Info bar */
    .info-bar { background: var(--teal); color: var(--white); padding: 1.2rem 4rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .info-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.82rem; }
    .info-icon { font-size: 1rem; }

    /* Section base */
    section { padding: 5rem 4rem; }
    .section-tag { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--teal); margin-bottom: 0.6rem; }
    .section-title { font-family: 'Libre Baskerville', serif; font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 400; line-height: 1.2; color: var(--charcoal); margin-bottom: 0.8rem; }
    .section-intro { font-size: 0.95rem; line-height: 1.8; color: var(--warm-gray); max-width: 560px; }

    /* Services */
    .services-section { background: var(--white); }
    .services-header { margin-bottom: 3rem; }
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .service-card { border: 1px solid rgba(42,123,124,0.15); border-radius: 16px; padding: 2rem; transition: all 0.3s; cursor: default; }
    .service-card:hover { border-color: var(--teal); box-shadow: 0 8px 30px rgba(42,123,124,0.1); transform: translateY(-3px); }
    .service-icon { width: 48px; height: 48px; background: var(--teal-pale); border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; font-size: 1.4rem; }
    .service-card h3 { font-family: 'Libre Baskerville', serif; font-size: 1.05rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.6rem; }
    .service-card p { font-size: 0.83rem; line-height: 1.6; color: var(--warm-gray); margin-bottom: 0.8rem; }
    .service-duration { font-size: 0.73rem; color: var(--teal); font-weight: 600; }

    /* About / Doctor */
    .about-section { background: var(--cream); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
    .doctor-img { border-radius: 20px; overflow: hidden; position: relative; }
    .doctor-img img { width: 100%; display: block; aspect-ratio: 4/5; object-fit: cover; object-position: top; }
    .doctor-strip { position: absolute; bottom: 0; left: 0; right: 0; background: var(--teal); color: var(--white); padding: 1.2rem 1.5rem; }
    .doctor-strip .name { font-family: 'Libre Baskerville', serif; font-size: 1.1rem; }
    .doctor-strip .role { font-size: 0.72rem; opacity: 0.85; margin-top: 0.2rem; }
    .about-content h2 { font-family: 'Libre Baskerville', serif; font-size: 2rem; font-weight: 400; line-height: 1.3; color: var(--charcoal); margin-bottom: 1.2rem; }
    .about-content p { font-size: 0.93rem; line-height: 1.8; color: var(--warm-gray); margin-bottom: 1rem; }
    .education-list { list-style: none; margin: 1.5rem 0; }
    .education-list li { display: flex; gap: 1rem; padding: 0.8rem 0; border-bottom: 1px solid rgba(0,0,0,0.06); font-size: 0.83rem; }
    .edu-year { min-width: 60px; font-weight: 600; color: var(--teal); }
    .edu-text { color: var(--warm-gray); }

    /* How it works */
    .how-section { background: var(--teal-pale); }
    .how-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 3rem; }
    .how-step { text-align: center; }
    .step-num { width: 56px; height: 56px; border-radius: 50%; background: var(--teal); color: var(--white); display: flex; align-items: center; justify-content: center; font-family: 'Libre Baskerville', serif; font-size: 1.4rem; font-weight: 700; margin: 0 auto 1rem; }
    .how-step h3 { font-size: 0.95rem; font-weight: 600; color: var(--charcoal); margin-bottom: 0.5rem; }
    .how-step p { font-size: 0.8rem; line-height: 1.6; color: var(--warm-gray); }

    /* CTA */
    .cta-section { background: var(--charcoal); color: var(--white); text-align: center; padding: 5rem 4rem; }
    .cta-section h2 { font-family: 'Libre Baskerville', serif; font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 400; margin-bottom: 1rem; }
    .cta-section h2 em { font-style: italic; color: #7dc5c6; }
    .cta-section p { font-size: 0.95rem; color: rgba(255,255,255,0.65); max-width: 460px; margin: 0 auto 2rem; line-height: 1.7; }
    .cta-phones { display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2rem; }
    .phone-item { font-size: 0.85rem; color: rgba(255,255,255,0.6); display: flex; flex-direction: column; align-items: center; gap: 0.2rem; }
    .phone-item strong { font-size: 1.1rem; color: var(--white); }

    /* Footer */
    footer { background: #111820; color: rgba(255,255,255,0.5); padding: 2rem 4rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.78rem; flex-wrap: wrap; gap: 1rem; }
    footer a { color: rgba(255,255,255,0.35); text-decoration: none; }

    /* Fade */
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* Mobile */
    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; }
      .hero-content { padding: 5rem 1.5rem 2.5rem; }
      .hero-image { height: 300px; }
      .hero-credentials { gap: 1rem; }
      .info-bar { padding: 1rem 1.5rem; flex-direction: column; align-items: flex-start; }
      section { padding: 3rem 1.5rem; }
      .services-grid { grid-template-columns: 1fr; }
      .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      .how-grid { grid-template-columns: repeat(2, 1fr); }
      .cta-section { padding: 3rem 1.5rem; }
      footer { flex-direction: column; text-align: center; padding: 1.5rem; }
      .nav-links { display: none; flex-direction: column; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: var(--white); justify-content: center; align-items: center; gap: 2rem; z-index: 99; }
      .nav-links.open { display: flex; }
      .nav-links a { font-size: 1.1rem; }
      .hamburger { display: flex; z-index: 101; }
    }
  </style>
</head>
<body>

  <a href="/dev/portfolio" class="back-btn">← Torna al Portfolio</a>

  <nav>
    <div class="nav-brand">
      <span class="doctor-name">Dott.ssa Elena Ferretti</span>
      <span class="doctor-title">Medicina Generale &amp; Preventiva · Milano</span>
    </div>
    <div class="nav-links" id="navLinks">
      <a href="#servizi">Servizi</a>
      <a href="#chi-sono">Chi Sono</a>
      <a href="#come-funziona">Come Funziona</a>
      <a href="#contatti" class="nav-cta">Prenota Visita</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Hero -->
  <div class="hero">
    <div class="hero-content fade-in">
      <span class="trust-badge">✓ Convenzionata SSN</span>
      <h1>Dott.ssa<br /><strong>Elena Ferretti</strong></h1>
      <p class="hero-subtitle">Medico di medicina generale &amp; preventiva</p>
      <p class="hero-sub">Studio a Milano Porta Romana dal 2014. Seguo pazienti adulti con un approccio attento alla persona, non solo alla malattia. Disponibile per visite in studio, teleconsulto e check-up preventivi.</p>
      <div class="hero-actions">
        <a href="#contatti" class="btn-primary">Prenota una Visita</a>
        <a href="#servizi" class="btn-outline">Scopri i Servizi</a>
      </div>
      <div class="hero-credentials">
        <div class="cred-item"><div class="cred-num">12+</div><div class="cred-label">anni di<br />attività</div></div>
        <div class="cred-item"><div class="cred-num">850+</div><div class="cred-label">pazienti<br />attivi</div></div>
        <div class="cred-item"><div class="cred-num">4.9★</div><div class="cred-label">su Google<br />(127 rec.)</div></div>
      </div>
    </div>
    <div class="hero-image">
      <img src="/images/portfolio/medico-hero.jpg" alt="Dott.ssa Elena Ferretti" loading="eager" />
      <div class="hero-image-overlay"></div>
    </div>
  </div>

  <!-- Info bar -->
  <div class="info-bar fade-in">
    <div class="info-item"><span class="info-icon">📍</span> Via Crema 14, Milano (Porta Romana)</div>
    <div class="info-item"><span class="info-icon">📞</span> 02 1234 5678</div>
    <div class="info-item"><span class="info-icon">🕐</span> Lun–Ven 8:30–13:00 / 15:00–18:30</div>
    <div class="info-item"><span class="info-icon">💬</span> Teleconsulto disponibile</div>
  </div>

  <!-- Services -->
  <section class="services-section" id="servizi">
    <div class="services-header fade-in">
      <p class="section-tag">Prestazioni</p>
      <h2 class="section-title">Cosa puoi prenotare</h2>
      <p class="section-intro">Visite in studio, teleconsulto e check-up preventivi. Prenotazione online in meno di due minuti.</p>
    </div>
    <div class="services-grid">
      <div class="service-card fade-in">
        <div class="service-icon">🩺</div>
        <h3>Visita Generale</h3>
        <p>Valutazione generale dello stato di salute, anamnesi, esame fisico completo. Prima visita per nuovi pazienti o visita di controllo.</p>
        <div class="service-duration">⏱ 30–45 min · in studio</div>
      </div>
      <div class="service-card fade-in" style="transition-delay: 0.1s">
        <div class="service-icon">📋</div>
        <h3>Check-up Preventivo</h3>
        <p>Valutazione del rischio cardiovascolare, metabolico e oncologico. Include ECG, spirometria e prescrizione esami mirati all'età.</p>
        <div class="service-duration">⏱ 60 min · in studio</div>
      </div>
      <div class="service-card fade-in" style="transition-delay: 0.2s">
        <div class="service-icon">💻</div>
        <h3>Teleconsulto</h3>
        <p>Consulto video per rinnovo terapie, risultati esami, sintomi minori o dubbi urgenti. Risposta entro 2 ore in orario di studio.</p>
        <div class="service-duration">⏱ 15–20 min · online</div>
      </div>
      <div class="service-card fade-in" style="transition-delay: 0s">
        <div class="service-icon">🧪</div>
        <h3>Gestione Esami</h3>
        <p>Prescrizione, interpretazione e follow-up di esami del sangue, imaging diagnostico e test specialistici.</p>
        <div class="service-duration">⏱ 20 min · in studio o online</div>
      </div>
      <div class="service-card fade-in" style="transition-delay: 0.1s">
        <div class="service-icon">💊</div>
        <h3>Gestione Patologie Croniche</h3>
        <p>Follow-up periodico per ipertensione, diabete, ipotiroidismo, dislipidemia. Piano terapeutico personalizzato e monitoraggio nel tempo.</p>
        <div class="service-duration">⏱ 30 min · in studio</div>
      </div>
      <div class="service-card fade-in" style="transition-delay: 0.2s">
        <div class="service-icon">🌿</div>
        <h3>Medicina di Stile di Vita</h3>
        <p>Programmi personalizzati su alimentazione, attività fisica, gestione dello stress e prevenzione attiva, integrati con la terapia tradizionale.</p>
        <div class="service-duration">⏱ 45 min · in studio</div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about-section" id="chi-sono">
    <div class="about-grid">
      <div class="fade-in">
        <div class="doctor-img">
          <img src="/images/portfolio/medico-hero.jpg" alt="Dott.ssa Elena Ferretti" />
          <div class="doctor-strip">
            <div class="name">Dott.ssa Elena Ferretti</div>
            <div class="role">Medicina Generale &amp; Preventiva · Ordine dei Medici Milano n. 45821</div>
          </div>
        </div>
      </div>
      <div class="about-content fade-in" style="transition-delay: 0.15s">
        <p class="section-tag">Chi Sono</p>
        <h2>Un approccio alla salute che parte dalla <em>persona</em></h2>
        <p>Mi sono laureata in Medicina e Chirurgia a Bologna nel 2008 e ho aperto lo studio a Milano nel 2014 dopo anni di specializzazione in medicina preventiva. Nel corso degli anni ho costruito un rapporto di fiducia con oltre 850 pazienti, molti dei quali seguiti da quasi un decennio.</p>
        <p>Credo che la medicina generale sia la specialità più difficile e più utile. Non si tratta di risolvere problemi isolati, ma di seguire una persona nel tempo, capire il contesto della sua vita e aiutarla a fare scelte di salute consapevoli.</p>
        <ul class="education-list">
          <li><span class="edu-year">2008</span><span class="edu-text">Laurea in Medicina e Chirurgia, Università di Bologna (110/110 con lode)</span></li>
          <li><span class="edu-year">2011</span><span class="edu-text">Specializzazione in Igiene e Medicina Preventiva</span></li>
          <li><span class="edu-year">2013</span><span class="edu-text">Master in Lifestyle Medicine, Università Bocconi</span></li>
          <li><span class="edu-year">2014</span><span class="edu-text">Apertura Studio Milano, Convenzionata SSN Regione Lombardia</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="how-section" id="come-funziona">
    <div class="fade-in" style="text-align: center;">
      <p class="section-tag">Come Funziona</p>
      <h2 class="section-title">Dalla prenotazione alla visita</h2>
    </div>
    <div class="how-grid">
      <div class="how-step fade-in">
        <div class="step-num">1</div>
        <h3>Prenota online</h3>
        <p>Scegli il tipo di visita e un orario disponibile. Conferma in meno di 2 minuti, senza telefonate.</p>
      </div>
      <div class="how-step fade-in" style="transition-delay: 0.1s">
        <div class="step-num">2</div>
        <h3>Promemoria automatico</h3>
        <p>Ricevi conferma via email e SMS 24 ore prima. Puoi spostare o cancellare fino a 2 ore prima.</p>
      </div>
      <div class="how-step fade-in" style="transition-delay: 0.2s">
        <div class="step-num">3</div>
        <h3>Visita in studio</h3>
        <p>Sala d'attesa senza sovraffollamento. Arrivi, ti accoglie l'assistente e in pochi minuti sei dalla dottoressa.</p>
      </div>
      <div class="how-step fade-in" style="transition-delay: 0.3s">
        <div class="step-num">4</div>
        <h3>Follow-up digitale</h3>
        <p>Ricevi il referto e le indicazioni via email. Per domande successive, il teleconsulto è disponibile entro 2 ore.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" id="contatti">
    <h2 class="fade-in">Prenota la tua <em>visita</em></h2>
    <p class="fade-in">Posti disponibili questa settimana. Prenota online in 2 minuti o chiamaci direttamente.</p>
    <div class="cta-phones fade-in">
      <div class="phone-item"><span>Telefono studio</span><strong>02 1234 5678</strong></div>
      <div class="phone-item"><span>WhatsApp</span><strong>340 123 4567</strong></div>
    </div>
    <a href="#" class="btn-primary fade-in" style="font-size: 0.95rem; padding: 1rem 2.5rem;">Prenota Online Ora</a>
  </section>

  <footer>
    <span>© 2026 Dott.ssa Elena Ferretti — Via Crema 14, 20135 Milano</span>
    <span>P.IVA 08765432101 &nbsp;|&nbsp; <a href="#">Privacy</a> &nbsp;|&nbsp; <a href="#">Cookie</a></span>
  </footer>

  <script>
    const btn = document.getElementById('hamburger');
    const nav = document.getElementById('navLinks');
    btn?.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', open);
    });
    nav?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      nav.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
    }));
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  </script>
</body>
</html>
