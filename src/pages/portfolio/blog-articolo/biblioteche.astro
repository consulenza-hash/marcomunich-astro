    }
    .bio-content p { font-size: 0.92rem; color: #666; line-height: 1.7; }

    /* ===== RELATED ===== */
    .related { margin-top: 50px; }
    .related-title {
      font-family: 'Merriweather', Georgia, serif;
      font-size: 1.4rem; font-weight: 700;
      margin-bottom: 24px; padding-bottom: 12px;
      border-bottom: 2px solid #e63946; display: inline-block;
    }
    .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .related-card {
      display: flex; gap: 16px; text-decoration: none; color: inherit;
      padding: 16px; border-radius: 12px; border: 1px solid #f0f0f0;
      transition: all 0.3s ease;
    }
    .related-card:hover { border-color: rgba(230,57,70,0.2); box-shadow: 0 8px 30px rgba(0,0,0,0.05); transform: translateY(-3px); }
    .related-img { width: 100px; height: 80px; border-radius: 8px; overflow: hidden; flex-shrink: 0; }
    .related-cat { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #e63946; }
    .related-body h3 { font-family: 'Merriweather', Georgia, serif; font-size: 0.9rem; font-weight: 700; line-height: 1.4; margin: 6px 0; color: #1a1a1a; }
    .related-meta { font-size: 0.78rem; color: #999; }

    /* ===== COMMENTS ===== */
    .comments { margin-top: 50px; }
    .comments-title {
      font-family: 'Merriweather', Georgia, serif;
      font-size: 1.3rem; font-weight: 700; margin-bottom: 24px;
    }
    .comment-count {
      display: inline-flex; align-items: center; justify-content: center;
      width: 28px; height: 28px; border-radius: 50%;
      background: #e63946; color: #fff; font-size: 0.75rem; font-weight: 700;
      vertical-align: middle; margin-left: 8px;
    }
    .comment {
      display: flex; gap: 16px; padding: 20px 0;
      border-bottom: 1px solid #f0f0f0;
    }
    .comment:last-child { border-bottom: none; }
    .comment-avatar {
      width: 42px; height: 42px; border-radius: 50%; flex-shrink: 0;
      background: #f5f5f5; color: #999;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.8rem;
    }
    .comment-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 6px; }
    .comment-header strong { font-size: 0.92rem; }
    .comment-date { font-size: 0.78rem; color: #aaa; }
    .comment-body p { font-size: 0.92rem; color: #555; line-height: 1.7; }

    /* ===== SIDEBAR ===== */
    .sidebar-sticky {
      position: sticky; top: 80px;
      display: flex; flex-direction: column; gap: 30px;
    }
    .glass-card {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(230,57,70,0.08); border-radius: 16px;
      padding: 28px; transition: all 0.3s ease;
    }
    .glass-card:hover { border-color: rgba(230,57,70,0.2); box-shadow: 0 8px 30px rgba(230,57,70,0.06); }
    .sidebar-title {
      font-family: 'Merriweather', Georgia, serif;
      font-size: 1rem; font-weight: 700; margin-bottom: 20px;
      padding-bottom: 12px; border-bottom: 2px solid #e63946; display: inline-block;
    }
    .sidebar-text { font-size: 0.88rem; color: #666; margin-bottom: 16px; line-height: 1.6; }
    .newsletter-form { display: flex; flex-direction: column; gap: 10px; }
    .newsletter-input {
      padding: 12px 16px; border: 1.5px solid #e5e5e5; border-radius: 10px;
      font-size: 0.88rem; font-family: inherit; transition: border-color 0.3s ease; outline: none;
    }
    .newsletter-input:focus { border-color: #e63946; }
    .newsletter-btn {
      padding: 12px; background: #e63946; color: #fff; border: none;
      border-radius: 10px; font-size: 0.85rem; font-weight: 700;
      cursor: pointer; transition: all 0.3s ease;
    }
    .newsletter-btn:hover { background: #c1121f; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(230,57,70,0.3); }
    .most-read { list-style: none; display: flex; flex-direction: column; gap: 16px; }
    .most-read li { display: flex; gap: 14px; align-items: flex-start; }
    .most-read-num {
      font-family: 'Merriweather', Georgia, serif; font-size: 1.6rem; font-weight: 900;
      color: #eee; flex-shrink: 0; line-height: 1; transition: color 0.3s ease;
    }
    .most-read li:hover .most-read-num { color: #e63946; }
    .most-read a {
      font-size: 0.88rem; color: #333; text-decoration: none;
      line-height: 1.5; font-weight: 600; transition: color 0.3s ease;
    }
    .most-read a:hover { color: #e63946; }

    /* ===== FOOTER ===== */
    .footer { background: #0a0a0a; color: #fff; padding: 60px 5vw; }
    .footer-inner { max-width: 1200px; margin: 0 auto; text-align: center; }
    .footer-brand h3 { font-family: 'Merriweather', Georgia, serif; font-size: 1.5rem; margin-bottom: 8px; }
    .footer-brand p { color: #888; font-size: 0.9rem; margin-bottom: 30px; }
    .footer-links { display: flex; justify-content: center; flex-wrap: wrap; gap: 30px; margin-bottom: 30px; }
    .footer-links a { color: #888; text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
    .footer-links a:hover { color: #e63946; }
    .footer-copy { font-size: 0.78rem; color: #555; border-top: 1px solid #222; padding-top: 24px; }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 1024px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar-sticky { position: static; }
    }
    @media (max-width: 768px) {
      .article-header { padding: 80px 5vw 30px; }
      .related-grid { grid-template-columns: 1fr; }
      .related-card { flex-direction: row; }
      .author-bio { flex-direction: column; align-items: center; text-align: center; }
      .back-btn { top: 12px; left: 12px; padding: 8px 14px; font-size: 0.78rem; }
    }
    @media (max-width: 480px) {
      .article-title { font-size: 1.6rem; }
      .share-section { flex-direction: column; }
    }
  </style>
</body>
</html>
