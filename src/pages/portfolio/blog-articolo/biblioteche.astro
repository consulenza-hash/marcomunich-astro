  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const delay = el.dataset.delay || 0;
          setTimeout(() => el.classList.add('visible'), Number(delay));
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach((el, i) => {
      el.dataset.delay = (i % 5) * 100;
      observer.observe(el);
    });
  </script>

  <style>
    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Source Sans 3', 'Segoe UI', sans-serif;
      background: #ffffff;
      color: #1a1a1a;
      line-height: 1.7;
      overflow-x: hidden;
      position: relative;
    }

    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f5f5f5; }
    ::-webkit-scrollbar-thumb { background: #e63946; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #c1121f; }

    .noise {
      position: fixed; inset: 0; pointer-events: none; z-index: 9999; opacity: 0.03;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 256px 256px;
    }

    .fade-in {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    .floating-circle {
      position: fixed; border-radius: 50%; pointer-events: none; z-index: -1; opacity: 0.05; background: #e63946;
    }
    .c1 { width: 400px; height: 400px; top: 10%; right: -100px; animation: floatA 20s ease-in-out infinite; }
    .c2 { width: 250px; height: 250px; bottom: 20%; left: -80px; animation: floatB 25s ease-in-out infinite; }
    @keyframes floatA {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(30px, -20px) scale(1.05); }
      66% { transform: translate(-20px, 20px) scale(0.95); }
    }
    @keyframes floatB {
      0%, 100% { transform: translate(0, 0); }
      50% { transform: translate(40px, -30px); }
    }

    /* ===== BACK BUTTON ===== */
    .back-btn {
      position: fixed; top: 20px; left: 20px; z-index: 1000;
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(230,57,70,0.2); border-radius: 50px;
      color: #1a1a1a; text-decoration: none;
      font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }
    .back-btn:hover {
      background: #e63946; color: #fff; border-color: #e63946;
      transform: translateX(-4px);
      box-shadow: 0 4px 25px rgba(230,57,70,0.25);
    }
    .back-arrow { font-size: 1.1rem; transition: transform 0.3s ease; }
    .back-btn:hover .back-arrow { transform: translateX(-3px); }

    /* ===== ARTICLE HEADER ===== */
    .article-header { padding: 100px 5vw 40px; }
    .header-inner { max-width: 780px; margin: 0 auto; text-align: center; }
    .article-category {
      display: inline-block; font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: #e63946; border: 1.5px solid #e63946;
      padding: 4px 14px; border-radius: 3px; margin-bottom: 24px;
    }
    .article-title {
      font-family: 'Merriweather', Georgia, serif;
      font-size: clamp(2rem, 4vw, 3rem); font-weight: 900;
      line-height: 1.2; margin-bottom: 20px;
      background: linear-gradient(135deg, #0a0a0a 0%, #e63946 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .article-excerpt { font-size: 1.15rem; color: #555; line-height: 1.8; margin-bottom: 30px; }
    .article-meta { display: flex; flex-direction: column; align-items: center; gap: 16px; }
    .author-info { display: flex; align-items: center; gap: 12px; }
    .author-avatar {
      width: 48px; height: 48px; border-radius: 50%;
      background: #e63946; color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700; font-size: 0.9rem;
    }
    .author-name { display: block; font-weight: 700; color: #1a1a1a; }
    .author-role { display: block; font-size: 0.82rem; color: #888; }
    .meta-details { display: flex; align-items: center; gap: 12px; font-size: 0.85rem; color: #888; }
    .meta-dot { width: 4px; height: 4px; border-radius: 50%; background: #ccc; }

    /* ===== HERO IMAGE ===== */
    .article-hero { max-width: 960px; margin: 0 auto 40px; padding: 0 5vw; }
    .hero-img-container {
      border-radius: 16px; overflow: hidden; aspect-ratio: 16/7;
      box-shadow: 0 20px 50px rgba(0,0,0,0.08);
    }
    .img-caption { font-size: 0.78rem; color: #aaa; margin-top: 10px; text-align: center; }

    /* ===== LAYOUT ===== */
    .layout {
      max-width: 1200px; margin: 0 auto; padding: 0 5vw 80px;
      display: grid; grid-template-columns: 1fr 320px; gap: 60px; align-items: start;
    }

    /* ===== ARTICLE BODY ===== */
