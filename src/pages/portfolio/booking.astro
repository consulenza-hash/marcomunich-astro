---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Studio Rinascita — Counseling e Percorsi di Crescita Personale</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Noise overlay -->
  <div class="noise"></div>

  <!-- Organic blob shapes -->
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <!-- Back button -->
  <a href="/dev/portfolio" class="back-btn">
    <span class="back-arrow">&larr;</span> Torna al Portfolio
  </a>

  <!-- Hero -->
  <header class="hero fade-in">
    <div class="hero-inner">
      <span class="hero-label">Counseling &amp; Crescita Personale</span>
      <h1 class="hero-title">Studio<br/><span class="hero-title-light">Rinascita</span></h1>
      <p class="hero-sub">Uno spazio sicuro per ritrovare te stesso. Percorsi di counseling personalizzati per individui e coppie, in un ambiente accogliente e riservato.</p>
      <div class="hero-actions">
        <a href="#servizi" class="btn btn-primary">Scopri i Servizi</a>
        <a href="#prenota" class="btn btn-outline">Prenota un Incontro</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">8+</span>
          <span class="stat-label">Anni esperienza</span>
        </div>
        <div class="stat">
          <span class="stat-num">4.9</span>
          <span class="stat-label">Valutazione</span>
        </div>
        <div class="stat">
          <span class="stat-num">500+</span>
          <span class="stat-label">Persone seguite</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Services -->
  <section id="servizi" class="services">
    <div class="section-inner">
      <div class="section-header fade-in">
        <span class="section-label">I Servizi</span>
        <h2 class="section-title">Percorsi su misura per la tua crescita</h2>
      </div>
      <div class="services-grid">
        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="service-name">Consulenza Iniziale</h3>
          <p class="service-desc">Un primo incontro conoscitivo per capire le tue esigenze e trovare insieme il percorso pi&ugrave; adatto a te. Senza impegno, in totale riservatezza.</p>
          <div class="service-footer">
            <span class="service-price">Gratuita</span>
            <span class="service-duration">30 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot"></span>
            <span>Disponibile questa settimana</span>
          </div>
        </div>

        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
