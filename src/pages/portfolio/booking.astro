  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const delay = el.dataset.delay || 0;
          setTimeout(() => el.classList.add('visible'), Number(delay));
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach((el, i) => {
      el.dataset.delay = (i % 6) * 120;
      observer.observe(el);
    });

    // ===== CALENDAR =====
    let selectedDay = '24';
    let selectedSlot = '14:00';

    document.querySelectorAll('.cal-day.available').forEach(day => {
      day.addEventListener('click', () => {
        document.querySelectorAll('.cal-day').forEach(d => d.classList.remove('selected'));
        day.classList.add('selected');
        selectedDay = day.textContent.trim();
        document.querySelector('.timeslots-title').textContent = 'Orari disponibili — ' + selectedDay + ' Marzo';
      });
    });

    // ===== TIME SLOTS =====
    document.querySelectorAll('.slot:not(.unavailable)').forEach(slot => {
      slot.addEventListener('click', () => {
        document.querySelectorAll('.slot').forEach(s => s.classList.remove('active'));
        slot.classList.add('active');
        selectedSlot = slot.textContent.trim();
      });
    });

    // ===== SERVICE CARDS =====
    document.querySelectorAll('.service-card').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', () => {
        const service = card.querySelector('.service-name')?.textContent || '';
        const price = card.querySelector('.service-price')?.textContent || '';
        showBookingToast('✓ Selezionato: ' + service + ' (' + price + ')');
        document.getElementById('prenota')?.scrollIntoView({ behavior: 'smooth' });
      });
    });

    // ===== CONFERMA =====
    document.querySelector('.btn-block').addEventListener('click', () => {
      document.getElementById('bookNome').textContent = 'Ospite';
      document.getElementById('bookData').textContent = selectedDay + ' Marzo 2026 alle ' + selectedSlot;
      document.getElementById('bookingModal').classList.add('open');
      document.getElementById('bookingOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    });

    function closeBookingModal() {
      document.getElementById('bookingModal').classList.remove('open');
      document.getElementById('bookingOverlay').classList.remove('open');
      document.body.style.overflow = '';
      showBookingToast('✓ Prenotazione confermata! Ti aspettiamo.');
    }

    let bToastTimeout;
    function showBookingToast(msg) {
      const t = document.getElementById('booking-toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(bToastTimeout);
      bToastTimeout = setTimeout(() => t.classList.remove('show'), 3200);
    }
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: linear-gradient(180deg, #f0fdf4 0%, #ffffff 40%, #f0fdf4 100%);
      color: #1a1a1a;
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* Custom scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f0fdf4; }
    ::-webkit-scrollbar-thumb { background: #059669; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #047857; }

    /* Noise */
    .noise {
      position: fixed; inset: 0; pointer-events: none; z-index: 9999; opacity: 0.02;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 256px;
    }

    /* Organic blobs */
    .blob {
      position: fixed;
      border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
      pointer-events: none;
      z-index: -1;
      opacity: 0.08;
      background: #059669;
    }
    .blob-1 {
      width: 500px; height: 500px; top: -100px; right: -150px;
      animation: blobMorph1 20s ease-in-out infinite;
    }
    .blob-2 {
      width: 350px; height: 350px; bottom: 10%; left: -100px;
      background: #10b981;
      animation: blobMorph2 25s ease-in-out infinite;
    }
    .blob-3 {
      width: 200px; height: 200px; top: 50%; right: 5%;
      background: #34d399;
      animation: blobMorph1 18s ease-in-out infinite reverse;
    }
    @keyframes blobMorph1 {
      0%, 100% { border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%; transform: translate(0,0) rotate(0deg); }
      33% { border-radius: 70% 30% 50% 50% / 30% 30% 70% 70%; transform: translate(20px,-20px) rotate(5deg); }
      66% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; transform: translate(-15px,15px) rotate(-3deg); }
    }
    @keyframes blobMorph2 {
      0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; transform: translate(0,0); }
      50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; transform: translate(30px,-25px); }
    }

    /* Fade-in */
    .fade-in {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* Floating circles */
    .floating-circle { position: fixed; border-radius: 50%; pointer-events: none; z-index: -1; opacity: 0.04; background: #059669; }
    .fc1 { width: 300px; height: 300px; bottom: 5%; right: -80px; animation: floatA 22s ease-in-out infinite; }
    .fc2 { width: 180px; height: 180px; top: 30%; left: -60px; animation: floatA 18s ease-in-out infinite reverse; }
    @keyframes floatA {
      0%,100% { transform: translate(0,0); }
      50% { transform: translate(30px,-20px); }
    }

    /* Back button */
    .back-btn {
      position: fixed; bottom: 2rem; left: 20px; z-index: 1000;
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px;
      background: rgba(255,255,255,0.8);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(5,150,105,0.15);
      border-radius: 50px;
      color: #1a1a1a; text-decoration: none;
      font-size: 0.85rem; font-weight: 600;
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }
    .back-btn:hover {
      background: #059669; color: #fff; border-color: #059669;
      transform: translateX(-4px);
      box-shadow: 0 4px 25px rgba(5,150,105,0.25);
    }
    .back-arrow { font-size: 1.1rem; transition: transform 0.3s; }
    .back-btn:hover .back-arrow { transform: translateX(-3px); }

    /* Sections */
    .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 5vw; }
    .section-header { text-align: center; margin-bottom: 50px; }
    .section-label {
      display: inline-block;
      font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: #059669;
      border: 1.5px solid rgba(5,150,105,0.3);
      padding: 4px 16px; border-radius: 50px;
      margin-bottom: 16px;
    }
    .section-title {
      font-family: 'Nunito', sans-serif;
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 800;
      background: linear-gradient(135deg, #065f46, #059669);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1.2;
    }

    /* Hero */
    .hero { padding: 120px 5vw 80px; text-align: center; }
    .hero-inner { max-width: 800px; margin: 0 auto; }
    .hero-label {
      display: inline-block; font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.18em; color: #059669;
      background: rgba(5,150,105,0.08); padding: 6px 20px; border-radius: 50px;
      margin-bottom: 24px;
    }
    .hero-title {
      font-family: 'Nunito', sans-serif;
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 800; line-height: 1.1;
      background: linear-gradient(135deg, #065f46 0%, #059669 50%, #34d399 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      margin-bottom: 24px;
    }
    .hero-title-light { font-weight: 400; }
    .hero-sub {
      font-size: 1.15rem; color: #555; max-width: 600px; margin: 0 auto 36px; line-height: 1.8;
    }
    .hero-actions { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; margin-bottom: 60px; }

    /* Buttons */
    .btn {
      display: inline-flex; align-items: center; padding: 14px 32px;
      border-radius: 50px; font-size: 0.9rem; font-weight: 700;
      text-decoration: none; transition: all 0.3s ease; border: 2px solid transparent;
      cursor: pointer; font-family: inherit;
    }
    .btn-primary {
      background: #059669; color: #fff; border-color: #059669;
    }
    .btn-primary:hover {
      background: #047857; transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(5,150,105,0.3);
    }
    .btn-outline {
      background: transparent; color: #059669; border-color: #059669;
    }
    .btn-outline:hover {
      background: #059669; color: #fff; transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(5,150,105,0.2);
    }
    .btn-block { width: 100%; justify-content: center; margin-top: 20px; }

    /* Stats */
    .hero-stats {
      display: flex; justify-content: center; gap: 60px;
    }
    .stat { text-align: center; }
    .stat-num {
      display: block; font-family: 'Nunito', sans-serif;
      font-size: 2rem; font-weight: 800; color: #059669;
    }
    .stat-label { font-size: 0.8rem; color: #888; font-weight: 500; }

    /* Services */
    .services { padding: 80px 0; }
    .services-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;
    }
    .service-card {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border: 1.5px solid rgba(5,150,105,0.1);
      border-radius: 20px; padding: 32px;
      transition: all 0.4s cubic-bezier(0.16,1,0.3,1);
      position: relative; overflow: hidden;
    }
    .service-card::before {
      content: ''; position: absolute; inset: 0;
      border-radius: 20px; padding: 2px;
      background: linear-gradient(135deg, transparent, rgba(5,150,105,0.3), transparent);
      -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor; mask-composite: exclude;
      opacity: 0; transition: opacity 0.4s ease;
    }
    .service-card:hover::before { opacity: 1; }
    .service-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 20px 50px rgba(5,150,105,0.1);
      border-color: rgba(5,150,105,0.2);
    }
    .service-icon {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, #ecfdf5, #d1fae5);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      color: #059669; margin-bottom: 20px;
    }
    .service-name {
      font-family: 'Nunito', sans-serif;
      font-size: 1.15rem; font-weight: 700; color: #111; margin-bottom: 10px;
    }
    .service-desc { font-size: 0.88rem; color: #666; line-height: 1.7; margin-bottom: 18px; }
    .service-footer {
      display: flex; justify-content: space-between; align-items: center;
      padding-top: 14px; border-top: 1px solid rgba(0,0,0,0.05);
      margin-bottom: 12px;
    }
    .service-price { font-family: 'Nunito', sans-serif; font-size: 1.3rem; font-weight: 800; color: #059669; }
    .service-duration { font-size: 0.8rem; color: #999; font-weight: 500; }
    .service-avail { display: flex; align-items: center; gap: 8px; font-size: 0.78rem; color: #666; }
    .avail-dot {
      width: 8px; height: 8px; border-radius: 50%; background: #10b981;
      animation: pulse 2s ease-in-out infinite;
    }
    .avail-dot.delayed { background: #f59e0b; animation-name: pulseOrange; }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.5); }
      50% { box-shadow: 0 0 0 6px rgba(16,185,129,0); }
    }
    @keyframes pulseOrange {
      0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0.5); }
      50% { box-shadow: 0 0 0 6px rgba(245,158,11,0); }
    }

    /* Booking / Calendar */
    .booking { padding: 80px 0; }
    .booking-layout {
      display: grid; grid-template-columns: 1fr 1fr; gap: 30px;
    }
    .glass-card {
      background: rgba(255,255,255,0.75);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(5,150,105,0.1);
      border-radius: 20px; padding: 30px;
    }
    .cal-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 20px;
    }
    .cal-month { font-family: 'Nunito', sans-serif; font-size: 1.1rem; font-weight: 700; }
    .cal-nav {
      width: 36px; height: 36px; border-radius: 50%;
      background: rgba(5,150,105,0.08); border: 1px solid rgba(5,150,105,0.15);
      font-size: 1rem; cursor: pointer; transition: all 0.3s; color: #059669;
    }
    .cal-nav:hover { background: #059669; color: #fff; }
    .cal-weekdays {
      display: grid; grid-template-columns: repeat(7, 1fr);
      text-align: center; font-size: 0.72rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em; color: #999;
      margin-bottom: 10px;
    }
    .cal-days {
      display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px;
    }
    .cal-day {
      aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
      border-radius: 10px; font-size: 0.85rem; font-weight: 500; color: #333;
      cursor: pointer; transition: all 0.2s ease;
    }
    .cal-day.other { color: #ccc; }
    .cal-day.today {
      background: rgba(5,150,105,0.1); color: #059669; font-weight: 700;
    }
    .cal-day.available { color: #059669; font-weight: 600; }
    .cal-day.available:hover {
      background: rgba(5,150,105,0.15); transform: scale(1.1);
    }
    .cal-day.selected {
      background: #059669; color: #fff; font-weight: 700;
      box-shadow: 0 4px 15px rgba(5,150,105,0.3);
    }

    /* Time slots */
    .timeslots-title { font-family: 'Nunito', sans-serif; font-size: 1rem; font-weight: 700; margin-bottom: 20px; }
    .slots-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
    }
    .slot {
      padding: 12px; border-radius: 12px; border: 1.5px solid rgba(5,150,105,0.15);
      background: rgba(255,255,255,0.6); font-size: 0.88rem; font-weight: 600;
      color: #333; cursor: pointer; transition: all 0.3s; font-family: inherit;
    }
    .slot:hover:not(.unavailable) {
      border-color: #059669; background: rgba(5,150,105,0.05);
      box-shadow: 0 0 20px rgba(5,150,105,0.15);
    }
    .slot.active {
      background: #059669; color: #fff; border-color: #059669;
      box-shadow: 0 4px 20px rgba(5,150,105,0.3);
    }
    .slot.unavailable {
      opacity: 0.35; cursor: not-allowed; text-decoration: line-through;
    }

    /* Testimonials */
    .testimonials { padding: 80px 0; }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .testimonial-card {
      background: rgba(255,255,255,0.75);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(5,150,105,0.08);
      border-radius: 20px; padding: 32px;
      transition: all 0.4s ease;
    }
    .testimonial-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 15px 40px rgba(5,150,105,0.08);
    }
    .slide-left.visible { animation: slideFromLeft 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
    .slide-right.visible { animation: slideFromRight 0.8s cubic-bezier(0.16,1,0.3,1) forwards; }
    @keyframes slideFromLeft {
      from { opacity: 0; transform: translateX(-40px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes slideFromRight {
      from { opacity: 0; transform: translateX(40px); }
      to { opacity: 1; transform: translateX(0); }
    }
    .testimonial-stars { color: #f59e0b; font-size: 1rem; margin-bottom: 16px; letter-spacing: 2px; }
    .testimonial-text { font-size: 0.92rem; color: #444; line-height: 1.7; margin-bottom: 20px; }
    .testimonial-author { display: flex; gap: 12px; align-items: center; }
    .testimonial-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
    }
    .testimonial-name { font-weight: 700; font-size: 0.88rem; }
    .testimonial-role { font-size: 0.78rem; color: #999; }

    /* Contact */
    .contact { padding: 80px 0; }
    .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
    .contact-details { display: flex; flex-direction: column; gap: 24px; margin-top: 30px; }
    .contact-item { display: flex; gap: 16px; align-items: flex-start; font-size: 0.92rem; color: #555; }
    .contact-item strong { color: #111; display: block; margin-bottom: 2px; }
    .contact-icon {
      width: 44px; height: 44px; flex-shrink: 0; border-radius: 12px;
      background: rgba(5,150,105,0.08); color: #059669;
      display: flex; align-items: center; justify-content: center;
    }
    .map-pin { position: relative; }
    .map-placeholder {
      aspect-ratio: 4/3; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 16px;
      background: linear-gradient(135deg, #ecfdf5, #d1fae5);
      color: #888; font-size: 0.9rem;
    }
    .map-pin-anim {
      animation: bounce 2s ease-in-out infinite;
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-12px); }
    }

    /* Footer */
    .footer { background: #065f46; color: #fff; padding: 60px 5vw; text-align: center; }
    .footer-inner { max-width: 800px; margin: 0 auto; }
    .footer-brand { font-family: 'Nunito', sans-serif; font-size: 1.5rem; font-weight: 800; margin-bottom: 8px; }
    .footer-sub { color: rgba(255,255,255,0.6); font-size: 0.9rem; margin-bottom: 30px; }
    .footer-links { display: flex; justify-content: center; flex-wrap: wrap; gap: 24px; margin-bottom: 24px; }
    .footer-links a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 0.85rem; transition: color 0.3s; }
    .footer-links a:hover { color: #fff; }
    .footer-copy { font-size: 0.78rem; color: rgba(255,255,255,0.35); border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px; }

    /* Responsive */
    @media (max-width: 1024px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .testimonials-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .services-grid { grid-template-columns: 1fr; }
      .booking-layout { grid-template-columns: 1fr; }
      .contact-grid { grid-template-columns: 1fr; }
      .hero-stats { gap: 30px; }
      .hero { padding: 100px 5vw 60px; }
      .back-btn { top: 12px; left: 12px; padding: 8px 14px; font-size: 0.78rem; }
      .slots-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 480px) {
      .hero { padding: 72px 5vw 48px; }
      .hero-title { font-size: 2.2rem; }
      .hero-actions { flex-direction: column; align-items: center; }
      .hero-stats { flex-direction: column; gap: 16px; }
      .slots-grid { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

  <!-- Booking Confirm Modal -->
  <div style="position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:9998;opacity:0;pointer-events:none;transition:opacity 0.3s" id="bookingOverlay" onclick="closeBookingModal()"></div>
  <div id="bookingModal" style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);width:min(440px,90vw);background:#f9fdf9;border-radius:20px;padding:48px 36px;z-index:9999;opacity:0;pointer-events:none;transition:all 0.35s cubic-bezier(0.4,0,0.2,1);text-align:center;color:#1a1a1a;">
    <div style="font-size:3rem;margin-bottom:16px">✅</div>
    <h3 style="font-size:1.5rem;font-weight:700;color:#059669;margin-bottom:8px">Appuntamento confermato!</h3>
    <p style="color:#666;font-size:0.9rem;margin-bottom:24px">Riceverai una conferma via email con i dettagli dell'incontro.</p>
    <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:12px;padding:20px;margin-bottom:24px;text-align:left;">
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #dcfce7;font-size:0.85rem"><span style="color:#666">Con</span><span style="font-weight:600">Elena Marchetti</span></div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:0.85rem"><span style="color:#666">Quando</span><span style="font-weight:600;color:#059669" id="bookData">—</span></div>
    </div>
    <button onclick="closeBookingModal()" style="width:100%;background:#059669;color:#fff;border:none;padding:16px;border-radius:10px;font-size:1rem;font-weight:700;cursor:pointer;">Perfetto, grazie!</button>
  </div>
  <div id="booking-toast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#1a1a1a;border:1px solid #059669;color:#86efac;padding:13px 26px;border-radius:50px;font-size:0.84rem;z-index:99999;opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);white-space:nowrap;pointer-events:none;"></div>
  <style>#bookingModal.open,#bookingOverlay.open{opacity:1!important;pointer-events:all!important;transform:translate(-50%,-50%) scale(1)!important}#booking-toast.show{opacity:1!important;transform:translateX(-50%) translateY(0)!important}</style>
</body>
</html>
