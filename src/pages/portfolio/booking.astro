---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Armonia Wellness — Prenota il Tuo Benessere</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Noise overlay -->
  <div class="noise"></div>

  <!-- Organic blob shapes -->
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>

  <!-- Back button -->
  <a href="/dev/portfolio" class="back-btn">
    <span class="back-arrow">&larr;</span> Torna al Portfolio
  </a>

  <!-- Hero -->
  <header class="hero fade-in">
    <div class="hero-inner">
      <span class="hero-label">Centro Benessere Premium</span>
      <h1 class="hero-title">Armonia<br/><span class="hero-title-light">Wellness &amp; Spa</span></h1>
      <p class="hero-sub">Riscopri l'equilibrio tra corpo e mente. Prenota il tuo percorso di benessere personalizzato in un ambiente progettato per rigenerarti.</p>
      <div class="hero-actions">
        <a href="#servizi" class="btn btn-primary">Scopri i Trattamenti</a>
        <a href="#prenota" class="btn btn-outline">Prenota Ora</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">12+</span>
          <span class="stat-label">Trattamenti</span>
        </div>
        <div class="stat">
          <span class="stat-num">4.9</span>
          <span class="stat-label">Valutazione</span>
        </div>
        <div class="stat">
          <span class="stat-num">2k+</span>
          <span class="stat-label">Clienti felici</span>
        </div>
      </div>
    </div>
  </header>

  <!-- Services -->
  <section id="servizi" class="services">
    <div class="section-inner">
      <div class="section-header fade-in">
        <span class="section-label">I Nostri Trattamenti</span>
        <h2 class="section-title">Percorsi su misura per il tuo benessere</h2>
      </div>
      <div class="services-grid">
        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3 class="service-name">Massaggio Rilassante</h3>
          <p class="service-desc">60 minuti di puro relax con oli essenziali biologici e tecniche di massaggio svedese.</p>
          <div class="service-footer">
            <span class="service-price">&euro;85</span>
            <span class="service-duration">60 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot"></span>
            <span>Disponibile oggi</span>
          </div>
        </div>

        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h3 class="service-name">Trattamento Viso Luxury</h3>
          <p class="service-desc">Pulizia profonda, maschera all'acido ialuronico e massaggio facciale rigenerante.</p>
          <div class="service-footer">
            <span class="service-price">&euro;120</span>
            <span class="service-duration">90 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot"></span>
            <span>Disponibile oggi</span>
          </div>
        </div>

        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="service-name">Percorso Detox Completo</h3>
          <p class="service-desc">Sauna finlandese, bagno turco, scrub corpo e massaggio drenante linfatico.</p>
          <div class="service-footer">
            <span class="service-price">&euro;180</span>
            <span class="service-duration">120 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot delayed"></span>
            <span>Prossima disponibilità: domani</span>
          </div>
        </div>

        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
          </div>
          <h3 class="service-name">Yoga &amp; Meditazione</h3>
          <p class="service-desc">Sessione guidata di hatha yoga con meditazione mindfulness in sala panoramica.</p>
          <div class="service-footer">
            <span class="service-price">&euro;45</span>
            <span class="service-duration">75 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot"></span>
            <span>Disponibile oggi</span>
          </div>
        </div>

        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h3 class="service-name">Hot Stone Therapy</h3>
          <p class="service-desc">Pietre laviche calde posizionate sui punti energetici per un rilascio profondo delle tensioni.</p>
          <div class="service-footer">
            <span class="service-price">&euro;110</span>
            <span class="service-duration">75 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot"></span>
            <span>Disponibile oggi</span>
          </div>
        </div>

        <div class="service-card fade-in">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          </div>
          <h3 class="service-name">Pacchetto Coppia Romantica</h3>
          <p class="service-desc">Massaggio in coppia, vasca idromassaggio privata, tisana e petali di rosa.</p>
          <div class="service-footer">
            <span class="service-price">&euro;250</span>
            <span class="service-duration">150 min</span>
          </div>
          <div class="service-avail">
            <span class="avail-dot delayed"></span>
            <span>Su prenotazione</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendar / Booking -->
  <section id="prenota" class="booking">
    <div class="section-inner">
      <div class="section-header fade-in">
        <span class="section-label">Prenota Online</span>
