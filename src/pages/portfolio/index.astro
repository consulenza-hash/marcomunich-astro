---
import BaseLayout from '@layouts/BaseLayout.astro';
export const prerender = true;

const demos = [
  { href: "/portfolio/ecommerce",        tag: "SHOP",      title: "E-commerce",        desc: "Shop online con carrello, pagamenti Stripe e gestione ordini integrata.", accent: "#00e5ff" },
  { href: "/portfolio/corso-online",     tag: "PLATFORM",  title: "Corso Online",      desc: "Piattaforma di formazione con area riservata, video-lezioni e progressi.", accent: "#ff2d92" },
  { href: "/portfolio/sito-vetrina",     tag: "VETRINA",   title: "Sito Vetrina",      desc: "Pagina professionale con bio, servizi offerti e form di contatto.", accent: "#00e5ff" },
  { href: "/portfolio/landing-page",     tag: "LANDING",   title: "Landing Page",      desc: "Pagina di lancio ottimizzata per conversione e raccolta contatti.", accent: "#ff2d92" },
  { href: "/portfolio/blog",             tag: "MAGAZINE",  title: "Blog & Magazine",   desc: "Sito editoriale con articoli, categorie e ottimizzazione SEO.", accent: "#00e5ff" },
  { href: "/portfolio/booking",          tag: "BOOKING",   title: "Booking",           desc: "Sistema di prenotazioni online con calendario e conferma automatica.", accent: "#ff2d92" },
  { href: "/portfolio/portfolio-creativo", tag: "CREATIVE", title: "Portfolio Creativo", desc: "Galleria lavori con lightbox, filtri per categoria e animazioni.", accent: "#00e5ff" },
  { href: "/portfolio/ristorante",       tag: "FOOD",      title: "Ristorante",        desc: "Menu digitale, prenotazione tavolo online e mappa interattiva.", accent: "#ff2d92" },
  { href: "/portfolio/saas",             tag: "APP",       title: "SaaS Dashboard",    desc: "Applicazione web con area utente, analytics e gestione dati.", accent: "#00e5ff" },
  { href: "/portfolio/non-profit",       tag: "ORG",       title: "Non-Profit",        desc: "Sito per associazioni con donazioni online, eventi e volontariato.", accent: "#ff2d92" },
  { href: "/portfolio/immobiliare",      tag: "REALTY",    title: "Immobiliare",       desc: "Catalogo proprietà con filtri avanzati, mappa e schede dettaglio.", accent: "#00e5ff" },
  { href: "/portfolio/wedding",          tag: "EVENT",     title: "Wedding & Eventi",  desc: "Inviti digitali, conferma RSVP, countdown e gallery fotografica.", accent: "#ff2d92" },
];
---

<BaseLayout
  title="Portfolio — Siti e App — Marco Munich"
  description="Demo navigabili di siti web e applicazioni costruiti con Astro, Tailwind e stack moderno. E-commerce, landing, booking, SaaS, non-profit e altro."
  currentPath="/portfolio/"
>

<div class="pf-page">

  <!-- HERO -->
  <section class="pf-hero">
    <div class="pf-container">
      <div class="pf-status-bar">
        <span class="pf-pill"><span class="pf-pulse"></span> DEMO NAVIGABILI</span>
        <span class="pf-pill">SYS · portfolio</span>
        <span class="pf-pill">{demos.length} progetti</span>
      </div>
      <h1 class="pf-h1">
        <span class="pf-h1__chrome">LAVORI.</span>
      </h1>
      <p class="pf-hero__tag">
        Demo navigabili costruiti con stack moderno — Astro, React, Tailwind, Stripe, API esterne. Ogni sito simula un cliente diverso: puoi aprirli, cliccare, esplorare. ✦
      </p>
      <div class="pf-window">
        <div class="pf-window__bar">
          <span></span><span></span><span></span>
          <span class="pf-window__title">marcomunich.com / portfolio</span>
        </div>
        <div class="pf-window__body">
          <div class="pf-cmd">$ ls demos/</div>
          <div class="pf-output">ecommerce/ corso-online/ sito-vetrina/ landing-page/</div>
          <div class="pf-output">blog/ booking/ portfolio-creativo/ ristorante/</div>
          <div class="pf-output">saas/ non-profit/ immobiliare/ wedding/ <span class="pf-output--ok">...</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID DEMO -->
  <section class="pf-section">
    <div class="pf-container">
      <h2 class="pf-section__title"><span class="pf-arrow">▸</span> DEMO NAVIGABILI · {demos.length} PROGETTI</h2>
      <div class="pf-grid">
        {demos.map((d, i) => (
          <a href={d.href} class="pf-card" style={`--ac: ${d.accent}`}>
            <div class="pf-card__head">
              <span class="pf-card__num">[ {String(i + 1).padStart(2, '0')} ]</span>
              <span class="pf-card__tag">{d.tag}</span>
            </div>
            <h3 class="pf-card__title">{d.title}</h3>
            <p class="pf-card__desc">{d.desc}</p>
            <span class="pf-card__cta">// vedi demo →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="pf-cta">
    <div class="pf-container">
      <div class="pf-cta__box">
        <p class="pf-cta__kicker">// hai un progetto in testa?</p>
        <h2 class="pf-cta__title"><span class="pf-h1__chrome">COSTRUIAMOLO.</span></h2>
        <p class="pf-cta__sub">
          Queste demo mostrano il tipo di lavoro. Il tuo sito parte da zero, costruito su misura per te.
        </p>
        <a href="/#contatti" class="pf-btn">[ INIZIA UN PROGETTO → ]</a>
      </div>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  .pf-page { color: #f0e9ff; font-family: 'Inter', system-ui, sans-serif; position: relative; min-height: 100vh; }
  .pf-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; width: 100%; position: relative; z-index: 2; }

  /* HERO */
  .pf-hero { padding: 5rem 0 4rem; }
  .pf-status-bar { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .pf-pill { display: inline-flex; align-items: center; gap: 0.4rem; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 600; color: #00e5ff; background: rgba(0,229,255,0.08); border: 1px solid rgba(0,229,255,0.4); padding: 0.35rem 0.8rem; border-radius: 999px; }
  .pf-pulse { width: 7px; height: 7px; background: #6ee870; border-radius: 50%; animation: pfpulse 2s infinite; }
  @keyframes pfpulse { 0%,100% { box-shadow: 0 0 0 0 rgba(110,232,112,0.5); } 50% { box-shadow: 0 0 0 6px transparent; } }

  .pf-h1 { font-family: 'Inter', sans-serif; font-weight: 900; font-size: clamp(3.5rem, 12vw, 10rem); line-height: 0.9; letter-spacing: -0.05em; margin: 0 0 2rem; }
  .pf-h1__chrome { display: block; background: linear-gradient(180deg, #ffffff 0%, #d8d8d8 25%, #909090 45%, #ffffff 55%, #f5f5f5 75%, #b5b5b5 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; color: transparent; }
  .pf-hero__tag { font-size: 1.1rem; line-height: 1.7; color: rgba(240,233,255,0.78); max-width: 620px; margin: 0 0 3rem; }

  .pf-window { background: rgba(10,5,18,0.6); border: 1px solid rgba(240,233,255,0.15); border-radius: 8px; overflow: hidden; backdrop-filter: blur(20px); max-width: 580px; box-shadow: 0 0 40px rgba(138,58,255,0.25); }
  .pf-window__bar { background: rgba(255,255,255,0.05); padding: 0.55rem 1rem; display: flex; align-items: center; gap: 0.4rem; border-bottom: 1px solid rgba(240,233,255,0.1); }
  .pf-window__bar > span:nth-child(1) { width: 11px; height: 11px; border-radius: 50%; background: #ff5f57; }
  .pf-window__bar > span:nth-child(2) { width: 11px; height: 11px; border-radius: 50%; background: #febc2e; }
  .pf-window__bar > span:nth-child(3) { width: 11px; height: 11px; border-radius: 50%; background: #28c840; }
  .pf-window__title { margin-left: 1rem; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: rgba(240,233,255,0.55); }
  .pf-window__body { padding: 1.2rem 1.5rem; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; line-height: 1.9; }
  .pf-cmd { color: #00e5ff; }
  .pf-output { color: rgba(240,233,255,0.65); margin-left: 1rem; }
  .pf-output--ok { color: #6ee870; }

  /* SECTION */
  .pf-section { padding: 5rem 0 6rem; }
  .pf-section__title { font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; font-weight: 700; letter-spacing: 0.2em; color: #ff2d92; margin: 0 0 3rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,45,146,0.3); }
  .pf-arrow { color: #00e5ff; }

  /* GRID */
  .pf-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
  .pf-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(240,233,255,0.15); border-top: 3px solid var(--ac); border-radius: 12px; padding: 1.8rem; text-decoration: none; color: #f0e9ff; display: flex; flex-direction: column; gap: 0.6rem; backdrop-filter: blur(10px); transition: all 0.2s ease; }
  .pf-card:hover { border-color: var(--ac); box-shadow: 0 0 40px rgba(0,229,255,0.12); transform: translateY(-3px); }
  .pf-card__head { display: flex; justify-content: space-between; align-items: center; }
  .pf-card__num { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: #ff2d92; letter-spacing: 0.1em; }
  .pf-card__tag { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; letter-spacing: 0.15em; color: rgba(240,233,255,0.45); }
  .pf-card__title { font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.25rem; color: #fff; letter-spacing: -0.01em; margin: 0.3rem 0 0; }
  .pf-card__desc { font-size: 0.88rem; line-height: 1.65; color: rgba(240,233,255,0.65); flex-grow: 1; margin: 0; }
  .pf-card__cta { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: var(--ac); margin-top: 0.8rem; transition: color 0.2s; }

  /* CTA */
  .pf-cta { padding: 5rem 0 7rem; }
  .pf-cta__box { text-align: center; background: linear-gradient(135deg, rgba(138,58,255,0.1) 0%, rgba(0,229,255,0.08) 100%); border: 1px solid rgba(240,233,255,0.2); border-radius: 24px; padding: 5rem 3rem; backdrop-filter: blur(20px); box-shadow: 0 0 80px rgba(255,45,146,0.15); }
  .pf-cta__kicker { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #00e5ff; margin: 0 0 2rem; letter-spacing: 0.2em; }
  .pf-cta__title { font-size: clamp(2.5rem, 7vw, 5.5rem); line-height: 0.9; margin: 0 0 2rem; }
  .pf-cta__sub { font-size: 1.05rem; color: rgba(240,233,255,0.75); max-width: 500px; margin: 0 auto 3rem; line-height: 1.7; }
  .pf-btn { font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 700; letter-spacing: 0.05em; padding: 1.3rem 2.4rem; text-decoration: none; border-radius: 4px; display: inline-block; background: linear-gradient(180deg, #ffffff 0%, #cccccc 100%); color: #0a0512; box-shadow: 0 0 40px rgba(255,45,146,0.4); border: 1px solid #fff; transition: all 0.2s ease; }
  .pf-btn:hover { box-shadow: 0 0 60px rgba(255,45,146,0.7); transform: translateY(-2px); }

  @media (max-width: 1024px) { .pf-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .pf-grid { grid-template-columns: 1fr; }
    .pf-cta__box { padding: 3rem 1.6rem; }
    .pf-section__title { font-size: 0.78rem; }
  }
</style>
