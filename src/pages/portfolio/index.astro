---
export const prerender = true;
---

<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sviluppo Siti Web — Marco Munich</title>
  <meta name="description" content="Progettazione e sviluppo siti web professionali. E-commerce, landing page, SaaS, portfolio e molto altro." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <nav class="topbar">
    <a href="https://marcomunich.com" class="back-link">← marcomunich.com</a>
  </nav>

  <header class="hero">
    <p class="hero-label">Web Development</p>
    <h1 class="hero-title">Sviluppo Siti Web</h1>
    <p class="hero-subtitle">
      Siti web veloci, moderni e costruiti su misura. Ogni progetto parte dalle tue esigenze
      e diventa un prodotto digitale che funziona davvero.
    </p>
  </header>

  <main class="grid-section">
    <div class="card-grid">

      <a href="/portfolio/ecommerce" class="card" style="--accent: #10b981;">
        <span class="card-icon">🛒</span>
        <h2 class="card-title">E-commerce</h2>
        <p class="card-desc">Shop online con carrello, pagamenti sicuri e gestione ordini integrata.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/corso-online" class="card" style="--accent: #8b5cf6;">
        <span class="card-icon">🎓</span>
        <h2 class="card-title">Corso Online</h2>
        <p class="card-desc">Piattaforma di formazione con area riservata, video-lezioni e progressi.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/sito-vetrina" class="card" style="--accent: #3b82f6;">
        <span class="card-icon">💼</span>
        <h2 class="card-title">Sito Vetrina</h2>
        <p class="card-desc">Pagina professionale con bio, servizi offerti e form di contatto.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/landing-page" class="card" style="--accent: #f59e0b;">
        <span class="card-icon">🚀</span>
        <h2 class="card-title">Landing Page</h2>
        <p class="card-desc">Pagina di lancio ottimizzata per conversione e raccolta contatti.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/blog" class="card" style="--accent: #ec4899;">
        <span class="card-icon">📝</span>
        <h2 class="card-title">Blog &amp; Magazine</h2>
        <p class="card-desc">Sito editoriale con articoli, categorie e ottimizzazione SEO.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/booking" class="card" style="--accent: #14b8a6;">
        <span class="card-icon">📅</span>
        <h2 class="card-title">Booking</h2>
        <p class="card-desc">Sistema di prenotazioni online con calendario e conferma automatica.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/portfolio-creativo" class="card" style="--accent: #a855f7;">
        <span class="card-icon">🎨</span>
        <h2 class="card-title">Portfolio Creativo</h2>
        <p class="card-desc">Galleria lavori con lightbox, filtri per categoria e animazioni.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/ristorante" class="card" style="--accent: #ef4444;">
        <span class="card-icon">🍽️</span>
        <h2 class="card-title">Ristorante</h2>
        <p class="card-desc">Menu digitale, prenotazione tavolo online e mappa interattiva.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/saas" class="card" style="--accent: #06b6d4;">
        <span class="card-icon">📊</span>
        <h2 class="card-title">SaaS Dashboard</h2>
        <p class="card-desc">Applicazione web con area utente, analytics e gestione dati.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/non-profit" class="card" style="--accent: #22c55e;">
        <span class="card-icon">💚</span>
        <h2 class="card-title">Non-Profit</h2>
        <p class="card-desc">Sito per associazioni con donazioni online, eventi e volontariato.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/immobiliare" class="card" style="--accent: #f97316;">
        <span class="card-icon">🏠</span>
        <h2 class="card-title">Immobiliare</h2>
        <p class="card-desc">Catalogo proprietà con filtri avanzati, mappa e schede dettaglio.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

      <a href="/portfolio/wedding" class="card" style="--accent: #e879f9;">
        <span class="card-icon">💍</span>
        <h2 class="card-title">Wedding &amp; Eventi</h2>
        <p class="card-desc">Inviti digitali, conferma RSVP, countdown e gallery fotografica.</p>
        <span class="card-link">Vedi Demo →</span>
      </a>

    </div>
  </main>

  <footer class="footer">
    <p>&copy; 2026 Marco Munich — Tutti i diritti riservati</p>
  </footer>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: #0a0a0a;
      color: #e5e5e5;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Top bar */
    .topbar {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 24px 0;
    }

    .back-link {
      color: #737373;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: color 0.2s;
    }

    .back-link:hover {
      color: #ffffff;
    }

    /* Hero */
    .hero {
      max-width: 1200px;
      margin: 0 auto;
      padding: 80px 24px 64px;
      text-align: center;
    }

    .hero-label {
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #525252;
      margin-bottom: 20px;
    }

    .hero-title {
      font-size: clamp(36px, 6vw, 64px);
      font-weight: 700;
      color: #ffffff;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 24px;
      background: linear-gradient(to bottom right, #ffffff, #a3a3a3);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero-subtitle {
      font-size: 18px;
      line-height: 1.7;
      color: #737373;
      max-width: 560px;
      margin: 0 auto;
    }

    /* Grid */
    .grid-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px 96px;
    }

    .card-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    @media (min-width: 640px) {
      .card-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .card-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Card */
    .card {
      display: flex;
      flex-direction: column;
      padding: 32px;
      border-radius: 16px;
      background: #141414;
      border: 1px solid #1f1f1f;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
      position: relative;
      overflow: hidden;
    }

    .card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .card:hover {
      border-color: #2a2a2a;
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    }

    .card:hover::before {
      opacity: 1;
    }

    .card:hover .card-link {
      color: var(--accent);
    }

    .card-icon {
      font-size: 32px;
      margin-bottom: 20px;
      display: block;
      width: 56px;
      height: 56px;
      line-height: 56px;
      text-align: center;
      background: #1a1a1a;
      border-radius: 12px;
      border: 1px solid #252525;
    }

    .card-title {
      font-size: 18px;
      font-weight: 600;
      color: #ffffff;
      margin-bottom: 10px;
      letter-spacing: -0.01em;
    }

    .card-desc {
      font-size: 14px;
      line-height: 1.6;
      color: #737373;
      flex-grow: 1;
      margin-bottom: 20px;
    }

    .card-link {
      font-size: 14px;
      font-weight: 500;
      color: #525252;
      transition: color 0.3s;
    }

    /* Footer */
    .footer {
      max-width: 1200px;
      margin: 0 auto;
      padding: 32px 24px;
      border-top: 1px solid #1a1a1a;
      text-align: center;
    }

    .footer p {
      font-size: 13px;
      color: #404040;
    }
  </style>
</body>
</html>
