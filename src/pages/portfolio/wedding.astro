---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Wedding — Portfolio Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="/dev/portfolio" class="back-btn">&larr; Torna al Portfolio</a>

  <!-- Floating hearts -->
  <div class="hearts-container">
    <div class="heart" style="--x: 10%; --size: 18px; --dur: 8s; --delay: 0s"></div>
    <div class="heart" style="--x: 25%; --size: 12px; --dur: 12s; --delay: 2s"></div>
    <div class="heart" style="--x: 40%; --size: 22px; --dur: 10s; --delay: 4s"></div>
    <div class="heart" style="--x: 55%; --size: 14px; --dur: 9s; --delay: 1s"></div>
    <div class="heart" style="--x: 70%; --size: 20px; --dur: 11s; --delay: 3s"></div>
    <div class="heart" style="--x: 85%; --size: 16px; --dur: 7s; --delay: 5s"></div>
    <div class="heart" style="--x: 15%; --size: 10px; --dur: 13s; --delay: 6s"></div>
    <div class="heart" style="--x: 60%; --size: 24px; --dur: 14s; --delay: 1.5s"></div>
    <div class="heart" style="--x: 90%; --size: 11px; --dur: 9s; --delay: 7s"></div>
    <div class="heart" style="--x: 35%; --size: 15px; --dur: 10s; --delay: 3.5s"></div>
  </div>

  <!-- Hero with parallax -->
  <section class="hero" id="hero">
    <div class="hero-bg"></div>
    <div class="hero-content fade-in">
      <div class="flourish">
        <svg viewBox="0 0 200 30" fill="none" stroke="#b76e79" stroke-width="1"><path d="M0 15 C40 0, 60 30, 100 15 C140 0, 160 30, 200 15" /></svg>
      </div>
      <p class="hero-subtitle">Insieme per sempre</p>
      <h1 class="hero-title">Giulia <span class="amp">&amp;</span> Alessandro</h1>
      <p class="hero-date">12 Settembre 2026 &mdash; Villa Borghese, Roma</p>
      <div class="flourish flip">
        <svg viewBox="0 0 200 30" fill="none" stroke="#b76e79" stroke-width="1"><path d="M0 15 C40 0, 60 30, 100 15 C140 0, 160 30, 200 15" /></svg>
      </div>
    </div>
  </section>

  <!-- Countdown -->
  <section class="countdown-section fade-in">
    <h2 class="section-label">Mancano</h2>
    <div class="countdown">
      <div class="countdown-item">
        <div class="countdown-num" id="cd-days">175</div>
        <span class="countdown-label">Giorni</span>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-item">
        <div class="countdown-num" id="cd-hours">14</div>
        <span class="countdown-label">Ore</span>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-item">
        <div class="countdown-num" id="cd-mins">32</div>
        <span class="countdown-label">Minuti</span>
      </div>
      <div class="countdown-sep">:</div>
      <div class="countdown-item">
        <div class="countdown-num" id="cd-secs">08</div>
        <span class="countdown-label">Secondi</span>
      </div>
    </div>
  </section>

  <!-- Ornament divider -->
  <div class="divider">
    <svg viewBox="0 0 400 40" fill="none" stroke="#b76e79" stroke-width="1" class="divider-svg">
      <path d="M0 20 C50 5, 80 35, 120 20 C160 5, 200 35, 200 20 C200 5, 240 35, 280 20 C320 5, 350 35, 400 20" />
    </svg>
  </div>

  <!-- Our Story Timeline -->
  <section class="timeline-section">
    <div class="section-header fade-in">
      <h2 class="section-title">La nostra <span class="rose-text">storia</span></h2>
    </div>
    <div class="timeline">
      <div class="timeline-line"></div>
      <div class="timeline-item left fade-in" style="--delay: 0s">
        <div class="timeline-dot"></div>
        <div class="timeline-card">
          <span class="timeline-date">Giugno 2019</span>
          <h3>Il primo incontro</h3>
          <p>Un caff&egrave; in piazza Navona, due sguardi che si incrociano. Da quel momento, tutto &egrave; cambiato.</p>
        </div>
      </div>
      <div class="timeline-item right fade-in" style="--delay: 0.15s">
        <div class="timeline-dot"></div>
        <div class="timeline-card">
          <span class="timeline-date">Dicembre 2020</span>
          <h3>Il primo viaggio insieme</h3>
          <p>Una settimana a Parigi sotto la neve. La citt&agrave; dell&rsquo;amore ha reso tutto pi&ugrave; speciale.</p>
        </div>
      </div>
      <div class="timeline-item left fade-in" style="--delay: 0.3s">
        <div class="timeline-dot"></div>
        <div class="timeline-card">
          <span class="timeline-date">Agosto 2024</span>
          <h3>La proposta</h3>
          <p>Al tramonto sulla costiera amalfitana, con un anello e una domanda che aspettava da tempo.</p>
        </div>
      </div>
      <div class="timeline-item right fade-in" style="--delay: 0.45s">
        <div class="timeline-dot"></div>
        <div class="timeline-card">
          <span class="timeline-date">12 Settembre 2026</span>
          <h3>Il grande giorno</h3>
          <p>Villa Borghese, i nostri amici pi&ugrave; cari e la promessa di una vita insieme.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Ornament divider -->
  <div class="divider">
    <svg viewBox="0 0 400 40" fill="none" stroke="#b76e79" stroke-width="1" class="divider-svg">
      <path d="M0 20 C50 5, 80 35, 120 20 C160 5, 200 35, 200 20 C200 5, 240 35, 280 20 C320 5, 350 35, 400 20" />
    </svg>
  </div>

  <!-- Gallery -->
  <section class="gallery-section">
    <div class="section-header fade-in">
      <h2 class="section-title">I nostri <span class="rose-text">momenti</span></h2>
    </div>
    <div class="gallery-grid fade-in">
      <div class="gallery-item">
        <img src="/images/portfolio/wedding-rings.jpg" alt="Fedi nuziali" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
        <div class="gallery-overlay">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#b76e79" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
      </div>
      <div class="gallery-item tall">
        <img src="/images/portfolio/wedding-flowers.jpg" alt="Fiori nuziali" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
        <div class="gallery-overlay">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#b76e79" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/wedding-cake.jpg" alt="Torta nuziale" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
        <div class="gallery-overlay">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#b76e79" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
      </div>
      <div class="gallery-item wide">
        <img src="/images/portfolio/wedding-venue.jpg" alt="Location matrimonio" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
        <div class="gallery-overlay">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#b76e79" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/wedding-bride.jpg" alt="Sposa" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
        <div class="gallery-overlay">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#b76e79" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/wedding-toast.jpg" alt="Brindisi" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
        <div class="gallery-overlay">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="#b76e79" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </div>
      </div>
    </div>
  </section>

  <!-- RSVP -->
  <section class="rsvp-section">
    <div class="rsvp-inner fade-in">
      <h2 class="section-title light">Conferma la tua <span class="rose-text">presenza</span></h2>
      <p class="rsvp-desc">Saremo felicissimi di averti con noi in questo giorno speciale.</p>
      <form class="rsvp-form" id="rsvp-form">
        <div class="form-group">
          <input type="text" id="rsvp-name" required />
          <label for="rsvp-name">Nome e Cognome</label>
        </div>
        <div class="form-group">
          <input type="email" id="rsvp-email" required />
          <label for="rsvp-email">Email</label>
        </div>
        <div class="form-row">
          <div class="form-group">
            <input type="number" id="rsvp-guests" min="1" max="5" required />
            <label for="rsvp-guests">Numero ospiti</label>
          </div>
          <div class="form-group">
            <select id="rsvp-menu" required>
              <option value="" disabled selected></option>
              <option>Tradizionale</option>
              <option>Vegetariano</option>
              <option>Vegano</option>
            </select>
            <label for="rsvp-menu" class="select-label">Preferenza men&ugrave;</label>
          </div>
        </div>
        <div class="form-group">
          <textarea id="rsvp-msg" rows="3"></textarea>
          <label for="rsvp-msg">Un messaggio per gli sposi</label>
        </div>
        <button type="submit" class="rsvp-btn" id="rsvp-submit">
          <span class="btn-text">Conferma presenza</span>
        </button>
      </form>
    </div>
    <!-- Confetti canvas -->
    <canvas id="confetti-canvas"></canvas>
  </section>

  <footer class="footer fade-in">
    <div class="flourish">
      <svg viewBox="0 0 200 30" fill="none" stroke="#b76e79" stroke-width="1"><path d="M0 15 C40 0, 60 30, 100 15 C140 0, 160 30, 200 15" /></svg>
    </div>
    <p>Giulia &amp; Alessandro &mdash; 12.09.2026</p>
  </footer>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Lato', sans-serif; color: #4a3728; background: #fdf2f8; overflow-x: hidden;
      font-weight: 300;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #fdf2f8; }
    ::-webkit-scrollbar-thumb { background: #b76e79; border-radius: 3px; }
    ::-webkit-scrollbar-thumb:hover { background: #a15d67; }

    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }

    .back-btn {
      position: fixed; bottom: 2rem; left: 20px; z-index: 1000;
      background: rgba(253,242,248,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(183,110,121,0.3); color: #b76e79; padding: 10px 20px; border-radius: 12px;
      text-decoration: none; font-size: 0.875rem; font-weight: 400; transition: all 0.3s ease;
      font-family: 'Lato', sans-serif;
    }
    .back-btn:hover { background: rgba(183,110,121,0.1); transform: translateX(-4px); box-shadow: 0 4px 20px rgba(183,110,121,0.15); }

    .rose-text { color: #b76e79; }
    .section-header { text-align: center; margin-bottom: 48px; }
    .section-title { font-size: 2.5rem; font-weight: 600; color: #4a3728; }
    .section-title.light { color: #fdf2f8; }
    .section-label { text-align: center; font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; color: #b76e79; font-style: italic; margin-bottom: 24px; }

    .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; transition-delay: var(--delay, 0s); }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* Flourish */
    .flourish { width: 160px; margin: 0 auto; opacity: 0.6; }
    .flourish.flip svg { transform: scaleY(-1); }

    /* Divider */
    .divider { text-align: center; padding: 40px 0; }
    .divider-svg { width: 200px; height: 40px; opacity: 0.4; }

    /* ===== FLOATING HEARTS ===== */
    .hearts-container { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .heart {
      position: absolute; left: var(--x); bottom: -30px;
      width: var(--size); height: var(--size);
      animation: floatHeart var(--dur) ease-in-out infinite;
      animation-delay: var(--delay);
      opacity: 0;
    }
    .heart::before, .heart::after {
      content: ''; position: absolute;
      width: var(--size); height: var(--size);
      background: #b76e79; border-radius: 50% 50% 0 0;
    }
    .heart::before { left: calc(var(--size) * -0.5); transform: rotate(-45deg); transform-origin: 100% 100%; }
    .heart::after { left: 0; transform: rotate(45deg); transform-origin: 0 100%; }
    @keyframes floatHeart {
      0% { transform: translateY(0) rotate(0deg) scale(0.5); opacity: 0; }
      10% { opacity: 0.3; }
      50% { opacity: 0.15; }
      100% { transform: translateY(-100vh) rotate(20deg) scale(1); opacity: 0; }
    }

    /* ===== HERO ===== */
    .hero {
      position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center;
      overflow: hidden; padding: 80px 24px;
    }
    .hero-bg {
      position: absolute; inset: 0;
      background: url('/images/portfolio/wedding-couple.jpg') center/cover no-repeat;
      z-index: 0;
    }
    .hero-bg::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(253,242,248,0.82) 0%, rgba(252,231,243,0.78) 50%, rgba(251,207,232,0.75) 100%);
    }
    .hero-content { position: relative; z-index: 2; text-align: center; }
    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif; font-size: 1.25rem; font-style: italic;
      color: #b76e79; margin-bottom: 12px; letter-spacing: 0.1em;
    }
    .hero-title {
      font-size: 4.5rem; font-weight: 600; color: #4a3728; line-height: 1.1; margin: 16px 0;
    }
    .amp {
      font-style: italic; font-weight: 400;
      background: linear-gradient(135deg, #b76e79, #d4a574);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      font-size: 3.5rem;
    }
    .hero-date { font-size: 1.1rem; color: #78716c; letter-spacing: 0.15em; margin-top: 16px; }

    /* ===== COUNTDOWN ===== */
    .countdown-section { padding: 60px 24px; background: #fff; }
    .countdown { display: flex; justify-content: center; align-items: center; gap: 8px; }
    .countdown-item { text-align: center; }
    .countdown-num {
      font-family: 'Cormorant Garamond', serif; font-size: 3.5rem; font-weight: 600; color: #4a3728;
      width: 90px; height: 90px; display: flex; align-items: center; justify-content: center;
      background: #fdf2f8; border-radius: 16px; border: 1px solid rgba(183,110,121,0.15);
      position: relative; overflow: hidden;
    }
    .countdown-num::after {
      content: ''; position: absolute; left: 0; right: 0; top: 50%;
      height: 1px; background: rgba(183,110,121,0.1);
    }
    .countdown-label { font-size: 0.75rem; color: #b76e79; text-transform: uppercase; letter-spacing: 0.1em; margin-top: 8px; display: block; }
    .countdown-sep { font-family: 'Cormorant Garamond', serif; font-size: 2.5rem; color: #b76e79; opacity: 0.4; padding-bottom: 20px; }

    /* ===== TIMELINE ===== */
    .timeline-section { padding: 100px 24px; }
    .timeline { position: relative; max-width: 800px; margin: 0 auto; }
    .timeline-line {
      position: absolute; left: 50%; top: 0; bottom: 0; width: 2px;
      background: rgba(183,110,121,0.2); transform: translateX(-50%);
    }
    .timeline-line::after {
      content: ''; position: absolute; left: 0; top: 0; width: 100%; height: 0;
      background: #b76e79; transition: height 2s ease;
    }
    .timeline.animate .timeline-line::after { height: 100%; }
    .timeline-item {
      position: relative; width: 50%; padding: 0 40px 60px;
    }
    .timeline-item.left { left: 0; text-align: right; }
    .timeline-item.right { left: 50%; text-align: left; }
    .timeline-dot {
      position: absolute; top: 4px; width: 16px; height: 16px;
      background: #b76e79; border: 3px solid #fdf2f8; border-radius: 50%;
      z-index: 2;
    }
    .timeline-item.left .timeline-dot { right: -8px; }
    .timeline-item.right .timeline-dot { left: -8px; }
    .timeline-card {
      background: #fff; border-radius: 16px; padding: 24px;
      border: 1px solid rgba(183,110,121,0.12);
      box-shadow: 0 4px 20px rgba(0,0,0,0.04);
      transition: all 0.3s ease;
    }
    .timeline-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(183,110,121,0.12); }
    .timeline-date { font-size: 0.8rem; color: #b76e79; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
    .timeline-card h3 { font-size: 1.35rem; font-weight: 600; color: #4a3728; margin: 8px 0; }
    .timeline-card p { font-size: 0.9rem; color: #78716c; line-height: 1.7; }

    /* ===== GALLERY ===== */
    .gallery-section { padding: 80px 24px; background: #fff; }
    .gallery-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: 200px;
      gap: 16px; max-width: 900px; margin: 0 auto;
    }
    .gallery-item {
      border-radius: 16px; overflow: hidden; position: relative; cursor: pointer;
      transition: transform 0.4s ease;
    }
    .gallery-item.tall { grid-row: span 2; }
    .gallery-item.wide { grid-column: span 2; }
    .gallery-item:hover { transform: scale(1.03); z-index: 2; }
    .gallery-overlay {
      position: absolute; inset: 0; background: rgba(183,110,121,0.2);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.3s ease;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }

    /* ===== RSVP ===== */
    .rsvp-section {
      padding: 100px 24px; position: relative; overflow: hidden;
      background: linear-gradient(160deg, #4a3728 0%, #3d2d1f 100%);
    }
    .rsvp-inner { max-width: 560px; margin: 0 auto; position: relative; z-index: 2; }
    .rsvp-desc { text-align: center; color: #c4a882; font-size: 1.05rem; margin: 12px 0 40px; line-height: 1.7; }
    .rsvp-form { display: flex; flex-direction: column; gap: 28px; }

    /* Floating label inputs */
    .form-group { position: relative; }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%; padding: 16px 0 8px; border: none;
      border-bottom: 2px solid rgba(183,110,121,0.3);
      background: transparent; color: #fdf2f8; font-size: 1rem;
      font-family: 'Lato', sans-serif; outline: none; transition: border-color 0.3s ease;
    }
    .form-group select { cursor: pointer; }
    .form-group select option { color: #4a3728; background: #fff; }
    .form-group label {
      position: absolute; top: 16px; left: 0;
      font-size: 0.9rem; color: #c4a882; pointer-events: none;
      transition: all 0.3s ease;
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-bottom-color: #b76e79; }
    .form-group input:focus ~ label,
    .form-group input:valid ~ label,
    .form-group textarea:focus ~ label,
    .form-group textarea:valid ~ label,
    .form-group select:focus ~ label,
    .form-group select:valid ~ .select-label {
      top: -4px; font-size: 0.7rem; color: #b76e79;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

    .rsvp-btn {
      font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600;
      padding: 16px 40px; border: 2px solid #b76e79; border-radius: 40px;
      background: transparent; color: #b76e79; cursor: pointer;
      transition: all 0.4s ease; position: relative; overflow: hidden; align-self: center;
    }
    .rsvp-btn::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, #b76e79, #d4a574);
      transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease;
      z-index: 0;
    }
    .rsvp-btn:hover::before { transform: scaleX(1); }
    .rsvp-btn:hover { color: #fff; border-color: transparent; }
    .btn-text { position: relative; z-index: 1; }

    #confetti-canvas {
      position: absolute; inset: 0; pointer-events: none; z-index: 3;
    }

    /* Footer */
    .footer {
      text-align: center; padding: 60px 24px; color: #b76e79;
      font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-style: italic;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-title { font-size: 2.75rem; }
      .amp { font-size: 2.25rem; }
      .countdown-num { width: 65px; height: 65px; font-size: 2.5rem; }
      .timeline-line { left: 24px; }
      .timeline-item { width: 100%; left: 0 !important; padding-left: 56px; padding-right: 0; text-align: left !important; }
      .timeline-dot { left: 16px !important; right: auto !important; }
      .gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 200px; }
      .gallery-item.tall, .gallery-item.wide { grid-row: span 1; grid-column: span 1; }
      .form-row { grid-template-columns: 1fr; }
      .section-title { font-size: 2rem; }
      .back-btn { top: 12px; left: 12px; font-size: 0.8rem; padding: 8px 14px; }
    }
    @media (max-width: 480px) {
      .hero-title { font-size: 2rem; }
      .hero { padding: 60px 20px; }
      .countdown-num { width: 52px; height: 52px; font-size: 1.8rem; }
      .countdown-sep { font-size: 1.6rem; padding-bottom: 14px; }
      .timeline-section { padding: 60px 20px; }
      .gallery-section { padding: 60px 20px; }
    }
  </style>

  <script is:inline>
    // Intersection Observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          // Animate timeline line
          const tl = entry.target.closest('.timeline');
          if (tl) tl.classList.add('animate');
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // Parallax hero
    window.addEventListener('scroll', () => {
      const hero = document.getElementById('hero');
      if (hero) {
        const scrolled = window.scrollY;
        hero.querySelector('.hero-bg').style.transform = 'translateY(' + scrolled * 0.4 + 'px)';
      }
    });

    // Countdown timer
    function updateCountdown() {
      const wedding = new Date('2026-09-12T15:00:00');
      const now = new Date();
      const diff = wedding - now;
      if (diff <= 0) return;
      const days = Math.floor(diff / (1000 * 60 * 60 * 24));
      const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const secs = Math.floor((diff % (1000 * 60)) / 1000);
      document.getElementById('cd-days').textContent = days;
      document.getElementById('cd-hours').textContent = String(hours).padStart(2, '0');
      document.getElementById('cd-mins').textContent = String(mins).padStart(2, '0');
      document.getElementById('cd-secs').textContent = String(secs).padStart(2, '0');
    }
    updateCountdown();
    setInterval(updateCountdown, 1000);

    // Confetti on RSVP hover
    const canvas = document.getElementById('confetti-canvas');
    const ctx = canvas.getContext('2d');
    let confettiParticles = [];
    let animating = false;

    function resizeCanvas() {
      const section = canvas.parentElement;
      canvas.width = section.offsetWidth;
      canvas.height = section.offsetHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    function createConfetti() {
      confettiParticles = [];
      const colors = ['#b76e79', '#d4a574', '#f9a8d4', '#fbbf24', '#c084fc'];
      for (let i = 0; i < 60; i++) {
        confettiParticles.push({
          x: canvas.width / 2 + (Math.random() - 0.5) * 200,
          y: canvas.height * 0.7,
          vx: (Math.random() - 0.5) * 10,
          vy: -Math.random() * 12 - 4,
          size: Math.random() * 6 + 3,
          color: colors[Math.floor(Math.random() * colors.length)],
          rotation: Math.random() * 360,
          rotSpeed: (Math.random() - 0.5) * 10,
          life: 1
        });
      }
    }

    function animateConfetti() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;
      confettiParticles.forEach(p => {
        if (p.life <= 0) return;
        alive = true;
        p.x += p.vx;
        p.vy += 0.3;
        p.y += p.vy;
        p.rotation += p.rotSpeed;
        p.life -= 0.008;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate((p.rotation * Math.PI) / 180);
        ctx.globalAlpha = p.life;
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.6);
        ctx.restore();
      });
      if (alive) {
        requestAnimationFrame(animateConfetti);
      } else {
        animating = false;
      }
    }

    document.getElementById('rsvp-submit').addEventListener('mouseenter', () => {
      if (!animating) {
        animating = true;
        createConfetti();
        animateConfetti();
      }
    });

    // ===== RSVP FORM SUBMIT =====
    document.getElementById('rsvp-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('rsvp-name').value.trim();
      const guests = document.getElementById('rsvp-guests').value;
      if (!name) { showWeddingToast('Inserisci il tuo nome'); return; }
      // Trigger confetti
      animating = true;
      createConfetti();
      animateConfetti();
      // Show success message
      const form = document.getElementById('rsvp-form');
      form.style.display = 'none';
      const success = document.createElement('div');
      success.innerHTML = `<div style="text-align:center;padding:32px 0;">
        <div style="font-size:3rem;margin-bottom:16px">🎊</div>
        <h3 style="font-family:'Playfair Display',serif;font-size:1.5rem;color:#b76e79;margin-bottom:12px">Grazie, ${name}!</h3>
        <p style="color:#8b7355;line-height:1.7">La tua presenza è confermata per ${guests || '1'} ${parseInt(guests) === 1 ? 'ospite' : 'ospiti'}.<br>Giulia & Alessandro non vedono l'ora di festeggiare con te!</p>
      </div>`;
      form.parentNode.insertBefore(success, form);
    });

    // ===== GALLERY LIGHTBOX =====
    const weddingPhotos = ['💒','🌸','🥂','💃','🎂','🌹'];
    const weddingLabels = ['La cerimonia','Decorazioni floreali','Il brindisi','Primo ballo','La torta','Bouquet'];
    let wPhoto = 0;
    document.querySelectorAll('.gallery-item').forEach((item, i) => {
      item.style.cursor = 'pointer';
      item.addEventListener('click', () => {
        wPhoto = i % weddingPhotos.length;
        document.getElementById('wLightboxEmoji').textContent = weddingPhotos[wPhoto];
        document.getElementById('wLightboxLabel').textContent = weddingLabels[wPhoto];
        document.getElementById('wLightboxCounter').textContent = (wPhoto+1) + ' / ' + weddingPhotos.length;
        document.getElementById('wLightbox').classList.add('open');
        document.getElementById('wLightboxOverlay').classList.add('open');
        document.body.style.overflow = 'hidden';
      });
    });
    function closeWLightbox() {
      document.getElementById('wLightbox').classList.remove('open');
      document.getElementById('wLightboxOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }
    function wLightboxNav(dir) {
      wPhoto = (wPhoto + dir + weddingPhotos.length) % weddingPhotos.length;
      document.getElementById('wLightboxEmoji').textContent = weddingPhotos[wPhoto];
      document.getElementById('wLightboxLabel').textContent = weddingLabels[wPhoto];
      document.getElementById('wLightboxCounter').textContent = (wPhoto+1) + ' / ' + weddingPhotos.length;
    }

    let wToastTimeout;
    function showWeddingToast(msg) {
      const t = document.getElementById('w-toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(wToastTimeout);
      wToastTimeout = setTimeout(() => t.classList.remove('show'), 3000);
    }
  </script>

  <!-- Gallery Lightbox -->
  <div style="position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:9998;opacity:0;pointer-events:none;transition:opacity 0.3s" id="wLightboxOverlay" onclick="closeWLightbox()"></div>
  <div id="wLightbox" style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);width:min(500px,90vw);background:#faf8f5;border-radius:16px;z-index:9999;opacity:0;pointer-events:none;transition:all 0.35s cubic-bezier(0.4,0,0.2,1);overflow:hidden;">
    <button onclick="closeWLightbox()" style="position:absolute;top:12px;right:12px;background:rgba(0,0,0,0.1);border:none;width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:0.9rem;color:#5a3e35;">✕</button>
    <div style="height:260px;display:flex;align-items:center;justify-content:center;background:#f9f1ea;font-size:7rem" id="wLightboxEmoji">💒</div>
    <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 24px;">
      <div>
        <div style="font-family:'Playfair Display',serif;color:#b76e79;font-size:1rem" id="wLightboxLabel">La cerimonia</div>
        <div style="font-size:0.75rem;color:#bbb" id="wLightboxCounter">1 / 6</div>
      </div>
      <div style="display:flex;gap:8px">
        <button onclick="wLightboxNav(-1)" style="background:#f0e8e2;border:none;width:36px;height:36px;border-radius:50%;cursor:pointer;color:#b76e79;font-size:1rem;">←</button>
        <button onclick="wLightboxNav(1)" style="background:#f0e8e2;border:none;width:36px;height:36px;border-radius:50%;cursor:pointer;color:#b76e79;font-size:1rem;">→</button>
      </div>
    </div>
  </div>
  <div id="w-toast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#1a1208;border:1px solid #b76e79;color:#b76e79;padding:13px 26px;border-radius:50px;font-size:0.84rem;z-index:99999;opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);white-space:nowrap;pointer-events:none;"></div>
  <style>#wLightbox.open,#wLightboxOverlay.open{opacity:1!important;pointer-events:all!important;transform:translate(-50%,-50%) scale(1)!important}#w-toast.show{opacity:1!important;transform:translateX(-50%) translateY(0)!important}</style>
</body>
</html>
