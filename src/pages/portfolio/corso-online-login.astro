---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login — La Tua Academy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0118;
      color: #e0dce8;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow-x: hidden;
      position: relative;
    }

    /* Animated gradient orbs */
    .orb {
      position: fixed;
      border-radius: 50%;
      filter: blur(100px);
      opacity: 0.4;
      pointer-events: none;
      z-index: 0;
    }
    .orb-1 {
      width: 500px; height: 500px;
      background: radial-gradient(circle, #7c3aed 0%, transparent 70%);
      top: -10%; left: -10%;
      animation: orbFloat1 12s ease-in-out infinite;
    }
    .orb-2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, #06b6d4 0%, transparent 70%);
      bottom: -10%; right: -10%;
      animation: orbFloat2 15s ease-in-out infinite;
    }
    .orb-3 {
      width: 300px; height: 300px;
      background: radial-gradient(circle, #a78bfa 0%, transparent 70%);
      top: 50%; left: 60%;
      animation: orbFloat3 10s ease-in-out infinite;
    }
    @keyframes orbFloat1 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(80px, 60px) scale(1.1); }
      66% { transform: translate(-40px, 100px) scale(0.9); }
    }
    @keyframes orbFloat2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33% { transform: translate(-60px, -80px) scale(1.15); }
      66% { transform: translate(50px, -40px) scale(0.85); }
    }
    @keyframes orbFloat3 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50% { transform: translate(-100px, -60px) scale(1.2); }
    }

    /* Back button */
    .back-btn {
      position: fixed;
      top: 24px; left: 24px;
      z-index: 100;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: rgba(124, 58, 237, 0.15);
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 12px;
      color: #a78bfa;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      backdrop-filter: blur(12px);
      transition: all 0.3s ease;
    }
    .back-btn:hover {
      background: rgba(124, 58, 237, 0.25);
      border-color: rgba(124, 58, 237, 0.6);
      transform: translateX(-4px);
    }

    /* Card */
    .login-card {
      position: relative;
      z-index: 10;
      width: 100%;
      max-width: 440px;
      margin: 80px 20px 40px;
      background: rgba(20, 10, 40, 0.6);
      border: 1px solid rgba(124, 58, 237, 0.2);
      border-radius: 24px;
      padding: 40px 36px;
      backdrop-filter: blur(24px);
      box-shadow: 0 24px 80px rgba(124, 58, 237, 0.12), 0 0 0 1px rgba(255,255,255,0.04) inset;
    }

    /* Logo */
    .logo {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      text-align: center;
      margin-bottom: 32px;
      background: linear-gradient(135deg, #7c3aed, #a78bfa, #06b6d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Tab switcher */
    .tab-wrapper { position: relative; margin-bottom: 28px; }
    .tab-row {
      display: flex;
      background: rgba(124, 58, 237, 0.08);
      border-radius: 12px;
      padding: 4px;
      position: relative;
    }
    .tab-radio { display: none; }
    .tab-label {
      flex: 1;
      text-align: center;
      padding: 10px 0;
      font-size: 0.9rem;
      font-weight: 600;
      color: rgba(167, 139, 250, 0.6);
      cursor: pointer;
      border-radius: 10px;
      transition: color 0.3s ease;
      z-index: 2;
      position: relative;
    }
    .tab-slider {
      position: absolute;
      top: 4px;
      left: 4px;
      width: calc(50% - 4px);
      height: calc(100% - 8px);
      background: rgba(124, 58, 237, 0.25);
      border-radius: 10px;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1;
    }
    #tab-register:checked ~ .tab-row .tab-slider {
      transform: translateX(100%);
    }
    #tab-login:checked ~ .tab-row .tab-label[for="tab-login"],
    #tab-register:checked ~ .tab-row .tab-label[for="tab-register"] {
      color: #e0dce8;
    }

    /* Tab content */
    .tab-content { display: none; }
    #tab-login:checked ~ .tab-login-content,
    #tab-register:checked ~ .tab-register-content {
      display: block;
      animation: fadeIn 0.3s ease;
    }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    /* Floating label inputs */
    .input-group {
      position: relative;
      margin-bottom: 20px;
    }
    .input-group input[type="text"],
    .input-group input[type="email"],
    .input-group input[type="password"] {
      width: 100%;
      padding: 16px 16px 8px;
      background: rgba(124, 58, 237, 0.06);
      border: 1.5px solid rgba(124, 58, 237, 0.2);
      border-radius: 12px;
      color: #e0dce8;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .input-group input:focus {
      border-color: #7c3aed;
      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.15), 0 0 20px rgba(124, 58, 237, 0.08);
    }
    .input-group.cyan input:focus {
      border-color: #06b6d4;
      box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.15), 0 0 20px rgba(6, 182, 212, 0.08);
    }
    .input-group label {
      position: absolute;
      top: 50%;
      left: 16px;
      transform: translateY(-50%);
      font-size: 0.9rem;
      color: rgba(167, 139, 250, 0.5);
      pointer-events: none;
      transition: all 0.25s ease;
    }
    .input-group input:focus + label,
    .input-group input:not(:placeholder-shown) + label {
      top: 10px;
      transform: translateY(0);
      font-size: 0.7rem;
      color: #a78bfa;
    }
    .input-group.cyan input:focus + label,
    .input-group.cyan input:not(:placeholder-shown) + label {
      color: #06b6d4;
    }

    /* Password toggle */
    .pw-toggle {
      position: absolute;
      right: 14px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: rgba(167, 139, 250, 0.5);
      font-size: 0.8rem;
      transition: color 0.2s;
    }
    .pw-toggle:hover { color: #a78bfa; }

    /* Checkbox */
    .checkbox-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }
    .checkbox-row input[type="checkbox"] {
      appearance: none;
      width: 18px; height: 18px;
      border: 1.5px solid rgba(124, 58, 237, 0.3);
      border-radius: 5px;
      background: rgba(124, 58, 237, 0.06);
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
      transition: all 0.2s;
    }
    .checkbox-row input[type="checkbox"]:checked {
      background: #7c3aed;
      border-color: #7c3aed;
    }
    .checkbox-row input[type="checkbox"]:checked::after {
      content: '';
      position: absolute;
      left: 5px; top: 2px;
      width: 5px; height: 9px;
      border: solid #fff;
      border-width: 0 2px 2px 0;
      transform: rotate(45deg);
    }
    .checkbox-row label {
      font-size: 0.85rem;
      color: rgba(224, 220, 232, 0.7);
      cursor: pointer;
    }

    /* Buttons */
    .btn-primary {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 12px;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      color: #fff;
    }
    .btn-purple {
      background: linear-gradient(135deg, #7c3aed, #6d28d9);
      box-shadow: 0 4px 20px rgba(124, 58, 237, 0.3);
    }
    .btn-purple:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(124, 58, 237, 0.45);
    }
    .btn-cyan {
      background: linear-gradient(135deg, #06b6d4, #0891b2);
      box-shadow: 0 4px 20px rgba(6, 182, 212, 0.3);
    }
    .btn-cyan:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(6, 182, 212, 0.45);
    }

    /* Forgot password */
    .forgot-link {
      display: block;
      text-align: right;
      font-size: 0.8rem;
      color: rgba(167, 139, 250, 0.6);
      text-decoration: none;
      margin-bottom: 20px;
      transition: color 0.2s;
    }
    .forgot-link:hover { color: #a78bfa; }

    /* Divider */
    .divider {
      display: flex;
      align-items: center;
      gap: 16px;
      margin: 24px 0;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(124, 58, 237, 0.15);
    }
    .divider span {
      font-size: 0.8rem;
      color: rgba(167, 139, 250, 0.4);
      text-transform: lowercase;
    }

    /* Google button */
    .btn-google {
      width: 100%;
      padding: 12px;
      border: 1.5px solid rgba(124, 58, 237, 0.25);
      border-radius: 12px;
      background: transparent;
      color: #e0dce8;
      font-family: 'Inter', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      transition: all 0.3s ease;
    }
    .btn-google:hover {
      background: rgba(124, 58, 237, 0.08);
      border-color: rgba(124, 58, 237, 0.45);
      transform: translateY(-1px);
    }
    .btn-google svg { width: 20px; height: 20px; }

    /* Footer */
    .card-footer {
      text-align: center;
      margin-top: 28px;
      font-size: 0.8rem;
      color: rgba(167, 139, 250, 0.4);
    }
    .card-footer a {
      color: #a78bfa;
      text-decoration: none;
      transition: color 0.2s;
    }
    .card-footer a:hover { color: #c4b5fd; }

    /* Responsive */
    @media (max-width: 480px) {
      .login-card {
        margin: 70px 12px 24px;
        padding: 28px 20px;
        border-radius: 20px;
      }
      .logo { font-size: 1.4rem; }
      .back-btn { top: 16px; left: 16px; padding: 8px 14px; font-size: 0.8rem; }
      .orb { opacity: 0.25; }
    }
  </style>
</head>
<body>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <a href="/portfolio/corso-online" class="back-btn">&larr; Torna al Corso</a>

  <div class="login-card">
    <div class="logo">La Tua Academy</div>

    <div class="tab-wrapper">
      <input type="radio" name="tab" id="tab-login" class="tab-radio" checked />
      <input type="radio" name="tab" id="tab-register" class="tab-radio" />
      <div class="tab-row">
        <label class="tab-label" for="tab-login">Accedi</label>
        <label class="tab-label" for="tab-register">Registrati</label>
        <div class="tab-slider"></div>
      </div>

      <!-- Login Tab -->
      <div class="tab-login-content tab-content">
        <form onsubmit="return false;" style="margin-top: 24px;">
          <div class="input-group">
            <input type="email" id="login-email" placeholder=" " autocomplete="email" />
            <label for="login-email">Email</label>
          </div>
          <div class="input-group">
            <input type="password" id="login-password" placeholder=" " autocomplete="current-password" />
            <label for="login-password">Password</label>
            <button type="button" class="pw-toggle" onclick="togglePw(this)" aria-label="Mostra password">Mostra</button>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="remember" />
            <label for="remember">Ricordami</label>
          </div>
          <a href="#" class="forgot-link">Hai dimenticato la password?</a>
          <button type="submit" class="btn-primary btn-purple">Accedi</button>
        </form>
        <div class="divider"><span>oppure</span></div>
        <button type="button" class="btn-google">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Accedi con Google
        </button>
      </div>

      <!-- Register Tab -->
      <div class="tab-register-content tab-content">
        <form onsubmit="return false;" style="margin-top: 24px;">
          <div class="input-group cyan">
            <input type="text" id="reg-name" placeholder=" " autocomplete="name" />
            <label for="reg-name">Nome</label>
          </div>
          <div class="input-group cyan">
            <input type="email" id="reg-email" placeholder=" " autocomplete="email" />
            <label for="reg-email">Email</label>
          </div>
          <div class="input-group cyan">
            <input type="password" id="reg-password" placeholder=" " autocomplete="new-password" />
            <label for="reg-password">Password</label>
            <button type="button" class="pw-toggle" onclick="togglePw(this)" aria-label="Mostra password">Mostra</button>
          </div>
          <div class="input-group cyan">
            <input type="password" id="reg-confirm" placeholder=" " autocomplete="new-password" />
            <label for="reg-confirm">Conferma Password</label>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="terms" />
            <label for="terms">Accetto i Termini e le Condizioni</label>
          </div>
          <button type="submit" class="btn-primary btn-cyan">Crea Account</button>
        </form>
      </div>
    </div>

    <div class="card-footer">Hai bisogno di aiuto? <a href="#">Contattaci</a></div>
  </div>

  <script>
    function togglePw(btn) {
      const input = btn.previousElementSibling;
      if (!input) return;
      const isPassword = input.type === 'password';
      input.type = isPassword ? 'text' : 'password';
      btn.textContent = isPassword ? 'Nascondi' : 'Mostra';
    }
  </script>
</body>
</html>
