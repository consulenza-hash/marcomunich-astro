---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chi Siamo — Casa &amp; Territorio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="/portfolio/immobiliare" class="back-btn">&larr; Torna all'agenzia</a>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content fade-in">
      <span class="hero-tag">Chi Siamo</span>
      <h1 class="hero-title">Casa &amp; Territorio &mdash; <span class="gradient-text">Dal 1998 al servizio del territorio</span></h1>
      <p class="hero-desc">Una storia di famiglia, passione per il territorio e attenzione al cliente. Da quasi tre decenni, il punto di riferimento immobiliare per Verona e il Lago di Garda.</p>
    </div>
    <div class="hero-decor">
      <div class="hero-orb orb-1"></div>
      <div class="hero-orb orb-2"></div>
    </div>
  </section>

  <!-- Story -->
  <section class="story-section">
    <div class="story-inner">
      <div class="section-header fade-in">
        <h2 class="section-title">La nostra <span class="gradient-text">storia</span></h2>
      </div>
      <div class="story-content fade-in">
        <p>Nel 1998, Roberto Colombo apre il primo ufficio in Via Verdi, nel cuore di Verona. L'intuizione era semplice ma lungimirante: un'agenzia immobiliare che conoscesse ogni angolo del territorio, dal centro storico scaligero alle rive del Lago di Garda, dalla campagna vicentina alle colline della Valpolicella.</p>
        <p>Quella che era nata come un'attivit&agrave; individuale &egrave; cresciuta negli anni in un'azienda familiare. Oggi, con la seconda generazione alla guida, Casa &amp; Territorio conta un team di professionisti certificati e una rete di collaborazioni consolidata con notai, geometri, architetti e istituti di credito.</p>
        <p>La filosofia non &egrave; mai cambiata: ogni immobile ha una storia, ogni cliente merita un percorso personalizzato. Non vendiamo case &mdash; costruiamo relazioni.</p>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="stats-inner">
      <div class="stat-item fade-in" style="--delay: 0s">
        <span class="stat-num"><span class="counter" data-target="500">0</span>+</span>
        <span class="stat-label">Vendite concluse</span>
      </div>
      <div class="stat-item fade-in" style="--delay: 0.1s">
        <span class="stat-num"><span class="counter" data-target="1200">0</span>+</span>
        <span class="stat-label">Contratti di affitto</span>
      </div>
      <div class="stat-item fade-in" style="--delay: 0.2s">
        <span class="stat-num"><span class="counter" data-target="28">0</span></span>
        <span class="stat-label">Anni di esperienza</span>
      </div>
      <div class="stat-item fade-in" style="--delay: 0.3s">
        <span class="stat-num"><span class="counter" data-target="98">0</span>%</span>
        <span class="stat-label">Clienti soddisfatti</span>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="team-section">
    <div class="team-inner">
      <div class="section-header fade-in">
        <h2 class="section-title">Il nostro <span class="gradient-text">team</span></h2>
        <p class="section-sub">Professionisti con esperienza, passione e conoscenza del territorio</p>
      </div>
      <div class="team-grid">
        <div class="team-card fade-in" style="--delay: 0s">
          <div class="team-avatar" style="background:#2563eb;">LR</div>
          <h3>Laura Romani</h3>
          <span class="team-role">Responsabile vendite</span>
          <p>15 anni di esperienza nel settore immobiliare, specializzata in immobili di pregio nel centro storico di Verona e nelle zone residenziali pi&ugrave; esclusive della provincia.</p>
        </div>
        <div class="team-card fade-in" style="--delay: 0.1s">
          <div class="team-avatar" style="background:#1e40af;">MC</div>
          <h3>Marco Colombo</h3>
          <span class="team-role">Specialista affitti</span>
          <p>Certificato FIAIP, gestisce oltre 200 contratti di locazione attivi. Esperto in contratti commerciali, residenziali e transitorio per studenti e professionisti.</p>
        </div>
        <div class="team-card fade-in" style="--delay: 0.2s">
          <div class="team-avatar" style="background:#2563eb;">SB</div>
          <h3>Sara Bellini</h3>
          <span class="team-role">Consulente zona laghi</span>
          <p>Esperta del mercato immobiliare del Lago di Garda e della Valpolicella. Accompagna clienti italiani e internazionali nella ricerca della propriet&agrave; ideale.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Come Lavoriamo -->
  <section class="process-section">
    <div class="process-inner">
      <div class="section-header fade-in">
        <h2 class="section-title">Come <span class="gradient-text">lavoriamo</span></h2>
        <p class="section-sub">Un percorso chiaro e trasparente, dall'inizio alla fine</p>
      </div>
      <div class="process-grid">
        <div class="process-card fade-in" style="--delay: 0s">
          <span class="process-num">01</span>
          <h3>Valutazione gratuita</h3>
          <p>Analisi di mercato e stima del valore reale dell'immobile, senza impegno.</p>
        </div>
        <div class="process-card fade-in" style="--delay: 0.1s">
          <span class="process-num">02</span>
          <h3>Shooting fotografico professionale</h3>
          <p>Servizio fotografico, video e virtual tour per presentare al meglio la propriet&agrave;.</p>
        </div>
        <div class="process-card fade-in" style="--delay: 0.15s">
          <span class="process-num">03</span>
          <h3>Pubblicazione su 15+ portali</h3>
          <p>Visibilit&agrave; massima su Immobiliare.it, Idealista, Casa.it e oltre 12 piattaforme.</p>
        </div>
        <div class="process-card fade-in" style="--delay: 0.2s">
          <span class="process-num">04</span>
          <h3>Assistenza legale e notarile</h3>
          <p>Supporto completo nella gestione di documenti, contratti e pratiche burocratiche.</p>
        </div>
        <div class="process-card fade-in" style="--delay: 0.25s">
          <span class="process-num">05</span>
          <h3>Supporto post-vendita</h3>
          <p>Non ci fermiamo al rogito: restiamo al tuo fianco anche dopo la conclusione dell'affare.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="partners-section">
    <div class="partners-inner fade-in">
      <div class="section-header">
        <h2 class="section-title">Convenzioni <span class="gradient-text">mutui</span></h2>
        <p class="section-sub">Accordi privilegiati con i principali istituti di credito</p>
      </div>
      <div class="partners-grid">
        <div class="partner-card">
          <span class="partner-name">Intesa Sanpaolo</span>
          <span class="partner-desc">Tassi agevolati per i nostri clienti</span>
        </div>
        <div class="partner-card">
          <span class="partner-name">UniCredit</span>
          <span class="partner-desc">Pre-delibera rapida e consulenza dedicata</span>
        </div>
        <div class="partner-card">
          <span class="partner-name">Banco BPM</span>
          <span class="partner-desc">Soluzioni flessibili per acquisto e ristrutturazione</span>
        </div>
      </div>
    </div>
  </section>

  <footer>
    <p class="footer-name">Casa &amp; Territorio Srl</p>
    <p>Via Verdi 12, 37121 Verona (VR) &mdash; Tel. 045 800 1234 &mdash; info@casaeterritorio.it</p>
    <p style="margin-top:8px;">P.IVA 04567890123 &mdash; &copy; 2026 Tutti i diritti riservati.</p>
  </footer>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #1e293b; background: #f8fafc; overflow-x: hidden; }

    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f1f5f9; }
    ::-webkit-scrollbar-thumb { background: #2563eb; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #1d4ed8; }

    h1, h2, h3 { font-family: 'Plus Jakarta Sans', sans-serif; }

    .back-btn {
      position: fixed; top: 20px; left: 20px; z-index: 1000;
      background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(37,99,235,0.2); color: #1e40af; padding: 10px 20px; border-radius: 12px;
      text-decoration: none; font-size: 0.875rem; font-weight: 600; transition: all 0.3s ease;
    }
    .back-btn:hover { background: rgba(37,99,235,0.1); transform: translateX(-4px); box-shadow: 0 4px 20px rgba(37,99,235,0.15); }

    .gradient-text { background: linear-gradient(135deg, #2563eb, #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .section-header { text-align: center; margin-bottom: 48px; }
    .section-title { font-size: 2.25rem; font-weight: 800; color: #1e293b; }
    .section-sub { color: #64748b; font-size: 1rem; margin-top: 8px; }

    .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; transition-delay: var(--delay, 0s); }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* Hero */
    .hero {
      position: relative; padding: 120px 24px 80px; text-align: center;
      background: linear-gradient(180deg, #fff 0%, #f0f4ff 100%); overflow: hidden;
    }
    .hero-content { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }
    .hero-tag {
      display: inline-block; background: rgba(37,99,235,0.08); color: #2563eb;
      padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; margin-bottom: 20px;
    }
    .hero-title { font-size: 2.75rem; font-weight: 800; line-height: 1.15; color: #1e293b; margin-bottom: 16px; }
    .hero-desc { font-size: 1.1rem; color: #64748b; max-width: 560px; margin: 0 auto; line-height: 1.7; }

    .hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.12; pointer-events: none; }
    .hero-orb.orb-1 { width: 400px; height: 400px; background: #2563eb; top: -100px; right: -100px; animation: float1 20s ease-in-out infinite; }
    .hero-orb.orb-2 { width: 300px; height: 300px; background: #7c3aed; bottom: -80px; left: -80px; animation: float2 25s ease-in-out infinite; }
    @keyframes float1 { 0%, 100% { transform: translate(0,0); } 50% { transform: translate(-40px, 60px); } }
    @keyframes float2 { 0%, 100% { transform: translate(0,0); } 50% { transform: translate(50px, -40px); } }

    /* Story */
    .story-section { padding: 80px 24px; max-width: 800px; margin: 0 auto; }
    .story-content p { font-size: 1.05rem; color: #475569; line-height: 1.85; margin-bottom: 20px; }
    .story-content p:last-child { margin-bottom: 0; }

    /* Stats */
    .stats-section { padding: 80px 24px; background: linear-gradient(135deg, #1e293b, #0f172a); }
    .stats-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; max-width: 1000px; margin: 0 auto; text-align: center; }
    .stat-num { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2.75rem; font-weight: 800; color: #fff; display: block; }
    .stat-label { font-size: 0.9rem; color: #94a3b8; margin-top: 4px; display: block; }

    /* Team */
    .team-section { padding: 100px 24px; max-width: 1100px; margin: 0 auto; }
    .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .team-card {
      text-align: center; background: #fff; border-radius: 20px; padding: 36px 24px;
      border: 1px solid #e2e8f0; transition: all 0.4s ease;
    }
    .team-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(37,99,235,0.1); }
    .team-avatar {
      width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 16px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 700; font-size: 1.2rem; font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .team-card h3 { font-size: 1.1rem; font-weight: 700; color: #1e293b; margin-bottom: 4px; }
    .team-role {
      display: inline-block; font-size: 0.8rem; font-weight: 600; color: #2563eb;
      margin-bottom: 12px;
    }
    .team-card p { font-size: 0.88rem; color: #64748b; line-height: 1.65; }

    /* Process */
    .process-section { padding: 100px 24px; background: #f0f4ff; }
    .process-inner { max-width: 1000px; margin: 0 auto; }
    .process-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px; }
    .process-card {
      background: #fff; border-radius: 16px; padding: 28px 24px;
      border: 1px solid #e2e8f0; transition: all 0.3s ease;
    }
    .process-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(37,99,235,0.08); }
    .process-num {
      display: inline-block; font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.8rem; font-weight: 800; color: #2563eb;
      background: rgba(37,99,235,0.08); padding: 4px 12px; border-radius: 8px;
      margin-bottom: 14px;
    }
    .process-card h3 { font-size: 1rem; font-weight: 700; color: #1e293b; margin-bottom: 8px; }
    .process-card p { font-size: 0.88rem; color: #64748b; line-height: 1.6; }

    /* Partners */
    .partners-section { padding: 80px 24px; max-width: 900px; margin: 0 auto; }
    .partners-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .partner-card {
      text-align: center; background: #fff; border-radius: 16px; padding: 28px 20px;
      border: 1px solid #e2e8f0; transition: all 0.3s ease;
    }
    .partner-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(37,99,235,0.08); }
    .partner-name { display: block; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.1rem; font-weight: 700; color: #1e293b; margin-bottom: 6px; }
    .partner-desc { font-size: 0.85rem; color: #64748b; }

    /* Footer */
    footer { text-align: center; padding: 48px 24px 32px; color: #64748b; font-size: 0.85rem; border-top: 1px solid #e2e8f0; max-width: 1200px; margin: 0 auto; }
    .footer-name { font-weight: 700; color: #1e293b; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.1rem; margin-bottom: 8px; }

    /* Responsive */
    @media (max-width: 1024px) {
      .team-grid { grid-template-columns: repeat(2, 1fr); }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
      .partners-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .hero-title { font-size: 2rem; }
      .team-grid { grid-template-columns: 1fr; }
      .stats-inner { grid-template-columns: 1fr 1fr; gap: 24px; }
      .stat-num { font-size: 2rem; }
      .section-title { font-size: 1.75rem; }
      .partners-grid { grid-template-columns: 1fr; }
      .process-grid { grid-template-columns: 1fr; }
      .back-btn { top: 12px; left: 12px; font-size: 0.8rem; padding: 8px 14px; }
    }
  </style>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          entry.target.querySelectorAll('.counter').forEach(c => animateCounter(c));
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    function animateCounter(el) {
      if (el.dataset.animated) return;
      el.dataset.animated = 'true';
      const target = parseFloat(el.dataset.target);
      const duration = 2000;
      const start = performance.now();
      function update(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(target * eased).toLocaleString('it-IT');
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }
  </script>
</body>
</html>
