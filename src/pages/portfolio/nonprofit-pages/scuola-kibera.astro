---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Scuola di Kibera — Mani Aperte ODV</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="/portfolio/non-profit" class="back-btn">&larr; Torna a Mani Aperte</a>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/portfolio/np-children.jpg" alt="Bambini di Kibera" loading="eager" style="width:100%;height:100%;object-fit:cover;display:block;position:absolute;inset:0;" />
    </div>
    <div class="hero-content fade-in">
      <span class="hero-tag">Progetto attivo</span>
      <h1 class="hero-title">Scuola di Kibera</h1>
      <p class="hero-location">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-3px;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Kibera, Nairobi, Kenya
      </p>
    </div>
    <div class="hero-shape shape-1"></div>
    <div class="hero-shape shape-2"></div>
  </section>

  <!-- Progress -->
  <section class="progress-section">
    <div class="progress-card fade-in">
      <div class="progress-header">
        <div>
          <span class="progress-label">Avanzamento</span>
          <span class="progress-pct">78%</span>
        </div>
        <div class="progress-amounts">
          <span class="raised">&euro;45.000 raccolti</span>
          <span class="goal">su &euro;58.000 obiettivo</span>
        </div>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" style="--target: 78%"></div>
      </div>
      <p class="progress-remaining">Mancano ancora <strong>&euro;13.000</strong> per completare il progetto</p>
    </div>
  </section>

  <!-- Description -->
  <section class="description">
    <div class="desc-inner">
      <div class="desc-text fade-in">
        <h2>Il progetto</h2>
        <p>La Scuola di Kibera nasce dall'esigenza di offrire un luogo sicuro e dignitoso per l'istruzione dei bambini nello slum pi&ugrave; grande dell'Africa orientale. A Kibera vivono oltre 250.000 persone in condizioni di estrema povert&agrave;, e l'accesso all'istruzione primaria resta una sfida quotidiana per migliaia di famiglie.</p>
        <p>Il nostro obiettivo &egrave; costruire una scuola capace di accogliere 200 bambini tra i 6 e i 12 anni, con 6 aule spaziose e luminose, una biblioteca dotata di 500 volumi in inglese e swahili, e un'area gioco esterna recintata e sicura.</p>
        <p>La scuola sar&agrave; gestita da personale locale formato e stipendiato direttamente dal progetto. Abbiamo scelto di coinvolgere maestranze e artigiani della comunit&agrave; di Kibera per la costruzione, garantendo cos&igrave; un impatto economico immediato sul territorio.</p>
        <p>Il programma didattico seguir&agrave; il curriculum nazionale keniota, integrato da laboratori pratici di informatica, agricoltura urbana e igiene. Ogni bambino ricever&agrave; gratuitamente materiale scolastico, divisa e un pasto caldo al giorno.</p>
      </div>
      <div class="desc-stats fade-in" style="--delay:0.2s">
        <div class="stat-card">
          <span class="stat-num">200</span>
          <span class="stat-label">Bambini da accogliere</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">6</span>
          <span class="stat-label">Aule previste</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">1</span>
          <span class="stat-label">Biblioteca</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">1</span>
          <span class="stat-label">Area gioco</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="timeline-section">
    <div class="section-header fade-in">
      <span class="section-tag">Cronologia</span>
      <h2 class="section-title">Lo stato dei <span class="gradient-text-warm">lavori</span></h2>
    </div>
    <div class="timeline">
      <div class="timeline-item completed fade-in">
        <div class="timeline-marker">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="timeline-content">
          <span class="timeline-date">Marzo 2024</span>
          <h3>Avvio del progetto</h3>
          <p>Acquisizione del terreno, ottenimento dei permessi comunali, avvio della campagna di raccolta fondi.</p>
        </div>
      </div>
      <div class="timeline-item completed fade-in">
        <div class="timeline-marker">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="timeline-content">
          <span class="timeline-date">Luglio 2024</span>
          <h3>Fondamenta completate</h3>
          <p>Scavo, gettata di cemento armato, impianto fognario e predisposizione idrica. Lavoro eseguito da maestranze locali.</p>
        </div>
      </div>
      <div class="timeline-item completed fade-in">
        <div class="timeline-marker">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div class="timeline-content">
          <span class="timeline-date">Dicembre 2024</span>
          <h3>Muri portanti eretti</h3>
          <p>Struttura in blocchi di cemento con rinforzi in acciaio. Tutte e 6 le aule hanno i muri perimetrali completati.</p>
        </div>
      </div>
      <div class="timeline-item current fade-in">
        <div class="timeline-marker">
          <span class="marker-pulse"></span>
        </div>
        <div class="timeline-content">
          <span class="timeline-date">In corso — Marzo 2026</span>
          <h3>Copertura del tetto</h3>
          <p>Installazione della struttura portante in acciaio e delle lamiere zincate. Lavori al 60% di completamento.</p>
        </div>
      </div>
      <div class="timeline-item future fade-in">
        <div class="timeline-marker"></div>
        <div class="timeline-content">
          <span class="timeline-date">Settembre 2026</span>
          <h3>Inaugurazione prevista</h3>
          <p>Completamento finiture, arredi, attrezzature didattiche e cerimonia di apertura con la comunit&agrave;.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Fund Breakdown -->
  <section class="funds-section">
    <div class="section-header fade-in">
      <span class="section-tag">Trasparenza</span>
      <h2 class="section-title">Come vengono <span class="gradient-text-warm">usati i fondi</span></h2>
    </div>
    <div class="funds-grid">
      <div class="fund-card fade-in" style="--delay:0s">
        <div class="fund-amount">&euro;25.000</div>
        <div class="fund-bar"><div class="fund-fill" style="--w:43%"></div></div>
        <h3>Materiali da costruzione</h3>
        <p>Cemento, blocchi, acciaio, lamiere, legname, impianto elettrico e idraulico</p>
      </div>
      <div class="fund-card fade-in" style="--delay:0.1s">
        <div class="fund-amount">&euro;18.000</div>
        <div class="fund-bar"><div class="fund-fill" style="--w:31%"></div></div>
        <h3>Manodopera locale</h3>
        <p>Muratori, carpentieri, elettricisti e idraulici della comunit&agrave; di Kibera</p>
      </div>
      <div class="fund-card fade-in" style="--delay:0.2s">
        <div class="fund-amount">&euro;10.000</div>
        <div class="fund-bar"><div class="fund-fill" style="--w:17%"></div></div>
        <h3>Attrezzature scolastiche</h3>
        <p>Banchi, sedie, lavagne, libri, materiale didattico e informatico</p>
      </div>
      <div class="fund-card fade-in" style="--delay:0.3s">
        <div class="fund-amount">&euro;5.000</div>
        <div class="fund-bar"><div class="fund-fill" style="--w:9%"></div></div>
        <h3>Trasporti e logistica</h3>
        <p>Trasporto materiali, spedizioni dall'Italia, spostamenti del team</p>
      </div>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="gallery-section">
    <div class="section-header fade-in">
      <span class="section-tag">Dal cantiere</span>
      <h2 class="section-title">Immagini dal <span class="gradient-text-warm">campo</span></h2>
    </div>
    <div class="gallery-grid fade-in">
      <div class="gallery-item">
        <img src="/images/portfolio/np-children.jpg" alt="Bambini della scuola" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        <span>I futuri studenti</span>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/np-building.jpg" alt="Costruzione in corso" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        <span>Muri portanti</span>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/np-teamwork.jpg" alt="Lavoro di squadra" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        <span>Maestranze locali</span>
      </div>
      <div class="gallery-item">
        <img src="/images/portfolio/np-volunteers.jpg" alt="Volontari" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        <span>I volontari italiani</span>
      </div>
    </div>
  </section>

  <!-- Donate CTA -->
  <section class="donate-section">
    <div class="donate-inner fade-in">
      <h2 class="section-title light">Dona a questo <span class="gradient-text-warm">progetto</span></h2>
      <p class="donate-desc">Ogni contributo ci avvicina all'inaugurazione. Scegli l'importo che preferisci: anche &euro;10 fanno la differenza.</p>
      <div class="donate-amounts">
        <button class="donate-btn" data-amount="10">&euro;10</button>
        <button class="donate-btn featured" data-amount="25">&euro;25</button>
        <button class="donate-btn" data-amount="50">&euro;50</button>
        <button class="donate-btn" data-amount="100">&euro;100</button>
      </div>
      <button class="cta-btn">Dona ora &rarr;</button>
    </div>
  </section>

  <!-- Updates -->
  <section class="updates-section">
    <div class="section-header fade-in">
      <span class="section-tag">Notizie</span>
      <h2 class="section-title">Aggiornamenti <span class="gradient-text-warm">dal campo</span></h2>
    </div>
    <div class="updates-list">
      <div class="update-card fade-in">
        <div class="update-date">
          <span class="update-day">15</span>
          <span class="update-month">Mar</span>
          <span class="update-year">2026</span>
        </div>
        <div class="update-body">
          <h3>Il tetto prende forma</h3>
          <p>Questa settimana il team ha completato l'installazione della struttura portante in acciaio per il tetto delle prime 4 aule. Le lamiere zincate sono arrivate da Nairobi e l'installazione inizier&agrave; luned&igrave;. Nonostante le piogge dei giorni scorsi, i lavori procedono in linea con le tempistiche previste. Il caposquadra James Ochieng ci ha detto che il morale &egrave; alto e che la comunit&agrave; segue i progressi con entusiasmo.</p>
        </div>
      </div>
      <div class="update-card fade-in">
        <div class="update-date">
          <span class="update-day">28</span>
          <span class="update-month">Feb</span>
          <span class="update-year">2026</span>
        </div>
        <div class="update-body">
          <h3>Visita del team italiano</h3>
          <p>Quattro volontari di Mani Aperte hanno trascorso due settimane a Kibera per verificare lo stato dei lavori e incontrare le famiglie coinvolte. La visita ha confermato la qualit&agrave; delle lavorazioni e il forte legame creato con la comunit&agrave; locale. Abbiamo anche incontrato il preside designato, la Prof.ssa Grace Wanjiku, che ha iniziato a lavorare sulla selezione degli insegnanti.</p>
        </div>
      </div>
    </div>
  </section>

  <footer class="footer fade-in">
    <p>&copy; 2026 Mani Aperte ODV &mdash; C.F. 92012345678 &mdash; Destina il tuo 5x1000: inserisci il nostro codice fiscale nella dichiarazione dei redditi.</p>
  </footer>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Open Sans', sans-serif; color: #1c1917; overflow-x: hidden; background: #fffbeb; }

    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #fef3c7; }
    ::-webkit-scrollbar-thumb { background: #f59e0b; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #d97706; }

    h1, h2, h3 { font-family: 'Poppins', sans-serif; }

    .gradient-text-warm { background: linear-gradient(135deg, #f59e0b, #ef4444); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; transition-delay: var(--delay, 0s); }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    .section-header { text-align: center; margin-bottom: 48px; }
    .section-tag {
      display: inline-block; font-family: 'Poppins', sans-serif;
      font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
      color: #f59e0b; margin-bottom: 12px;
    }
    .section-title { font-size: 2.25rem; font-weight: 700; color: #1c1917; line-height: 1.2; }
    .section-title.light { color: #fff; }

    /* Back button */
    .back-btn {
      position: fixed; top: 20px; left: 20px; z-index: 1000;
      background: rgba(255,255,255,0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(245,158,11,0.3); color: #92400e; padding: 10px 20px; border-radius: 12px;
      text-decoration: none; font-size: 0.875rem; font-weight: 600; transition: all 0.3s ease;
    }
    .back-btn:hover {
      background: rgba(245,158,11,0.15); transform: translateX(-4px);
      box-shadow: 0 4px 20px rgba(245,158,11,0.2);
    }

    /* Hero */
    .hero {
      position: relative; min-height: 60vh; display: flex; align-items: flex-end;
      overflow: hidden; padding: 80px 24px 60px;
    }
    .hero-bg { position: absolute; inset: 0; z-index: 0; }
    .hero-bg::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to top, rgba(28,25,23,0.9) 0%, rgba(28,25,23,0.4) 50%, rgba(28,25,23,0.2) 100%);
    }
    .hero-content { position: relative; z-index: 2; max-width: 800px; }
    .hero-tag {
      display: inline-block; background: rgba(245,158,11,0.9); color: #fff;
      padding: 6px 16px; border-radius: 20px; font-size: 0.8rem; font-weight: 600;
      margin-bottom: 16px; font-family: 'Poppins', sans-serif;
    }
    .hero-title { font-size: 3rem; font-weight: 800; line-height: 1.1; color: #fff; margin-bottom: 12px; }
    .hero-location { font-size: 1.1rem; color: rgba(255,255,255,0.7); }
    .hero-shape { position: absolute; border-radius: 50%; opacity: 0.1; z-index: 1; }
    .shape-1 { width: 300px; height: 300px; background: #f59e0b; top: -80px; right: -60px; }
    .shape-2 { width: 200px; height: 200px; background: #ef4444; bottom: -40px; left: -30px; }

    /* Progress */
    .progress-section { padding: 0 24px; margin-top: -40px; position: relative; z-index: 3; }
    .progress-card {
      max-width: 800px; margin: 0 auto; background: #fff; border-radius: 20px;
      padding: 32px; box-shadow: 0 16px 48px rgba(0,0,0,0.08);
      border: 1px solid rgba(245,158,11,0.1);
    }
    .progress-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 16px; flex-wrap: wrap; gap: 12px; }
    .progress-label { font-size: 0.85rem; color: #78716c; font-weight: 500; }
    .progress-pct { font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 800; color: #f59e0b; margin-left: 8px; }
    .progress-amounts { text-align: right; }
    .raised { display: block; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 1.1rem; color: #1c1917; }
    .goal { font-size: 0.85rem; color: #78716c; }
    .progress-bar { height: 12px; background: #fef3c7; border-radius: 6px; overflow: hidden; }
    .progress-fill {
      height: 100%; width: 0; background: linear-gradient(90deg, #f59e0b, #ef4444);
      border-radius: 6px; transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .progress-fill.animate { width: var(--target); }
    .progress-remaining { margin-top: 12px; font-size: 0.9rem; color: #78716c; text-align: center; }

    /* Description */
    .description { padding: 80px 24px; }
    .desc-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1.5fr 1fr; gap: 60px; align-items: start; }
    .desc-text h2 { font-size: 1.8rem; font-weight: 700; margin-bottom: 20px; color: #1c1917; }
    .desc-text p { font-size: 0.95rem; color: #57534e; line-height: 1.8; margin-bottom: 16px; }
    .desc-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .stat-card {
      background: #fff; border-radius: 16px; padding: 24px; text-align: center;
      border: 1px solid rgba(245,158,11,0.1); box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    }
    .stat-num { display: block; font-family: 'Poppins', sans-serif; font-size: 2rem; font-weight: 800; color: #92400e; }
    .stat-label { font-size: 0.8rem; color: #78716c; font-weight: 500; }

    /* Timeline */
    .timeline-section { padding: 80px 24px; background: #fef9ee; }
    .timeline { max-width: 700px; margin: 0 auto; position: relative; padding-left: 48px; }
    .timeline::before {
      content: ''; position: absolute; left: 19px; top: 0; bottom: 0;
      width: 2px; background: linear-gradient(to bottom, #f59e0b, #fef3c7);
    }
    .timeline-item { position: relative; margin-bottom: 36px; }
    .timeline-item:last-child { margin-bottom: 0; }
    .timeline-marker {
      position: absolute; left: -48px; top: 4px;
      width: 40px; height: 40px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; z-index: 1;
    }
    .timeline-item.completed .timeline-marker { background: #059669; }
    .timeline-item.current .timeline-marker { background: #f59e0b; }
    .timeline-item.future .timeline-marker { background: #d6d3d1; }
    .marker-pulse {
      width: 12px; height: 12px; background: #fff; border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    @keyframes pulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(255,255,255,0.4); } 50% { box-shadow: 0 0 0 8px rgba(255,255,255,0); } }
    .timeline-content {
      padding: 20px 24px; background: #fff; border-radius: 14px;
      border: 1px solid rgba(245,158,11,0.1);
    }
    .timeline-date { font-size: 0.78rem; color: #f59e0b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
    .timeline-content h3 { font-size: 1.1rem; font-weight: 700; color: #1c1917; margin: 6px 0; }
    .timeline-content p { font-size: 0.88rem; color: #57534e; line-height: 1.6; }

    /* Funds */
    .funds-section { padding: 80px 24px; max-width: 1000px; margin: 0 auto; }
    .funds-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .fund-card {
      background: #fff; border-radius: 16px; padding: 28px;
      border: 1px solid rgba(245,158,11,0.1); transition: all 0.3s ease;
    }
    .fund-card:hover { transform: translateY(-4px); box-shadow: 0 12px 36px rgba(245,158,11,0.1); }
    .fund-amount { font-family: 'Poppins', sans-serif; font-size: 1.5rem; font-weight: 800; color: #92400e; margin-bottom: 8px; }
    .fund-bar { height: 6px; background: #fef3c7; border-radius: 3px; overflow: hidden; margin-bottom: 14px; }
    .fund-fill { height: 100%; background: linear-gradient(90deg, #f59e0b, #ef4444); border-radius: 3px; width: var(--w); }
    .fund-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
    .fund-card p { font-size: 0.85rem; color: #57534e; line-height: 1.5; }

    /* Gallery */
    .gallery-section { padding: 80px 24px; max-width: 1000px; margin: 0 auto; }
    .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
    .gallery-item {
      border-radius: 16px; overflow: hidden; aspect-ratio: 1;
      position: relative; cursor: pointer; transition: transform 0.4s ease;
    }
    .gallery-item:hover { transform: scale(1.03); z-index: 2; }
    .gallery-item span {
      position: absolute; bottom: 12px; left: 12px; right: 12px;
      color: #fff; font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.85rem;
      opacity: 0; transform: translateY(10px); transition: all 0.3s ease;
      text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }
    .gallery-item:hover span { opacity: 1; transform: translateY(0); }

    /* Donate */
    .donate-section {
      padding: 100px 24px; background: linear-gradient(160deg, #1c1917 0%, #292524 100%);
      position: relative; overflow: hidden;
    }
    .donate-section::before {
      content: ''; position: absolute; top: -50%; right: -20%;
      width: 600px; height: 600px; border-radius: 50%;
      background: radial-gradient(circle, rgba(245,158,11,0.15) 0%, transparent 70%);
    }
    .donate-inner { max-width: 700px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
    .donate-desc { color: #a8a29e; font-size: 1.05rem; line-height: 1.7; margin: 16px 0 40px; }
    .donate-amounts { display: flex; justify-content: center; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
    .donate-btn {
      font-family: 'Poppins', sans-serif; font-size: 1.1rem; font-weight: 600;
      padding: 16px 32px; border-radius: 14px; border: 2px solid rgba(245,158,11,0.3);
      background: transparent; color: #fbbf24; cursor: pointer; transition: all 0.3s ease;
    }
    .donate-btn:hover, .donate-btn.featured {
      background: #f59e0b; color: #1c1917; border-color: #f59e0b;
      transform: scale(1.05); box-shadow: 0 8px 30px rgba(245,158,11,0.3);
    }
    .cta-btn {
      font-family: 'Poppins', sans-serif; font-size: 1rem; font-weight: 600;
      padding: 16px 40px; border-radius: 14px; border: none;
      background: linear-gradient(135deg, #f59e0b, #ef4444); color: #fff;
      cursor: pointer; transition: all 0.3s ease;
    }
    .cta-btn:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(245,158,11,0.4); }

    /* Updates */
    .updates-section { padding: 80px 24px; max-width: 800px; margin: 0 auto; }
    .updates-list { display: flex; flex-direction: column; gap: 24px; }
    .update-card {
      display: flex; gap: 24px; background: #fff; border-radius: 16px; padding: 28px;
      border: 1px solid rgba(245,158,11,0.1); transition: all 0.3s ease;
    }
    .update-card:hover { box-shadow: 0 8px 30px rgba(245,158,11,0.08); }
    .update-date {
      flex-shrink: 0; width: 72px; text-align: center; padding-top: 4px;
    }
    .update-day { display: block; font-family: 'Poppins', sans-serif; font-size: 1.8rem; font-weight: 800; color: #92400e; line-height: 1; }
    .update-month { display: block; font-family: 'Poppins', sans-serif; font-size: 0.78rem; font-weight: 600; color: #f59e0b; text-transform: uppercase; }
    .update-year { display: block; font-size: 0.72rem; color: #a8a29e; }
    .update-body h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: #1c1917; }
    .update-body p { font-size: 0.9rem; color: #57534e; line-height: 1.7; }

    /* Footer */
    .footer { text-align: center; padding: 40px 24px; color: #78716c; font-size: 0.85rem; }

    /* Responsive */
    @media (max-width: 768px) {
      .hero-title { font-size: 2rem; }
      .hero { min-height: 50vh; }
      .desc-inner { grid-template-columns: 1fr; }
      .desc-stats { grid-template-columns: repeat(4, 1fr); }
      .funds-grid { grid-template-columns: 1fr; }
      .gallery-grid { grid-template-columns: repeat(2, 1fr); }
      .update-card { flex-direction: column; gap: 12px; }
      .update-date { width: auto; text-align: left; display: flex; gap: 8px; align-items: baseline; }
      .update-day { font-size: 1.2rem; }
      .section-title { font-size: 1.75rem; }
      .back-btn { top: 12px; left: 12px; font-size: 0.8rem; padding: 8px 14px; }
      .timeline { padding-left: 40px; }
      .timeline::before { left: 15px; }
      .timeline-marker { left: -40px; width: 32px; height: 32px; }
    }
    @media (max-width: 480px) {
      .desc-stats { grid-template-columns: repeat(2, 1fr); }
      .donate-amounts { gap: 10px; }
      .donate-btn { padding: 12px 24px; font-size: 1rem; }
    }
  </style>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          entry.target.querySelectorAll('.progress-fill').forEach(fill => fill.classList.add('animate'));
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    document.querySelectorAll('.donate-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.donate-btn').forEach(b => b.classList.remove('featured'));
        btn.classList.add('featured');
      });
    });
  </script>
</body>
</html>
