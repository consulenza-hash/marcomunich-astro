---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Podere del Sole — Agriturismo di Charme in Toscana</title>
  <meta name="description" content="Agriturismo di charme nel cuore della Toscana. Camere eleganti, piscina panoramica, cucina tipica e esperienze autentiche tra le colline senesi." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Nunito:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Back to Portfolio -->
  <a href="/dev/portfolio" class="back-btn" aria-label="Torna al Portfolio">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    <span>Portfolio</span>
  </a>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero" id="hero">
    <div class="hero-noise"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content reveal">
      <p class="hero-tag">Agriturismo di Charme</p>
      <h1>Podere del Sole</h1>
      <p class="hero-sub">Un angolo di Toscana dove il tempo rallenta,<br/>tra colline dorate e tramonti infiniti</p>
      <a href="#camere" class="hero-cta">Scopri le Camere</a>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="#faf7f2" stroke-width="1.5" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12l7 7 7-7"/></svg>
    </div>
  </section>

  <!-- Curved divider -->
  <div class="divider-wave divider-wave--cream">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>

  <!-- ═══════════════ CAMERE ═══════════════ -->
  <section class="section section--light" id="camere">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag">Ospitalita' Autentica</p>
        <h2>Le Nostre Camere</h2>
        <p class="section-desc">Ogni camera racconta una storia diversa. Arredi recuperati, tessuti naturali e panorami che tolgono il fiato — il lusso della semplicita'.</p>
      </div>
      <div class="rooms-grid">
        <!-- Room 1 -->
        <div class="room-card reveal" style="--delay:.1s">
          <div class="room-img-wrap">
            <img src="/images/portfolio/bb-room1.jpg" alt="Camera Tramonto — vista sulle colline toscane" loading="lazy" />
            <div class="room-price"><span>€ 180</span>/notte</div>
          </div>
          <div class="room-body">
            <div class="room-accent"></div>
            <h3>Camera Tramonto</h3>
            <p>Vista panoramica sulle colline, letto king-size, bagno con vasca in pietra e terrazza privata. 35 mq di pura eleganza rustica.</p>
            <ul class="room-features">
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Terrazza privata</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Vasca in pietra</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Aria condizionata</li>
            </ul>
          </div>
        </div>
        <!-- Room 2 -->
        <div class="room-card reveal" style="--delay:.25s">
          <div class="room-img-wrap">
            <img src="/images/portfolio/bb-room2.jpg" alt="Suite Oliveto — suite con soggiorno" loading="lazy" />
            <div class="room-price"><span>€ 240</span>/notte</div>
          </div>
          <div class="room-body">
            <div class="room-accent"></div>
            <h3>Suite Oliveto</h3>
            <p>La nostra suite piu' spaziosa: soggiorno separato, camino originale del '700, doccia a pioggia e affaccio sull'oliveto secolare. 55 mq.</p>
            <ul class="room-features">
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Camino originale</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Soggiorno privato</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Minibar artigianale</li>
            </ul>
          </div>
        </div>
        <!-- Room 3 -->
        <div class="room-card reveal" style="--delay:.4s">
          <div class="room-img-wrap">
            <img src="/images/portfolio/bb-room3.jpg" alt="Camera Vigna — affaccio sul vigneto" loading="lazy" />
            <div class="room-price"><span>€ 160</span>/notte</div>
          </div>
          <div class="room-body">
            <div class="room-accent"></div>
            <h3>Camera Vigna</h3>
            <p>Intimita' e calore: travi a vista, letto in ferro battuto, bagno con doccia walk-in e una finestra che incornicia il nostro vigneto. 28 mq.</p>
            <ul class="room-features">
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Travi a vista</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Vista vigneto</li>
              <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>Colazione inclusa</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Organic divider -->
  <div class="divider-wave divider-wave--dark">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,20 C240,70 480,0 720,40 C960,80 1200,10 1440,30 L1440,80 L0,80 Z" fill="#2d2418"/></svg>
  </div>

  <!-- ═══════════════ LA STRUTTURA ═══════════════ -->
  <section class="section section--dark" id="struttura">
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="struttura-grid">
        <div class="struttura-image reveal" style="--delay:.1s">
          <div class="blob-frame">
            <img src="/images/portfolio/bb-struttura.jpg" alt="Podere del Sole — la struttura" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:inherit;" loading="lazy" />
          </div>
        </div>
        <div class="struttura-text reveal" style="--delay:.25s">
          <p class="section-tag section-tag--light">Tradizione e Natura</p>
          <h2>La Struttura</h2>
          <p>Un casale del XVIII secolo restaurato con amore, dove ogni pietra conserva la memoria di generazioni. Circondato da oliveti, vigneti e boschi di querce, il Podere del Sole offre un'esperienza di ospitalita' che unisce il fascino dell'antico al comfort contemporaneo.</p>
          <p>La nostra filosofia e' semplice: rispetto per la terra, cura per le persone, attenzione ai dettagli. Dall'orto biodinamico alla cantina scavata nel tufo, ogni angolo racconta la nostra passione.</p>
          <div class="stats-row">
            <div class="stat">
              <span class="stat-number" data-target="8">0</span>
              <span class="stat-label">Camere</span>
            </div>
            <div class="stat">
              <span class="stat-number" data-target="2">0</span>
              <span class="stat-label">Ettari</span>
            </div>
            <div class="stat">
              <span class="stat-number" data-target="1">0</span>
              <span class="stat-label">Piscina</span>
            </div>
            <div class="stat">
              <span class="stat-number" data-target="1">0</span>
              <span class="stat-label">Ristorante</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Curved divider -->
  <div class="divider-wave divider-wave--cream-up">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,60 C320,0 640,80 960,30 C1120,10 1320,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>

  <!-- ═══════════════ ESPERIENZE ═══════════════ -->
  <section class="section section--light" id="esperienze">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag">Vivere la Toscana</p>
        <h2>Le Esperienze</h2>
        <p class="section-desc">Non solo un soggiorno, ma un viaggio sensoriale. Scoprite i sapori, i profumi e i ritmi di questa terra straordinaria.</p>
      </div>
      <div class="bento-grid">
        <div class="bento-item bento-item--wide reveal" style="--delay:.1s;--accent:#c4956a">
          <div class="bento-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h3>Degustazione Vini e Olio</h3>
          <p>Visita guidata alla nostra cantina con degustazione di 5 etichette locali, accompagnata dall'olio nuovo del frantoio.</p>
        </div>
        <div class="bento-item reveal" style="--delay:.2s;--accent:#7c8c6c">
          <div class="bento-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="1.5" stroke-linecap="round"><path d="M3 3h18v18H3z"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
          </div>
          <h3>Corso di Cucina</h3>
          <p>Imparate a fare la pasta fresca con la nostra cuoca Marta. Pici, pappardelle e ravioli — e poi si mangia tutti insieme.</p>
        </div>
        <div class="bento-item reveal" style="--delay:.3s;--accent:#c4956a">
          <div class="bento-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <h3>Passeggiate a Cavallo</h3>
          <p>Attraversate i sentieri tra le colline al tramonto, guidati dai nostri amici equini.</p>
        </div>
        <div class="bento-item reveal" style="--delay:.15s;--accent:#7c8c6c">
          <div class="bento-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#7c8c6c" stroke-width="1.5" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3>Yoga all'Alba</h3>
          <p>Sessioni guidate nella terrazza panoramica con vista sulla Val d'Orcia. Il modo migliore per iniziare la giornata.</p>
        </div>
        <div class="bento-item bento-item--wide reveal" style="--delay:.35s;--accent:#c4956a">
          <div class="bento-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#c4956a" stroke-width="1.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Tour Borghi Medievali</h3>
          <p>Montalcino, Pienza, Montepulciano — vi accompagniamo alla scoperta dei borghi piu' belli d'Italia, con soste gastronomiche incluse.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Organic divider -->
  <div class="divider-wave divider-wave--dark">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,50 C200,10 400,70 600,30 C800,-10 1100,60 1440,20 L1440,80 L0,80 Z" fill="#2d2418"/></svg>
  </div>

  <!-- ═══════════════ RECENSIONI ═══════════════ -->
  <section class="section section--dark" id="recensioni">
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag section-tag--light">Dicono di Noi</p>
        <h2>Recensioni degli Ospiti</h2>
      </div>
      <div class="reviews-scroll">
        <div class="review-card reveal" style="--delay:.1s">
          <div class="review-quote" aria-hidden="true">&ldquo;</div>
          <div class="review-stars" aria-label="5 stelle">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>Un luogo magico. Siamo arrivati per due notti e siamo rimasti cinque. La colazione con le torte di Marta vale il viaggio da sola. Torneremo ogni anno.</p>
          <div class="review-author">
            <strong>Giulia e Marco R.</strong>
            <span>Milano — Settembre 2025</span>
          </div>
        </div>
        <div class="review-card reveal" style="--delay:.2s">
          <div class="review-quote" aria-hidden="true">&ldquo;</div>
          <div class="review-stars" aria-label="5 stelle">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>La suite Oliveto e' un sogno. Il camino acceso, il panorama all'alba, il silenzio rotto solo dalle cicale. Perfetto per il nostro anniversario.</p>
          <div class="review-author">
            <strong>Thomas e Helene W.</strong>
            <span>Zurigo — Giugno 2025</span>
          </div>
        </div>
        <div class="review-card reveal" style="--delay:.3s">
          <div class="review-quote" aria-hidden="true">&ldquo;</div>
          <div class="review-stars" aria-label="5 stelle">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>I bambini hanno adorato l'orto e gli animali. Noi abbiamo adorato la piscina e il vino. Ospitalita' autentica, lontana dal turismo di massa.</p>
          <div class="review-author">
            <strong>Famiglia Bianchi</strong>
            <span>Roma — Agosto 2025</span>
          </div>
        </div>
        <div class="review-card reveal" style="--delay:.4s">
          <div class="review-quote" aria-hidden="true">&ldquo;</div>
          <div class="review-stars" aria-label="5 stelle">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p>We came for the landscape, we stayed for the people. Antonio and his family made us feel like old friends. The cooking class was unforgettable.</p>
          <div class="review-author">
            <strong>Sarah &amp; David L.</strong>
            <span>London — Maggio 2025</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Curved divider -->
  <div class="divider-wave divider-wave--cream-up">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z" fill="#faf7f2"/></svg>
  </div>

  <!-- ═══════════════ DOVE SIAMO ═══════════════ -->
  <section class="section section--light" id="dove-siamo">
    <div class="container">
      <div class="section-header reveal">
        <p class="section-tag">Raggiungerci</p>
        <h2>Dove Siamo</h2>
      </div>
      <div class="location-grid">
        <div class="map-placeholder reveal" style="--delay:.1s">
          <div class="map-box">
            <div class="map-pin">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="#c4956a" stroke="#2d2418" stroke-width="1"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3" fill="#2d2418"/></svg>
            </div>
            <p class="map-label">Localita' Poggio Sereno, 42<br/>53024 Montalcino (SI)<br/>Toscana, Italia</p>
          </div>
        </div>
        <div class="directions reveal" style="--delay:.25s">
          <h3>Come Arrivare</h3>
          <p>Immerso nelle colline tra Montalcino e Pienza, il Podere del Sole e' facilmente raggiungibile da tutte le principali citta' toscane.</p>
          <div class="distance-badges">
            <div class="distance-badge">
              <span class="distance-km">12 km</span>
              <span class="distance-place">Montalcino</span>
            </div>
            <div class="distance-badge">
              <span class="distance-km">35 km</span>
              <span class="distance-place">Siena</span>
            </div>
            <div class="distance-badge">
              <span class="distance-km">110 km</span>
              <span class="distance-place">Firenze</span>
            </div>
            <div class="distance-badge">
              <span class="distance-km">85 km</span>
              <span class="distance-place">Aeroporto Perugia</span>
            </div>
          </div>
          <p class="directions-note">Parcheggio gratuito in struttura. Servizio navetta da Siena disponibile su richiesta.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Organic divider -->
  <div class="divider-wave divider-wave--dark-grad">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none"><path d="M0,30 C480,80 960,0 1440,50 L1440,80 L0,80 Z" fill="#2d2418"/></svg>
  </div>

  <!-- ═══════════════ PRENOTA ═══════════════ -->
  <section class="section section--dark section--prenota" id="prenota">
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container container--narrow">
      <div class="section-header reveal">
        <p class="section-tag section-tag--light">Il Vostro Soggiorno</p>
        <h2>Prenota Ora</h2>
        <p class="section-desc" style="color:#d4c8b8">Compilate il modulo e vi risponderemo entro 24 ore con disponibilita' e preventivo personalizzato.</p>
      </div>
      <form class="booking-form reveal" style="--delay:.15s" onsubmit="event.preventDefault()">
        <div class="form-row">
          <div class="form-group">
            <input type="text" id="nome" required placeholder=" " />
            <label for="nome">Nome e Cognome</label>
          </div>
          <div class="form-group">
            <input type="email" id="email" required placeholder=" " />
            <label for="email">Email</label>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <input type="date" id="checkin" required placeholder=" " />
            <label for="checkin">Check-in</label>
          </div>
          <div class="form-group">
            <input type="date" id="checkout" required placeholder=" " />
            <label for="checkout">Check-out</label>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <select id="camera" required>
              <option value="" disabled selected></option>
              <option>Camera Tramonto — €180/notte</option>
              <option>Suite Oliveto — €240/notte</option>
              <option>Camera Vigna — €160/notte</option>
            </select>
            <label for="camera">Camera Preferita</label>
          </div>
          <div class="form-group">
            <select id="ospiti" required>
              <option value="" disabled selected></option>
              <option>1 Ospite</option>
              <option>2 Ospiti</option>
              <option>3 Ospiti</option>
              <option>4 Ospiti</option>
            </select>
            <label for="ospiti">Numero Ospiti</label>
          </div>
        </div>
        <div class="form-group form-group--full">
          <textarea id="note" rows="4" placeholder=" "></textarea>
          <label for="note">Note o Richieste Speciali</label>
        </div>
        <button type="submit" class="submit-btn">
          <span>Richiedi Disponibilita'</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </button>
      </form>
    </div>
  </section>

  <!-- ═══════════════ FOOTER ═══════════════ -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <h3>Podere del Sole</h3>
          <p>Agriturismo di Charme<br/>Montalcino, Toscana</p>
        </div>
        <div class="footer-links">
          <h4>Navigazione</h4>
          <a href="#camere">Camere</a>
          <a href="#struttura">La Struttura</a>
          <a href="#esperienze">Esperienze</a>
          <a href="#recensioni">Recensioni</a>
          <a href="#prenota">Prenota</a>
        </div>
        <div class="footer-contact">
          <h4>Contatti</h4>
          <p>+39 0577 123 456</p>
          <p>info@poderedelsoletoscana.it</p>
          <div class="footer-social">
            <a href="#" aria-label="Instagram">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="#" aria-label="Facebook">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
            <a href="#" aria-label="WhatsApp">
