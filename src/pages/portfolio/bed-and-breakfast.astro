---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Il Casale delle Querce — B&B in Toscana | Portfolio Demo</title>
  <meta name="description" content="Demo portfolio: sito per bed and breakfast e agriturismo in Toscana" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Nunito:wght@400;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- Back button -->
  <a href="/dev/portfolio" class="back-btn">&#8592; Torna al Portfolio</a>

  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-noise"></div>
    <div class="hero-content">
      <p class="hero-label">Agriturismo &amp; B&amp;B</p>
      <h1>Il Casale delle Querce</h1>
      <p class="hero-tagline">Ospitalit&agrave; autentica nel cuore della Toscana</p>
      <a href="#prenota" class="cta-btn">Prenota il tuo soggiorno</a>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <span></span>
    </div>
  </section>

  <!-- Le Nostre Camere -->
  <section class="section camere" id="camere">
    <div class="container">
      <h2 class="section-title fade-in">Le Nostre Camere</h2>
      <p class="section-subtitle fade-in">Ogni camera racconta una storia diversa, con arredi curati e vista sulle colline</p>
      <div class="rooms-grid">

        <div class="room-card fade-in">
          <div class="room-img-wrap">
            <img src="/images/portfolio/bb-room1.jpg" alt="Camera Ulivo — interni accoglienti con letto matrimoniale" loading="lazy" width="400" height="267" />
          </div>
          <div class="room-body">
            <h3>Camera Ulivo</h3>
            <p>Ampia camera con vista sul giardino degli ulivi, bagno privato con doccia a pioggia e terrazzino personale.</p>
            <div class="room-footer">
              <span class="room-price">da <strong>&euro;95</strong> / notte</span>
              <button class="btn-outline" type="button">Dettagli</button>
            </div>
          </div>
        </div>

        <div class="room-card fade-in">
          <div class="room-img-wrap">
            <img src="/images/portfolio/bb-room2.jpg" alt="Suite Lavanda — suite spaziosa con zona living" loading="lazy" width="400" height="267" />
          </div>
          <div class="room-body">
            <h3>Suite Lavanda</h3>
            <p>La nostra suite pi&ugrave; amata: zona living separata, vasca freestanding e profumo di lavanda fresca ogni mattina.</p>
            <div class="room-footer">
              <span class="room-price">da <strong>&euro;145</strong> / notte</span>
              <button class="btn-outline" type="button">Dettagli</button>
            </div>
          </div>
        </div>

        <div class="room-card fade-in">
          <div class="room-img-wrap">
            <img src="/images/portfolio/bb-room3.jpg" alt="Camera del Tramonto — camera romantica con vista colline" loading="lazy" width="400" height="267" />
          </div>
          <div class="room-body">
            <h3>Camera del Tramonto</h3>
            <p>Orientata a ovest per godere dei tramonti toscani, con letto a baldacchino e pavimento in cotto originale.</p>
            <div class="room-footer">
              <span class="room-price">da <strong>&euro;120</strong> / notte</span>
              <button class="btn-outline" type="button">Dettagli</button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- La Struttura -->
  <section class="section struttura" id="struttura">
    <div class="container struttura-grid">
      <div class="struttura-img fade-in">
        <div class="struttura-placeholder"></div>
      </div>
      <div class="struttura-text fade-in">
        <h2 class="section-title left">La Struttura</h2>
        <p>Il Casale delle Querce nasce dal restauro di un antico casale del Settecento, immerso tra le colline senesi. Ogni pietra racconta secoli di storia, ogni dettaglio &egrave; stato pensato per offrire comfort e autenticit&agrave;.</p>
        <p>Gli spazi comuni invitano al relax: dalla biblioteca con camino alla terrazza panoramica dove servire la colazione con prodotti del nostro orto.</p>
        <div class="stats-row">
          <div class="stat">
            <span class="stat-num">8</span>
            <span class="stat-label">Camere</span>
          </div>
          <div class="stat">
            <span class="stat-num">2</span>
            <span class="stat-label">Ettari di Giardino</span>
          </div>
          <div class="stat">
            <span class="stat-num">1</span>
            <span class="stat-label">Piscina Panoramica</span>
          </div>
          <div class="stat">
            <span class="stat-num">1</span>
            <span class="stat-label">Ristorante Interno</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Esperienze -->
  <section class="section esperienze" id="esperienze">
    <div class="container">
      <h2 class="section-title fade-in">Esperienze</h2>
      <p class="section-subtitle fade-in">Vivi la Toscana con attivit&agrave; pensate per rendere il soggiorno indimenticabile</p>
      <div class="exp-grid">

        <div class="exp-card fade-in">
          <span class="exp-icon" aria-hidden="true">&#127863;</span>
          <h3>Degustazione Vini</h3>
          <p>Visita le cantine locali con guida dedicata</p>
        </div>

        <div class="exp-card fade-in">
          <span class="exp-icon" aria-hidden="true">&#128692;</span>
          <h3>Escursioni in Bicicletta</h3>
          <p>Percorsi tra le colline con bici a disposizione</p>
        </div>

        <div class="exp-card fade-in">
          <span class="exp-icon" aria-hidden="true">&#127859;</span>
          <h3>Corso di Cucina</h3>
          <p>Impara i segreti della cucina toscana con lo chef</p>
        </div>

        <div class="exp-card fade-in">
          <span class="exp-icon" aria-hidden="true">&#129526;</span>
          <h3>Area Benessere</h3>
          <p>Sauna, bagno turco e massaggi su prenotazione</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Recensioni -->
  <section class="section recensioni" id="recensioni">
    <div class="container">
      <h2 class="section-title fade-in">Cosa Dicono i Nostri Ospiti</h2>
      <div class="reviews-wrap fade-in">

        <div class="review-card">
          <div class="review-stars" aria-label="5 stelle">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">Un luogo magico dove il tempo si ferma. La colazione con i prodotti dell'orto &egrave; stata un'esperienza straordinaria. Torneremo sicuramente.</p>
          <div class="review-author">
            <strong>Giulia e Marco R.</strong>
            <span>Ottobre 2025</span>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars" aria-label="5 stelle">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-text">La Suite Lavanda &egrave; semplicemente perfetta. Personale gentilissimo, posizione strategica per visitare i borghi toscani. Consigliatissimo.</p>
          <div class="review-author">
            <strong>Famiglia Bianchi</strong>
            <span>Agosto 2025</span>
          </div>
        </div>

        <div class="review-card">
          <div class="review-stars" aria-label="4 stelle">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
          <p class="review-text">Abbiamo partecipato al corso di cucina e alla degustazione: due giornate indimenticabili. Il casale &egrave; curato in ogni dettaglio.</p>
          <div class="review-author">
            <strong>Thomas &amp; Sarah W.</strong>
            <span>Settembre 2025</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Dove Siamo -->
  <section class="section dove-siamo" id="dove-siamo">
    <div class="container dove-grid">
      <div class="map-placeholder fade-in">
        <div class="map-pin" aria-hidden="true">&#128205;</div>
        <span>Mappa interattiva</span>
      </div>
      <div class="dove-text fade-in">
        <h2 class="section-title left">Dove Siamo</h2>
        <p class="dove-address">Strada Provinciale delle Colline, 42<br />53024 Montalcino (SI), Toscana</p>
        <h3>Come Arrivare</h3>
        <p>Dall'autostrada A1, uscita Valdichiana. Proseguire sulla SS326 in direzione Montalcino. Dopo il paese, seguire le indicazioni per Il Casale delle Querce (2 km su strada bianca).</p>
        <div class="distances">
          <span>&#128663; 45 min da Firenze</span>
          <span>&#128663; 30 min da Siena</span>
          <span>&#128663; 20 min da Montalcino</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Prenota -->
  <section class="section prenota" id="prenota">
    <div class="container">
      <h2 class="section-title fade-in">Prenota il Tuo Soggiorno</h2>
      <p class="section-subtitle fade-in">Compila il modulo e ti risponderemo entro 24 ore con disponibilit&agrave; e preventivo</p>
      <form class="booking-form fade-in" onsubmit="event.preventDefault();">
        <div class="form-row">
          <div class="form-group">
            <label for="checkin">Check-in</label>
            <input type="date" id="checkin" name="checkin" required />
          </div>
          <div class="form-group">
            <label for="checkout">Check-out</label>
            <input type="date" id="checkout" name="checkout" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="guests">Ospiti</label>
            <input type="number" id="guests" name="guests" min="1" max="6" value="2" required />
          </div>
          <div class="form-group">
            <label for="room-type">Tipo Camera</label>
            <select id="room-type" name="room-type" required>
              <option value="">Seleziona...</option>
              <option value="ulivo">Camera Ulivo — €95/notte</option>
              <option value="lavanda">Suite Lavanda — €145/notte</option>
              <option value="tramonto">Camera del Tramonto — €120/notte</option>
            </select>
          </div>
        </div>
        <div class="form-group full">
          <label for="message">Messaggio</label>
          <textarea id="message" name="message" rows="4" placeholder="Richieste particolari, orario di arrivo previsto..."></textarea>
        </div>
        <button type="submit" class="cta-btn submit-btn">Verifica Disponibilit&agrave;</button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-col">
        <h4>Il Casale delle Querce</h4>
        <p>Strada Provinciale delle Colline, 42<br />53024 Montalcino (SI)</p>
      </div>
      <div class="footer-col">
        <h4>Contatti</h4>
        <p>Tel: +39 0577 123 456<br />Email: info@casalequerce.it</p>
      </div>
      <div class="footer-col">
        <h4>Seguici</h4>
        <div class="social-links">
          <a href="#" aria-label="Instagram">&#9679; Instagram</a>
          <a href="#" aria-label="Facebook">&#9679; Facebook</a>
          <a href="#" aria-label="TripAdvisor">&#9679; TripAdvisor</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Il Casale delle Querce &mdash; Sito demo, nessun dato reale</p>
    </div>
  </footer>

  <script>
    // Scroll-triggered fade-in
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

      // Simple parallax on hero
      const hero = document.getElementById('hero');
      if (hero && window.innerWidth > 768) {
        window.addEventListener('scroll', () => {
          const scrolled = window.scrollY;
          hero.style.backgroundPositionY = (scrolled * 0.4) + 'px';
        }, { passive: true });
      }
    });
  </script>

</body>
</html>

<style>
  /* ── Reset & Base ──────────────────────────────────── */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: #c4956a #faf7f2;
  }
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #faf7f2; }
  ::-webkit-scrollbar-thumb { background: #c4956a; border-radius: 4px; }

  body {
    font-family: 'Nunito', sans-serif;
    color: #2d2418;
    background: #faf7f2;
    line-height: 1.7;
    overflow-x: hidden;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  img { display: block; max-width: 100%; height: auto; }
  a { color: inherit; text-decoration: none; }

  /* ── Back Button ───────────────────────────────────── */
  .back-btn {
    position: fixed;
    top: 20px;
    left: 20px;
    z-index: 100;
    background: rgba(250,247,242,.92);
    backdrop-filter: blur(8px);
    padding: 10px 20px;
    border-radius: 40px;
    font-size: .9rem;
    font-weight: 600;
    color: #2d2418;
    box-shadow: 0 2px 16px rgba(45,36,24,.1);
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .back-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(45,36,24,.18);
  }

  /* ── Section Common ────────────────────────────────── */
  .section {
    padding: 100px 0;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 16px;
    color: #2d2418;
  }
  .section-title.left { text-align: left; }
  .section-subtitle {
    text-align: center;
    color: #6b5d4f;
    max-width: 560px;
    margin: 0 auto 56px;
    font-size: 1.05rem;
  }

  /* Fade-in animation */
  .fade-in {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .7s ease, transform .7s ease;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Hero ───────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(165deg, #faf7f2 0%, #e8d5b5 25%, #c4956a 55%, #a0724e 75%, #7c8c6c 100%);
    background-size: 100% 200%;
    background-attachment: fixed;
    overflow: hidden;
  }
  .hero-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-repeat: repeat;
    pointer-events: none;
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 24px;
  }
  .hero-label {
    font-family: 'Nunito', sans-serif;
    font-size: .85rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #faf7f2;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.6rem, 6vw, 5rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 20px;
    text-shadow: 0 2px 32px rgba(45,36,24,.2);
  }
  .hero-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    font-style: italic;
    color: rgba(255,255,255,.9);
    margin-bottom: 40px;
  }
  .cta-btn {
    display: inline-block;
    background: #faf7f2;
    color: #2d2418;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    padding: 16px 40px;
    border-radius: 50px;
    border: none;
    cursor: pointer;
    transition: transform .25s ease, box-shadow .25s ease;
    box-shadow: 0 4px 24px rgba(45,36,24,.15);
  }
  .cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(45,36,24,.22);
  }

  /* Scroll indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 36px;
    z-index: 2;
  }
  .scroll-indicator span {
    display: block;
    width: 24px;
    height: 24px;
    border-right: 2px solid rgba(255,255,255,.7);
    border-bottom: 2px solid rgba(255,255,255,.7);
    transform: rotate(45deg);
    animation: scrollBounce 2s infinite;
  }
  @keyframes scrollBounce {
    0%   { opacity: 0; transform: rotate(45deg) translate(-8px,-8px); }
    50%  { opacity: 1; }
    100% { opacity: 0; transform: rotate(45deg) translate(8px,8px); }
  }

  /* ── Rooms ──────────────────────────────────────────── */
  .rooms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .room-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(45,36,24,.07);
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .room-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(45,36,24,.14);
  }
  .room-img-wrap {
    overflow: hidden;
    aspect-ratio: 3/2;
  }
  .room-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .5s ease;
  }
  .room-card:hover .room-img-wrap img {
    transform: scale(1.06);
  }
  .room-body {
    padding: 24px;
  }
  .room-body h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .room-body p {
    color: #6b5d4f;
    font-size: .95rem;
    margin-bottom: 20px;
  }
  .room-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .room-price {
    font-size: .95rem;
    color: #6b5d4f;
  }
  .room-price strong {
    font-size: 1.3rem;
    color: #c4956a;
  }
  .btn-outline {
    background: none;
    border: 1.5px solid #c4956a;
    color: #c4956a;
    font-family: 'Nunito', sans-serif;
    font-weight: 700;
    font-size: .85rem;
    padding: 8px 22px;
    border-radius: 30px;
    cursor: pointer;
    transition: background .25s ease, color .25s ease;
  }
  .btn-outline:hover {
    background: #c4956a;
    color: #fff;
  }

  /* ── La Struttura ──────────────────────────────────── */
  .struttura {
    background: #f3ede4;
  }
  .struttura-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .struttura-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 16px;
    background: linear-gradient(135deg, #e8d5b5, #c4956a 60%, #7c8c6c);
    box-shadow: 0 8px 32px rgba(45,36,24,.1);
  }
  .struttura-text p {
    color: #5a4d3f;
    margin-bottom: 16px;
    font-size: 1.05rem;
  }
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 32px;
  }
  .stat {
    text-align: center;
    padding: 16px 8px;
    background: #faf7f2;
    border-radius: 12px;
  }
  .stat-num {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 700;
    color: #c4956a;
  }
  .stat-label {
    display: block;
    font-size: .78rem;
    font-weight: 600;
    color: #6b5d4f;
    margin-top: 4px;
  }

  /* ── Esperienze ────────────────────────────────────── */
  .exp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px;
  }
  .exp-card {
    background: #fff;
    border-radius: 16px;
    padding: 36px 24px;
    text-align: center;
    box-shadow: 0 2px 16px rgba(45,36,24,.06);
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .exp-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 36px rgba(45,36,24,.13);
  }
  .exp-icon {
    display: block;
    font-size: 2.4rem;
    margin-bottom: 16px;
  }
  .exp-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .exp-card p {
    font-size: .92rem;
    color: #6b5d4f;
  }

  /* ── Recensioni ────────────────────────────────────── */
  .recensioni {
    background: #f3ede4;
  }
  .reviews-wrap {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .review-card {
    background: #faf7f2;
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 2px 12px rgba(45,36,24,.05);
  }
  .review-stars {
    color: #c4956a;
    font-size: 1.2rem;
    margin-bottom: 16px;
    letter-spacing: 2px;
  }
  .review-text {
    font-size: .95rem;
    color: #5a4d3f;
    font-style: italic;
    margin-bottom: 20px;
    line-height: 1.7;
  }
  .review-author strong {
