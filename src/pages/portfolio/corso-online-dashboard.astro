---
export const prerender = true;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — La Tua Academy</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #0a0118;
      color: #e0dce8;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* ── Layout ── */
    .layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      grid-template-rows: 64px 1fr;
      min-height: 100vh;
      width: 100%;
    }

    /* ── Top bar ── */
    .topbar {
      grid-column: 1 / -1;
      grid-row: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 28px;
      background: rgba(20, 10, 40, 0.7);
      border-bottom: 1px solid rgba(124, 58, 237, 0.12);
      backdrop-filter: blur(16px);
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .topbar-logo {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #7c3aed, #a78bfa, #06b6d4);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 18px;
    }
    .notif-bell {
      position: relative;
      width: 38px; height: 38px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 10px;
      background: rgba(124, 58, 237, 0.08);
      border: 1px solid rgba(124, 58, 237, 0.15);
      cursor: pointer;
      transition: all 0.3s;
      color: #a78bfa;
    }
    .notif-bell:hover {
      background: rgba(124, 58, 237, 0.15);
      animation: bellShake 0.5s ease;
    }
    .notif-bell::after {
      content: '';
      position: absolute;
      top: 8px; right: 9px;
      width: 8px; height: 8px;
      background: #06b6d4;
      border-radius: 50%;
      border: 2px solid #0a0118;
    }
    @keyframes bellShake {
      0%, 100% { transform: rotate(0); }
      20% { transform: rotate(12deg); }
      40% { transform: rotate(-10deg); }
      60% { transform: rotate(6deg); }
      80% { transform: rotate(-4deg); }
    }
    .user-area {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: linear-gradient(135deg, #7c3aed, #06b6d4);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.8rem;
      color: #fff;
    }
    .user-name {
      font-size: 0.85rem;
      font-weight: 500;
      color: #c4b5fd;
    }

    /* ── Sidebar ── */
    .sidebar {
      grid-column: 1;
      grid-row: 2;
      background: rgba(20, 10, 40, 0.5);
      border-right: 1px solid rgba(124, 58, 237, 0.1);
      backdrop-filter: blur(16px);
      padding: 28px 16px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .sidebar-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 12px;
      color: rgba(167, 139, 250, 0.6);
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.25s ease;
      position: relative;
    }
    .sidebar-item:hover {
      color: #e0dce8;
      background: rgba(124, 58, 237, 0.08);
    }
    .sidebar-item.active {
      color: #06b6d4;
      background: rgba(6, 182, 212, 0.08);
    }
    .sidebar-item.active::before {
      content: '';
      position: absolute;
      left: 0;
      top: 6px;
      bottom: 6px;
      width: 3px;
      border-radius: 0 3px 3px 0;
      background: #06b6d4;
      box-shadow: 0 0 12px rgba(6, 182, 212, 0.5);
    }
    .sidebar-item svg {
      width: 20px; height: 20px;
      flex-shrink: 0;
    }
    .sidebar-spacer { flex: 1; }
    .sidebar-item.logout { color: rgba(239, 68, 68, 0.6); }
    .sidebar-item.logout:hover { color: #ef4444; background: rgba(239, 68, 68, 0.06); }

    /* ── Main ── */
    .main {
      grid-column: 2;
      grid-row: 2;
      padding: 32px;
      overflow-y: auto;
      min-width: 0;
      width: 100%;
      box-sizing: border-box;
    }

    /* Welcome */
    .welcome h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 4px;
      background: linear-gradient(135deg, #e0dce8, #a78bfa);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .welcome .date {
      font-size: 0.85rem;
      color: rgba(167, 139, 250, 0.5);
      margin-bottom: 28px;
    }

    /* Stats */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 36px;
    }
    .stat-card {
      background: rgba(20, 10, 40, 0.6);
      border: 1px solid rgba(124, 58, 237, 0.12);
      border-radius: 16px;
      padding: 20px;
      backdrop-filter: blur(12px);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(124, 58, 237, 0.12);
    }
    .stat-label {
      font-size: 0.78rem;
      color: rgba(167, 139, 250, 0.5);
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .stat-value {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 2rem;
      font-weight: 700;
      color: #e0dce8;
    }
    .stat-card:nth-child(1) .stat-value { color: #7c3aed; }
    .stat-card:nth-child(2) .stat-value { color: #06b6d4; }
    .stat-card:nth-child(3) .stat-value { color: #a78bfa; }
    .stat-card:nth-child(4) .stat-value { color: #22d3ee; }

    /* Section title */
    .section-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 20px;
      color: #e0dce8;
    }

    /* Course cards */
    .courses-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }
    .course-card {
      background: rgba(20, 10, 40, 0.6);
      border: 1px solid rgba(124, 58, 237, 0.12);
      border-radius: 16px;
      overflow: hidden;
      backdrop-filter: blur(12px);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .course-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 48px rgba(124, 58, 237, 0.15);
    }
    .course-thumb {
      width: 100%;
      height: 160px;
      object-fit: cover;
      display: block;
    }
    .course-body { padding: 20px; }
    .course-title {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 12px;
      color: #e0dce8;
    }
    .progress-bar-wrap {
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: rgba(124, 58, 237, 0.12);
      margin-bottom: 8px;
      overflow: hidden;
    }
    .progress-bar {
      height: 100%;
      border-radius: 3px;
      width: 0;
      transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .progress-purple { background: linear-gradient(90deg, #7c3aed, #a78bfa); }
    .progress-cyan { background: linear-gradient(90deg, #06b6d4, #22d3ee); }
    .progress-green { background: linear-gradient(90deg, #10b981, #34d399); }
    .course-meta {
      font-size: 0.8rem;
      color: rgba(167, 139, 250, 0.5);
      margin-bottom: 16px;
    }
    .badge-complete {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 20px;
      background: rgba(16, 185, 129, 0.12);
      color: #34d399;
      font-size: 0.75rem;
      font-weight: 600;
      margin-bottom: 16px;
    }
    .course-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 20px;
      border: none;
      border-radius: 10px;
      font-family: 'Inter', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      color: #fff;
    }
    .course-btn.purple {
      background: linear-gradient(135deg, #7c3aed, #6d28d9);
      box-shadow: 0 3px 12px rgba(124, 58, 237, 0.25);
    }
    .course-btn.purple:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
    }
    .course-btn.green {
      background: linear-gradient(135deg, #10b981, #059669);
      box-shadow: 0 3px 12px rgba(16, 185, 129, 0.25);
    }
    .course-btn.green:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
    }

    /* Schedule */
    .schedule-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .schedule-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 16px 20px;
      background: rgba(20, 10, 40, 0.5);
      border: 1px solid rgba(124, 58, 237, 0.1);
      border-radius: 14px;
      transition: border-color 0.3s;
    }
    .schedule-item:hover { border-color: rgba(124, 58, 237, 0.25); }
    .schedule-time {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 0.85rem;
      font-weight: 600;
      color: #06b6d4;
      min-width: 130px;
    }
    .schedule-lesson {
      font-size: 0.9rem;
      font-weight: 500;
      color: #e0dce8;
      flex: 1;
    }
    .schedule-course {
      font-size: 0.78rem;
      color: rgba(167, 139, 250, 0.5);
    }

    /* Back btn */
    .back-btn {
      position: fixed;
      top: 76px; left: 24px;
      z-index: 9000;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 16px;
      background: rgba(124, 58, 237, 0.15);
      border: 1px solid rgba(124, 58, 237, 0.3);
      border-radius: 10px;
      color: #a78bfa;
      text-decoration: none;
      font-size: 0.8rem;
      font-weight: 500;
      backdrop-filter: blur(12px);
      transition: all 0.3s ease;
    }
    .back-btn:hover {
      background: rgba(124, 58, 237, 0.25);
      border-color: rgba(124, 58, 237, 0.6);
      transform: translateX(-4px);
    }

    /* Hamburger */
    .hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      flex-direction: column;
      gap: 5px;
      padding: 4px;
    }
    .hamburger span {
      display: block;
      width: 22px; height: 2px;
      background: #a78bfa;
      border-radius: 2px;
      transition: all 0.3s;
    }

    /* ── Responsive ── */
    @media (max-width: 1280px) {
      .stats-row { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 1024px) {
      .courses-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .layout {
        grid-template-columns: 1fr;
        grid-template-rows: 64px 1fr;
      }
      .sidebar {
        position: fixed;
        top: 64px; left: 0; bottom: 0;
        width: 260px;
        z-index: 40;
        transform: translateX(-100%);
        transition: transform 0.3s ease;
        border-right: 1px solid rgba(124, 58, 237, 0.15);
      }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay {
        display: none;
        position: fixed;
        inset: 0; top: 64px;
        background: rgba(10, 1, 24, 0.6);
        z-index: 39;
      }
      .sidebar-overlay.show { display: block; }
      .hamburger { display: flex; }
      .main { padding: 24px 16px; }
      .courses-grid { grid-template-columns: 1fr; }
      .stats-row { grid-template-columns: repeat(2, 1fr); }
      .welcome h1 { font-size: 1.4rem; }
      .back-btn { display: inline-flex; font-size: 0.75rem; padding: 6px 12px; }
      .user-name { display: none; }
      .schedule-time { min-width: auto; }
      .schedule-item { flex-wrap: wrap; gap: 8px; }
    }
    @media (max-width: 480px) {
      .stats-row { grid-template-columns: 1fr; }
      .stat-value { font-size: 1.6rem; }
    }

    /* Fade-in */
    .fade-in {
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-in.visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>
</head>
<body>
  <div class="layout">
    <!-- Top bar -->
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:16px;">
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
        <div class="topbar-logo">La Tua Academy</div>
      </div>
      <div class="topbar-right">
        <div class="notif-bell" title="Notifiche">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <div class="user-area">
          <div class="avatar">MR</div>
          <span class="user-name">Marco Rossi</span>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <nav class="sidebar" id="sidebar">
      <a class="sidebar-item active" href="#">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a class="sidebar-item" href="#">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        I Miei Corsi
      </a>
      <a class="sidebar-item" href="#">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Calendario
      </a>
      <a class="sidebar-item" href="#">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
        Certificati
      </a>
      <a class="sidebar-item" href="#">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        Impostazioni
      </a>
      <div class="sidebar-spacer"></div>
      <a class="sidebar-item logout" href="#">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Logout
      </a>
    </nav>

    <!-- Main content -->
    <main class="main">
      <a href="/portfolio/corso-online" class="back-btn">&larr; Torna al Corso</a>

      <div class="welcome fade-in">
        <h1>Bentornato, Marco</h1>
        <p class="date" id="todayDate"></p>
      </div>

      <!-- Stats -->
      <div class="stats-row fade-in">
        <div class="stat-card">
          <div class="stat-label">Corsi Attivi</div>
          <div class="stat-value" data-target="3">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Lezioni Completate</div>
          <div class="stat-value" data-target="24">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Ore di Studio</div>
          <div class="stat-value" data-target="18">0</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">Certificati</div>
          <div class="stat-value" data-target="1">0</div>
        </div>
      </div>

      <!-- Courses -->
      <h2 class="section-title fade-in">I tuoi corsi</h2>
      <div class="courses-grid">
        <div class="course-card fade-in">
          <img src="/images/portfolio/corso-laptop.jpg" alt="Full-Stack Web Development" class="course-thumb" loading="lazy" />
          <div class="course-body">
            <div class="course-title">Full-Stack Web Development</div>
            <div class="progress-bar-wrap">
              <div class="progress-bar progress-purple" data-progress="65"></div>
            </div>
            <div class="course-meta">12 di 18 lezioni &mdash; 65%</div>
            <button class="course-btn purple">Continua &rarr;</button>
          </div>
        </div>
        <div class="course-card fade-in">
          <img src="/images/portfolio/corso-study.jpg" alt="AI &amp; Machine Learning" class="course-thumb" loading="lazy" />
          <div class="course-body">
            <div class="course-title">AI &amp; Machine Learning</div>
            <div class="progress-bar-wrap">
              <div class="progress-bar progress-cyan" data-progress="30"></div>
            </div>
            <div class="course-meta">5 di 16 lezioni &mdash; 30%</div>
            <button class="course-btn purple">Continua &rarr;</button>
          </div>
        </div>
        <div class="course-card fade-in">
          <img src="/images/portfolio/corso-classroom.jpg" alt="UI/UX Design Masterclass" class="course-thumb" loading="lazy" />
          <div class="course-body">
            <div class="course-title">UI/UX Design Masterclass</div>
            <div class="progress-bar-wrap">
              <div class="progress-bar progress-green" data-progress="100"></div>
            </div>
            <div class="badge-complete">Completato</div>
            <button class="course-btn green">Scarica Certificato</button>
          </div>
        </div>
      </div>

      <!-- Schedule -->
      <h2 class="section-title fade-in">Prossime lezioni</h2>
      <div class="schedule-list fade-in">
        <div class="schedule-item">
          <div class="schedule-time">Domani, 10:00</div>
          <div class="schedule-lesson">React Hooks Avanzati</div>
          <div class="schedule-course">Full-Stack Web Dev</div>
        </div>
        <div class="schedule-item">
          <div class="schedule-time">Mercoledì, 15:00</div>
          <div class="schedule-lesson">Reti Neurali</div>
          <div class="schedule-course">AI &amp; Machine Learning</div>
        </div>
        <div class="schedule-item">
          <div class="schedule-time">Venerdì, 11:00</div>
          <div class="schedule-lesson">Live Q&amp;A</div>
          <div class="schedule-course">Full-Stack Web Dev</div>
        </div>
      </div>
    </main>
  </div>

  <script is:inline>
    // Date
    const d = new Date();
    const months = ['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];
    const days = ['Domenica','Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato'];
    document.getElementById('todayDate').textContent =
      days[d.getDay()] + ' ' + d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();

    // Fade-in observer
    const fadeObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); fadeObs.unobserve(e.target); } });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => fadeObs.observe(el));

    // Counter animation
    const counterObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        const el = e.target;
        const target = parseInt(el.dataset.target, 10);
        let current = 0;
        const step = Math.max(1, Math.floor(target / 30));
        const timer = setInterval(() => {
          current += step;
          if (current >= target) { current = target; clearInterval(timer); }
          el.textContent = current;
        }, 40);
        counterObs.unobserve(el);
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.stat-value[data-target]').forEach(el => counterObs.observe(el));

    // Progress bar animation
    const progressObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (!e.isIntersecting) return;
        e.target.style.width = e.target.dataset.progress + '%';
        progressObs.unobserve(e.target);
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.progress-bar[data-progress]').forEach(el => progressObs.observe(el));

    // Hamburger / sidebar
    const hamburger = document.getElementById('hamburger');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebarOverlay');
    function toggleSidebar() {
      sidebar.classList.toggle('open');
      overlay.classList.toggle('show');
    }
    hamburger.addEventListener('click', toggleSidebar);
    overlay.addEventListener('click', toggleSidebar);

    // ===== COURSE BUTTONS =====
    document.querySelectorAll('.course-btn.purple').forEach((btn, i) => {
      btn.addEventListener('click', () => openVideoPlayer(i));
    });

    document.querySelector('.course-btn.green')?.addEventListener('click', () => {
      showDashToast('📜 Certificato scaricato! Controlla la cartella Download.');
    });

    // ===== VIDEO PLAYER =====
    const courses = [
      { title: 'Python per il Machine Learning', lesson: 'Lezione 7 — Reti Neurali Convoluzionali', duration: '42:18' },
      { title: 'UX Design Avanzato', lesson: 'Lezione 3 — Design System e Atomic Design', duration: '38:55' },
    ];

    function openVideoPlayer(i) {
      const c = courses[i] || courses[0];
      document.getElementById('vpTitle').textContent = c.title;
      document.getElementById('vpLesson').textContent = c.lesson;
      document.getElementById('vpDuration').textContent = c.duration;
      document.getElementById('vpProgress').style.width = '0%';
      document.getElementById('vpPlaying').textContent = '▶';
      document.getElementById('videoPlayer').classList.add('open');
      document.getElementById('vpOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeVideoPlayer() {
      document.getElementById('videoPlayer').classList.remove('open');
      document.getElementById('vpOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    let vpInterval;
    let vpSeconds = 0;
    let vpPlaying = false;

    function togglePlay() {
      vpPlaying = !vpPlaying;
      document.getElementById('vpPlaying').textContent = vpPlaying ? '⏸' : '▶';
      if (vpPlaying) {
        vpInterval = setInterval(() => {
          vpSeconds += 1;
          const pct = Math.min((vpSeconds / 120) * 100, 100);
          document.getElementById('vpProgress').style.width = pct + '%';
          const m = Math.floor(vpSeconds / 60);
          const s = vpSeconds % 60;
          document.getElementById('vpTime').textContent = m + ':' + String(s).padStart(2,'0');
          if (vpSeconds >= 120) { clearInterval(vpInterval); vpPlaying = false; document.getElementById('vpPlaying').textContent = '▶'; }
        }, 1000);
      } else {
        clearInterval(vpInterval);
      }
    }

    // ===== NOTIFICATION BELL =====
    document.querySelector('.notif-bell')?.addEventListener('click', () => {
      showDashToast('🔔 3 nuove notifiche: lezione aggiunta, nuovo badge, messaggio dal tutor');
    });

    // ===== LOGOUT =====
    document.querySelector('.sidebar-item.logout')?.addEventListener('click', (e) => {
      e.preventDefault();
      showDashToast('👋 Arrivederci! Sessione terminata.');
      setTimeout(() => window.location.href = '/portfolio/corso-online-login', 1500);
    });

    // ===== SCHEDULE LESSONS =====
    document.querySelectorAll('.schedule-lesson').forEach(lesson => {
      lesson.style.cursor = 'pointer';
      lesson.addEventListener('click', () => {
        showDashToast('📅 ' + lesson.textContent + ' — Promemoria impostato!');
      });
    });

    // ===== TOAST =====
    let dashToastTimeout;
    function showDashToast(msg) {
      const t = document.getElementById('dash-toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(dashToastTimeout);
      dashToastTimeout = setTimeout(() => t.classList.remove('show'), 3200);
    }
  </script>

  <!-- Video Player Modal -->
  <div style="position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:9998;opacity:0;pointer-events:none;transition:opacity 0.3s" id="vpOverlay" onclick="closeVideoPlayer()"></div>
  <div id="videoPlayer" style="position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);width:min(700px,92vw);background:#0d0d1a;border:1px solid rgba(139,92,246,0.2);border-radius:16px;z-index:9999;opacity:0;pointer-events:none;transition:all 0.35s cubic-bezier(0.4,0,0.2,1);overflow:hidden;">
    <button onclick="closeVideoPlayer()" style="position:absolute;top:12px;right:12px;background:rgba(255,255,255,0.08);border:none;color:rgba(255,255,255,0.6);width:32px;height:32px;border-radius:50%;cursor:pointer;font-size:0.9rem;z-index:1;">✕</button>
    <!-- Fake video area -->
    <div style="background:#050510;height:320px;display:flex;align-items:center;justify-content:center;position:relative;">
      <div style="text-align:center">
        <div style="font-size:4rem;margin-bottom:16px">🎓</div>
        <p style="color:rgba(255,255,255,0.5);font-size:0.85rem" id="vpLesson">Lezione 7 — Reti Neurali</p>
      </div>
      <!-- Progress bar -->
      <div style="position:absolute;bottom:0;left:0;right:0;height:4px;background:rgba(255,255,255,0.08)">
        <div id="vpProgress" style="height:100%;background:linear-gradient(90deg,#8b5cf6,#06b6d4);width:0%;transition:width 0.5s linear;"></div>
      </div>
    </div>
    <!-- Controls -->
    <div style="padding:16px 24px;display:flex;align-items:center;gap:16px;border-bottom:1px solid rgba(255,255,255,0.06);">
      <button onclick="togglePlay()" id="vpPlaying" style="background:linear-gradient(135deg,#8b5cf6,#06b6d4);border:none;color:#fff;width:44px;height:44px;border-radius:50%;cursor:pointer;font-size:1.1rem;">▶</button>
      <div style="flex:1">
        <div style="font-size:0.9rem;color:#fff;font-weight:600;margin-bottom:2px" id="vpTitle">Python ML</div>
        <div style="font-size:0.75rem;color:rgba(255,255,255,0.4)"><span id="vpTime">0:00</span> / <span id="vpDuration">42:18</span></div>
      </div>
      <button onclick="showDashToast('🔖 Segnalibro salvato al momento ' + document.getElementById(\'vpTime\').textContent)" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);padding:8px 14px;border-radius:8px;cursor:pointer;font-size:0.8rem;">🔖 Segna</button>
      <button onclick="showDashToast('📝 Note aggiunte!')" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);padding:8px 14px;border-radius:8px;cursor:pointer;font-size:0.8rem;">📝 Note</button>
    </div>
    <!-- Lesson list -->
    <div style="padding:16px 24px;max-height:180px;overflow-y:auto;">
      <p style="font-size:0.72rem;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.3);margin-bottom:12px">Prossime lezioni</p>
      <div onclick="showDashToast('▶ Lezione 8 avviata')" style="padding:10px 12px;border-radius:8px;cursor:pointer;background:rgba(139,92,246,0.1);border:1px solid rgba(139,92,246,0.2);margin-bottom:8px;font-size:0.85rem;color:#c4b5fd;">8 — Transfer Learning con TensorFlow <span style="float:right;opacity:0.5">38:42</span></div>
      <div onclick="showDashToast('▶ Lezione 9 avviata')" style="padding:10px 12px;border-radius:8px;cursor:pointer;transition:background 0.2s;margin-bottom:8px;font-size:0.85rem;color:rgba(255,255,255,0.5);">9 — Ottimizzazione dei modelli <span style="float:right;opacity:0.5">45:10</span></div>
      <div onclick="showDashToast('▶ Lezione 10 avviata')" style="padding:10px 12px;border-radius:8px;cursor:pointer;font-size:0.85rem;color:rgba(255,255,255,0.5);">10 — Deploy su cloud <span style="float:right;opacity:0.5">52:18</span></div>
    </div>
  </div>
  <div id="dash-toast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#0d0d1a;border:1px solid rgba(139,92,246,0.4);color:#c4b5fd;padding:13px 26px;border-radius:50px;font-size:0.84rem;z-index:99999;opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);white-space:nowrap;pointer-events:none;max-width:90vw;text-align:center;"></div>
  <style>#videoPlayer.open,#vpOverlay.open{opacity:1!important;pointer-events:all!important;transform:translate(-50%,-50%) scale(1)!important}#dash-toast.show{opacity:1!important;transform:translateX(-50%) translateY(0)!important}</style>
</body>
</html>
