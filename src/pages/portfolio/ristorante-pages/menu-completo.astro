---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Menu Completo — Osteria del Borgo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="noise"></div>

  <a href="/portfolio/ristorante" class="back-btn">
    <span class="back-arrow">&larr;</span> Torna al Ristorante
  </a>

  <!-- Hero -->
  <header class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content fade-in">
      <div class="ornament">&mdash;&nbsp;&nbsp;&#10038;&nbsp;&nbsp;&mdash;</div>
      <h1 class="hero-title">Menu Completo</h1>
      <p class="hero-sub">I nostri piatti cambiano con le stagioni &middot; Coperto &euro;3</p>
      <div class="ornament">&mdash;&nbsp;&nbsp;&#10038;&nbsp;&nbsp;&mdash;</div>
    </div>
  </header>

  <!-- Menu -->
  <section class="menu-section">
    <div class="section-inner">

      <!-- Antipasti -->
      <div class="menu-category fade-in">
        <h2 class="menu-cat-title">Antipasti</h2>
        <div class="gold-line"></div>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Tartare di Manzo</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;16</span>
        </div>
        <p class="menu-item-desc">Tuorlo d'uovo di fattoria, tartufo nero del Chianti, olio EVO nostrano</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Burrata Pugliese</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;14</span>
        </div>
        <p class="menu-item-desc">Pomodorini confit dell'orto, basilico fresco, pane toscano croccante</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Carpaccio di Branzino</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;18</span>
        </div>
        <p class="menu-item-desc">Agrumi di stagione, finocchietto selvatico, olio extravergine Moraiolo</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Crostini Toscani</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;10</span>
        </div>
        <p class="menu-item-desc">Fegatini di pollo alla tradizione, sfumati al vin santo, capperi e cipolla</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Tagliere di Salumi Toscani</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;15</span>
        </div>
        <p class="menu-item-desc">Prosciutto toscano DOP, finocchiona, capocollo, lardo di Colonnata, schiacciata</p>
      </div>

      <!-- Divider -->
      <div class="menu-divider"><span>&#9830;</span></div>

      <!-- Primi -->
      <div class="menu-category fade-in">
        <h2 class="menu-cat-title">Primi Piatti</h2>
        <div class="gold-line"></div>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Pappardelle al Cinghiale</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;16</span>
        </div>
        <p class="menu-item-desc">Rag&ugrave; di cinghiale cotto lentamente per 6 ore, pecorino toscano stagionato</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Risotto allo Zafferano con Ossobuco</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;18</span>
        </div>
        <p class="menu-item-desc">Zafferano puro, ossobuco brasato al vino rosso, gremolata di agrumi</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Ravioli Ricotta e Spinaci</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;14</span>
        </div>
        <p class="menu-item-desc">Pasta fresca fatta a mano, burro fuso e salvia dell'orto, parmigiano 24 mesi</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Spaghetti alle Vongole Veraci</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;17</span>
        </div>
        <p class="menu-item-desc">Vongole fresche del Tirreno, aglio, prezzemolo, peperoncino, vino bianco</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Ribollita della Tradizione</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;12</span>
        </div>
        <p class="menu-item-desc">Pane toscano raffermo, cavolo nero dell'orto, fagioli cannellini, olio nuovo</p>
      </div>

      <!-- Divider -->
      <div class="menu-divider"><span>&#9830;</span></div>

      <!-- Secondi -->
      <div class="menu-category fade-in">
        <h2 class="menu-cat-title">Secondi</h2>
        <div class="gold-line"></div>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Filetto di Manzo alla Griglia</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;28</span>
        </div>
        <p class="menu-item-desc">Chianina selezionata, verdure di stagione grigliate, riduzione al Chianti Classico</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Branzino al Forno</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;24</span>
        </div>
        <p class="menu-item-desc">Patate novelle arrosto, olive taggiasche, capperi di Pantelleria, pomodorini</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Tagliata di Black Angus</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;26</span>
        </div>
        <p class="menu-item-desc">Rucola selvatica, scaglie di Grana Padano 30 mesi, aceto balsamico tradizionale</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Pollo Ruspante Arrosto</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;18</span>
        </div>
        <p class="menu-item-desc">Allevamento locale, rosmarino e salvia dell'orto, patate al forno croccanti</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Bistecca alla Fiorentina</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;5/hg</span>
        </div>
        <p class="menu-item-desc">Chianina certificata, minimo 1 kg, cotta alla brace con legna di quercia. Per 2 persone.</p>
      </div>

      <!-- Divider -->
      <div class="menu-divider"><span>&#9830;</span></div>

      <!-- Contorni -->
      <div class="menu-category fade-in">
        <h2 class="menu-cat-title">Contorni</h2>
        <div class="gold-line"></div>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Verdure Grigliate</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;6</span>
        </div>
        <p class="menu-item-desc">Zucchine, melanzane e peperoni dell'orto, olio extravergine e origano</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Patate al Forno</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;5</span>
        </div>
        <p class="menu-item-desc">Patate novelle con rosmarino e aglio, croccanti fuori e morbide dentro</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Insalata Mista</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;5</span>
        </div>
        <p class="menu-item-desc">Lattuga, rucola, pomodorini e carote dell'orto, condita con olio EVO nostrano</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Spinaci Saltati</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;6</span>
        </div>
        <p class="menu-item-desc">Spinaci freschi saltati in padella con aglio, olio e peperoncino</p>
      </div>

      <!-- Divider -->
      <div class="menu-divider"><span>&#9830;</span></div>

      <!-- Dolci -->
      <div class="menu-category fade-in">
        <h2 class="menu-cat-title">Dolci</h2>
        <div class="gold-line"></div>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Tiramis&ugrave; della Casa</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;8</span>
        </div>
        <p class="menu-item-desc">Ricetta della nonna Maria, mascarpone fresco, caff&egrave; espresso, cacao amaro</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Panna Cotta alla Vaniglia</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;7</span>
        </div>
        <p class="menu-item-desc">Vaniglia del Madagascar, coulis di frutti di bosco freschi del nostro orto</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Tortino al Cioccolato Fondente</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;9</span>
        </div>
        <p class="menu-item-desc">Cuore caldo fondente, gelato alla crema fatto in casa, cacao in polvere</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Selezione di Formaggi Stagionati</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;12</span>
        </div>
        <p class="menu-item-desc">Pecorino toscano, gorgonzola DOP, parmigiano 36 mesi con miele e noci</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Cantucci e Vin Santo</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;8</span>
        </div>
        <p class="menu-item-desc">Cantucci alle mandorle fatti in casa, Vin Santo del Chianti invecchiato 5 anni</p>
      </div>

      <!-- Divider -->
      <div class="menu-divider"><span>&#9830;</span></div>

      <!-- Vini -->
      <div class="menu-category fade-in">
        <h2 class="menu-cat-title">I Nostri Vini</h2>
        <div class="gold-line"></div>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Chianti Classico DOCG</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;24</span>
        </div>
        <p class="menu-item-desc">Castello di Verrazzano &mdash; Sangiovese in purezza, note di ciliegia e spezie dolci. Ideale con primi e carni rosse.</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Brunello di Montalcino DOCG</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;45</span>
        </div>
        <p class="menu-item-desc">Podere Le Ripi &mdash; Invecchiato 4 anni, elegante e strutturato. Perfetto con il filetto e la tagliata.</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Vernaccia di San Gimignano DOCG</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;22</span>
        </div>
        <p class="menu-item-desc">Tenuta Le Calcinaie &mdash; Bianco fresco e minerale, note di fiori bianchi e agrumi. Ottimo con pesce e antipasti.</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Bolgheri Rosso DOC</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;32</span>
        </div>
        <p class="menu-item-desc">Tenuta Guado al Tasso &mdash; Blend di Cabernet e Merlot, vellutato e avvolgente. Accompagna splendidamente la bistecca.</p>
      </div>
      <div class="menu-item fade-in">
        <div class="menu-item-header">
          <h3 class="menu-item-name">Rosato Toscana IGT</h3>
          <div class="menu-item-dots"></div>
          <span class="menu-item-price">&euro;18</span>
        </div>
        <p class="menu-item-desc">Villa Antinori &mdash; Fresco e fruttato, note di fragola e rosa. Versatile per tutto il pasto, perfetto d'estate.</p>
      </div>

      <!-- Footer note -->
      <div class="menu-footer fade-in">
        <div class="menu-divider"><span>&#10038;</span></div>
        <p class="menu-note">Informazioni su allergeni disponibili su richiesta.<br/>Coperto &euro;2,50.</p>
        <p class="menu-note" style="margin-top:8px;opacity:0.5;">I prezzi sono IVA inclusa. Il menu pu&ograve; variare in base alla disponibilit&agrave; dei prodotti stagionali.</p>
      </div>

    </div>
  </section>

  <!-- Footer -->
  <footer class="footer fade-in">
    <div class="footer-inner">
      <div class="ornament">&mdash;&nbsp;&nbsp;&#10038;&nbsp;&nbsp;&mdash;</div>
      <h3 class="footer-brand">Osteria del Borgo</h3>
      <p class="footer-address">Via del Borgo Antico 23, Greve in Chianti (FI) &middot; +39 055 123 4567</p>
      <div class="footer-copy">&copy; 2026 Osteria del Borgo di Conti G. &amp; C. Snc &middot; P.IVA 01234567890</div>
    </div>
  </footer>

  <div class="floating-circle fg1"></div>
  <div class="floating-circle fg2"></div>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const delay = entry.target.dataset.delay || 0;
          setTimeout(() => entry.target.classList.add('visible'), Number(delay));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.fade-in').forEach((el, i) => {
      el.dataset.delay = (i % 5) * 100;
      observer.observe(el);
    });
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Lato', 'Segoe UI', sans-serif;
      background: #0a0a0a; color: #e8e0d4; line-height: 1.7; overflow-x: hidden;
    }
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0a0a0a; }
    ::-webkit-scrollbar-thumb { background: #d4a853; border-radius: 3px; }

    .noise {
      position: fixed; inset: 0; pointer-events: none; z-index: 9999; opacity: 0.04;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-repeat: repeat; background-size: 256px;
    }

    .fade-in {
      opacity: 0; transform: translateY(20px);
      transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    .floating-circle { position: fixed; border-radius: 50%; pointer-events: none; z-index: -1; opacity: 0.03; background: #d4a853; }
    .fg1 { width: 350px; height: 350px; top: 15%; right: -100px; animation: floatG 20s ease-in-out infinite; }
    .fg2 { width: 200px; height: 200px; bottom: 10%; left: -60px; animation: floatG 25s ease-in-out infinite reverse; }
    @keyframes floatG { 0%,100% { transform: translate(0,0); } 50% { transform: translate(25px,-20px); } }

    .ornament { font-size: 0.85rem; color: #d4a853; letter-spacing: 0.3em; margin-bottom: 16px; opacity: 0.6; }

    .back-btn {
      position: fixed; top: 20px; left: 20px; z-index: 1000;
      display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px;
      background: rgba(10,10,10,0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(212,168,83,0.2); border-radius: 0;
      color: rgba(212,168,83,0.7); text-decoration: none;
      font-size: 0.78rem; font-weight: 400; letter-spacing: 0.1em; text-transform: uppercase;
      transition: all 0.3s ease;
    }
    .back-btn:hover { color: #d4a853; border-color: rgba(212,168,83,0.5); transform: translateX(-4px); }
    .back-arrow { transition: transform 0.3s; }
    .back-btn:hover .back-arrow { transform: translateX(-3px); }

    /* Hero */
    .hero {
      min-height: 40vh; display: flex; align-items: center; justify-content: center;
      position: relative; text-align: center; overflow: hidden;
      background: linear-gradient(135deg, #1a2e1a 0%, #0a0a0a 50%, #1a2e1a 100%);
      padding: 120px 24px 60px;
    }
    .hero-overlay {
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(212,168,83,0.05) 0%, transparent 70%);
    }
    .hero-content { position: relative; z-index: 2; }
    .hero-title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: clamp(2.5rem, 7vw, 4.5rem); font-weight: 400; color: #fff;
      letter-spacing: 0.08em; margin: 16px 0;
      background: linear-gradient(135deg, #ffffff 0%, #d4a853 60%, #ffffff 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .hero-sub {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.1rem; font-style: italic; color: rgba(212,168,83,0.6); letter-spacing: 0.1em;
    }

    /* Menu */
    .menu-section { padding: 60px 0 40px; }
    .section-inner { max-width: 750px; margin: 0 auto; padding: 0 24px; }

    .menu-category { text-align: center; margin: 48px 0 24px; }
    .menu-category:first-child { margin-top: 0; }
    .menu-cat-title {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.8rem; font-weight: 400; color: #d4a853; letter-spacing: 0.08em;
    }
    .gold-line {
      width: 60px; height: 1px; margin: 12px auto 0;
      background: linear-gradient(90deg, transparent, #d4a853, transparent);
    }

    .menu-item { padding: 16px 0; border-bottom: 1px solid rgba(212,168,83,0.08); }
    .menu-item-header { display: flex; align-items: baseline; gap: 12px; }
    .menu-item-name {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.15rem; font-weight: 500; color: #f5f0e1; white-space: nowrap;
    }
    .menu-item-dots { flex: 1; border-bottom: 1px dotted rgba(212,168,83,0.2); margin-bottom: 4px; min-width: 20px; }
    .menu-item-price {
      font-family: 'Cormorant Garamond', Georgia, serif;
      font-size: 1.15rem; font-weight: 600; color: #d4a853; white-space: nowrap;
    }
    .menu-item-desc { font-size: 0.85rem; color: rgba(232,224,212,0.5); margin-top: 4px; font-style: italic; }

    .menu-divider {
      text-align: center; padding: 32px 0;
      color: #d4a853; font-size: 0.7rem; opacity: 0.4;
    }

    .menu-footer { text-align: center; padding: 40px 0 20px; }
    .menu-note { font-size: 0.85rem; color: rgba(232,224,212,0.6); font-style: italic; }

    /* Footer */
    .footer {
      padding: 60px 24px 32px; text-align: center;
      border-top: 1px solid rgba(212,168,83,0.1);
    }
    .footer-inner { max-width: 600px; margin: 0 auto; }
    .footer-brand {
      font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 400;
      color: #d4a853; margin: 12px 0 8px;
    }
    .footer-address { font-size: 0.85rem; color: rgba(232,224,212,0.5); }
    .footer-copy { font-size: 0.75rem; color: rgba(232,224,212,0.3); margin-top: 16px; }

    @media (max-width: 768px) {
      .menu-item-name { font-size: 1rem; white-space: normal; }
      .menu-item-header { flex-wrap: wrap; }
      .menu-item-dots { display: none; }
      .menu-item-price { margin-left: auto; }
      .back-btn { top: 12px; left: 12px; bottom: auto; font-size: 0.75rem; padding: 8px 14px; }
    }
  </style>
</body>
</html>
