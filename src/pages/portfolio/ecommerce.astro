    <div class="stat-item">
      <span class="stat-number" data-target="1250">0</span>
      <span class="stat-label">Clienti Soddisfatti</span>
    </div>
    <div class="stat-item">
      <span class="stat-number" data-target="48">0</span>
      <span class="stat-label">Brand Esclusivi</span>
    </div>
    <div class="stat-item">
      <span class="stat-number" data-target="15">0</span>
      <span class="stat-label">Anni di Esperienza</span>
    </div>
    <div class="stat-item">
      <span class="stat-number" data-target="320">0</span>
      <span class="stat-label">Pezzi in Collezione</span>
