    <div class="marquee">
      <span>VALENTINO</span><span class="sep">&bull;</span>
      <span>BOTTEGA VENETA</span><span class="sep">&bull;</span>
      <span>BRUNELLO CUCINELLI</span><span class="sep">&bull;</span>
      <span>TOM FORD</span><span class="sep">&bull;</span>
      <span>LORO PIANA</span><span class="sep">&bull;</span>
      <span>ZEGNA</span><span class="sep">&bull;</span>
      <span>VALENTINO</span><span class="sep">&bull;</span>
      <span>BOTTEGA VENETA</span><span class="sep">&bull;</span>
      <span>BRUNELLO CUCINELLI</span><span class="sep">&bull;</span>
      <span>TOM FORD</span><span class="sep">&bull;</span>
      <span>LORO PIANA</span><span class="sep">&bull;</span>
      <span>ZEGNA</span><span class="sep">&bull;</span>
