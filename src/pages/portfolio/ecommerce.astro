      <div class="product-card fade-in" style="--delay: 0.1s">
        <div class="product-image">
          <div class="product-placeholder">
            <div class="product-shape shape-jacket"></div>
          </div>
          <div class="product-overlay">
            <button class="quick-view-btn">Vista Rapida</button>
