        <div class="mockup-inner"></div>
      </div>
      <div class="mockup mockup-2">
        <div class="mockup-inner"></div>
      </div>
      <div class="mockup mockup-3">
        <div class="mockup-inner"></div>
      </div>
    </div>
  </section>

  <!-- Brand marquee -->
