---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nome Agenzia Immobiliare — Trova la Casa dei Tuoi Sogni</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fff; color: #1e293b; line-height: 1.6; }

    .back-btn {
      position: fixed; top: 16px; left: 16px; z-index: 1000;
      background: #2563eb; color: #fff; text-decoration: none;
      padding: 8px 16px; border-radius: 8px; font-size: 14px; font-weight: 500;
      box-shadow: 0 4px 12px rgba(37,99,235,.35); transition: background .2s;
    }
    .back-btn:hover { background: #1d4ed8; }

    /* Navbar */
    .navbar {
      background: #fff; padding: 0 48px; height: 72px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid #e2e8f0; position: sticky; top: 0; z-index: 100;
    }
    .nav-logo { font-size: 20px; font-weight: 800; color: #1e293b; }
    .nav-logo span { color: #2563eb; }
    .nav-links { display: flex; gap: 28px; list-style: none; }
    .nav-links a { text-decoration: none; color: #64748b; font-size: 15px; font-weight: 500; transition: color .2s; }
    .nav-links a:hover { color: #2563eb; }
    .nav-cta {
      padding: 10px 24px; background: #2563eb; color: #fff; text-decoration: none;
      border-radius: 8px; font-size: 14px; font-weight: 600; transition: background .2s;
    }
    .nav-cta:hover { background: #1d4ed8; }

    /* Hero */
    .hero {
      padding: 80px 48px 48px; text-align: center;
      background: linear-gradient(180deg, #eff6ff 0%, #fff 100%);
    }
    .hero h1 { font-size: 48px; font-weight: 800; color: #0f172a; margin-bottom: 12px; }
    .hero p { font-size: 18px; color: #64748b; margin-bottom: 40px; }

    /* Search bar */
    .search-bar {
      max-width: 900px; margin: 0 auto; background: #fff;
      border-radius: 16px; padding: 20px 24px;
      box-shadow: 0 8px 32px rgba(0,0,0,.1); display: flex; gap: 16px; align-items: end; flex-wrap: wrap;
    }
    .search-field { display: flex; flex-direction: column; gap: 6px; flex: 1; min-width: 140px; }
    .search-field label { font-size: 12px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
    .search-field select, .search-field input {
      padding: 12px 14px; border: 2px solid #e2e8f0; border-radius: 10px;
      font-size: 15px; color: #1e293b; background: #f8fafc; outline: none;
      transition: border-color .2s;
    }
    .search-field select:focus, .search-field input:focus { border-color: #2563eb; }
    .search-btn {
      padding: 12px 32px; background: #2563eb; color: #fff; border: none;
      border-radius: 10px; font-size: 16px; font-weight: 700; cursor: pointer;
      transition: background .2s; white-space: nowrap;
    }
    .search-btn:hover { background: #1d4ed8; }

    /* Section */
    section { padding: 80px 48px; }
    .section-title { font-size: 36px; font-weight: 800; text-align: center; color: #0f172a; margin-bottom: 12px; }
    .section-sub { text-align: center; color: #64748b; font-size: 17px; max-width: 560px; margin: 0 auto 48px; }

    /* Listings */
    .listings-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; max-width: 1200px; margin: 0 auto; }
    .listing-card {
      background: #fff; border-radius: 16px; overflow: hidden;
      box-shadow: 0 2px 16px rgba(0,0,0,.06); transition: transform .2s, box-shadow .2s;
    }
    .listing-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,.12); }
    .listing-img { height: 200px; position: relative; }
    .listing-card:nth-child(1) .listing-img { background: linear-gradient(135deg, #93c5fd, #3b82f6); }
    .listing-card:nth-child(2) .listing-img { background: linear-gradient(135deg, #a5b4fc, #6366f1); }
    .listing-card:nth-child(3) .listing-img { background: linear-gradient(135deg, #6ee7b7, #10b981); }
    .listing-card:nth-child(4) .listing-img { background: linear-gradient(135deg, #fcd34d, #f59e0b); }
    .listing-card:nth-child(5) .listing-img { background: linear-gradient(135deg, #fda4af, #f43f5e); }
    .listing-card:nth-child(6) .listing-img { background: linear-gradient(135deg, #c4b5fd, #8b5cf6); }
    .listing-badge {
      position: absolute; top: 16px; left: 16px; padding: 6px 14px;
      background: #2563eb; color: #fff; border-radius: 8px;
      font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
    }
    .listing-badge.rent { background: #10b981; }
    .listing-body { padding: 20px; }
    .listing-price { font-size: 24px; font-weight: 800; color: #0f172a; }
    .listing-price span { font-size: 14px; font-weight: 400; color: #94a3b8; }
    .listing-addr { font-size: 15px; color: #64748b; margin: 6px 0 14px; }
    .listing-specs { display: flex; gap: 16px; font-size: 14px; color: #64748b; margin-bottom: 16px; }
    .listing-btn {
      display: block; text-align: center; padding: 12px;
      border: 2px solid #2563eb; color: #2563eb; border-radius: 10px;
      text-decoration: none; font-weight: 600; font-size: 15px; transition: all .2s;
    }
    .listing-btn:hover { background: #2563eb; color: #fff; }

    /* Value props */
    .values-section { background: #f8fafc; }
    .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; max-width: 1100px; margin: 0 auto; }
    .value-card { text-align: center; padding: 32px 20px; }
    .value-icon {
      width: 64px; height: 64px; border-radius: 16px; background: #eff6ff;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; margin: 0 auto 16px;
    }
    .value-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: #0f172a; }
    .value-card p { font-size: 15px; color: #64748b; }

    /* Team */
    .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; max-width: 900px; margin: 0 auto; }
    .team-card { text-align: center; padding: 32px 24px; background: #f8fafc; border-radius: 16px; }
    .team-avatar {
      width: 80px; height: 80px; border-radius: 50%; margin: 0 auto 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px; font-weight: 700; color: #fff;
    }
    .team-card:nth-child(1) .team-avatar { background: linear-gradient(135deg, #3b82f6, #1d4ed8); }
    .team-card:nth-child(2) .team-avatar { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
    .team-card:nth-child(3) .team-avatar { background: linear-gradient(135deg, #10b981, #059669); }
    .team-card h3 { font-size: 18px; font-weight: 700; color: #0f172a; }
    .team-role { font-size: 14px; color: #2563eb; font-weight: 500; margin: 4px 0 8px; }
    .team-phone { font-size: 14px; color: #64748b; }

    /* Contact */
    .contact-section { background: #0f172a; color: #e2e8f0; }
    .contact-section .section-title { color: #fff; }
    .contact-section .section-sub { color: #94a3b8; }
    .contact-form { max-width: 600px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .contact-form .full { grid-column: 1 / -1; }
    .contact-form input, .contact-form textarea, .contact-form select {
      width: 100%; padding: 14px 16px; background: #1e293b; border: 2px solid #334155;
      border-radius: 10px; color: #e2e8f0; font-size: 15px; font-family: inherit; outline: none;
      transition: border-color .2s;
    }
    .contact-form input::placeholder, .contact-form textarea::placeholder { color: #64748b; }
    .contact-form input:focus, .contact-form textarea:focus { border-color: #2563eb; }
    .contact-form textarea { resize: vertical; min-height: 120px; }
    .contact-submit {
      grid-column: 1 / -1; padding: 14px; background: #2563eb; color: #fff;
      border: none; border-radius: 10px; font-size: 16px; font-weight: 700;
      cursor: pointer; transition: background .2s;
    }
    .contact-submit:hover { background: #1d4ed8; }

    /* Footer */
    .footer { background: #0f172a; border-top: 1px solid #1e293b; padding: 32px 48px; text-align: center; }
    .footer p { color: #475569; font-size: 14px; }
    .footer a { color: #2563eb; text-decoration: none; }

    @media (max-width: 1024px) {
      .listings-grid { grid-template-columns: repeat(2, 1fr); }
      .values-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .nav-links, .nav-cta { display: none; }
      .hero h1 { font-size: 32px; }
      .search-bar { flex-direction: column; }
      .listings-grid, .team-grid { grid-template-columns: 1fr; }
      .values-grid { grid-template-columns: 1fr; }
      section { padding: 48px 20px; }
      .contact-form { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <a href="/portfolio" class="back-btn">&larr; Torna al Portfolio</a>

  <nav class="navbar">
    <div class="nav-logo"><span>Nome</span> Agenzia Immobiliare</div>
    <ul class="nav-links">
      <li><a href="#">Vendita</a></li>
      <li><a href="#">Affitto</a></li>
      <li><a href="#">Nuove Costruzioni</a></li>
      <li><a href="#">Valutazione</a></li>
    </ul>
    <a href="#" class="nav-cta">Contatti</a>
  </nav>

  <section class="hero">
    <h1>Trova la casa dei tuoi sogni</h1>
    <p>Oltre 500 immobili selezionati nelle migliori zone della citt&agrave;.</p>
    <div class="search-bar">
      <div class="search-field">
        <label>Tipo</label>
        <select>
          <option>Vendita</option>
          <option>Affitto</option>
        </select>
      </div>
      <div class="search-field">
        <label>Zona</label>
        <input type="text" placeholder="Es. Centro, Navigli..." />
      </div>
      <div class="search-field">
        <label>Prezzo Min</label>
        <input type="text" placeholder="&euro; 0" />
      </div>
      <div class="search-field">
        <label>Prezzo Max</label>
        <input type="text" placeholder="&euro; 500.000" />
      </div>
      <button class="search-btn">Cerca</button>
    </div>
  </section>

  <section>
    <h2 class="section-title">Immobili in Evidenza</h2>
    <p class="section-sub">Una selezione dei nostri immobili migliori, aggiornata ogni giorno.</p>
    <div class="listings-grid">
      <div class="listing-card">
        <div class="listing-img"><span class="listing-badge">Vendita</span></div>
        <div class="listing-body">
          <div class="listing-price">&euro;285.000</div>
          <div class="listing-addr">Via Roma 42, Centro</div>
          <div class="listing-specs">
            <span>&#128716; 3 camere</span>
            <span>&#128703; 2 bagni</span>
            <span>&#128208; 120 m&sup2;</span>
          </div>
          <a href="#" class="listing-btn">Dettagli</a>
        </div>
      </div>
      <div class="listing-card">
        <div class="listing-img"><span class="listing-badge rent">Affitto</span></div>
        <div class="listing-body">
          <div class="listing-price">&euro;950<span>/mese</span></div>
          <div class="listing-addr">Corso Buenos Aires 18, Loreto</div>
          <div class="listing-specs">
            <span>&#128716; 2 camere</span>
            <span>&#128703; 1 bagno</span>
            <span>&#128208; 75 m&sup2;</span>
          </div>
          <a href="#" class="listing-btn">Dettagli</a>
        </div>
      </div>
      <div class="listing-card">
        <div class="listing-img"><span class="listing-badge">Vendita</span></div>
        <div class="listing-body">
          <div class="listing-price">&euro;425.000</div>
          <div class="listing-addr">Via Tortona 7, Navigli</div>
          <div class="listing-specs">
            <span>&#128716; 4 camere</span>
            <span>&#128703; 2 bagni</span>
            <span>&#128208; 160 m&sup2;</span>
          </div>
          <a href="#" class="listing-btn">Dettagli</a>
        </div>
      </div>
      <div class="listing-card">
        <div class="listing-img"><span class="listing-badge rent">Affitto</span></div>
        <div class="listing-body">
          <div class="listing-price">&euro;1.200<span>/mese</span></div>
          <div class="listing-addr">Piazza Duomo 3, Centro</div>
          <div class="listing-specs">
            <span>&#128716; 2 camere</span>
            <span>&#128703; 1 bagno</span>
            <span>&#128208; 85 m&sup2;</span>
          </div>
          <a href="#" class="listing-btn">Dettagli</a>
        </div>
      </div>
      <div class="listing-card">
        <div class="listing-img"><span class="listing-badge">Vendita</span></div>
        <div class="listing-body">
          <div class="listing-price">&euro;189.000</div>
          <div class="listing-addr">Via Padova 112, NoLo</div>
          <div class="listing-specs">
            <span>&#128716; 2 camere</span>
            <span>&#128703; 1 bagno</span>
            <span>&#128208; 65 m&sup2;</span>
          </div>
          <a href="#" class="listing-btn">Dettagli</a>
        </div>
      </div>
      <div class="listing-card">
        <div class="listing-img"><span class="listing-badge">Vendita</span></div>
        <div class="listing-body">
          <div class="listing-price">&euro;620.000</div>
          <div class="listing-addr">Via Montenapoleone 8, Quadrilatero</div>
          <div class="listing-specs">
            <span>&#128716; 5 camere</span>
            <span>&#128703; 3 bagni</span>
            <span>&#128208; 210 m&sup2;</span>
          </div>
          <a href="#" class="listing-btn">Dettagli</a>
        </div>
      </div>
    </div>
  </section>

  <section class="values-section">
    <h2 class="section-title">Perch&eacute; Scegliere Noi</h2>
    <p class="section-sub">Da oltre 20 anni al servizio dei nostri clienti con professionalit&agrave; e passione.</p>
    <div class="values-grid">
      <div class="value-card">
        <div class="value-icon">&#127942;</div>
        <h3>Esperienza</h3>
        <p>Oltre 20 anni nel settore immobiliare con migliaia di compravendite concluse con successo.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">&#128270;</div>
        <h3>Trasparenza</h3>
        <p>Informazioni chiare e complete su ogni immobile. Nessuna sorpresa, solo certezze.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">&#127760;</div>
        <h3>Rete</h3>
        <p>Collaboriamo con le migliori agenzie e professionisti del settore in tutta Italia.</p>
      </div>
      <div class="value-card">
        <div class="value-icon">&#129309;</div>
        <h3>Assistenza</h3>
        <p>Ti accompagniamo in ogni fase: dalla ricerca alla firma, fino alla consegna delle chiavi.</p>
      </div>
    </div>
  </section>

  <section>
    <h2 class="section-title">Il Nostro Team</h2>
    <p class="section-sub">Professionisti dedicati pronti ad aiutarti.</p>
    <div class="team-grid">
      <div class="team-card">
        <div class="team-avatar">MR</div>
        <h3>Marco Rossi</h3>
        <div class="team-role">Direttore Commerciale</div>
        <div class="team-phone">&#128222; +39 02 1234 567</div>
      </div>
      <div class="team-card">
        <div class="team-avatar">LB</div>
        <h3>Laura Bianchi</h3>
        <div class="team-role">Agente Senior</div>
        <div class="team-phone">&#128222; +39 02 1234 568</div>
      </div>
      <div class="team-card">
        <div class="team-avatar">GV</div>
        <h3>Giuseppe Verdi</h3>
        <div class="team-role">Consulente Immobiliare</div>
        <div class="team-phone">&#128222; +39 02 1234 569</div>
      </div>
    </div>
  </section>

  <section class="contact-section">
    <h2 class="section-title">Contattaci</h2>
    <p class="section-sub">Compila il modulo e ti ricontatteremo entro 24 ore.</p>
    <form class="contact-form">
      <input type="text" placeholder="Nome" />
      <input type="text" placeholder="Cognome" />
      <input type="email" placeholder="Email" class="full" />
      <input type="tel" placeholder="Telefono" class="full" />
      <select class="full">
        <option>Sono interessato a...</option>
        <option>Comprare un immobile</option>
        <option>Vendere un immobile</option>
        <option>Affittare un immobile</option>
        <option>Valutazione gratuita</option>
      </select>
      <textarea class="full" placeholder="Messaggio..."></textarea>
      <button type="button" class="contact-submit">Invia Richiesta</button>
    </form>
  </section>

  <footer class="footer">
    <p>&copy; 2026 Nome Agenzia Immobiliare S.r.l. &mdash; P.IVA 01234567890 &mdash; <a href="#">Privacy</a> &mdash; <a href="#">Cookie</a></p>
  </footer>
</body>
</html>
