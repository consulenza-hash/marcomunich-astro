---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Casa &amp; Territorio — Agenzia Immobiliare Verona</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <a href="/dev/portfolio" class="back-btn">&larr; Torna al Portfolio</a>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content fade-in">
      <span class="hero-tag">Casa &amp; Territorio &mdash; Dal 1998 al servizio del territorio</span>
      <h1 class="hero-title">Trova la tua <span class="gradient-text">propriet&agrave; ideale</span></h1>
      <p class="hero-desc">500+ propriet&agrave; vendute, 1.200+ contratti di affitto, 98% clienti soddisfatti. Verona e provincia, Lago di Garda, campagna vicentina.</p>
      <!-- Search bar -->
      <div class="search-bar">
        <div class="search-field">
          <label>Localit&agrave;</label>
          <input type="text" placeholder="Roma, Milano, Firenze..." />
        </div>
        <div class="search-field">
          <label>Tipologia</label>
          <select>
            <option>Qualsiasi</option>
            <option>Appartamento</option>
            <option>Villa</option>
            <option>Attico</option>
            <option>Loft</option>
          </select>
        </div>
        <div class="search-field">
          <label>Budget max</label>
          <input type="text" placeholder="€500.000" />
        </div>
        <button class="search-submit">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          Cerca
        </button>
      </div>
    </div>
    <div class="hero-decor">
      <div class="hero-orb orb-1"></div>
      <div class="hero-orb orb-2"></div>
    </div>
  </section>

  <!-- Filter pills -->
  <section class="filters-section">
    <div class="filters-inner fade-in">
      <button class="filter-pill active">Tutti</button>
      <button class="filter-pill">Appartamenti</button>
      <button class="filter-pill">Ville</button>
      <button class="filter-pill">Attici</button>
      <button class="filter-pill">Nuove costruzioni</button>
      <button class="filter-pill">Lusso</button>
    </div>
  </section>

  <!-- Properties -->
  <section class="properties">
    <div class="section-header fade-in">
      <h2 class="section-title">Immobili in <span class="gradient-text">evidenza</span></h2>
      <p class="section-sub">Le proposte pi&ugrave; richieste della settimana</p>
    </div>
    <div class="properties-grid">
      <div class="property-card fade-in" style="--delay: 0s">
        <div class="property-img">
          <img src="/images/portfolio/immo-house1.jpg" alt="Attico Centro Storico" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="property-badge">Vendita</span>
          <div class="property-overlay">
            <span>3 camere &bull; 2 bagni &bull; 145 m&sup2;</span>
          </div>
        </div>
        <div class="property-body">
          <div class="property-location">Verona, Centro Storico</div>
          <h3>Attico con terrazza panoramica, travi a vista, parquet originale</h3>
          <div class="property-price">&euro;385.000</div>
        </div>
      </div>
      <div class="property-card fade-in" style="--delay: 0.1s">
        <div class="property-img">
          <img src="/images/portfolio/immo-apartment.jpg" alt="Bilocale Navigli" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="property-badge hot">Affitto</span>
          <div class="property-overlay">
            <span>1 camera &bull; 1 bagno &bull; 55 m&sup2;</span>
          </div>
        </div>
        <div class="property-body">
          <div class="property-location">Milano, Navigli</div>
          <h3>Bilocale ristrutturato, arredato, a 200m dalla fermata metro</h3>
          <div class="property-price">&euro;950/mese</div>
        </div>
      </div>
      <div class="property-card fade-in" style="--delay: 0.2s">
        <div class="property-img">
          <img src="/images/portfolio/immo-villa.jpg" alt="Villa Lago di Garda" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="property-badge">Vendita</span>
          <div class="property-overlay">
            <span>4 camere &bull; 3 bagni &bull; 280 m&sup2;</span>
          </div>
        </div>
        <div class="property-body">
          <div class="property-location">Lago di Garda, Lazise</div>
          <h3>Villa con giardino 1.500 mq, piscina, vista lago, box triplo</h3>
          <div class="property-price">&euro;720.000</div>
        </div>
      </div>
      <div class="property-card fade-in" style="--delay: 0.3s">
        <div class="property-img">
          <img src="/images/portfolio/immo-interior.jpg" alt="Trilocale Brera" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="property-badge hot">Affitto</span>
          <div class="property-overlay">
            <span>2 camere &bull; 1 bagno &bull; 85 m&sup2;</span>
          </div>
        </div>
        <div class="property-body">
          <div class="property-location">Milano, Brera</div>
          <h3>Trilocale in stabile d'epoca, ascensore, cantina</h3>
          <div class="property-price">&euro;1.400/mese</div>
        </div>
      </div>
      <div class="property-card fade-in" style="--delay: 0.4s">
        <div class="property-img">
          <img src="/images/portfolio/immo-exterior.jpg" alt="Casale Ristrutturato" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="property-badge">Vendita</span>
          <div class="property-overlay">
            <span>5 camere &bull; 3 bagni &bull; 320 m&sup2;</span>
          </div>
        </div>
        <div class="property-body">
          <div class="property-location">Campagna Vicentina</div>
          <h3>Casale ristrutturato con 8.000 mq di terreno e dependance</h3>
          <div class="property-price">&euro;495.000</div>
        </div>
      </div>
      <div class="property-card fade-in" style="--delay: 0.5s">
        <div class="property-img">
          <img src="/images/portfolio/immo-living.jpg" alt="Monolocale Studenti" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
          <span class="property-badge hot">Affitto</span>
          <div class="property-overlay">
            <span>1 camera &bull; 1 bagno &bull; 35 m&sup2;</span>
          </div>
        </div>
        <div class="property-body">
          <div class="property-location">Verona, Zona Universit&agrave;</div>
          <h3>Monolocale luminoso, spese incluse, zona universitaria</h3>
          <div class="property-price">&euro;650/mese</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map placeholder -->
  <section class="map-section fade-in">
    <div class="section-header">
      <h2 class="section-title">Esplora la <span class="gradient-text">mappa</span></h2>
    </div>
    <div class="map-placeholder">
      <div class="map-grid"></div>
      <div class="map-pin" style="top: 40%; left: 45%"><span class="pin-label">Verona</span></div>
      <div class="map-pin" style="top: 20%; left: 40%" data-delay="0.3s"><span class="pin-label">Lago di Garda</span></div>
      <div class="map-pin" style="top: 35%; left: 60%" data-delay="0.6s"><span class="pin-label">Vicenza</span></div>
      <div class="map-pin" style="top: 25%; left: 55%" data-delay="0.9s"><span class="pin-label">Padova</span></div>
      <div class="map-pin" style="top: 55%; left: 35%" data-delay="1.2s"><span class="pin-label">Mantova</span></div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    <div class="stats-inner">
      <div class="stat-item fade-in" style="--delay: 0s">
        <span class="stat-num"><span class="counter" data-target="500">0</span>+</span>
        <span class="stat-label">Propriet&agrave; vendute</span>
      </div>
      <div class="stat-item fade-in" style="--delay: 0.1s">
        <span class="stat-num"><span class="counter" data-target="1200">0</span>+</span>
        <span class="stat-label">Contratti di affitto</span>
      </div>
      <div class="stat-item fade-in" style="--delay: 0.2s">
        <span class="stat-num"><span class="counter" data-target="98">0</span>%</span>
        <span class="stat-label">Clienti soddisfatti</span>
      </div>
      <div class="stat-item fade-in" style="--delay: 0.3s">
        <span class="stat-num"><span class="counter" data-target="28">0</span></span>
        <span class="stat-label">Anni di esperienza</span>
      </div>
    </div>
  </section>

  <!-- Agents -->
  <section class="agents-section">
    <div class="section-header fade-in">
      <h2 class="section-title">Il nostro <span class="gradient-text">team</span></h2>
      <p class="section-sub">Perch&eacute; scegliere noi: dal 1998 al servizio del territorio</p>
    </div>
    <div class="agents-grid">
      <div class="agent-card fade-in" style="--delay: 0s">
        <div class="agent-photo">
          <div style="width:80px;height:80px;border-radius:50%;background:#2563eb;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.2rem;flex-shrink:0;">LR</div>
          <div class="agent-socials">
            <a href="#">Li</a><a href="#">Tw</a><a href="#">Em</a>
          </div>
        </div>
        <h3>Laura Romani</h3>
        <p>Responsabile vendite, 15 anni di esperienza</p>
      </div>
      <div class="agent-card fade-in" style="--delay: 0.1s">
        <div class="agent-photo">
          <div style="width:80px;height:80px;border-radius:50%;background:#1e40af;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.2rem;flex-shrink:0;">MC</div>
          <div class="agent-socials">
            <a href="#">Li</a><a href="#">Tw</a><a href="#">Em</a>
          </div>
        </div>
        <h3>Marco Colombo</h3>
        <p>Specialista affitti, certificato FIAIP</p>
      </div>
      <div class="agent-card fade-in" style="--delay: 0.2s">
        <div class="agent-photo">
          <div style="width:80px;height:80px;border-radius:50%;background:#2563eb;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.2rem;flex-shrink:0;">SB</div>
          <div class="agent-socials">
            <a href="#">Li</a><a href="#">Tw</a><a href="#">Em</a>
          </div>
        </div>
        <h3>Sara Bellini</h3>
        <p>Consulente immobiliare, esperta zona laghi</p>
      </div>
    </div>
  </section>

  <!-- Skeleton loader -->
  <section class="skeleton-section fade-in">
    <p class="skeleton-label">Caricamento altri immobili...</p>
    <div class="skeleton-grid">
      <div class="skeleton-card"><div class="skeleton-img shimmer"></div><div class="skeleton-line shimmer"></div><div class="skeleton-line short shimmer"></div></div>
      <div class="skeleton-card"><div class="skeleton-img shimmer"></div><div class="skeleton-line shimmer"></div><div class="skeleton-line short shimmer"></div></div>
      <div class="skeleton-card"><div class="skeleton-img shimmer"></div><div class="skeleton-line shimmer"></div><div class="skeleton-line short shimmer"></div></div>
    </div>
  </section>

  <footer style="text-align:center;padding:48px 24px 32px;color:#64748b;font-size:0.85rem;border-top:1px solid #e2e8f0;max-width:1200px;margin:0 auto;">
    <p style="font-weight:700;color:#1e293b;font-family:'Plus Jakarta Sans',sans-serif;font-size:1.1rem;margin-bottom:8px;">Casa &amp; Territorio Srl</p>
    <p>Via Verdi 12, 37121 Verona (VR) &mdash; Tel. 045 800 1234 &mdash; info@casaeterritorio.it</p>
    <p style="margin-top:8px;">P.IVA 04567890123 &mdash; &copy; 2026 Tutti i diritti riservati.</p>
  </footer>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #1e293b; background: #f8fafc; overflow-x: hidden; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #f1f5f9; }
    ::-webkit-scrollbar-thumb { background: #2563eb; border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: #1d4ed8; }

    h1, h2, h3 { font-family: 'Plus Jakarta Sans', sans-serif; }

    .back-btn {
      position: fixed; bottom: 2rem; left: 20px; z-index: 1000;
      background: rgba(255,255,255,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(37,99,235,0.2); color: #1e40af; padding: 10px 20px; border-radius: 12px;
      text-decoration: none; font-size: 0.875rem; font-weight: 600; transition: all 0.3s ease;
    }
    .back-btn:hover { background: rgba(37,99,235,0.1); transform: translateX(-4px); box-shadow: 0 4px 20px rgba(37,99,235,0.15); }

    .gradient-text { background: linear-gradient(135deg, #2563eb, #7c3aed); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .section-header { text-align: center; margin-bottom: 48px; }
    .section-title { font-size: 2.25rem; font-weight: 800; color: #1e293b; }
    .section-sub { color: #64748b; font-size: 1rem; margin-top: 8px; }

    .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease; transition-delay: var(--delay, 0s); }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* ===== HERO ===== */
    .hero {
      position: relative; padding: 120px 24px 80px; text-align: center;
      background: linear-gradient(180deg, #fff 0%, #f0f4ff 100%);
      overflow: hidden;
    }
    .hero-content { position: relative; z-index: 2; max-width: 800px; margin: 0 auto; }
    .hero-tag {
      display: inline-block; background: rgba(37,99,235,0.08); color: #2563eb;
      padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; margin-bottom: 20px;
    }
    .hero-title { font-size: 3.25rem; font-weight: 800; line-height: 1.1; color: #1e293b; margin-bottom: 16px; }
    .hero-desc { font-size: 1.1rem; color: #64748b; max-width: 560px; margin: 0 auto 40px; line-height: 1.7; }

    /* Search bar */
    .search-bar {
      display: flex; gap: 1px; background: rgba(255,255,255,0.7);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(37,99,235,0.15); border-radius: 20px; padding: 8px;
      box-shadow: 0 8px 40px rgba(37,99,235,0.1); max-width: 760px; margin: 0 auto;
    }
    .search-field { flex: 1; padding: 12px 16px; text-align: left; }
    .search-field label { display: block; font-size: 0.7rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }
    .search-field input, .search-field select {
      width: 100%; border: none; outline: none; background: none; font-size: 0.9rem; color: #1e293b;
      font-family: 'Inter', sans-serif;
    }
    .search-field input::placeholder { color: #94a3b8; }
    .search-field select { cursor: pointer; }
    .search-field:focus-within { background: rgba(37,99,235,0.04); border-radius: 12px; }
    .search-submit {
      display: flex; align-items: center; gap: 8px; background: #2563eb; color: #fff;
      border: none; border-radius: 14px; padding: 14px 28px; font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 0.9rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; white-space: nowrap;
    }
    .search-submit:hover { background: #1d4ed8; transform: scale(1.02); box-shadow: 0 8px 24px rgba(37,99,235,0.3); }

    .hero-orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.12; pointer-events: none; }
    .hero-orb.orb-1 { width: 400px; height: 400px; background: #2563eb; top: -100px; right: -100px; animation: float1 20s ease-in-out infinite; }
    .hero-orb.orb-2 { width: 300px; height: 300px; background: #7c3aed; bottom: -80px; left: -80px; animation: float2 25s ease-in-out infinite; }
    @keyframes float1 { 0%, 100% { transform: translate(0,0); } 50% { transform: translate(-40px, 60px); } }
    @keyframes float2 { 0%, 100% { transform: translate(0,0); } 50% { transform: translate(50px, -40px); } }

    /* ===== FILTERS ===== */
    .filters-section { padding: 32px 24px; }
    .filters-inner { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
    .filter-pill {
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.85rem; font-weight: 600;
      padding: 10px 20px; border-radius: 12px; border: 1px solid #e2e8f0; background: #fff;
      color: #64748b; cursor: pointer; transition: all 0.3s ease;
    }
    .filter-pill:hover { border-color: #2563eb; color: #2563eb; }
    .filter-pill.active {
      background: #2563eb; color: #fff; border-color: #2563eb;
      box-shadow: 0 4px 16px rgba(37,99,235,0.3);
    }

    /* ===== PROPERTIES ===== */
    .properties { padding: 60px 24px 80px; max-width: 1200px; margin: 0 auto; }
    .properties-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .property-card {
      background: #fff; border-radius: 20px; overflow: hidden;
      border: 1px solid #e2e8f0; transition: all 0.4s ease;
    }
    .property-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(37,99,235,0.12); border-color: rgba(37,99,235,0.2); }
    .property-img {
      height: 220px; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center;
    }
    .property-card:hover .property-img { transform: scale(1.03); }
    .property-img { transition: transform 0.6s ease; }
    .property-badge {
      position: absolute; top: 16px; left: 16px; background: #2563eb; color: #fff;
      font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 8px; z-index: 2;
    }
    .property-badge.hot { background: #ef4444; }
    .property-overlay {
      position: absolute; inset: 0; background: rgba(30,41,59,0.6);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.3s ease;
    }
    .property-card:hover .property-overlay { opacity: 1; }
    .property-overlay span { color: #fff; font-size: 0.9rem; font-weight: 500; }
    .property-body { padding: 20px; }
    .property-location { font-size: 0.8rem; color: #2563eb; font-weight: 600; margin-bottom: 6px; }
    .property-body h3 { font-size: 1.05rem; font-weight: 700; color: #1e293b; margin-bottom: 12px; line-height: 1.3; }
    .property-price {
      font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.25rem; font-weight: 800;
      background: linear-gradient(135deg, #2563eb, #7c3aed);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    /* ===== MAP ===== */
    .map-section { padding: 80px 24px; max-width: 1000px; margin: 0 auto; }
    .map-placeholder {
      position: relative; height: 400px; border-radius: 24px;
      background: linear-gradient(135deg, #e0e7ff, #dbeafe); overflow: hidden;
      border: 1px solid rgba(37,99,235,0.15);
    }
    .map-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(37,99,235,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(37,99,235,0.05) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    .map-pin {
      position: absolute; width: 20px; height: 20px;
      background: #2563eb; border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
      animation: pinDrop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      animation-delay: var(--pin-delay, 0s);
      box-shadow: 0 4px 12px rgba(37,99,235,0.4);
    }
    .map-pin::after {
      content: ''; position: absolute; width: 8px; height: 8px;
      background: #fff; border-radius: 50%; top: 6px; left: 6px;
    }
    .pin-label {
      position: absolute; top: -28px; left: 50%; transform: translateX(-50%) rotate(45deg);
      font-size: 0.75rem; font-weight: 600; color: #1e40af; white-space: nowrap;
      background: rgba(255,255,255,0.9); padding: 2px 8px; border-radius: 6px;
    }
    @keyframes pinDrop {
      0% { transform: rotate(-45deg) translateY(-60px); opacity: 0; }
      100% { transform: rotate(-45deg) translateY(0); opacity: 1; }
    }

    /* ===== STATS ===== */
    .stats-section { padding: 80px 24px; background: linear-gradient(135deg, #1e293b, #0f172a); }
    .stats-inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; max-width: 1000px; margin: 0 auto; text-align: center; }
    .stat-num { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2.75rem; font-weight: 800; color: #fff; display: block; }
    .stat-label { font-size: 0.9rem; color: #94a3b8; margin-top: 4px; display: block; }

    /* ===== AGENTS ===== */
    .agents-section { padding: 100px 24px; max-width: 1100px; margin: 0 auto; }
    .agents-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .agent-card {
      text-align: center; background: #fff; border-radius: 20px; padding: 32px 20px;
      border: 1px solid #e2e8f0; transition: all 0.4s ease;
    }
    .agent-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(37,99,235,0.1); }
    .agent-photo {
      width: 100px; height: 100px; border-radius: 50%; margin: 0 auto 16px;
      display: flex; align-items: center; justify-content: center;
      position: relative; overflow: hidden; transition: transform 0.4s ease;
    }
    .agent-card:hover .agent-photo { transform: scale(1.08); }
    .agent-initials { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.5rem; font-weight: 800; color: #fff; position: relative; z-index: 1; }
    .agent-socials {
      position: absolute; bottom: 0; left: 0; right: 0;
      display: flex; justify-content: center; gap: 6px;
      padding: 8px; background: rgba(0,0,0,0.5);
      transform: translateY(100%); transition: transform 0.3s ease;
    }
    .agent-card:hover .agent-socials { transform: translateY(0); }
    .agent-socials a {
      color: #fff; font-size: 0.65rem; font-weight: 700;
      width: 24px; height: 24px; border-radius: 50%; background: rgba(255,255,255,0.2);
      display: flex; align-items: center; justify-content: center; text-decoration: none;
      transition: background 0.2s;
    }
    .agent-socials a:hover { background: rgba(255,255,255,0.4); }
    .agent-card h3 { font-size: 1.05rem; font-weight: 700; color: #1e293b; margin-bottom: 4px; }
    .agent-card p { font-size: 0.85rem; color: #64748b; }

    /* ===== SKELETON LOADER ===== */
    .skeleton-section { padding: 40px 24px 80px; max-width: 1200px; margin: 0 auto; text-align: center; }
    .skeleton-label { font-size: 0.9rem; color: #94a3b8; margin-bottom: 24px; }
    .skeleton-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .skeleton-card { background: #fff; border-radius: 20px; overflow: hidden; border: 1px solid #e2e8f0; }
    .skeleton-img { height: 200px; }
    .skeleton-line { height: 16px; margin: 16px; border-radius: 8px; }
    .skeleton-line.short { width: 40%; height: 12px; }
    .shimmer {
      background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* Responsive */
    @media (max-width: 1024px) {
      .properties-grid { grid-template-columns: repeat(2, 1fr); }
      .agents-grid { grid-template-columns: repeat(2, 1fr); }
      .stats-inner { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .hero-title { font-size: 2.25rem; }
      .search-bar { flex-direction: column; gap: 0; }
      .search-field { border-bottom: 1px solid #e2e8f0; }
      .search-submit { width: 100%; justify-content: center; margin: 8px 0 0; }
      .properties-grid, .skeleton-grid { grid-template-columns: 1fr; }
      .agents-grid { grid-template-columns: 1fr 1fr; }
      .stats-inner { grid-template-columns: 1fr 1fr; gap: 24px; }
      .stat-num { font-size: 2rem; }
      .section-title { font-size: 1.75rem; }
      .map-placeholder { height: 260px; }
      .back-btn { top: 12px; left: 12px; font-size: 0.8rem; padding: 8px 14px; }
    }
    @media (max-width: 480px) {
      .agents-grid { grid-template-columns: 1fr; }
      .agents-section { padding: 60px 20px; }
      .map-section { padding: 60px 20px; }
    }
  </style>

  <script is:inline>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          entry.target.querySelectorAll('.counter').forEach(c => animateCounter(c));
          // Animate map pins
          entry.target.querySelectorAll('.map-pin').forEach((pin, i) => {
            pin.style.setProperty('--pin-delay', (i * 0.3) + 's');
          });
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    function animateCounter(el) {
      if (el.dataset.animated) return;
      el.dataset.animated = 'true';
      const target = parseFloat(el.dataset.target);
      const duration = 2000;
      const start = performance.now();
      function update(now) {
        const progress = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(target * eased).toLocaleString('it-IT');
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    // Filter pills toggle
    document.querySelectorAll('.filter-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        showImmoToast('Filtro: ' + pill.textContent.trim());
      });
    });

    // ===== PROPERTY DATA =====
    const properties = [
      { title: 'Attico con terrazza panoramica', location: 'Verona, Centro Storico', price: '€385.000', type: 'Vendita', rooms: '3 camere', baths: '2 bagni', size: '145 m²', floor: '6° piano', year: '1932 (ristrutturato 2019)', desc: 'Splendido attico con terrazza panoramica sul centro storico di Verona. Travi a vista originali, parquet in rovere, cucina su misura. Vista sull\'Arena e sul Duomo.', emoji: '🏛️' },
      { title: 'Bilocale ristrutturato arredato', location: 'Milano, Navigli', price: '€950/mese', type: 'Affitto', rooms: '1 camera', baths: '1 bagno', size: '55 m²', floor: '3° piano', year: 'Ristrutturato 2022', desc: 'Bilocale completamente arredato a 200m dalla fermata metro Porta Genova. Cucina a vista, bagno con doccia walk-in, armadi su misura. Disponibile subito.', emoji: '🏙️' },
      { title: 'Villa con piscina vista lago', location: 'Lago di Garda, Lazise', price: '€720.000', type: 'Vendita', rooms: '4 camere', baths: '3 bagni', size: '280 m²', floor: 'Villa indipendente', year: '2005', desc: 'Prestigiosa villa con giardino di 1.500 mq e piscina privata. Vista lago dalle camere principali. Box triplo, taverna, locale tecnico. A 5 minuti dal centro di Lazise.', emoji: '🏡' },
      { title: 'Trilocale in stabile d\'epoca', location: 'Milano, Brera', price: '€1.400/mese', type: 'Affitto', rooms: '2 camere', baths: '1 bagno', size: '85 m²', floor: '2° piano con ascensore', year: '1920 (facciata vincolata)', desc: 'Trilocale in elegante stabile liberty nel cuore di Brera. Soffitti alti 3.2m, parquet originale, cantina inclusa. A 5 min a piedi dal Castello Sforzesco.', emoji: '🏢' },
      { title: 'Casale con terreno e dependance', location: 'Campagna Vicentina', price: '€495.000', type: 'Vendita', rooms: '5 camere', baths: '3 bagni', size: '320 m²', floor: 'Su 2 piani + dependance', year: 'Fine \'800 (ristrutturato 2015)', desc: 'Bellissimo casale di campagna completamente ristrutturato con 8.000 mq di terreno, dependance autonoma di 60 mq, cantina per vini, pozzo artesiano.', emoji: '🌾' },
      { title: 'Monolocale luminoso zona università', location: 'Verona, Zona Università', price: '€650/mese', type: 'Affitto', rooms: 'Monolocale', baths: '1 bagno', size: '35 m²', floor: '1° piano', year: 'Ristrutturato 2021', desc: 'Monolocale luminoso con angolo cottura attrezzato. Spese condominiali incluse. Perfetto per studenti o lavoratori. A 10 min a piedi dall\'università e dal centro.', emoji: '🎓' },
    ];

    // ===== PROPERTY CARDS =====
    document.querySelectorAll('.property-card').forEach((card, i) => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', () => openPropertyModal(i));
    });

    function openPropertyModal(i) {
      const p = properties[i];
      document.getElementById('propEmoji').textContent = p.emoji;
      document.getElementById('propType').textContent = p.type;
      document.getElementById('propTitle').textContent = p.title;
      document.getElementById('propLocation').textContent = p.location;
      document.getElementById('propPrice').textContent = p.price;
      document.getElementById('propDesc').textContent = p.desc;
      document.getElementById('propDetails').innerHTML = `
        <div class="pd-row"><span>🛏️ Camere</span><span>${p.rooms}</span></div>
        <div class="pd-row"><span>🚿 Bagni</span><span>${p.baths}</span></div>
        <div class="pd-row"><span>📐 Superficie</span><span>${p.size}</span></div>
        <div class="pd-row"><span>🏗️ Piano</span><span>${p.floor}</span></div>
        <div class="pd-row"><span>🏛️ Anno</span><span>${p.year}</span></div>
      `;
      document.getElementById('immoModal').classList.add('open');
      document.getElementById('immoOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeImmoModal() {
      document.getElementById('immoModal').classList.remove('open');
      document.getElementById('immoOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }

    function requestInfo() {
      closeImmoModal();
      showImmoToast('✓ Richiesta inviata! Un agente ti contatterà entro 24 ore.');
    }

    // ===== SEARCH =====
    document.querySelector('.search-submit')?.addEventListener('click', () => {
      showImmoToast('🔍 Ricerca in corso... trovati 6 immobili');
    });

    // ===== TOAST =====
    let immoToastTimeout;
    function showImmoToast(msg) {
      const t = document.getElementById('immo-toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(immoToastTimeout);
      immoToastTimeout = setTimeout(() => t.classList.remove('show'), 3000);
    }
  </script>

  <!-- Property Modal -->
  <div class="immo-overlay" id="immoOverlay" onclick="closeImmoModal()"></div>
  <div class="immo-modal" id="immoModal">
    <button class="immo-close" onclick="closeImmoModal()">✕</button>
    <div class="immo-modal-top">
      <div class="immo-modal-img"><span id="propEmoji" style="font-size:5rem"></span></div>
      <div class="immo-modal-info">
        <span class="immo-modal-badge" id="propType">Vendita</span>
        <h3 class="immo-modal-title" id="propTitle"></h3>
        <p class="immo-modal-loc" id="propLocation"></p>
        <p class="immo-modal-price" id="propPrice"></p>
        <p class="immo-modal-desc" id="propDesc"></p>
      </div>
    </div>
    <div id="propDetails" class="prop-details"></div>
    <div class="immo-modal-actions">
      <button class="immo-btn-primary" onclick="requestInfo()">Richiedi informazioni →</button>
      <button class="immo-btn-secondary" onclick="showImmoToast('📅 Prenotazione visita inviata!');closeImmoModal()">Prenota visita</button>
    </div>
  </div>
  <div id="immo-toast"></div>

  <style>
    .immo-overlay { position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:9998;opacity:0;pointer-events:none;transition:opacity 0.3s; }
    .immo-overlay.open { opacity:1;pointer-events:all; }
    .immo-modal { position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0.9);width:min(640px,92vw);max-height:88vh;overflow-y:auto;background:#fff;border-radius:20px;z-index:9999;opacity:0;pointer-events:none;transition:all 0.35s cubic-bezier(0.4,0,0.2,1);color:#1a1a2e; }
    .immo-modal.open { opacity:1;pointer-events:all;transform:translate(-50%,-50%) scale(1); }
    .immo-close { position:absolute;top:16px;right:16px;background:#f0f0f0;border:none;width:36px;height:36px;border-radius:50%;cursor:pointer;font-size:1rem;z-index:1;transition:background 0.2s; }
    .immo-close:hover { background:#e0e0e0; }
    .immo-modal-top { display:grid;grid-template-columns:180px 1fr;gap:0; }
    .immo-modal-img { background:linear-gradient(135deg,#e8f4fd,#dbeafe);display:flex;align-items:center;justify-content:center;min-height:240px;border-radius:20px 0 0 0; }
    .immo-modal-info { padding:28px 28px 20px; }
    .immo-modal-badge { display:inline-block;background:#2563eb;color:#fff;font-size:0.72rem;font-weight:700;letter-spacing:1px;padding:4px 12px;border-radius:20px;margin-bottom:12px;text-transform:uppercase; }
    .immo-modal-title { font-size:1.15rem;font-weight:700;margin-bottom:8px;line-height:1.4;color:#1a1a2e; }
    .immo-modal-loc { font-size:0.85rem;color:#64748b;margin-bottom:8px; }
    .immo-modal-price { font-size:1.6rem;font-weight:800;color:#2563eb;margin-bottom:12px; }
    .immo-modal-desc { font-size:0.84rem;color:#555;line-height:1.6; }
    .prop-details { display:grid;grid-template-columns:1fr 1fr;gap:0;border-top:1px solid #f0f0f0;border-bottom:1px solid #f0f0f0; }
    .pd-row { display:flex;justify-content:space-between;padding:12px 28px;font-size:0.84rem;border-bottom:1px solid #f8f8f8; }
    .pd-row span:first-child { color:#64748b; }
    .pd-row span:last-child { font-weight:600;color:#1a1a2e; }
    .immo-modal-actions { display:flex;gap:12px;padding:20px 28px; }
    .immo-btn-primary { flex:1;background:#2563eb;color:#fff;border:none;padding:14px;border-radius:10px;font-weight:700;cursor:pointer;transition:opacity 0.2s; }
    .immo-btn-primary:hover { opacity:0.9; }
    .immo-btn-secondary { flex:1;background:#f0f4ff;color:#2563eb;border:2px solid #2563eb;padding:14px;border-radius:10px;font-weight:700;cursor:pointer;transition:all 0.2s; }
    .immo-btn-secondary:hover { background:#2563eb;color:#fff; }
    @media (max-width:520px) { .immo-modal-top{grid-template-columns:1fr} .immo-modal-img{min-height:140px;border-radius:20px 20px 0 0} .prop-details{grid-template-columns:1fr} }
    #immo-toast { position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#1a1a2e;border:1px solid #2563eb;color:#93c5fd;padding:13px 26px;border-radius:50px;font-size:0.84rem;z-index:99999;opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);white-space:nowrap;pointer-events:none; }
    #immo-toast.show { opacity:1;transform:translateX(-50%) translateY(0); }
  </style>
</body>
</html>
