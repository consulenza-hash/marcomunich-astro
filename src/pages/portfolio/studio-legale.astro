---
// Ferrini & Associati — mockup studio legale premium
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ferrini & Associati — Studio Legale Milano</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy: #0e1a24;
      --navy-mid: #1a2d3d;
      --cream: #f5f1ea;
      --cream-dark: #ede8df;
      --gold: #c9a96e;
      --gold-light: #d9be8a;
      --text: #1e2c36;
      --muted: #6b7a85;
      --serif: 'Cormorant Garamond', Georgia, serif;
      --sans: 'Inter', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }
    body { font-family: var(--sans); background: var(--cream); color: var(--text); line-height: 1.6; }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    /* ── Nav ── */
    .nav {
      background: var(--cream); border-bottom: 1px solid var(--cream-dark);
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 2.5rem;
    }
    .nav-logo {
      font-family: var(--serif); font-size: 0.85rem; letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--navy); font-weight: 400;
    }
    .nav-links {
      display: flex; gap: 2.2rem; font-size: 0.65rem; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--muted);
    }
    .nav-links a:hover { color: var(--navy); }
    .nav-cta {
      font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
      background: var(--navy); color: var(--cream); padding: 0.5rem 1.3rem;
    }

    /* ── Hero ── */
    .hero { overflow: hidden; height: 500px; }
    .hero img { width: 100%; height: 100%; object-fit: cover; }
    .hero-caption {
      background: var(--cream); padding: 2.8rem 2.5rem 3.5rem;
      border-bottom: 1px solid var(--cream-dark);
    }
    .hero-caption-eyebrow {
      font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 0.9rem;
    }
    .hero-caption h1 {
      font-family: var(--serif); font-size: 2.4rem; font-weight: 300;
      color: var(--navy); line-height: 1.2; max-width: 560px;
    }
    .hero-caption h1 em { font-style: italic; color: var(--navy-mid); }

    /* ── Areas ── */
    .areas { background: var(--navy); padding: 4rem 2.5rem; }
    .areas-label {
      font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 2.5rem;
    }
    .areas-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .area-card {
      border-top: 1px solid rgba(201,169,110,0.3); padding-top: 1.5rem;
    }
    .area-num {
      font-family: var(--serif); font-size: 2rem; font-weight: 300; color: var(--gold);
      opacity: 0.4; margin-bottom: 0.8rem; line-height: 1;
    }
    .area-title {
      font-family: var(--serif); font-size: 1.15rem; font-weight: 300; color: var(--cream);
      font-style: italic; margin-bottom: 0.7rem;
    }
    .area-desc { font-size: 0.78rem; line-height: 1.9; color: rgba(245,241,234,0.5); }

    /* ── Team ── */
    .team { background: var(--cream); padding: 4rem 2.5rem; border-bottom: 1px solid var(--cream-dark); }
    .team-label {
      font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 2.5rem;
    }
    .team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
    .team-card { display: flex; flex-direction: column; }
    .team-card-img {
      width: 100%; aspect-ratio: 3/4; overflow: hidden; margin-bottom: 1.4rem;
    }
    .team-card-img img { width: 100%; height: 100%; object-fit: cover; object-position: top; }
    .team-card-name {
      font-family: var(--serif); font-size: 1.3rem; font-weight: 300; color: var(--navy);
      font-style: italic; margin-bottom: 0.3rem;
    }
    .team-card-title {
      font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 0.9rem; padding-bottom: 0.9rem;
      border-bottom: 1px solid var(--cream-dark);
    }
    .team-card-spec { font-size: 0.78rem; line-height: 1.8; color: #4a5a66; }

    /* ── Detail strip ── */
    .detail-strip { height: 280px; overflow: hidden; }
    .detail-strip img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }

    /* ── Quote ── */
    .quote-section {
      background: var(--navy-mid); padding: 4rem 2.5rem; text-align: center;
    }
    .quote-text {
      font-family: var(--serif); font-size: 1.5rem; font-weight: 300; color: var(--cream);
      font-style: italic; line-height: 1.6; max-width: 600px; margin: 0 auto 1.2rem;
    }
    .quote-source { font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); }

    /* ── CTA ── */
    .cta {
      background: var(--navy); padding: 4.5rem 2.5rem; text-align: center;
    }
    .cta-eyebrow {
      font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 1.2rem; display: block;
    }
    .cta h2 {
      font-family: var(--serif); font-size: 2rem; font-weight: 300; color: var(--cream);
      font-style: italic; margin-bottom: 1rem; line-height: 1.3;
    }
    .cta-info {
      font-size: 0.78rem; color: rgba(245,241,234,0.5); margin-bottom: 2rem;
      letter-spacing: 0.06em;
    }
    .cta-btn {
      display: inline-block; font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--navy); background: var(--gold); padding: 0.75rem 2.2rem;
    }

    /* ── Footer ── */
    .footer {
      background: var(--cream); border-top: 1px solid var(--cream-dark);
      padding: 1.5rem 2.5rem; display: flex; justify-content: space-between; align-items: center;
    }
    .footer-name { font-family: var(--serif); font-size: 0.8rem; color: var(--muted); font-style: italic; }
    .footer-addr { font-size: 0.62rem; letter-spacing: 0.08em; color: var(--muted); }

    /* ── Back btn ── */
    .back-btn {
      position: fixed; top: 1.2rem; left: 1.5rem; z-index: 999;
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: var(--navy); color: rgba(245,241,234,0.7);
      text-decoration: none; font-family: var(--sans);
      font-size: 0.8rem; letter-spacing: 0.05em; padding: 0.55rem 1rem;
      border-radius: 2rem; transition: all 0.2s;
    }
    .back-btn:hover { color: var(--cream); }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero { height: 300px; }
      .areas-grid { grid-template-columns: 1fr; gap: 1.5rem; }
      .team-grid { grid-template-columns: 1fr; gap: 2rem; }
      .footer { flex-direction: column; gap: 0.5rem; text-align: center; }
    }
  </style>
</head>
<body>
  <a href="/dev/portfolio" class="back-btn">← Portfolio</a>

  <nav class="nav">
    <div class="nav-logo">Ferrini & Associati</div>
    <div class="nav-links">
      <a href="#">Aree di pratica</a>
      <a href="#">Il team</a>
      <a href="#">Pubblicazioni</a>
      <a href="#">Contatti</a>
    </div>
    <a href="#" class="nav-cta">Consulenza</a>
  </nav>

  <div class="hero">
    <img src="/images/portfolio/legale-hero.jpg" alt="Studio Ferrini & Associati" />
  </div>
  <div class="hero-caption">
    <div class="hero-caption-eyebrow">Milano · Dal 1994</div>
    <h1>Trent'anni di diritto.<br /><em>Una reputazione costruita caso per caso.</em></h1>
  </div>

  <div class="areas">
    <div class="areas-label">Aree di pratica</div>
    <div class="areas-grid">
      <div class="area-card">
        <div class="area-num">01</div>
        <div class="area-title">Diritto Civile e Contrattuale</div>
        <p class="area-desc">Contratti complessi, responsabilità civile, tutela del patrimonio personale e familiare. Assistenza nelle controversie tra privati e aziende.</p>
      </div>
      <div class="area-card">
        <div class="area-num">02</div>
        <div class="area-title">Diritto Commerciale e Societario</div>
        <p class="area-desc">Costituzione e ristrutturazione societaria, M&A, governance aziendale, contratti internazionali e operazioni straordinarie d'impresa.</p>
      </div>
      <div class="area-card">
        <div class="area-num">03</div>
        <div class="area-title">Diritto del Lavoro</div>
        <p class="area-desc">Consulenza a imprese e manager: rapporti di lavoro, licenziamenti, accordi sindacali, piani di incentivazione e protezione dei dati.</p>
      </div>
    </div>
  </div>

  <div class="team">
    <div class="team-label">Il team</div>
    <div class="team-grid">
      <div class="team-card">
        <div class="team-card-img">
          <img src="/images/portfolio/legale-partner.jpg" alt="Avv. Marco Ferrini" />
        </div>
        <div class="team-card-name">Marco Ferrini</div>
        <div class="team-card-title">Fondatore · Senior Partner</div>
        <p class="team-card-spec">Diritto civile e commerciale, operazioni cross-border. Abilitato al patrocinio davanti alle giurisdizioni superiori.</p>
      </div>
      <div class="team-card">
        <div class="team-card-img">
          <img src="/images/portfolio/legale-avv2.jpg" alt="Avv. Sara Conti" />
        </div>
        <div class="team-card-name">Sara Conti</div>
        <div class="team-card-title">Associate · Diritto del Lavoro</div>
        <p class="team-card-spec">Specializzata in diritto del lavoro e relazioni industriali. Consulenza a imprese multinazionali e manager di primo livello.</p>
      </div>
      <div class="team-card">
        <div class="team-card-img">
          <img src="/images/portfolio/legale-avv3.jpg" alt="Avv. Luca Mancini" />
        </div>
        <div class="team-card-name">Luca Mancini</div>
        <div class="team-card-title">Associate · M&amp;A e Societario</div>
        <p class="team-card-spec">M&amp;A, governance societaria e startup. Esperienza in operazioni di venture capital e ristrutturazioni aziendali.</p>
      </div>
    </div>
  </div>

  <div class="detail-strip">
    <img src="/images/portfolio/legale-detail.jpg" alt="Studio Ferrini — dettaglio" />
  </div>

  <div class="quote-section">
    <p class="quote-text">"Il diritto non è una formula. È una conversazione tra la norma e la realtà del vostro caso."</p>
    <div class="quote-source">Avv. Marco Ferrini</div>
  </div>

  <div class="cta">
    <span class="cta-eyebrow">Prima consulenza</span>
    <h2>Raccontateci il vostro caso.<br />Ascoltiamo prima di parlare.</h2>
    <div class="cta-info">Milano · Corso Venezia, 22 · studio@ferrini-associati.it · +39 02 7640 1180</div>
    <a href="#" class="cta-btn">Richiedi un appuntamento</a>
  </div>

  <div class="footer">
    <div class="footer-name">Ferrini & Associati — Studio Legale</div>
    <div class="footer-addr">P.IVA 08234710969 · Ordine degli Avvocati di Milano</div>
  </div>

</body>
</html>
