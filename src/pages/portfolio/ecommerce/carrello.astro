---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Il Tuo Carrello — Luxe Noir</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Noise overlay -->
  <div class="noise"></div>

  <!-- Announcement bar -->
  <div class="announcement-bar">
    Spedizione gratuita sopra i &euro;150 &nbsp;|&nbsp; Reso facile entro 14 giorni
  </div>

  <!-- Navigation -->
  <nav class="main-nav">
    <a href="/portfolio/ecommerce" class="nav-logo gradient-text">LUXE NOIR</a>
    <div class="nav-links">
      <a href="/portfolio/ecommerce#nuovi">Nuovi Arrivi</a>
      <a href="/portfolio/ecommerce#collezione">Donna</a>
      <a href="#">Uomo</a>
      <a href="#">Accessori</a>
      <a href="/portfolio/ecommerce/brand">Il Brand</a>
    </div>
  </nav>

  <!-- Cart Section -->
  <section class="cart-section">
    <div class="cart-header">
      <h1 class="cart-title">
        Il Tuo <span class="gradient-text">Carrello</span>
        <span class="cart-count">(2 articoli)</span>
      </h1>
    </div>

    <div class="cart-layout">
      <!-- Cart items -->
      <div class="cart-items">
        <!-- Item 1 -->
        <div class="cart-item">
          <a href="/portfolio/ecommerce/prodotto" class="item-image">
            <img src="/images/portfolio/ecom-borsa.jpg" alt="Borsa Strutturata in Pelle" />
          </a>
          <div class="item-details">
            <div class="item-top">
              <div>
                <h3 class="item-name">Borsa Strutturata in Pelle</h3>
                <p class="item-variant">Colore: Nero &bull; Taglia Unica</p>
              </div>
              <button class="item-remove" aria-label="Rimuovi articolo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </div>
            <div class="item-bottom">
              <div class="item-qty">
                <button class="qty-btn" aria-label="Diminuisci">-</button>
                <span class="qty-value">1</span>
                <button class="qty-btn" aria-label="Aumenta">+</button>
              </div>
              <p class="item-price">&euro;289</p>
            </div>
          </div>
        </div>

        <!-- Item 2 -->
        <div class="cart-item">
          <a href="/portfolio/ecommerce/prodotto" class="item-image">
            <img src="/images/portfolio/ecom-foulard.jpg" alt="Foulard in Seta Stampata" />
          </a>
          <div class="item-details">
            <div class="item-top">
              <div>
                <h3 class="item-name">Foulard in Seta Stampata</h3>
                <p class="item-variant">Colore: Bordeaux &bull; 90&times;90 cm</p>
              </div>
              <button class="item-remove" aria-label="Rimuovi articolo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </button>
            </div>
            <div class="item-bottom">
              <div class="item-qty">
                <button class="qty-btn" aria-label="Diminuisci">-</button>
                <span class="qty-value">1</span>
                <button class="qty-btn" aria-label="Aumenta">+</button>
              </div>
              <p class="item-price">&euro;145</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Cart summary -->
      <div class="cart-summary">
        <div class="summary-card">
          <h2 class="summary-title">Riepilogo Ordine</h2>

          <div class="summary-row">
            <span>Subtotale</span>
            <span>&euro;434</span>
          </div>
          <div class="summary-row">
            <span>Spedizione</span>
            <span class="free-shipping">Gratuita</span>
          </div>
          <p class="shipping-note">Spedizione gratuita per ordini superiori a &euro;150</p>

          <!-- Discount code -->
          <div class="discount-section">
            <p class="discount-label">Codice Sconto</p>
            <div class="discount-form">
              <input type="text" placeholder="Inserisci codice" class="discount-input" />
              <button class="discount-btn">Applica</button>
            </div>
          </div>

          <div class="summary-divider"></div>

          <div class="summary-row total-row">
            <span>Totale</span>
            <span class="total-price">&euro;434</span>
          </div>

          <button class="btn-checkout">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            Procedi al Checkout
          </button>

          <a href="/portfolio/ecommerce" class="continue-link">&larr; Continua lo Shopping</a>

          <!-- Trust badges -->
          <div class="trust-badges">
            <div class="trust-badge">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>Pagamenti Sicuri</span>
            </div>
            <div class="trust-badge">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="1.5"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/></svg>
              <span>Reso Gratuito</span>
            </div>
            <div class="trust-badge">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>Spedizione Tracciata</span>
            </div>
          </div>

          <!-- Payment icons -->
          <div class="payment-icons">
            <span class="pay-icon">VISA</span>
            <span class="pay-icon">MC</span>
            <span class="pay-icon">AMEX</span>
            <span class="pay-icon">PP</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-grid">
      <div class="footer-col">
        <h3 class="footer-logo gradient-text">LUXE NOIR</h3>
        <p class="footer-tagline">L'arte del lusso accessibile.</p>
        <p class="footer-address">Via Montenapoleone 42, 20121 Milano (MI)</p>
        <p class="footer-address">Tel. +39 02 7600 1234</p>
      </div>
      <div class="footer-col">
        <h4>Collezioni</h4>
        <a href="/portfolio/ecommerce#nuovi">Nuovi Arrivi</a>
        <a href="/portfolio/ecommerce#collezione">Donna</a>
        <a href="#">Uomo</a>
        <a href="#">Accessori</a>
      </div>
      <div class="footer-col">
        <h4>Servizio Clienti</h4>
        <a href="#">Spedizioni</a>
        <a href="#">Reso gratuito</a>
        <a href="#">Pagamenti sicuri</a>
        <a href="#">Contattaci</a>
      </div>
      <div class="footer-col">
        <h4>Seguici</h4>
        <a href="#">Instagram</a>
        <a href="#">Pinterest</a>
        <a href="#">Facebook</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; 2026 Luxe Noir S.r.l. &mdash; P.IVA 12345678901</p>
      <p class="footer-demo">Demo template di Marco Munich</p>
    </div>
  </footer>

<style>
  /* ========== RESET & BASE ========== */
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Montserrat', sans-serif;
    background: #0a0a0a;
    color: #e8e0d4;
    overflow-x: hidden;
    line-height: 1.6;
  }
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #0a0a0a; }
  ::-webkit-scrollbar-thumb { background: #c9a96e; border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: #dbb878; }

  .noise {
    position: fixed; inset: 0; z-index: 9999; pointer-events: none; opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
  }
  .gradient-text {
    background: linear-gradient(135deg, #c9a96e 0%, #f0d89c 40%, #c9a96e 60%, #a67c3d 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }

  /* ========== ANNOUNCEMENT BAR ========== */
  .announcement-bar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 110;
    background: linear-gradient(90deg, #c9a96e, #a67c3d);
    color: #0a0a0a; text-align: center;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 1px; padding: 8px 16px;
  }

  /* ========== NAV ========== */
  .main-nav {
    position: fixed; top: 32px; left: 0; right: 0; z-index: 105;
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 40px;
    background: rgba(10,10,10,0.75); backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(201,169,110,0.1);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem; font-weight: 700; text-decoration: none; letter-spacing: 3px;
  }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a {
    color: rgba(232,224,212,0.7); text-decoration: none;
    font-size: 0.82rem; font-weight: 400; letter-spacing: 0.5px; transition: color 0.3s ease;
  }
  .nav-links a:hover { color: #c9a96e; }

  /* ========== CART SECTION ========== */
  .cart-section {
    max-width: 1200px; margin: 0 auto;
    padding: 120px 24px 80px;
  }
  .cart-header { margin-bottom: 48px; }
  .cart-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
  }
  .cart-count {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem; font-weight: 400;
    color: rgba(232,224,212,0.5);
    -webkit-text-fill-color: rgba(232,224,212,0.5);
  }

  .cart-layout {
    display: grid; grid-template-columns: 1fr 400px; gap: 48px;
    align-items: start;
  }

  /* ========== CART ITEMS ========== */
  .cart-items { display: flex; flex-direction: column; gap: 24px; }
  .cart-item {
    display: flex; gap: 20px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(201,169,110,0.08);
    border-radius: 16px; padding: 20px;
    transition: border-color 0.3s ease;
  }
  .cart-item:hover { border-color: rgba(201,169,110,0.2); }
  .item-image {
    width: 120px; height: 140px; flex-shrink: 0;
    border-radius: 12px; overflow: hidden;
    background: linear-gradient(135deg, #131313, #1a1a1a);
  }
  .item-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .item-details { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
  .item-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .item-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem; font-weight: 400; margin-bottom: 4px;
  }
  .item-variant {
    font-size: 0.78rem; color: rgba(232,224,212,0.4);
  }
  .item-remove {
    background: none; border: none; color: rgba(232,224,212,0.3);
    cursor: pointer; padding: 4px; transition: color 0.3s ease;
  }
  .item-remove:hover { color: #b04040; }
  .item-bottom {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 16px;
  }
  .item-qty { display: flex; align-items: center; gap: 0; }
  .qty-btn {
    width: 32px; height: 32px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201,169,110,0.15);
    color: #e8e0d4; font-size: 1rem;
    cursor: pointer; transition: all 0.3s ease;
    font-family: 'Montserrat', sans-serif;
  }
  .qty-btn:first-child { border-radius: 8px 0 0 8px; }
  .qty-btn:last-child { border-radius: 0 8px 8px 0; }
  .qty-btn:hover { background: rgba(201,169,110,0.1); border-color: #c9a96e; }
  .qty-value {
    width: 40px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.03);
    border-top: 1px solid rgba(201,169,110,0.15);
    border-bottom: 1px solid rgba(201,169,110,0.15);
    font-size: 0.88rem; font-weight: 500;
  }
  .item-price {
    font-size: 1.1rem; font-weight: 600; color: #c9a96e;
    font-family: 'Playfair Display', serif;
  }

  /* ========== CART SUMMARY ========== */
  .summary-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(201,169,110,0.1);
    border-radius: 20px; padding: 32px;
    position: sticky; top: 100px;
  }
  .summary-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem; font-weight: 700;
    margin-bottom: 28px;
  }
  .summary-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 10px 0;
    font-size: 0.9rem; color: rgba(232,224,212,0.7);
  }
  .free-shipping { color: #6aaa64; font-weight: 500; }
  .shipping-note {
    font-size: 0.75rem; color: rgba(232,224,212,0.35);
    margin-top: 4px; margin-bottom: 20px;
  }

  /* Discount */
  .discount-section { margin-bottom: 20px; }
  .discount-label {
    font-size: 0.82rem; color: rgba(232,224,212,0.5);
    margin-bottom: 8px;
  }
  .discount-form { display: flex; gap: 8px; }
  .discount-input {
    flex: 1; padding: 10px 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201,169,110,0.15);
    border-radius: 10px; color: #e8e0d4;
    font-family: 'Montserrat', sans-serif; font-size: 0.85rem;
    outline: none; transition: border-color 0.3s ease;
  }
  .discount-input::placeholder { color: rgba(232,224,212,0.3); }
  .discount-input:focus { border-color: #c9a96e; }
  .discount-btn {
    padding: 10px 18px;
    background: transparent;
    border: 1px solid rgba(201,169,110,0.3);
    border-radius: 10px;
    color: #c9a96e;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem; font-weight: 600;
    letter-spacing: 0.5px; text-transform: uppercase;
    cursor: pointer; transition: all 0.3s ease;
  }
  .discount-btn:hover {
    background: rgba(201,169,110,0.1);
    border-color: #c9a96e;
  }

  .summary-divider {
    height: 1px; background: rgba(201,169,110,0.1);
    margin: 12px 0;
  }
  .total-row {
    font-weight: 700; font-size: 1.05rem;
    color: #e8e0d4;
    padding: 16px 0;
  }
  .total-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem; color: #c9a96e;
  }

  /* Checkout button */
  .btn-checkout {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; padding: 16px;
    background: linear-gradient(135deg, #c9a96e, #a67c3d);
    color: #0a0a0a; border: none; border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.88rem; font-weight: 600; letter-spacing: 1.5px;
    text-transform: uppercase; cursor: pointer;
    transition: all 0.3s ease; margin-bottom: 16px;
  }
  .btn-checkout:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(201,169,110,0.3);
  }

  .continue-link {
    display: block; text-align: center;
    color: rgba(232,224,212,0.5); text-decoration: none;
    font-size: 0.85rem; transition: color 0.3s ease;
    margin-bottom: 28px;
  }
  .continue-link:hover { color: #c9a96e; }

  /* Trust badges */
  .trust-badges {
    display: flex; flex-direction: column; gap: 12px;
    padding-top: 20px; border-top: 1px solid rgba(201,169,110,0.08);
    margin-bottom: 20px;
  }
  .trust-badge {
    display: flex; align-items: center; gap: 10px;
    font-size: 0.78rem; color: rgba(232,224,212,0.5);
  }

  /* Payment icons */
  .payment-icons {
    display: flex; gap: 8px; justify-content: center;
    padding-top: 16px; border-top: 1px solid rgba(201,169,110,0.08);
  }
  .pay-icon {
    padding: 6px 12px;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(201,169,110,0.1);
    border-radius: 6px;
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 1px; color: rgba(232,224,212,0.4);
  }

  /* ========== FOOTER ========== */
  .footer {
    border-top: 1px solid rgba(201,169,110,0.08);
    padding: 60px 24px 32px; max-width: 1200px; margin: 0 auto;
  }
  .footer-grid {
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px; margin-bottom: 48px;
  }
  .footer-logo {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem; font-weight: 700; margin-bottom: 8px;
  }
  .footer-tagline { font-size: 0.85rem; color: rgba(232,224,212,0.4); }
  .footer-address { font-size: 0.8rem; color: rgba(232,224,212,0.4); line-height: 1.7; }
  .footer-col h4 {
    font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase;
    color: #c9a96e; margin-bottom: 16px;
  }
  .footer-col a {
    display: block; color: rgba(232,224,212,0.5);
    text-decoration: none; font-size: 0.85rem;
    margin-bottom: 8px; transition: color 0.3s ease;
  }
  .footer-col a:hover { color: #c9a96e; }
  .footer-bottom {
    border-top: 1px solid rgba(201,169,110,0.06);
    padding-top: 24px; text-align: center;
  }
  .footer-bottom p { font-size: 0.75rem; color: rgba(232,224,212,0.3); }
  .footer-demo { margin-top: 12px; font-style: italic; }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 900px) {
    .cart-layout { grid-template-columns: 1fr; }
    .summary-card { position: static; }
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .nav-links { display: none; }
  }
  @media (max-width: 600px) {
    .cart-item { flex-direction: column; }
    .item-image { width: 100%; height: 200px; }
    .footer-grid { grid-template-columns: 1fr; }
    .payment-icons { flex-wrap: wrap; }
    .announcement-bar { font-size: 0.7rem; padding: 6px 12px; }
    .main-nav { top: 28px; padding: 10px 20px; }
  }
</style>
</body>
</html>
