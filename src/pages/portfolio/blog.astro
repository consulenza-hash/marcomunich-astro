      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      display: block;
      border-radius: 10px;
      position: relative;
      overflow: hidden;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
