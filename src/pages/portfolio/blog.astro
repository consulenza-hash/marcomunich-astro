      transition: all 0.3s ease;
    }
    .tag:hover {
      background: linear-gradient(135deg, #dc2626, #ef4444);
      color: #fff;
      transform: scale(1.05);
    }

    /* ===== FOOTER ===== */
    .footer {
      background: #0a0a0a;
