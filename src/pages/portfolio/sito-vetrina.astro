---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Studio Terraviva — Architettura & Design</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <!-- Organic shapes -->
  <div class="organic-shapes" aria-hidden="true">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
  </div>

  <!-- Back button -->
  <a href="/dev/portfolio" class="back-btn">
    <span class="back-arrow">&larr;</span> Torna al Portfolio
  </a>

  <!-- Nav -->
  <nav class="nav fade-in">
    <div class="nav-logo">Terraviva</div>
    <div class="nav-links" id="navLinks">
      <a href="#servizi">Servizi</a>
      <a href="#progetti">Progetti</a>
      <a href="#chi-siamo">Chi Siamo</a>
      <a href="#contatti" class="nav-cta">Contattaci</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content fade-in">
      <p class="hero-tag">Studio di Architettura & Interior Design &mdash; Padova</p>
      <h1 class="hero-title">Spazi che <span class="text-terracotta">Dialogano</span><br />con il <span class="text-sage">Territorio</span></h1>
      <p class="hero-sub">L'Arch. Francesca Moretti e il team di Studio Terraviva progettano residenze, ristrutturazioni e interni che rispettano chi li abita. Dal 2015 a Padova, oltre 40 progetti completati.</p>
      <a href="#progetti" class="btn-primary">Scopri i Nostri Progetti</a>
    </div>
    <div class="hero-image fade-in" style="--delay:0.2s">
      <img src="/images/portfolio/vetrina-professional.jpg" alt="Professional woman" loading="eager" style="width:100%;height:100%;object-fit:cover;display:block;border-radius:40% 60% 55% 45% / 55% 40% 60% 45%;" />
    </div>
    <!-- Curved divider -->
    <div class="curve-divider">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,60 C360,120 1080,0 1440,60 L1440,120 L0,120 Z" fill="#faf8f5"/>
      </svg>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="servizi">
    <div class="section-header fade-in">
      <p class="section-tag">I Nostri Servizi</p>
      <h2 class="section-title">Cosa <span class="text-terracotta">Facciamo</span></h2>
    </div>
    <div class="service-grid">
      <div class="service-card fade-in" style="--delay:0s">
        <div class="card-front">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
          </div>
          <h3>Progettazione Residenziale</h3>
          <p>Dal concept alla consegna chiavi in mano: rilievi, progetto architettonico, render 3D, direzione lavori e collaudo finale. A partire da &euro;3.000.</p>
        </div>
        <div class="card-back">
          <h3>Progettazione Residenziale</h3>
          <ul>
            <li>Rilievo e analisi del sito</li>
            <li>Progetto preliminare e definitivo</li>
            <li>Render fotorealistici 3D</li>
            <li>Pratiche edilizie e permessi</li>
            <li>Direzione lavori e collaudo</li>
          </ul>
          <a href="#" class="service-link">Da &euro;3.000 &rarr;</a>
        </div>
      </div>
      <div class="service-card fade-in" style="--delay:0.1s">
        <div class="card-front">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"></path></svg>
          </div>
          <h3>Ristrutturazione</h3>
          <p>Interventi completi su edifici esistenti: consolidamento strutturale, adeguamento sismico, efficientamento energetico e nuova distribuzione degli spazi. A partire da &euro;5.000.</p>
        </div>
        <div class="card-back">
          <h3>Ristrutturazione</h3>
          <ul>
            <li>Perizia e stato di fatto</li>
            <li>Progetto di ristrutturazione</li>
            <li>Adeguamento sismico e energetico</li>
            <li>Gestione imprese e fornitori</li>
            <li>Pratiche Superbonus e detrazioni</li>
          </ul>
          <a href="#" class="service-link">Da &euro;5.000 &rarr;</a>
        </div>
      </div>
      <div class="service-card fade-in" style="--delay:0.2s">
        <div class="card-front">
          <div class="service-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22c-4.97 0-9-2.686-9-6v-4c0-3.314 4.03-6 9-6s9 2.686 9 6v4c0 3.314-4.03 6-9 6z"></path><path d="M12 12c-4.97 0-9-2.686-9-6s4.03-6 9-6 9 2.686 9 6-4.03 6-9 6z"></path></svg>
          </div>
          <h3>Interior Design</h3>
          <p>Concept creativo, moodboard, selezione materiali e arredi su misura. Illuminotecnica, tessuti e finiture curati nel dettaglio. A partire da &euro;2.000.</p>
        </div>
        <div class="card-back">
          <h3>Interior Design</h3>
          <ul>
            <li>Concept e moodboard personalizzato</li>
            <li>Layout e distribuzione interna</li>
            <li>Selezione materiali e finiture</li>
            <li>Progetto illuminotecnico</li>
            <li>Arredi su misura e styling</li>
          </ul>
          <a href="#" class="service-link">Da &euro;2.000 &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave divider -->
  <div class="wave-divider wave-beige-to-white">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,40 C240,80 480,0 720,40 C960,80 1200,0 1440,40 L1440,80 L0,80 Z" fill="#f5f0eb"/>
    </svg>
  </div>

  <!-- Projects -->
  <section class="projects" id="progetti">
    <div class="section-header fade-in">
      <p class="section-tag">Portfolio</p>
      <h2 class="section-title">Progetti <span class="text-sage">Recenti</span></h2>
    </div>
    <div class="project-grid">
      <div class="project-card project-large fade-in" style="--delay:0s">
        <div class="project-img">
          <img src="/images/portfolio/vetrina-loft.jpg" alt="Villa Ulivo" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        </div>
        <div class="project-info">
          <span class="project-cat">Residenziale</span>
          <h3>Villa Ulivo — Puglia</h3>
          <p>Ristrutturazione di un trullo storico con ampliamento moderno in pietra locale e vetro.</p>
        </div>
      </div>
      <div class="project-card fade-in" style="--delay:0.1s">
        <div class="project-img">
          <img src="/images/portfolio/vetrina-loft.jpg" alt="Loft Navigli" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        </div>
        <div class="project-info">
          <span class="project-cat">Interior</span>
          <h3>Loft Navigli — Milano</h3>
          <p>Spazio industriale trasformato in residenza con materiali di recupero.</p>
        </div>
      </div>
      <div class="project-card fade-in" style="--delay:0.2s">
        <div class="project-img">
          <img src="/images/portfolio/vetrina-garden.jpg" alt="Giardino Segreto" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" />
        </div>
        <div class="project-info">
          <span class="project-cat">Paesaggismo</span>
          <h3>Giardino Segreto — Toscana</h3>
          <p>2000mq di giardino mediterraneo con sistema di raccolta acque piovane.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wave divider -->
  <div class="wave-divider wave-white-to-beige">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
      <path d="M0,40 C360,0 720,80 1080,40 C1260,20 1380,50 1440,40 L1440,80 L0,80 Z" fill="#faf8f5"/>
    </svg>
  </div>

  <!-- About -->
  <section class="about" id="chi-siamo">
    <div class="about-content fade-in">
      <p class="section-tag">Chi Siamo</p>
      <h2 class="section-title">Lo <span class="text-terracotta">Studio</span></h2>
      <p class="about-text">L'Arch. Francesca Moretti fonda Studio Terraviva nel 2015 a Padova. Progettiamo spazi che dialogano con il territorio e rispettano chi li abita. Oltre 40 progetti completati tra residenze private, ristrutturazioni e spazi commerciali. Il nostro team di 6 professionisti lavora con un approccio che privilegia i materiali locali, l'efficienza energetica e la cura del dettaglio.</p>
      <div class="about-stats">
        <div class="about-stat">
          <strong>40+</strong>
          <span>Progetti Completati</span>
        </div>
        <div class="about-stat">
          <strong>11</strong>
          <span>Anni di Attivit&agrave;</span>
        </div>
        <div class="about-stat">
          <strong>6</strong>
          <span>Professionisti</span>
        </div>
      </div>
    </div>
    <div class="about-image fade-in" style="--delay:0.2s">
      <img src="/images/portfolio/vetrina-professional.jpg" alt="About studio" loading="lazy" style="width:100%;aspect-ratio:4/5;object-fit:cover;display:block;border-radius:20px;" />
    </div>
  </section>

  <!-- Testimonials scroll -->
  <section class="testimonials">
    <div class="section-header fade-in">
      <p class="section-tag">Dicono di Noi</p>
      <h2 class="section-title">Esperienze dei <span class="text-sage">Clienti</span></h2>
    </div>
    <div class="testimonial-scroll fade-in">
      <div class="testimonial-track">
        <div class="testimonial-card">
          <p>"Francesca e il suo team hanno ristrutturato la nostra casa anni '60 rispettando la struttura originale ma rendendola moderna e luminosa. Lavoro impeccabile, tempi rispettati."</p>
          <div class="testimonial-author">
            <div style="width:40px;height:40px;border-radius:50%;background:#c2703e;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">GR</div>
            <div>
              <strong>Giovanni Rigoni</strong>
              <span>Ristrutturazione, Abano Terme (PD)</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p>"Ci hanno seguito dalla scelta del terreno fino alla consegna delle chiavi. La villa &egrave; esattamente come la immaginavamo, anzi meglio. Consigliamo Studio Terraviva a chiunque."</p>
          <div class="testimonial-author">
            <div style="width:40px;height:40px;border-radius:50%;background:#7c8c6c;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">EB</div>
            <div>
              <strong>Elena e Paolo Bruni</strong>
              <span>Progettazione residenziale, Selvazzano (PD)</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p>"L'interior design del nostro appartamento ha cambiato il modo in cui viviamo gli spazi. Ogni dettaglio &egrave; pensato, dai materiali alla luce. Professionali e creativi."</p>
          <div class="testimonial-author">
            <div style="width:40px;height:40px;border-radius:50%;background:#c2703e;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">SM</div>
            <div>
              <strong>Silvia Meneghin</strong>
              <span>Interior Design, Padova Centro</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <p>"Ho affidato a Terraviva la ristrutturazione del mio studio dentistico. Risultato eccellente: i pazienti si sentono a loro agio e lo spazio &egrave; funzionale al massimo."</p>
          <div class="testimonial-author">
            <div style="width:40px;height:40px;border-radius:50%;background:#7c8c6c;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:0.85rem;flex-shrink:0;">DT</div>
            <div>
              <strong>Dott. Marco Trevisan</strong>
              <span>Ristrutturazione commerciale, Cittadella (PD)</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact" id="contatti">
    <div class="contact-inner fade-in">
      <div class="contact-text">
        <p class="section-tag">Contattaci</p>
        <h2 class="section-title">Parliamo del Tuo <span class="text-terracotta">Progetto</span></h2>
        <p>Ogni grande progetto inizia con una conversazione. Raccontaci la tua idea e costruiremo insieme la soluzione migliore.</p>
      </div>
      <form class="contact-form" onsubmit="event.preventDefault()">
        <input type="text" placeholder="Il tuo nome" class="form-input" />
        <input type="email" placeholder="La tua email" class="form-input" />
        <textarea placeholder="Raccontaci il tuo progetto..." class="form-input form-textarea"></textarea>
        <button type="submit" class="btn-primary">Invia Messaggio</button>
      </form>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <h3>Studio Terraviva</h3>
        <p>Via Daniele Manin 8, 35122 Padova (PD)<br/>Tel. 049 876 5432 &mdash; info@studioterraviva.it</p>
      </div>
      <div class="footer-links">
        <a href="#">Servizi</a>
        <a href="#">Progetti</a>
        <a href="#">Chi Siamo</a>
        <a href="#">Instagram</a>
      </div>
    </div>
    <p class="footer-copy">&copy; 2026 Studio Terraviva di Arch. Francesca Moretti &mdash; P.IVA 04123456789 &mdash; Tutti i diritti riservati.</p>
  </footer>

  <script is:inline>
    // Hamburger menu
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('navLinks');
    hamburger.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', isOpen);
    });
    navLinks.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        navLinks.classList.remove('open');
        hamburger.classList.remove('open');
        hamburger.setAttribute('aria-expanded', false);
      });
    });
  </script>

  <script is:inline>
    // Fade-in observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // ===== CONTACT FORM =====
    document.querySelector('.contact-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      const inputs = e.target.querySelectorAll('.form-input');
      if (!inputs[0].value || !inputs[1].value) { showSvToast('Compila nome ed email'); return; }
      inputs.forEach(i => i.value = '');
      showSvToast('✓ Messaggio inviato! Ti risponderemo entro 24 ore.');
    });

    // ===== SERVICE LINKS =====
    document.querySelectorAll('.service-link').forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const service = link.closest('.service-card')?.querySelector('h3')?.textContent || '';
        showSvToast('📩 Contattaci per un preventivo su: ' + service);
      });
    });

    // ===== PROJECT CARDS =====
    document.querySelectorAll('.project-card').forEach(card => {
      card.style.cursor = 'pointer';
      card.addEventListener('click', () => {
        const title = card.querySelector('h3')?.textContent || 'Progetto';
        showSvToast('📁 ' + title + ' — Galleria completa disponibile su richiesta');
      });
    });

    let svToastTimeout;
    function showSvToast(msg) {
      const t = document.getElementById('sv-toast');
      t.textContent = msg;
      t.classList.add('show');
      clearTimeout(svToastTimeout);
      svToastTimeout = setTimeout(() => t.classList.remove('show'), 3500);
    }
  </script>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #faf8f5;
      color: #2d2a26;
      overflow-x: hidden;
      line-height: 1.6;
    }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #faf8f5; }
    ::-webkit-scrollbar-thumb { background: #c2703e; border-radius: 4px; }

    .text-terracotta { color: #c2703e; }
    .text-sage { color: #7c8c6c; }

    .fade-in {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
      transition-delay: var(--delay, 0s);
    }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    /* ========== ORGANIC SHAPES ========== */
    .organic-shapes { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .shape {
      position: absolute; border-radius: 50%;
      opacity: 0.06;
      animation: floatShape 25s ease-in-out infinite;
    }
    .shape-1 {
      width: 500px; height: 500px; top: -150px; right: -100px;
      background: #c2703e;
      border-radius: 40% 60% 55% 45% / 55% 40% 60% 45%;
    }
    .shape-2 {
      width: 400px; height: 400px; bottom: 10%; left: -100px;
      background: #7c8c6c;
      border-radius: 55% 45% 40% 60% / 40% 55% 45% 60%;
      animation-delay: -8s;
    }
    .shape-3 {
      width: 300px; height: 300px; top: 40%; right: 10%;
      background: #c2703e;
      border-radius: 45% 55% 60% 40% / 60% 45% 55% 40%;
      animation-delay: -15s;
    }
    @keyframes floatShape {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      33% { transform: translate(30px, -20px) rotate(5deg); }
      66% { transform: translate(-20px, 15px) rotate(-3deg); }
    }

    /* ========== BACK BUTTON ========== */
    .back-btn {
      position: fixed; bottom: 2rem; left: 24px; z-index: 9000;
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 20px;
      background: rgba(250,248,245,0.85);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(194,112,62,0.15);
      border-radius: 50px;
      color: #c2703e;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      transition: all 0.3s ease;
    }
    .back-btn:hover {
      background: rgba(194,112,62,0.08);
      border-color: rgba(194,112,62,0.4);
      box-shadow: 0 4px 16px rgba(194,112,62,0.1);
    }
    .back-arrow { transition: transform 0.3s ease; }
    .back-btn:hover .back-arrow { transform: translateX(-3px); }

    /* ========== NAV ========== */
    .nav {
      position: relative; z-index: 10;
      display: flex; justify-content: space-between; align-items: center;
      max-width: 1100px; margin: 0 auto;
      padding: 24px 24px 0;
    }
    .nav-logo {
      font-family: 'DM Serif Display', serif;
      font-size: 1.6rem; color: #2d2a26;
    }
    .nav-links { display: flex; gap: 32px; align-items: center; }
    .hamburger { display: none; }
    .nav-links a {
      color: #6b6560; text-decoration: none; font-size: 0.9rem;
      transition: color 0.3s ease;
    }
    .nav-links a:hover { color: #c2703e; }
    .nav-cta {
      padding: 8px 20px !important;
      background: #c2703e !important;
      color: #fff !important;
      border-radius: 50px;
    }
    .nav-cta:hover { opacity: 0.9; }

    /* ========== HERO ========== */
    .hero {
      position: relative;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: center;
      max-width: 1100px; margin: 0 auto;
      padding: 100px 24px 180px;
    }
    .hero-tag {
      font-size: 0.8rem; letter-spacing: 3px; text-transform: uppercase;
      color: #c2703e; margin-bottom: 16px;
    }
    .hero-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      line-height: 1.15;
      font-weight: 400;
      margin-bottom: 24px;
      color: #2d2a26;
    }
    .hero-sub {
      font-size: 1rem; font-weight: 300;
      color: #8a847e; line-height: 1.8;
      margin-bottom: 36px; max-width: 480px;
    }
    .btn-primary {
      display: inline-block; padding: 14px 36px;
      background: #c2703e; color: #fff;
      text-decoration: none; font-size: 0.85rem; font-weight: 600;
      border-radius: 50px; border: none; cursor: pointer;
      transition: all 0.3s ease;
      font-family: 'DM Sans', sans-serif;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(194,112,62,0.25);
    }

    .hero-image { position: relative; }
    .hero-img-placeholder {
      width: 100%; aspect-ratio: 4/5;
      background: linear-gradient(135deg, #e8ddd4, #d4c4b0);
      border-radius: 40% 60% 55% 45% / 55% 40% 60% 45%;
      position: relative; overflow: hidden;
    }
    .img-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(194,112,62,0.1), rgba(124,140,108,0.1));
    }

    .curve-divider {
      position: absolute; bottom: 0; left: 0; right: 0;
      line-height: 0;
    }
    .curve-divider svg { width: 100%; height: 80px; }

    /* ========== SECTIONS COMMON ========== */
    .section-header { text-align: center; margin-bottom: 60px; }
    .section-tag {
      font-size: 0.8rem; letter-spacing: 3px; text-transform: uppercase;
      color: #c2703e; margin-bottom: 12px;
    }
    .section-title {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 400; color: #2d2a26;
    }

    /* ========== SERVICES ========== */
    .services { max-width: 1100px; margin: 0 auto; padding: 80px 24px; position: relative; z-index: 1; }
    .service-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
    .service-card {
      position: relative;
      height: 360px;
      perspective: 1000px;
      cursor: pointer;
    }
    .card-front, .card-back {
      position: absolute; inset: 0;
      border-radius: 20px;
      padding: 36px;
      backface-visibility: hidden;
      transition: transform 0.7s cubic-bezier(0.16,1,0.3,1);
      display: flex; flex-direction: column;
    }
    .card-front {
      background: #fff;
      border: 1px solid #ede8e3;
      box-shadow: 0 4px 20px rgba(0,0,0,0.04);
    }
    .card-back {
      background: #c2703e;
      color: #fff;
      transform: rotateY(180deg);
      justify-content: center;
    }
    .service-card:hover .card-front { transform: rotateY(-180deg); }
    .service-card:hover .card-back { transform: rotateY(0deg); }

    .service-icon {
      width: 56px; height: 56px;
      background: rgba(194,112,62,0.08);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      color: #c2703e;
      margin-bottom: 20px;
    }
    .card-front h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.3rem; font-weight: 400; margin-bottom: 12px;
    }
    .card-front p { font-size: 0.9rem; color: #8a847e; line-height: 1.7; }
    .card-back h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.3rem; font-weight: 400; margin-bottom: 16px;
    }
    .card-back ul { list-style: none; margin-bottom: 24px; }
    .card-back li {
      padding: 6px 0; font-size: 0.9rem;
      border-bottom: 1px solid rgba(255,255,255,0.15);
    }
    .service-link {
      color: #fff; text-decoration: none; font-weight: 600;
      font-size: 0.85rem; transition: opacity 0.3s ease;
    }
    .service-link:hover { opacity: 0.8; }

    /* ========== WAVE DIVIDERS ========== */
    .wave-divider { line-height: 0; position: relative; z-index: 1; }
    .wave-divider svg { width: 100%; height: 60px; }
    .wave-beige-to-white { background: #faf8f5; }
    .wave-white-to-beige { background: #f5f0eb; }

    /* ========== PROJECTS ========== */
    .projects {
      max-width: 1100px; margin: 0 auto; padding: 80px 24px;
      position: relative; z-index: 1;
      background: #f5f0eb;
    }
    .project-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .project-large { grid-row: span 2; }
    .project-card {
      border-radius: 20px; overflow: hidden;
      background: #fff;
      border: 1px solid #ede8e3;
      transition: all 0.4s ease;
      cursor: pointer;
    }
    .project-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 40px rgba(0,0,0,0.06);
    }
    .project-img {
      width: 100%; aspect-ratio: 16/10;
      overflow: hidden;
    }
    .project-large .project-img { aspect-ratio: 4/5; }
    .project-placeholder {
      width: 100%; height: 100%;
      background: linear-gradient(135deg, #e8ddd4, #d4c4b0);
    }
    .project-info { padding: 24px; }
    .project-cat {
      font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;
      color: #7c8c6c; margin-bottom: 4px; display: block;
    }
    .project-info h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.2rem; font-weight: 400; margin-bottom: 8px;
    }
    .project-info p { font-size: 0.85rem; color: #8a847e; line-height: 1.6; }

    /* ========== ABOUT ========== */
    .about {
      max-width: 1100px; margin: 0 auto; padding: 80px 24px;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: center;
      position: relative; z-index: 1;
    }
    .about-text {
      font-size: 1rem; color: #6b6560; line-height: 1.8;
      margin-bottom: 32px;
    }
    .about-stats { display: flex; gap: 32px; }
    .about-stat { text-align: center; }
    .about-stat strong {
      display: block;
      font-family: 'DM Serif Display', serif;
      font-size: 2rem; color: #c2703e;
    }
    .about-stat span { font-size: 0.75rem; color: #8a847e; letter-spacing: 1px; text-transform: uppercase; }
    .about-img-placeholder {
      width: 100%; aspect-ratio: 4/5;
      background: linear-gradient(135deg, #d4c4b0, #e8ddd4);
      border-radius: 20px;
    }

    /* ========== TESTIMONIALS ========== */
    .testimonials {
      padding: 80px 0; position: relative; z-index: 1;
      overflow: hidden;
    }
    .testimonial-scroll {
      position: relative;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding: 0 24px 24px;
      scrollbar-width: none;
    }
    .testimonial-scroll::-webkit-scrollbar { display: none; }
    .testimonial-scroll::before,
    .testimonial-scroll::after {
      content: ''; position: absolute; top: 0; bottom: 0; width: 80px; z-index: 2; pointer-events: none;
    }
    .testimonial-scroll::before { left: 0; background: linear-gradient(to right, #faf8f5, transparent); }
    .testimonial-scroll::after { right: 0; background: linear-gradient(to left, #faf8f5, transparent); }

    .testimonial-track {
      display: flex; gap: 24px;
      width: max-content;
    }
    .testimonial-card {
      width: 360px;
      scroll-snap-align: start;
      background: #fff;
      border: 1px solid #ede8e3;
      border-radius: 20px;
      padding: 32px;
      flex-shrink: 0;
      transition: all 0.3s ease;
    }
    .testimonial-card:hover {
      border-color: rgba(194,112,62,0.3);
      box-shadow: 0 8px 24px rgba(0,0,0,0.05);
    }
    .testimonial-card p {
      font-size: 0.95rem; line-height: 1.7; color: #6b6560;
      font-style: italic; margin-bottom: 20px;
    }
    .testimonial-author { display: flex; align-items: center; gap: 12px; }
    .testimonial-author strong { display: block; font-size: 0.9rem; color: #2d2a26; }
    .testimonial-author span { font-size: 0.75rem; color: #8a847e; }

    /* ========== CONTACT ========== */
    .contact {
      max-width: 1100px; margin: 0 auto; padding: 80px 24px;
      position: relative; z-index: 1;
    }
    .contact-inner {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: start;
      background: #fff;
      border: 1px solid #ede8e3;
      border-radius: 24px;
      padding: 60px;
    }
    .contact-text p:not(.section-tag) {
      font-size: 0.95rem; color: #8a847e; line-height: 1.7; margin-top: 16px;
    }
    .contact-form { display: flex; flex-direction: column; gap: 16px; }
    .form-input {
      padding: 14px 20px;
      background: #faf8f5;
      border: 1px solid #ede8e3;
      border-radius: 12px;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem; color: #2d2a26;
      outline: none;
      transition: border-color 0.3s ease;
    }
    .form-input::placeholder { color: #b5afa9; }
    .form-input:focus { border-color: #c2703e; }
    .form-textarea { min-height: 120px; resize: vertical; }

    /* ========== FOOTER ========== */
    .footer {
      border-top: 1px solid #ede8e3;
      padding: 40px 24px 24px;
      max-width: 1100px; margin: 0 auto;
      position: relative; z-index: 1;
    }
    .footer-inner {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 24px; flex-wrap: wrap; gap: 16px;
    }
    .footer-brand h3 {
      font-family: 'DM Serif Display', serif;
      font-size: 1.4rem; color: #2d2a26;
    }
    .footer-brand p { font-size: 0.8rem; color: #8a847e; }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a {
      color: #8a847e; text-decoration: none; font-size: 0.85rem;
      transition: color 0.3s ease;
    }
    .footer-links a:hover { color: #c2703e; }
    .footer-copy {
      text-align: center; font-size: 0.7rem; color: #b5afa9;
      border-top: 1px solid #ede8e3; padding-top: 20px;
    }

    /* ========== RESPONSIVE ========== */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; padding-bottom: 140px; }
      .hero-image { max-width: 400px; margin: 0 auto; }
      .service-grid { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
      .service-card { height: auto; min-height: 280px; }
      .project-grid { grid-template-columns: 1fr; }
      .project-large { grid-row: span 1; }
      .about { grid-template-columns: 1fr; }
      .about-image { max-width: 400px; margin: 0 auto; }
      .contact-inner { grid-template-columns: 1fr; padding: 40px; }
      .nav-links { display: none; }
      .nav-links.open {
        display: flex; flex-direction: column; gap: 0;
        position: fixed; top: 0; left: 0; right: 0;
        background: rgba(255,252,247,0.98); backdrop-filter: blur(20px);
        padding: 80px 32px 40px; z-index: 200;
      }
      .nav-links.open a {
        padding: 16px 0; font-size: 1rem; color: #2d2a26;
        border-bottom: 1px solid rgba(0,0,0,0.08);
      }
      .nav-links.open .nav-cta {
        margin-top: 16px; text-align: center;
        padding: 12px 20px !important;
      }
      .hamburger {
        display: flex; flex-direction: column; justify-content: space-between;
        width: 24px; height: 18px; background: none; border: none;
        cursor: pointer; padding: 0; z-index: 201;
      }
      .hamburger span {
        display: block; height: 2px; width: 100%; background: #2d2a26;
        transition: all 0.3s ease; transform-origin: center;
      }
      .hamburger.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
      .hamburger.open span:nth-child(2) { opacity: 0; }
      .hamburger.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
      .hero { padding: 60px 24px 80px; }
    }
    @media (max-width: 600px) {
      .hero-title { font-size: 2rem; }
      .about-stats { flex-direction: column; gap: 16px; }
      .contact-inner { padding: 24px; }
      .back-btn { font-size: 0.75rem; padding: 8px 14px; }
      .testimonial-scroll { max-width: 100%; box-sizing: border-box; padding: 0 16px 24px; }
      .testimonial-card { width: 300px; max-width: calc(100vw - 48px); padding: 24px; box-sizing: border-box; }
    }
  </style>
  <div id="sv-toast" style="position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#1e1e1e;border:1px solid #8b6f4e;color:#d4a678;padding:13px 26px;border-radius:50px;font-size:0.84rem;z-index:99999;opacity:0;transition:all 0.4s cubic-bezier(0.4,0,0.2,1);white-space:nowrap;pointer-events:none;max-width:90vw;text-align:center;"></div>
  <style>#sv-toast.show{opacity:1!important;transform:translateX(-50%) translateY(0)!important}</style>
</body>
