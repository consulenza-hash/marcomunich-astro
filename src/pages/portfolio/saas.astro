---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NomeApp — Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #0f172a; color: #e2e8f0; min-height: 100vh; }

    .back-btn {
      position: fixed; top: 16px; left: 16px; z-index: 1000;
      background: #6366f1; color: #fff; text-decoration: none;
      padding: 8px 16px; border-radius: 8px; font-size: 14px; font-weight: 500;
      box-shadow: 0 4px 12px rgba(99,102,241,.4);
      transition: background .2s;
    }
    .back-btn:hover { background: #4f46e5; }

    .layout { display: flex; min-height: 100vh; }

    /* Sidebar */
    .sidebar {
      width: 240px; background: #1e293b; padding: 24px 0; flex-shrink: 0;
      border-right: 1px solid #334155;
    }
    .sidebar-logo {
      padding: 0 24px 32px; font-size: 20px; font-weight: 700; color: #fff;
      display: flex; align-items: center; gap: 10px;
    }
    .sidebar-logo span {
      width: 32px; height: 32px; background: #6366f1; border-radius: 8px;
      display: flex; align-items: center; justify-content: center; font-size: 16px; color: #fff;
    }
    .sidebar nav a {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 24px; color: #94a3b8; text-decoration: none; font-size: 15px;
      transition: all .2s; border-left: 3px solid transparent;
    }
    .sidebar nav a:hover { color: #e2e8f0; background: rgba(99,102,241,.08); }
    .sidebar nav a.active {
      color: #6366f1; background: rgba(99,102,241,.1);
      border-left-color: #6366f1; font-weight: 600;
    }
    .sidebar nav a .icon { font-size: 18px; width: 22px; text-align: center; }

    /* Main */
    .main { flex: 1; display: flex; flex-direction: column; }

    /* Top bar */
    .topbar {
      height: 64px; background: #1e293b; border-bottom: 1px solid #334155;
      display: flex; align-items: center; padding: 0 32px; gap: 16px;
    }
    .search-box {
      flex: 1; max-width: 400px; position: relative;
    }
    .search-box input {
      width: 100%; padding: 10px 16px 10px 40px; background: #0f172a;
      border: 1px solid #334155; border-radius: 8px; color: #e2e8f0;
      font-size: 14px; outline: none;
    }
    .search-box input::placeholder { color: #64748b; }
    .search-box::before {
      content: '\1F50D'; position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%); font-size: 14px; opacity: .5;
    }
    .topbar-right { display: flex; align-items: center; gap: 20px; margin-left: auto; }
    .notif-bell {
      width: 40px; height: 40px; border-radius: 8px; background: #0f172a;
      border: 1px solid #334155; display: flex; align-items: center;
      justify-content: center; font-size: 18px; cursor: pointer; position: relative;
    }
    .notif-bell::after {
      content: ''; width: 8px; height: 8px; background: #ef4444; border-radius: 50%;
      position: absolute; top: 8px; right: 8px; border: 2px solid #1e293b;
    }
    .avatar {
      width: 36px; height: 36px; border-radius: 50%; background: linear-gradient(135deg, #6366f1, #8b5cf6);
      display: flex; align-items: center; justify-content: center; font-size: 14px;
      font-weight: 600; color: #fff; cursor: pointer;
    }

    /* Content */
    .content { padding: 32px; flex: 1; }
    .welcome h1 { font-size: 28px; font-weight: 700; color: #fff; }
    .welcome p { color: #64748b; margin-top: 4px; font-size: 15px; }

    /* Stat cards */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-top: 28px; }
    .stat-card {
      background: #1e293b; border-radius: 12px; padding: 24px;
      border: 1px solid #334155;
    }
    .stat-card .label { font-size: 14px; color: #64748b; margin-bottom: 8px; }
    .stat-card .value { font-size: 32px; font-weight: 700; color: #fff; }
    .stat-card .sub { font-size: 13px; color: #22c55e; margin-top: 4px; }
    .stat-card:nth-child(1) .value { color: #6366f1; }
    .stat-card:nth-child(4) .value { color: #22c55e; }

    /* Chart */
    .chart-section {
      background: #1e293b; border-radius: 12px; padding: 24px;
      border: 1px solid #334155; margin-top: 28px;
    }
    .chart-section h2 { font-size: 18px; font-weight: 600; color: #fff; margin-bottom: 24px; }
    .chart { display: flex; align-items: flex-end; gap: 24px; height: 180px; padding: 0 20px; }
    .bar-group { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .bar {
      width: 100%; max-width: 48px; border-radius: 6px 6px 0 0;
      background: linear-gradient(180deg, #6366f1, #4f46e5); position: relative;
      transition: opacity .2s;
    }
    .bar:hover { opacity: .8; }
    .bar-label { font-size: 13px; color: #64748b; }
    .bar-val {
      position: absolute; top: -22px; left: 50%; transform: translateX(-50%);
      font-size: 12px; color: #94a3b8; white-space: nowrap;
    }

    /* Table */
    .table-section {
      background: #1e293b; border-radius: 12px; padding: 24px;
      border: 1px solid #334155; margin-top: 28px;
    }
    .table-section h2 { font-size: 18px; font-weight: 600; color: #fff; margin-bottom: 20px; }
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 12px 16px; font-size: 13px; color: #64748b; font-weight: 500; border-bottom: 1px solid #334155; }
    td { padding: 14px 16px; font-size: 14px; border-bottom: 1px solid rgba(51,65,85,.5); }
    tr:last-child td { border-bottom: none; }
    .badge {
      display: inline-block; padding: 4px 12px; border-radius: 20px;
      font-size: 12px; font-weight: 600;
    }
    .badge-green { background: rgba(34,197,94,.15); color: #22c55e; }
    .badge-yellow { background: rgba(234,179,8,.15); color: #eab308; }
    .badge-gray { background: rgba(148,163,184,.15); color: #94a3b8; }

    .footer {
      padding: 20px 32px; border-top: 1px solid #334155; color: #475569;
      font-size: 13px; text-align: center;
    }

    @media (max-width: 1024px) {
      .sidebar { display: none; }
      .stats { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .stats { grid-template-columns: 1fr; }
      .content { padding: 20px; }
      table { font-size: 13px; }
      th, td { padding: 10px 8px; }
    }
  </style>
</head>
<body>
  <a href="/portfolio" class="back-btn">&larr; Torna al Portfolio</a>

  <div class="layout">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <span>N</span> NomeApp
      </div>
      <nav>
        <a href="#" class="active"><span class="icon">&#9632;</span> Dashboard</a>
        <a href="#"><span class="icon">&#9744;</span> Progetti</a>
        <a href="#"><span class="icon">&#9786;</span> Team</a>
        <a href="#"><span class="icon">&#9650;</span> Analytics</a>
        <a href="#"><span class="icon">&#9881;</span> Impostazioni</a>
      </nav>
    </aside>

    <div class="main">
      <header class="topbar">
        <div class="search-box">
          <input type="text" placeholder="Cerca progetti, task, persone..." />
        </div>
        <div class="topbar-right">
          <div class="notif-bell">&#128276;</div>
          <div class="avatar">MR</div>
        </div>
      </header>

      <div class="content">
        <div class="welcome">
          <h1>Bentornato, Marco</h1>
          <p>Ecco il riepilogo di oggi, 21 marzo 2026</p>
        </div>

        <div class="stats">
          <div class="stat-card">
            <div class="label">Progetti Attivi</div>
            <div class="value">12</div>
            <div class="sub">+2 questo mese</div>
          </div>
          <div class="stat-card">
            <div class="label">Task Completati</div>
            <div class="value">847</div>
            <div class="sub">+34 questa settimana</div>
          </div>
          <div class="stat-card">
            <div class="label">Team Members</div>
            <div class="value">8</div>
            <div class="sub">1 nuovo ingresso</div>
          </div>
          <div class="stat-card">
            <div class="label">Entrate</div>
            <div class="value">&euro;24.500</div>
            <div class="sub">+12% vs mese scorso</div>
          </div>
        </div>

        <div class="chart-section">
          <h2>Attivit&agrave; Settimanale</h2>
          <div class="chart">
            <div class="bar-group">
              <div class="bar" style="height:65%"><span class="bar-val">24</span></div>
              <span class="bar-label">Lun</span>
            </div>
            <div class="bar-group">
              <div class="bar" style="height:85%"><span class="bar-val">31</span></div>
              <span class="bar-label">Mar</span>
            </div>
            <div class="bar-group">
              <div class="bar" style="height:45%"><span class="bar-val">18</span></div>
              <span class="bar-label">Mer</span>
            </div>
            <div class="bar-group">
              <div class="bar" style="height:95%"><span class="bar-val">38</span></div>
              <span class="bar-label">Gio</span>
            </div>
            <div class="bar-group">
              <div class="bar" style="height:70%"><span class="bar-val">27</span></div>
              <span class="bar-label">Ven</span>
            </div>
            <div class="bar-group">
              <div class="bar" style="height:35%"><span class="bar-val">12</span></div>
              <span class="bar-label">Sab</span>
            </div>
          </div>
        </div>

        <div class="table-section">
          <h2>Attivit&agrave; Recenti</h2>
          <table>
            <thead>
              <tr>
                <th>Data</th>
                <th>Azione</th>
                <th>Utente</th>
                <th>Stato</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>21 Mar 2026</td>
                <td>Deploy v2.4.1 in produzione</td>
                <td>Marco R.</td>
                <td><span class="badge badge-green">Completato</span></td>
              </tr>
              <tr>
                <td>21 Mar 2026</td>
                <td>Review pull request #142</td>
                <td>Sara L.</td>
                <td><span class="badge badge-yellow">In Corso</span></td>
              </tr>
              <tr>
                <td>20 Mar 2026</td>
                <td>Aggiornamento design sistema</td>
                <td>Luca B.</td>
                <td><span class="badge badge-green">Completato</span></td>
              </tr>
              <tr>
                <td>20 Mar 2026</td>
                <td>Test integrazione API pagamenti</td>
                <td>Anna M.</td>
                <td><span class="badge badge-yellow">In Corso</span></td>
              </tr>
              <tr>
                <td>19 Mar 2026</td>
                <td>Migrazione database utenti</td>
                <td>Pietro G.</td>
                <td><span class="badge badge-gray">In Attesa</span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <footer class="footer">
        &copy; 2026 NomeApp S.r.l. &mdash; Tutti i diritti riservati
      </footer>
    </div>
  </div>
</body>
</html>
