---
export const prerender = true;
---
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Nome Associazione — Insieme per il Cambiamento</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', -apple-system, sans-serif; background: #fffbf0; color: #292524; line-height: 1.6; }

    .back-btn {
      position: fixed; top: 16px; left: 16px; z-index: 1000;
      background: #ea580c; color: #fff; text-decoration: none;
      padding: 8px 16px; border-radius: 8px; font-size: 14px; font-weight: 500;
      box-shadow: 0 4px 12px rgba(234,88,12,.35); transition: background .2s;
    }
    .back-btn:hover { background: #c2410c; }

    /* Navbar */
    .navbar {
      background: #fff; border-bottom: 1px solid #fed7aa;
      padding: 0 40px; height: 72px; display: flex; align-items: center;
      justify-content: space-between; position: sticky; top: 0; z-index: 100;
    }
    .nav-logo { font-size: 20px; font-weight: 700; color: #ea580c; display: flex; align-items: center; gap: 8px; }
    .nav-logo .heart { font-size: 24px; }
    .nav-links { display: flex; gap: 32px; list-style: none; }
    .nav-links a { text-decoration: none; color: #57534e; font-size: 15px; font-weight: 500; transition: color .2s; }
    .nav-links a:hover { color: #ea580c; }

    /* Hero */
    .hero {
      padding: 80px 40px 60px; text-align: center;
      background: linear-gradient(180deg, #fff7ed 0%, #fffbf0 100%);
    }
    .hero h1 { font-size: 48px; font-weight: 800; color: #1c1917; max-width: 700px; margin: 0 auto; line-height: 1.15; }
    .hero p { font-size: 18px; color: #78716c; margin-top: 16px; max-width: 560px; margin-left: auto; margin-right: auto; }
    .counters { display: flex; justify-content: center; gap: 60px; margin-top: 48px; }
    .counter { text-align: center; }
    .counter .num { font-size: 42px; font-weight: 800; color: #ea580c; }
    .counter .lbl { font-size: 15px; color: #78716c; margin-top: 4px; }
    .hero-cta {
      display: inline-block; margin-top: 40px; padding: 16px 48px;
      background: #ea580c; color: #fff; text-decoration: none;
      border-radius: 50px; font-size: 18px; font-weight: 700;
      box-shadow: 0 8px 24px rgba(234,88,12,.3); transition: transform .2s, box-shadow .2s;
    }
    .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(234,88,12,.4); }

    /* Section */
    section { padding: 80px 40px; }
    .section-title { font-size: 36px; font-weight: 800; text-align: center; color: #1c1917; margin-bottom: 12px; }
    .section-sub { text-align: center; color: #78716c; font-size: 17px; max-width: 600px; margin: 0 auto 48px; }

    /* Mission */
    .mission { background: #fff; text-align: center; }
    .mission-text { font-size: 22px; color: #44403c; max-width: 800px; margin: 0 auto; line-height: 1.7; }

    /* Projects */
    .projects-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; max-width: 1100px; margin: 0 auto; }
    .project-card { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,.06); transition: transform .2s; }
    .project-card:hover { transform: translateY(-4px); }
    .project-img { height: 180px; }
    .project-card:nth-child(1) .project-img { background: linear-gradient(135deg, #fed7aa, #fdba74); }
    .project-card:nth-child(2) .project-img { background: linear-gradient(135deg, #fde68a, #fbbf24); }
    .project-card:nth-child(3) .project-img { background: linear-gradient(135deg, #bbf7d0, #4ade80); }
    .project-body { padding: 24px; }
    .project-body h3 { font-size: 20px; font-weight: 700; color: #1c1917; margin-bottom: 8px; }
    .project-body p { font-size: 15px; color: #78716c; margin-bottom: 16px; }
    .progress-bar { height: 8px; background: #f5f5f4; border-radius: 4px; overflow: hidden; margin-bottom: 8px; }
    .progress-fill { height: 100%; border-radius: 4px; background: #ea580c; }
    .progress-label { font-size: 13px; color: #a8a29e; margin-bottom: 16px; }
    .project-link { color: #ea580c; font-weight: 600; text-decoration: none; font-size: 15px; }
    .project-link:hover { text-decoration: underline; }

    /* How to help */
    .help-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; max-width: 900px; margin: 0 auto; }
    .help-card { text-align: center; padding: 40px 24px; background: #fff; border-radius: 16px; box-shadow: 0 2px 12px rgba(0,0,0,.05); }
    .help-icon { font-size: 48px; margin-bottom: 16px; }
    .help-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 8px; color: #1c1917; }
    .help-card p { font-size: 15px; color: #78716c; }

    /* Events */
    .events-section { background: #fff; }
    .events-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; max-width: 900px; margin: 0 auto; }
    .event-card { display: flex; gap: 20px; padding: 24px; border: 2px solid #fed7aa; border-radius: 16px; }
    .event-date {
      background: #ea580c; color: #fff; border-radius: 12px;
      min-width: 72px; height: 72px; display: flex; flex-direction: column;
      align-items: center; justify-content: center; flex-shrink: 0;
    }
    .event-date .day { font-size: 28px; font-weight: 800; line-height: 1; }
    .event-date .month { font-size: 13px; font-weight: 600; text-transform: uppercase; }
    .event-info h3 { font-size: 18px; font-weight: 700; color: #1c1917; }
    .event-info .loc { font-size: 14px; color: #a8a29e; margin: 4px 0 12px; }
    .event-btn {
      display: inline-block; padding: 8px 20px; border: 2px solid #ea580c;
      color: #ea580c; border-radius: 8px; text-decoration: none;
      font-size: 14px; font-weight: 600; transition: all .2s;
    }
    .event-btn:hover { background: #ea580c; color: #fff; }

    /* Donation */
    .donate-section { text-align: center; }
    .donate-amounts { display: flex; justify-content: center; gap: 16px; margin-bottom: 32px; flex-wrap: wrap; }
    .donate-amt {
      padding: 14px 28px; border: 2px solid #ea580c; border-radius: 12px;
      background: transparent; color: #ea580c; font-size: 18px; font-weight: 700;
      cursor: pointer; transition: all .2s;
    }
    .donate-amt:hover, .donate-amt.active { background: #ea580c; color: #fff; }
    .donate-cta {
      display: inline-block; padding: 16px 56px; background: #ea580c; color: #fff;
      border: none; border-radius: 50px; font-size: 18px; font-weight: 700;
      cursor: pointer; box-shadow: 0 8px 24px rgba(234,88,12,.3); transition: transform .2s;
    }
    .donate-cta:hover { transform: translateY(-2px); }

    /* Footer */
    .footer {
      background: #1c1917; color: #a8a29e; padding: 40px; text-align: center; font-size: 14px; line-height: 1.8;
    }
    .footer a { color: #ea580c; text-decoration: none; }

    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hero h1 { font-size: 32px; }
      .counters { flex-direction: column; gap: 24px; }
      .projects-grid, .help-grid, .events-grid { grid-template-columns: 1fr; }
      section { padding: 48px 20px; }
    }
  </style>
</head>
<body>
  <a href="/portfolio" class="back-btn">&larr; Torna al Portfolio</a>

  <nav class="navbar">
    <div class="nav-logo"><span class="heart">&#10084;</span> Nome Associazione</div>
    <ul class="nav-links">
      <li><a href="#">Chi Siamo</a></li>
      <li><a href="#">Progetti</a></li>
      <li><a href="#">Dona</a></li>
      <li><a href="#">Volontariato</a></li>
      <li><a href="#">Eventi</a></li>
    </ul>
  </nav>

  <section class="hero">
    <h1>Insieme possiamo fare la differenza</h1>
    <p>Dal 2015 lavoriamo ogni giorno per costruire un futuro migliore, una comunit&agrave; alla volta.</p>
    <div class="counters">
      <div class="counter"><div class="num">1.200</div><div class="lbl">Famiglie Aiutate</div></div>
      <div class="counter"><div class="num">45</div><div class="lbl">Volontari Attivi</div></div>
      <div class="counter"><div class="num">8</div><div class="lbl">Progetti Attivi</div></div>
    </div>
    <a href="#" class="hero-cta">Dona Ora</a>
  </section>

  <section class="mission">
    <h2 class="section-title">La Nostra Missione</h2>
    <p class="mission-text">
      Crediamo che ogni persona meriti accesso a cibo, istruzione e opportunit&agrave;.
      La nostra associazione opera sul territorio per sostenere le famiglie in difficolt&agrave;,
      promuovere l'inclusione sociale e costruire percorsi di autonomia che durano nel tempo.
    </p>
  </section>

  <section>
    <h2 class="section-title">I Nostri Progetti</h2>
    <p class="section-sub">Ogni progetto nasce dall'ascolto delle reali esigenze del territorio.</p>
    <div class="projects-grid">
      <div class="project-card">
        <div class="project-img"></div>
        <div class="project-body">
          <h3>Banco Alimentare Solidale</h3>
          <p>Distribuzione settimanale di generi alimentari a oltre 200 famiglie del territorio.</p>
          <div class="progress-bar"><div class="progress-fill" style="width:78%"></div></div>
          <div class="progress-label">78% dell'obiettivo raggiunto</div>
          <a href="#" class="project-link">Scopri di pi&ugrave; &rarr;</a>
        </div>
      </div>
      <div class="project-card">
        <div class="project-img"></div>
        <div class="project-body">
          <h3>Doposcuola per Tutti</h3>
          <p>Supporto scolastico gratuito per bambini e ragazzi delle scuole primarie e medie.</p>
          <div class="progress-bar"><div class="progress-fill" style="width:92%"></div></div>
          <div class="progress-label">92% dell'obiettivo raggiunto</div>
          <a href="#" class="project-link">Scopri di pi&ugrave; &rarr;</a>
        </div>
      </div>
      <div class="project-card">
        <div class="project-img"></div>
        <div class="project-body">
          <h3>Casa Accoglienza</h3>
          <p>Ospitalit&agrave; temporanea per persone senza dimora durante i mesi invernali.</p>
          <div class="progress-bar"><div class="progress-fill" style="width:54%"></div></div>
          <div class="progress-label">54% dell'obiettivo raggiunto</div>
          <a href="#" class="project-link">Scopri di pi&ugrave; &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <section style="background:#fff7ed">
    <h2 class="section-title">Come Puoi Aiutare</h2>
    <p class="section-sub">Ogni gesto conta. Scegli il modo che fa per te.</p>
    <div class="help-grid">
      <div class="help-card">
        <div class="help-icon">&#128147;</div>
        <h3>Dona</h3>
        <p>Anche un piccolo contributo pu&ograve; cambiare la vita di una famiglia. Ogni euro viene investito nei nostri progetti.</p>
      </div>
      <div class="help-card">
        <div class="help-icon">&#129309;</div>
        <h3>Volontariato</h3>
        <p>Unisciti al nostro team di volontari. Bastano poche ore alla settimana per fare la differenza.</p>
      </div>
      <div class="help-card">
        <div class="help-icon">&#128227;</div>
        <h3>Diffondi</h3>
        <p>Condividi la nostra missione sui social e nel tuo quartiere. La consapevolezza &egrave; il primo passo.</p>
      </div>
    </div>
  </section>

  <section class="events-section">
    <h2 class="section-title">Prossimi Eventi</h2>
    <p class="section-sub">Partecipa ai nostri eventi e scopri come contribuire.</p>
    <div class="events-grid">
      <div class="event-card">
        <div class="event-date">
          <span class="day">12</span>
          <span class="month">Apr</span>
        </div>
        <div class="event-info">
          <h3>Cena di Beneficenza</h3>
          <div class="loc">&#128205; Palazzo dei Congressi, Milano</div>
          <a href="#" class="event-btn">Partecipa</a>
        </div>
      </div>
      <div class="event-card">
        <div class="event-date">
          <span class="day">28</span>
          <span class="month">Apr</span>
        </div>
        <div class="event-info">
          <h3>Giornata del Volontariato</h3>
          <div class="loc">&#128205; Parco Sempione, Milano</div>
          <a href="#" class="event-btn">Partecipa</a>
        </div>
      </div>
    </div>
  </section>

  <section class="donate-section">
    <h2 class="section-title">Fai la Tua Donazione</h2>
    <p class="section-sub">Scegli l'importo e contribuisci a un futuro migliore.</p>
    <div class="donate-amounts">
      <button class="donate-amt">&euro;10</button>
      <button class="donate-amt active">&euro;25</button>
      <button class="donate-amt">&euro;50</button>
      <button class="donate-amt">&euro;100</button>
      <button class="donate-amt">Altro</button>
    </div>
    <button class="donate-cta">Dona Ora</button>
  </section>

  <footer class="footer">
    <p><strong>Nome Associazione ODV</strong> &mdash; C.F. 97123456789</p>
    <p>Via della Solidariet&agrave; 15, 20100 Milano (MI)</p>
    <p>Iscrizione RUNTS n. 12345 &mdash; <a href="#">Privacy Policy</a> &mdash; <a href="#">Statuto</a></p>
    <p style="margin-top:12px">&copy; 2026 Nome Associazione. Tutti i diritti riservati.</p>
  </footer>
</body>
</html>
