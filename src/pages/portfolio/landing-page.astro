  <!-- FAQ -->
  <section class="faq">
    <div class="section-header fade-in">
      <h2 class="section-title">Domande <span class="gradient-text">Frequenti</span></h2>
    </div>
    <div class="faq-list">
      <details class="faq-item fade-in" style="--delay:0s">
