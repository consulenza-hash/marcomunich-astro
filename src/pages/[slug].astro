---
/**
 * [slug].astro  — SSR (prerender = false)
 *
 * Legge il file .mdoc direttamente da GitHub raw: l'articolo è online
 * entro pochi secondi dal salvataggio su Keystatic, senza alcun rebuild.
 *
 * Layout: 2 colonne (contenuto + sidebar) — identico all'originale.
 */
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import { fetchArticolo, formatDataIt } from '@lib/articoli';
import { GITHUB_TOKEN } from 'astro:env/server';

// ── Dati del post ─────────────────────────────────────────────────────────────
const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404', 302);

const token = GITHUB_TOKEN;
const art   = await fetchArticolo(slug as string, token ?? undefined);

if (!art) {
  return Astro.redirect('/404', 302);
}

const title    = art.titolo;
const date     = formatDataIt(art.data);
const imageUrl = art.immagine
  ? (String(art.immagine).startsWith('/') ? art.immagine : `/images/articoli/${art.immagine}`)
  : null;

const seoTitle = art.seo_title       || title;
const seoDesc  = art.seo_description || art.descrizione || '';
// BreadcrumbList JSON-LD
const siteUrl = 'https://marcomunich.com';
// og:image richiede URL assoluto; priorità: seo_image dedicata → featured image → fallback OG default
const seoImage = art.seo_image
  ? (art.seo_image.startsWith('http') ? art.seo_image : `${siteUrl}${art.seo_image}`)
  : imageUrl
    ? `${siteUrl}${imageUrl}`
    : `${siteUrl}/og-image.jpg`;
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/`      },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: title,  item: `${siteUrl}/${slug}/` },
  ],
});

// FAQ Schema.org (AEO/GEO)
const faqSchema = art.schema_faq?.length
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: art.schema_faq.map((f) => ({
        '@type': 'Question',
        name: f.domanda,
        acceptedAnswer: { '@type': 'Answer', text: f.risposta },
      })),
    })
  : null;
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  image={seoImage}
  currentPath={`/${slug}/`}
  schemaType="Article"
  datePublished={art.data ?? ''}
  dateModified={art.data ?? ''}
  noIndex={art.seo_noindex}
  canonicalOverride={art.canonical_url}
>
  <!-- Structured data -->
  <script slot="head" type="application/ld+json" set:html={breadcrumbSchema} />
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <!-- ══ HERO articolo ══════════════════════════════════════════════════ -->
  <header class="art-hero">
    <div class="art-hero__inner">
      <nav class="art-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{title}</span>
      </nav>
      <h1 class="art-hero__title">{title}</h1>
      {date && <time class="art-hero__date" datetime={art.data}>Aggiornato il {date}</time>}
    </div>
  </header>

  <article class="article-page">

    <!-- ── Colonna principale ──────────────────────────────────────────── -->
    <div class="article-page__main">

      <!-- Immagine in evidenza -->
      {imageUrl && (
        <figure class="article-page__cover">
          <img
            src={imageUrl}
            alt={title}
            width="780"
            height="440"
            loading="eager"
            decoding="async"
          />
        </figure>
      )}

      <!-- Contenuto dell'articolo -->
      <div class="prose-marcomunich article-page__content">
        <Fragment set:html={art.htmlContent} />
      </div>

      <!-- FAQ (se presenti) -->
      {art.schema_faq?.length ? (
        <div class="article-faq">
          <h2 class="article-faq__title">Domande frequenti</h2>
          {art.schema_faq.map((f) => (
            <details class="article-faq__item">
              <summary class="article-faq__question">{f.domanda}</summary>
              <p class="article-faq__answer">{f.risposta}</p>
            </details>
          ))}
        </div>
      ) : null}

      <!-- Firma autore -->
      <div class="author-box">
        <img
          src="/og/marco-munich.png"
          alt="Marco Munich"
          class="author-box__photo"
          width="90"
          height="90"
          loading="lazy"
        />
        <div class="author-box__content">
          <p class="author-box__name">Marco Munich</p>
          <p class="author-box__bio">
            Ti aiuto a sviluppare un punto di vista autentico per promuoverti online come voce diversa dalle altre.
            Personal Branding Olistico per coach, counselor e operatori olistici.
          </p>
          <a href="https://wa.link/zva8dp" class="author-box__cta" target="_blank" rel="noopener noreferrer">
            Facciamo una chiacchierata →
          </a>
        </div>
      </div>

    </div>

    <!-- ── Sidebar ─────────────────────────────────────────────────────── -->
    <aside class="article-page__sidebar">

      <!-- Social icons -->
      <div class="sidebar-widget sidebar-widget--social">
        <a href="https://www.facebook.com/marcomunich.consulente/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a href="https://www.youtube.com/@marcomunich" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.instagram.com/marcomunich/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="url(#ig-gradient)" aria-hidden="true">
            <defs>
              <linearGradient id="ig-gradient" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%"   stop-color="#f09433"/>
                <stop offset="25%"  stop-color="#e6683c"/>
                <stop offset="50%"  stop-color="#dc2743"/>
                <stop offset="75%"  stop-color="#cc2366"/>
                <stop offset="100%" stop-color="#bc1888"/>
              </linearGradient>
            </defs>
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/marco-munich/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://twitter.com/marcomunich" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#000000" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>

      <!-- Donazione -->
      <div class="sidebar-widget sidebar-widget--donation">
        <p class="sidebar-donation__text">Se quello che pubblico ti ha aiutato in qualche modo, puoi fare una <a href="https://paypal.me/marcomunich83/">donazione qui</a></p>
        <a href="https://paypal.me/marcomunich83/" target="_blank" rel="noopener noreferrer" class="sidebar-donation__link">
          <img
            src="https://www.paypalobjects.com/it_IT/IT/i/btn/btn_donateCC_LG.gif"
            alt="Supporta con una donazione - PayPal"
            width="147"
            height="47"
            loading="lazy"
          />
        </a>
        <p class="sidebar-donation__note">Nel modulo donazione paypal è possibile scrivere un messaggio: mi piacerebbe sapere come ti ha aiutato, direttamente o indirettamente.</p>
      </div>

      <!-- CTA consulenza -->
      <div class="sidebar-widget sidebar-widget--cta">
        <h4>Facciamo una chiacchierata?</h4>
        <p>Se ti senti in linea con quello che penso, forse posso aiutarti a creare contenuto autentico.</p>
        <a href="https://wa.link/zva8dp" class="sidebar-cta-btn">
          Prenota gratis su WhatsApp
        </a>
      </div>

    </aside>
  </article>

</BaseLayout>

<style>
  /* ══ HERO ════════════════════════════════════════════════════════════════ */
  .art-hero {
    background: var(--black);
    padding: 5rem var(--pad) 4rem;
  }
  .art-hero__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .art-breadcrumb {
    font: 400 0.72rem/1 var(--sans);
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .art-breadcrumb a {
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .art-breadcrumb a:hover { color: var(--gold); opacity: 1; }
  .art-breadcrumb span[aria-hidden] { color: rgba(255,255,255,0.15); }
  .art-hero__title {
    font: 800 clamp(2rem, 4.5vw, 3.8rem)/1.1 var(--display);
    color: var(--white);
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .art-hero__date {
    font: 400 0.72rem/1 var(--sans);
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Layout 2 colonne ────────────────────────────────────────────────────── */
  .article-page {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem var(--pad) 6rem;
  }

  /* ── Immagine cover ──────────────────────────────────────────────────────── */
  .article-page__main {
    min-width: 0;
  }
  .article-page__cover {
    margin: 0 0 2.5rem;
  }
  .article-page__cover img {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────────── */
  .article-page__sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* ── Widget sidebar ──────────────────────────────────────────────────────── */
  .sidebar-widget {
    border: 1px solid rgba(10,10,10,0.08);
    padding: 1.5rem;
  }

  .sidebar-widget--social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    border: none;
    padding: 0;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(10,10,10,0.07);
  }
  .sidebar-widget--social a {
    display: flex;
    align-items: center;
    opacity: 0.6;
    transition: opacity 0.15s;
  }
  .sidebar-widget--social a:hover { opacity: 1; }

  .sidebar-donation__text {
    font: 300 0.82rem/1.6 var(--sans);
    color: var(--muted);
    margin-bottom: 1rem;
    text-align: center;
  }
  .sidebar-donation__text a { color: var(--black); }

  .sidebar-donation__link {
    display: flex;
    justify-content: center;
    margin-bottom: 0.75rem;
  }
  .sidebar-donation__link img { display: block; }

  .sidebar-donation__note {
    font: 300 0.72rem/1.5 var(--sans);
    color: var(--muted);
    text-align: center;
  }

  .sidebar-widget--cta {
    background: var(--paper);
    border: none;
  }
  .sidebar-widget--cta h4 {
    font: 300 1.2rem/1.3 var(--serif);
    font-style: italic;
    color: var(--black);
    margin-bottom: 0.75rem;
  }
  .sidebar-widget--cta p {
    font: 300 0.85rem/1.65 var(--sans);
    color: var(--muted);
    margin-bottom: 1.25rem;
  }
  .sidebar-cta-btn {
    display: inline-flex;
    align-items: center;
    font: 700 0.72rem/1 var(--sans);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.85rem 1.5rem;
    background: var(--gold);
    color: var(--white);
    border-radius: 1px;
    transition: background 0.15s, transform 0.12s;
    width: 100%;
    justify-content: center;
  }
  .sidebar-cta-btn:hover { background: var(--gold-d); transform: translateY(-1px); opacity: 1; }

  /* ── Firma autore ────────────────────────────────────────────────────────── */
  .author-box {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-top: 4rem;
    padding-top: 2.5rem;
    border-top: 2px solid var(--gold);
  }

  .author-box__photo {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(100%);
    flex-shrink: 0;
  }

  .author-box__name {
    font: 700 0.9rem/1 var(--sans);
    letter-spacing: 0.04em;
    color: var(--black);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .author-box__bio {
    font: 300 0.85rem/1.65 var(--sans);
    color: var(--muted);
    margin-bottom: 0.85rem;
  }

  .author-box__cta {
    font: 600 0.78rem/1 var(--sans);
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: opacity 0.15s;
  }
  .author-box__cta:hover { opacity: 0.75; }

  /* ── FAQ ─────────────────────────────────────────────────────────────────── */
  .article-faq {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(10,10,10,0.08);
  }
  .article-faq__title {
    font: 300 1.5rem/1.2 var(--serif);
    font-style: italic;
    color: var(--black);
    margin-bottom: 1.5rem;
  }
  .article-faq__item {
    border-bottom: 1px solid rgba(10,10,10,0.07);
    padding: 1rem 0;
  }
  .article-faq__question {
    font: 600 0.92rem/1.5 var(--sans);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: var(--black);
  }
  .article-faq__question::-webkit-details-marker { display: none; }
  .article-faq__question::after { content: '+'; font-size: 1.25rem; flex-shrink: 0; color: var(--gold); }
  details[open] .article-faq__question::after { content: '−'; }
  .article-faq__answer {
    font: 300 0.88rem/1.7 var(--sans);
    color: var(--muted);
    margin-top: 0.75rem;
  }

  /* ── Tabelle negli articoli ──────────────────────────────────────────────── */
  .article-page__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font: 300 0.88rem/1.5 var(--sans);
    overflow-x: auto;
    display: block;
  }
  .article-page__content :global(table.has-fixed-layout) {
    display: table;
    table-layout: fixed;
  }
  .article-page__content :global(thead) {
    background-color: var(--black);
    color: var(--white);
  }
  .article-page__content :global(th) {
    padding: 0.65rem 1rem;
    text-align: left;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    border: 1px solid var(--black);
  }
  .article-page__content :global(td) {
    padding: 0.6rem 1rem;
    border: 1px solid rgba(10,10,10,0.1);
    vertical-align: top;
  }
  .article-page__content :global(tbody tr:nth-child(even)) {
    background-color: var(--paper);
  }
  .article-page__content :global(tbody tr:hover) {
    background-color: #EDEAE3;
  }
  @media (max-width: 680px) {
    .article-page__content :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .article-page {
      grid-template-columns: 1fr;
    }
    .article-page__sidebar {
      border-top: 1px solid rgba(10,10,10,0.07);
      padding-top: 2rem;
    }
  }
</style>
