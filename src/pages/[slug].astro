---
/**
 * [slug].astro  — Static (prerender = true)
 *
 * Legge il file .mdoc direttamente da GitHub raw: l'articolo è online
 * entro pochi secondi dal salvataggio su Keystatic, senza alcun rebuild.
 */
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import jsYaml from 'js-yaml';
import Markdoc from '@markdoc/markdoc';

// ── getStaticPaths ──────────────────────────────────────────────────────────
export async function getStaticPaths() {
  const rawFiles = import.meta.glob('/src/content/articoli/*/index.mdoc', {
    eager: true,
    as: 'raw',
  }) as Record<string, string>;

  return Object.entries(rawFiles)
    .filter(([_, content]) => {
      // Filter out bozze and files without valid frontmatter
      const fmMatch = content.match(/^---\r?\n([\s\S]*?)\r?\n---/);
      if (!fmMatch) return false;
      const fmStr = fmMatch[1];
      return !/^bozza:\s*true/m.test(fmStr);
    })
    .map(([filePath, content]) => {
      const slug = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
      return { params: { slug }, props: { rawContent: content } };
    });
}

const { slug } = Astro.params;
const { rawContent } = Astro.props;

const seoTitle = art.seo_title       || title;
const seoDesc  = art.seo_description || art.descrizione || '';
const siteUrl  = 'https://marcomunich.com';
const seoImage = art.seo_image
  ? (art.seo_image.startsWith('http') ? art.seo_image : `${siteUrl}${art.seo_image}`)
  : imageUrl
    ? `${siteUrl}${imageUrl}`
    : `${siteUrl}/og-image.jpg`;

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/`      },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
    { '@type': 'ListItem', position: 3, name: title,  item: `${siteUrl}/${slug}/` },
  ],
});

const faqSchema = art.schema_faq?.length
  ? JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: fm.schema_faq.map((f: any) => ({
        '@type': 'Question',
        name: f.domanda,
        acceptedAnswer: { '@type': 'Answer', text: f.risposta },
      })),
    })
  : null;
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  image={seoImage}
  currentPath={`/${slug}/`}
  schemaType="Article"
  datePublished={fm.data ?? ''}
  dateModified={fm.data ?? ''}
  noIndex={fm.seo_noindex}
  canonicalOverride={fm.canonical_url}
>
  <script slot="head" type="application/ld+json" set:html={breadcrumbSchema} />
  {faqSchema && <script slot="head" type="application/ld+json" set:html={faqSchema} />}

  <!-- HERO ARTICOLO -->
  <header class="art-hero">
    <div class="art-hero__inner">
      <nav class="art-breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        <span aria-hidden="true">/</span>
        <span>{title}</span>
      </nav>
      <h1 class="art-hero__title">{title}</h1>
      {date && <time class="art-hero__date" datetime={fm.data}>Aggiornato il {date}</time>}
    </div>
  </header>

  <!-- LAYOUT ARTICOLO -->
  <div class="art-layout">

    <!-- Colonna principale -->
    <main class="art-main">

      {imageUrl && (
        <figure class="art-cover">
          <img
            src={imageUrl}
            alt={title}
            width="780"
            height="440"
            loading="eager"
            decoding="async"
          />
        </figure>
      )}

      <div class="prose-marcomunich art-content">
        <Fragment set:html={art.htmlContent} />
      </div>

      <!-- FAQ -->
      {art.schema_faq?.length ? (
        <div class="art-faq">
          <h2 class="art-faq__title">Domande frequenti</h2>
          {art.schema_faq.map((f) => (
            <details class="art-faq__item">
              <summary class="art-faq__q">{f.domanda}</summary>
              <p class="art-faq__a">{f.risposta}</p>
            </details>
          ))}
        </div>
      ) : null}

      <!-- Firma autore -->
      <div class="art-author">
        <img
          src="/og/marco-munich.png"
          alt="Marco Munich"
          class="art-author__photo"
          width="72"
          height="72"
          loading="lazy"
        />
        <div class="art-author__body">
          <p class="art-author__name">Marco Munich</p>
          <p class="art-author__bio">
            Personal branding olistico per coach, counselor e operatori olistici. Sette anni nel settore, oltre duecento articoli, decine di professionisti seguiti.
          </p>
          <a href="https://wa.link/zva8dp" class="art-author__cta" target="_blank" rel="noopener noreferrer">
            Facciamo una chiacchierata →
          </a>
        </div>
      </div>

    </main>

    <!-- Sidebar -->
    <aside class="art-sidebar">

      <!-- Social -->
      <div class="art-sidebar__social">
        <a href="https://www.facebook.com/marcomunich.consulente/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a href="https://www.youtube.com/@marcomunich" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.instagram.com/marcomun1ch/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/marco-munich/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>

      <!-- Donazione -->
      <div class="art-sidebar__widget">
        <p class="art-sidebar__widget-text">Se quello che pubblico ti ha aiutato, puoi fare una <a href="https://paypal.me/marcomunich83/" target="_blank" rel="noopener noreferrer">donazione qui</a>.</p>
        <a href="https://paypal.me/marcomunich83/" target="_blank" rel="noopener noreferrer">
          <img
            src="https://marcomunich.com/wp-content/uploads/2025/02/1522570276.png"
            alt="Supporta con una donazione - PayPal"
            width="200"
            height="56"
            loading="lazy"
            style="display:block;margin:0.75rem auto 0;"
          />
        </a>
      </div>

      <!-- CTA consulenza -->
      <div class="art-sidebar__cta">
        <p class="art-sidebar__cta-title">Vuoi parlarne?</p>
        <p class="art-sidebar__cta-text">Se ti senti in linea con quello che scrivo, posso aiutarti a costruire la tua presenza online.</p>
        <a href="https://wa.link/zva8dp" class="art-sidebar__cta-btn" target="_blank" rel="noopener noreferrer">
          Chiacchierata gratuita su WhatsApp
        </a>
      </div>

    </aside>

  </div>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .art-hero {
    background: #0d0d0d;
    padding: 7rem 2rem 4rem;
  }
  .art-hero__inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .art-breadcrumb {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .art-breadcrumb a {
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.15s;
  }
  .art-breadcrumb a:hover { color: #e85d00; opacity: 1; }
  .art-breadcrumb span[aria-hidden] { color: rgba(255,255,255,0.15); }
  .art-hero__title {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(1.8rem, 4vw, 3.2rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: #fff;
    margin-bottom: 1rem;
  }
  .art-hero__date {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── Layout 2 colonne ──────────────────────────────────────────────────── */
  .art-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 4rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 3.5rem 2rem 6rem;
    background: #fff;
  }

  /* ── Main ──────────────────────────────────────────────────────────────── */
  .art-main { min-width: 0; }
  .art-cover { margin: 0 0 2.5rem; }
  .art-cover img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 2px;
  }

  /* ── FAQ ───────────────────────────────────────────────────────────────── */
  .art-faq {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }
  .art-faq__title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    color: #0d0d0d;
    letter-spacing: -0.01em;
    margin-bottom: 1.2rem;
  }
  .art-faq__item {
    border-bottom: 1px solid #eee;
    padding: 0.9rem 0;
  }
  .art-faq__q {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: #0d0d0d;
  }
  .art-faq__q::-webkit-details-marker { display: none; }
  .art-faq__q::after { content: '+'; font-size: 1.1rem; flex-shrink: 0; color: #e85d00; }
  details[open] .art-faq__q::after { content: '−'; }
  .art-faq__a {
    font-size: 0.85rem;
    line-height: 1.75;
    color: #666;
    margin-top: 0.65rem;
  }

  /* ── Autore ────────────────────────────────────────────────────────────── */
  .art-author {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid #e85d00;
  }
  .art-author__photo {
    width: 72px;
    height: 72px;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(20%);
    flex-shrink: 0;
  }
  .art-author__name {
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #0d0d0d;
    margin-bottom: 0.4rem;
  }
  .art-author__bio {
    font-size: 0.82rem;
    line-height: 1.65;
    color: #666;
    margin-bottom: 0.7rem;
  }
  .art-author__cta {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: #e85d00;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .art-author__cta:hover { opacity: 0.75; }

  /* ── Sidebar ───────────────────────────────────────────────────────────── */
  .art-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .art-sidebar__social {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }
  .art-sidebar__social a {
    display: flex;
    align-items: center;
    opacity: 0.65;
    transition: opacity 0.15s;
  }
  .art-sidebar__social a:hover { opacity: 1; }
  .art-sidebar__widget {
    border: 1px solid #eee;
    padding: 1.25rem;
    border-radius: 4px;
  }
  .art-sidebar__widget-text {
    font-size: 0.8rem;
    line-height: 1.65;
    color: #666;
    text-align: center;
  }
  .art-sidebar__widget-text a { color: #0d0d0d; }
  .art-sidebar__cta {
    background: #f5f5f5;
    padding: 1.5rem;
    border-radius: 4px;
  }
  .art-sidebar__cta-title {
    font-family: 'Inter', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: #0d0d0d;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }
  .art-sidebar__cta-text {
    font-size: 0.82rem;
    line-height: 1.65;
    color: #666;
    margin-bottom: 1rem;
  }
  .art-sidebar__cta-btn {
    display: block;
    background: #25d366;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    text-align: center;
    padding: 0.75rem 1rem;
    border-radius: 50px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .art-sidebar__cta-btn:hover { background: #1fb959; opacity: 1; }

  /* Tabelle negli articoli */
  .art-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.88rem;
    overflow-x: auto;
    display: block;
  }
  .art-content :global(table.has-fixed-layout) {
    display: table;
    table-layout: fixed;
  }
  .art-content :global(thead) { background-color: #0d0d0d; color: #fff; }
  .art-content :global(th) {
    padding: 0.65rem 1rem;
    text-align: left;
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    border: 1px solid #0d0d0d;
  }
  .art-content :global(td) {
    padding: 0.6rem 1rem;
    border: 1px solid rgba(10,10,10,0.1);
    vertical-align: top;
  }
  .art-content :global(tbody tr:nth-child(even)) { background-color: #f9f9f9; }
  .art-content :global(tbody tr:hover) { background-color: #f0f0f0; }
  @media (max-width: 680px) {
    .art-content :global(table) { display: block; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .art-layout {
      grid-template-columns: 1fr;
      padding: 2.5rem 1.5rem 4rem;
    }
    .art-sidebar {
      border-top: 1px solid #eee;
      padding-top: 2rem;
    }
  }
</style>
