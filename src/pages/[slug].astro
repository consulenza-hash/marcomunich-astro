---
/**
 * [slug].astro
 * Pagina dinamica per ogni articolo del blog.
 * Genera una pagina statica per ciascun articolo preso dalla WP REST API.
 *
 * Layout: 2 colonne (contenuto + sidebar) — identico all'originale.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import {
  getAllPosts,
  getRelatedPosts,
  getFeaturedImageUrl,
  getPrimaryCategory,
  formatDate,
} from '@lib/wordpress';

// ── Generazione pagine statiche ───────────────────────────────────────────────
export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

// ── Dati del post corrente ────────────────────────────────────────────────────
const { post } = Astro.props;

const title       = post.title?.rendered ?? '';
const content     = post.content?.rendered ?? '';
const excerpt     = post.excerpt?.rendered ?? '';
const date        = formatDate(post.date);
const imageUrl    = getFeaturedImageUrl(post, 'large');
const category    = getPrimaryCategory(post);
const tags        = post._embedded?.['wp:term']?.[1] ?? [];

// Articoli correlati (stessa categoria)
const related = await getRelatedPosts(post.id, post.categories ?? [], 3);

// Meta SEO (Rank Math esporta questi campi, altrimenti usiamo excerpt)
const seoTitle = post.yoast_head_json?.title ?? title;
const seoDesc  = post.yoast_head_json?.description
              ?? post.excerpt?.rendered?.replace(/<[^>]+>/g, '').slice(0, 160)
              ?? '';
const seoImage = post.yoast_head_json?.og_image?.[0]?.url ?? imageUrl ?? '';
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  image={seoImage}
  currentPath={`/${post.slug}/`}
>

  <article class="article-page">

    <!-- ── Colonna principale ──────────────────────────────────────────── -->
    <div class="article-page__main">

      <!-- Breadcrumb -->
      <nav class="breadcrumb mb-4" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog/">Blog</a>
        {category && (
          <>
            <span aria-hidden="true">/</span>
            <a href={`/categoria/${category.slug}/`}>{category.name}</a>
          </>
        )}
      </nav>

      <!-- Titolo -->
      <h1 class="article-page__title">
        <Fragment set:html={title} />
      </h1>

      <!-- Meta: data + tag -->
      <div class="article-page__meta">
        <span>Ultimo aggiornamento il {date}</span>
        {tags.length > 0 && (
          <span class="article-page__tags">
            Tag:{' '}
            {tags.map((tag, i) => (
              <span>
                <a href={`/tag/${tag.slug}/`}>{tag.name}</a>
                {i < tags.length - 1 ? ', ' : ''}
              </span>
            ))}
          </span>
        )}
      </div>

      <!-- Player audio TTS (MeMentor) — nascosto via JS se il file non esiste -->
      <div class="tts-player" id={`tts-${post.id}`}>
        <span class="tts-player__label">Ascolta l'articolo:</span>
        <audio
          controls
          preload="metadata"
          class="tts-player__audio"
        >
          <source src={`https://marcomunich.com/wp-content/uploads/text-to-speech-tts/mementor-${post.id}-it.mp3`} type="audio/mpeg" />
        </audio>
      </div>
      <script define:vars={{ postId: post.id }}>
        // Nasconde il player se l'MP3 non esiste per questo articolo
        const wrapper = document.getElementById('tts-' + postId);
        if (wrapper) {
          const audio = wrapper.querySelector('audio');
          if (audio) {
            audio.addEventListener('error', () => {
              wrapper.style.display = 'none';
            });
            const source = audio.querySelector('source');
            if (source) {
              source.addEventListener('error', () => {
                wrapper.style.display = 'none';
              });
            }
          }
        }
      </script>

      <!-- Immagine in evidenza -->
      {imageUrl && (
        <figure class="article-page__cover">
          <img
            src={imageUrl}
            alt={title}
            width="780"
            height="440"
            loading="eager"
            decoding="async"
          />
        </figure>
      )}

      <!-- Contenuto dell'articolo -->
      <div class="prose-marcomunich article-page__content">
        <Fragment set:html={content} />
      </div>

      <!-- Firma autore -->
      <div class="author-box">
        <img
          src="https://marcomunich.com/wp-content/uploads/2020/09/119536256_3677336615611976_7436592590631298239_n.jpg"
          alt="Marco Munich"
          class="author-box__photo"
          width="90"
          height="90"
          loading="lazy"
        />
        <div class="author-box__content">
          <p class="author-box__name">Marco Munich</p>
          <p class="author-box__bio">
            Ti aiuto a sviluppare un punto di vista autentico per promuoverti online come voce diversa dalle altre.
            Personal Branding Olistico per coach, counselor e operatori olistici.
          </p>
          <a href="https://wa.link/zva8dp" class="author-box__cta" target="_blank" rel="noopener noreferrer">
            Facciamo una chiacchierata →
          </a>
        </div>
      </div>

    </div>

    <!-- ── Sidebar ─────────────────────────────────────────────────────── -->
    <aside class="article-page__sidebar">

      <!-- Social icons -->
      <div class="sidebar-widget sidebar-widget--social">
        <a href="https://www.facebook.com/marcomunich.consulente/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#1877F2" aria-hidden="true"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
        <a href="https://www.youtube.com/@marcomunich" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#FF0000" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <a href="https://www.instagram.com/marcomunich/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="url(#ig-gradient)" aria-hidden="true">
            <defs>
              <linearGradient id="ig-gradient" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#f09433"/>
                <stop offset="25%" stop-color="#e6683c"/>
                <stop offset="50%" stop-color="#dc2743"/>
                <stop offset="75%" stop-color="#cc2366"/>
                <stop offset="100%" stop-color="#bc1888"/>
              </linearGradient>
            </defs>
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/marco-munich/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#0A66C2" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://twitter.com/marcomunich" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="#000000" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>

      <!-- Donazione -->
      <div class="sidebar-widget sidebar-widget--donation">
        <p class="sidebar-donation__text">Se quello che pubblico ti ha aiutato in qualche modo, puoi fare una <a href="https://paypal.me/marcomunich83/">donazione qui</a></p>
        <a href="https://paypal.me/marcomunich83/" target="_blank" rel="noopener noreferrer" class="sidebar-donation__link">
          <img
            src="https://marcomunich.com/wp-content/uploads/2025/02/1522570276.png"
            alt="Supporta con una donazione - PayPal"
            width="331"
            height="92"
            loading="lazy"
          />
        </a>
        <p class="sidebar-donation__note">Nel modulo donazione paypal è possibile scrivere un messaggio: mi piacerebbe sapere come ti ha aiutato, direttamente o indirettamente.</p>
      </div>

      <!-- CTA consulenza -->
      <div class="sidebar-widget sidebar-widget--cta">
        <h4>Facciamo una Chiacchierata?</h4>
        <p>Se ti senti in linea con quello che penso, forse posso aiutarti a creare contenuto autentico.</p>
        <a href="https://wa.link/zva8dp" class="btn-primary mt-4 block text-center">
          PRENOTA UNA CONSULENZA GRATUITA
        </a>
      </div>

      <!-- Articoli correlati -->
      {related.length > 0 && (
        <div class="sidebar-widget--related">
          <h4 class="sidebar-widget__title">Ti può interessare anche:</h4>
          <ul class="sidebar-related__list">
            {related.map((relPost) => {
              const relImg = getFeaturedImageUrl(relPost, 'thumbnail');
              return (
                <li class="sidebar-related__item">
                  {relImg && (
                    <a href={`/${relPost.slug}/`} tabindex="-1" aria-hidden="true">
                      <img src={relImg} alt={relPost.title?.rendered} width="80" height="60" loading="lazy" />
                    </a>
                  )}
                  <div>
                    <a href={`/${relPost.slug}/`} class="sidebar-related__link">
                      <Fragment set:html={relPost.title?.rendered} />
                    </a>
                    <a href={`/${relPost.slug}/`} class="sidebar-related__read">Leggi l'articolo</a>
                  </div>
                </li>
              );
            })}
          </ul>
        </div>
      )}

    </aside>
  </article>

</BaseLayout>

<style>
  /* ── Layout 2 colonne ────────────────────────────────────────────────────── */
  .article-page {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  /* ── Titolo ──────────────────────────────────────────────────────────────── */
  .article-page__title {
    font-size: clamp(26px, 4vw, 40px);
    font-weight: 800;
    line-height: 1.15;
    color: #0A0A0A;
    margin: 12px 0 16px;
  }

  /* ── Meta ────────────────────────────────────────────────────────────────── */
  .article-page__meta {
    font-size: 12px;
    color: rgba(10,10,10,0.5);
    margin-bottom: 24px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .article-page__meta a { color: inherit; }

  /* ── Immagine cover ──────────────────────────────────────────────────────── */
  .article-page__cover {
    margin: 0 0 32px;
  }
  .article-page__cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Sidebar ─────────────────────────────────────────────────────────────── */
  .article-page__sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: 80px; /* allinea con il contenuto sotto titolo */
  }

  /* ── Widget sidebar ──────────────────────────────────────────────────────── */
  .sidebar-widget {
    border: 1px solid #E5E5E5;
    padding: 20px;
  }

  .sidebar-widget--social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
    border: none;
    padding: 0;
  }
  .sidebar-widget--social a {
    display: flex;
    align-items: center;
    opacity: 0.85;
    transition: opacity 0.15s;
  }
  .sidebar-widget--social a:hover { opacity: 1; }

  .sidebar-donation__text {
    font-size: 13px;
    line-height: 1.5;
    margin-bottom: 12px;
    text-align: center;
  }
  .sidebar-donation__text a { color: #0A0A0A; }

  .sidebar-donation__link {
    display: flex;
    justify-content: center;
    margin-bottom: 12px;
  }
  .sidebar-donation__link img { display: block; }

  .sidebar-donation__note {
    font-size: 11px;
    line-height: 1.5;
    color: rgba(10,10,10,0.55);
    text-align: center;
    margin-top: 8px;
  }

  .sidebar-widget--cta h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .sidebar-widget--cta p {
    font-size: 13px;
    line-height: 1.5;
    color: rgba(10,10,10,0.7);
  }

  /* ── Firma autore ────────────────────────────────────────────────────────── */
  .author-box {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 2px solid #0A0A0A;
  }

  .author-box__photo {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(100%);
    flex-shrink: 0;
  }

  .author-box__name {
    font-size: 16px;
    font-weight: 700;
    color: #0A0A0A;
    margin-bottom: 6px;
  }

  .author-box__bio {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(10,10,10,0.7);
    margin-bottom: 12px;
  }

  .author-box__cta {
    font-size: 13px;
    font-weight: 700;
    color: #0A0A0A;
    text-decoration: underline;
    text-underline-offset: 3px;
    letter-spacing: 0.03em;
  }

  .sidebar-widget__title {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 16px;
    border-bottom: 2px solid #0A0A0A;
    padding-bottom: 8px;
  }

  .sidebar-related__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sidebar-related__item {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .sidebar-related__item img {
    width: 70px !important;
    min-width: 70px;
    height: 70px !important;
    object-fit: cover;
    flex-shrink: 0;
  }
  .sidebar-related__link {
    font-size: 13px;
    font-weight: 600;
    line-height: 1.4;
    color: #0A0A0A;
    text-decoration: none;
    display: block;
    margin-bottom: 4px;
  }
  .sidebar-related__link:hover { opacity: 0.7; }
  .sidebar-related__read {
    font-size: 11px;
    color: rgba(10,10,10,0.5);
    text-decoration: underline;
  }

  /* ── Player audio TTS ───────────────────────────────────────────────────── */
  .tts-player {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 16px 0 24px;
    padding: 12px 16px;
    background: #F5F5F5;
    border-left: 3px solid #0A0A0A;
  }
  .tts-player__label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(10,10,10,0.55);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .tts-player__audio {
    width: 100%;
    height: 32px;
  }
  @media (max-width: 600px) {
    .tts-player { flex-direction: column; align-items: flex-start; }
    .tts-player__audio { width: 100%; }
  }

  /* ── Tabelle negli articoli ──────────────────────────────────────────────── */
  .article-page__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 28px 0;
    font-size: 14px;
    line-height: 1.5;
    overflow-x: auto;
    display: block;
  }
  .article-page__content :global(table.has-fixed-layout) {
    display: table;
    table-layout: fixed;
  }
  .article-page__content :global(thead) {
    background-color: #0A0A0A;
    color: #fff;
  }
  .article-page__content :global(th) {
    padding: 10px 14px;
    text-align: left;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.03em;
    border: 1px solid #0A0A0A;
  }
  .article-page__content :global(td) {
    padding: 9px 14px;
    border: 1px solid #E0E0E0;
    vertical-align: top;
  }
  .article-page__content :global(tbody tr:nth-child(even)) {
    background-color: #F9F9F9;
  }
  .article-page__content :global(tbody tr:hover) {
    background-color: #F2F2F2;
  }
  /* Wrap tabelle su mobile */
  @media (max-width: 680px) {
    .article-page__content :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .article-page {
      grid-template-columns: 1fr;
    }
    .article-page__sidebar {
      padding-top: 0;
      border-top: 1px solid #E5E5E5;
      padding-top: 32px;
    }
  }
</style>
