<script>
  const consentCheck = document.getElementById('pp-consent-check') as HTMLInputElement | null;
  const newsletterCheck = document.getElementById('pp-newsletter-check') as HTMLInputElement | null;
  const btn = document.getElementById('pp-buy-btn') as HTMLAnchorElement | null;

  function updateBtn() {
    if (!btn) return;
    const enabled = consentCheck?.checked ?? false;
    if (enabled) {
      btn.classList.remove('pp-price-box__btn--disabled');
      btn.removeAttribute('aria-disabled');
    } else {
      btn.classList.add('pp-price-box__btn--disabled');
      btn.setAttribute('aria-disabled', 'true');
    }
    // Aggiunge ?newsletter=1 all'href se newsletter spuntata
    const base = '/api/prompt-pack/checkout';
    btn.href = newsletterCheck?.checked ? `${base}?newsletter=1` : base;
  }

  consentCheck?.addEventListener('change', updateBtn);
  newsletterCheck?.addEventListener('change', updateBtn);
</script>

