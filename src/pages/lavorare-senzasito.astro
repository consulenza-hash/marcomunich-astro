---
import BaseLayout from '@layouts/BaseLayout.astro';

const steps = [
  {
    n: "1",
    title: "Vedremo insieme quanto è facile installare le piattaforme",
    text: "Magari hai una certa età e hai sempre visto i social e i mezzi tecnologici come complicati da utilizzare. In questa guida è spiegato tutto in modo molto semplice."
  },
  {
    n: "2",
    title: "Scopriremo le due metodologie di impatto nel pubblico e lo sforzo che serve",
    text: "Senza conoscere le due metodologie di impatto, si rischia di non sapere a quale tipo di sforzo si va incontro. Andiamo a capire questo prima di iniziare a mettere in pratica tutto."
  },
  {
    n: "3",
    title: "La mappa di quello che va fatto e il \"tragitto\" che il pubblico fa naturalmente",
    text: "Ti mostrerò esattamente quello che ho costruito io, senza particolari difficoltà — per agevolare il passaggio da potenziale cliente a cliente, senza funnel e cose complicate."
  },
  {
    n: "4",
    title: "Un elenco completo di tutti gli strumenti che utilizzo io stesso",
    text: "Quasi tutti gli strumenti sono gratuiti, tranne qualcuno con un costo veramente basso che ti permetterà di abbattere molto del lavoro, dei costi e dello sforzo."
  },
];

const ideals = [
  { title: "Sei sempre stato negato con i computer", text: "Non ti sei mai sentito in grado di gestire nulla di complicato e desideri iniziare a mettere in piedi qualcosa che lavori per te, non contro di te." },
  { title: "Vuoi prepararti per il lavoro da remoto", text: "Molti si sono informati su come lavorare online senza il contatto fisico. In questo percorso ti spiego come mettere in piedi tutto facilmente." },
  { title: "Hai già visto come lavoro e vuoi gli stessi strumenti", text: "Dentro il videocorso trovi un elenco completo di tutti gli strumenti che utilizzo, con consigli e possibilità di farmi domande." },
  { title: "Non hai voglia di impegnarti troppo", text: "È solo richiesto un impegno iniziale per impostare tutto. Poi funziona da sé e ti servirà il minimo sforzo." },
];
---

<BaseLayout
  title="Iniziare a Lavorare Senza sito Web - Marco Munich"
  description="Mini percorso per Coach, Counselor e Terapeuti. Due ore di lezione per iniziare a lavorare subito senza bisogno di un sito web."
  currentPath="/lavorare-senzasito/"
>

<style is:global>
  .green-page .btn-green {
    display: inline-block;
    background: #16A34A;
    color: #fff;
    padding: 16px 36px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    letter-spacing: .5px;
    transition: background .2s;
  }
  .green-page .btn-green:hover { background: #166534; opacity: 1; }

  .green-page .btn-outline-green {
    display: inline-block;
    background: transparent;
    color: #16A34A;
    padding: 14px 32px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    border: 2px solid #16A34A;
    transition: all .2s;
  }
  .green-page .btn-outline-green:hover { background: #16A34A; color: #fff; opacity: 1; }

  .green-page .step-item { display: flex; gap: 20px; align-items: flex-start; padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .green-page .step-item:last-child { border: none; }

  .green-page { overflow-x: hidden; }

  @media (max-width: 768px) {
    /* Grid 2-col → 1 col */
    .green-page .hero-grid,
    .green-page .two-col {
      display: block !important;
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    .green-page .hero-grid > *,
    .green-page .two-col > * {
      width: 100% !important;
      max-width: 100% !important;
      margin-bottom: 32px;
    }
    .green-page .hero-grid > *:last-child,
    .green-page .two-col > *:last-child { margin-bottom: 0; }

    /* Nasconde video hero */
    .green-page .hero-image {
      display: none !important;
      visibility: hidden !important;
    }

    /* Pricing */
    .green-page .costs-grid {
      display: block !important;
      grid-template-columns: 1fr !important;
      max-width: 520px !important;
      margin-left: auto !important;
      margin-right: auto !important;
    }
    .green-page .costs-grid > * {
      width: 100% !important;
      margin-bottom: 24px;
    }
    .green-page .costs-grid > *:last-child { margin-bottom: 0; }
    .green-page .cost-card-featured { margin-top: 20px !important; }

    /* Padding sezioni */
    .green-page section {
      padding-top: 48px !important;
      padding-bottom: 48px !important;
    }
  }
</style>

<div class="green-page">

<!-- ── HERO ──────────────────────────────────────────────────────────────── -->
<section style="background: #052e1a; color: #fff; padding: 80px 24px 0;">
  <div class="hero-grid" style="max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">

    <!-- Testo -->
    <div>
      <div style="display: inline-flex; align-items: center; gap: 8px; background: rgba(22,163,74,.15); border: 1px solid rgba(22,163,74,.4); color: #86efac; padding: 6px 14px; border-radius: 100px; font-size: 13px; font-weight: 700; letter-spacing: 2px; margin-bottom: 16px;">
        ★ MINI PERCORSO
      </div>
      <p style="font-size: 14px; color: #86efac; font-weight: 600; margin-bottom: 8px; letter-spacing: .5px;">Per Coach, Counselor e Terapeuti</p>
      <h1 style="font-size: clamp(34px, 4.5vw, 52px); font-weight: 800; line-height: 1.1; color: #fff; margin-bottom: 20px;">
        Iniziare a Lavorare<br><span style="color: #16A34A;">Senza sito Web</span>
      </h1>
      <p style="font-size: 17px; line-height: 1.7; color: #bbb; margin-bottom: 36px;">
        <strong style="color:#fff;">Due ore di lezione</strong> dove scopriamo tutto ciò che serve
        ad un Counselor, Coach o Terapeuta per <strong style="color:#fff;">iniziare a lavorare subito</strong>
        — preoccupandosi solo di creare contenuti e gestire il proprio lavoro.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <a href="#programma" class="btn-green">Scopri il programma →</a>
        <a href="#costi" class="btn-outline-green">Costi e informazioni</a>
      </div>
    </div>

    <!-- Video Hero -->
    <div class="hero-image" style="padding-bottom: 48px;">
      <div style="border-radius: 12px; overflow: hidden; aspect-ratio: 16/10; background: #064e29; position: relative;">
        <iframe
          src="https://www.youtube-nocookie.com/embed/lo1Ji3OkYCg?rel=0&modestbranding=1"
          title="Iniziare a Lavorare Senza sito Web"
          frameborder="0"
          allowfullscreen
          loading="eager"
          style="position:absolute; top:0; left:0; width:100%; height:100%;"
        ></iframe>
      </div>
    </div>

  </div>

  <!-- Striscia statistiche -->
  <div style="max-width:1100px; margin:48px auto 0; display:flex; gap:32px; flex-wrap:wrap; padding-bottom:40px; border-top:1px solid rgba(255,255,255,.07); padding-top:32px;">
    {[
      { n: "2", label: "Video lezioni" },
      { n: "~2h", label: "di contenuto" },
      { n: "1", label: "Risorsa con tutti i link" },
      { n: "0€", label: "Costo base (gratuito su YouTube)" },
    ].map(s => (
      <div>
        <p style="font-size:32px; font-weight:800; color:#16A34A; margin:0; line-height:1;">{s.n}</p>
        <p style="font-size:13px; color:#888; margin:4px 0 0; letter-spacing:.5px;">{s.label}</p>
      </div>
    ))}
  </div>
</section>

<!-- ── SCARICARE IL LAVORO ────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #fff;">
  <div class="two-col" style="max-width: 1080px; margin: 0 auto; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
    <div>
      <p style="color:#16A34A; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Il vantaggio</p>
      <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:16px;">Scaricare gran parte del lavoro</h2>
      <p style="color:#555; font-size:16px; line-height:1.8; margin-bottom:16px;">
        Ricordarsi l'appuntamento e ricordarlo al cliente, <strong>mandargli gli estremi di pagamento</strong>,
        fare loro delle domande pre-appuntamento per capire di cosa hanno bisogno…
      </p>
      <p style="color:#555; font-size:16px; line-height:1.8;">
        Tutte queste sono informazioni che di solito chiediamo a mano. In questo mini corso
        vediamo tutto quello che serve per lavorare senza il sito web — abbiamo solo bisogno
        dei social e degli strumenti che trovi nelle lezioni.
      </p>
    </div>
    <div style="border-radius:12px; overflow:hidden; aspect-ratio:16/10; background:#f0fdf4; position:relative;">
      <img
        src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=700&q=80&fit=crop"
        alt="Coach o counselor che lavora comodamente dal proprio ufficio senza sito web"
        style="width:100%; height:100%; object-fit:cover; display:block;"
        loading="lazy"
      />
      <div style="position:absolute; bottom:0; left:0; right:0; background:linear-gradient(transparent,rgba(5,46,26,.85)); padding:20px 24px;">
        <p style="color:#86efac; font-size:13px; font-style:italic; margin:0;">"Non serve un sito web per iniziare. Serve solo il sistema giusto."</p>
      </div>
    </div>
  </div>
</section>

<!-- ── DI COSA PARLEREMO ──────────────────────────────────────────────── -->
<section id="programma" style="padding: 80px 24px; background: #064e29;">
  <div style="max-width:1000px; margin:0 auto;">
    <p style="color:#86efac; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:12px;">Il programma</p>
    <h2 style="font-size:clamp(26px,3vw,38px); font-weight:800; color:#fff; margin-bottom:12px;">Di cosa parleremo nel Corso</h2>
    <p style="color:#aaa; margin-bottom:48px; font-size:16px;">Prenotazione e pagamento degli appuntamenti, grafiche, creazione degli articoli e strumenti di base da utilizzare.</p>
    <div>
      {steps.map(s => (
        <div class="step-item">
          <div style="flex-shrink:0; width:44px; height:44px; background:#16A34A; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:20px; font-weight:900; color:#fff;">{s.n}</div>
          <div>
            <h4 style="font-size:16px; font-weight:700; color:#fff; margin-bottom:8px;">{s.title}</h4>
            <p style="color:#aaa; font-size:15px; line-height:1.6; margin:0;">{s.text}</p>
          </div>
        </div>
      ))}
    </div>
    <div style="text-align:center; margin-top:48px;">
      <a href="#costi" class="btn-green">Ok, voglio sapere il costo →</a>
    </div>
  </div>
</section>

<!-- ── È IDEALE PER TE SE ─────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #f0fdf4;">
  <div style="max-width:1000px; margin:0 auto;">
    <h2 style="text-align:center; font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:48px;">È ideale per te <span style="color:#16A34A;">SE:</span></h2>
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px,1fr)); gap:20px;">
      {ideals.map((item, i) => (
        <div style="background:#fff; border-radius:8px; padding:28px; position:relative; overflow:hidden; border-top:3px solid #16A34A;">
          <div style="font-size:42px; font-weight:900; color:rgba(22,163,74,.08); position:absolute; top:8px; right:16px; line-height:1;">{i+1}</div>
          <h4 style="font-size:15px; font-weight:700; margin-bottom:10px; padding-right:20px; color:#052e1a;">{item.title}</h4>
          <p style="color:#555; font-size:14px; line-height:1.6; margin:0;">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── CORSO GRATUITO ─────────────────────────────────────────────────── -->
<section style="padding: 80px 24px; background: #052e1a;">
  <div class="two-col" style="max-width:1080px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:60px; align-items:center;">
    <div style="border-radius:12px; overflow:hidden; aspect-ratio:4/5; background:#064e29; position:relative;">
      <img
        src="https://marcomunich.com/wp-content/uploads/2019/04/foto_mia.jpg"
        alt="Marco Munich"
        style="width:100%; height:100%; object-fit:cover; display:block; opacity:.85;"
        loading="lazy"
      />
    </div>
    <div>
      <p style="color:#86efac; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; margin-bottom:16px;">Il corso è gratuito</p>
      <h2 style="font-size:clamp(24px,2.5vw,36px); font-weight:800; color:#fff; margin-bottom:20px;">
        Se senti che ti risuona,<br><strong style="text-decoration:underline;">IL CORSO è GRATUITO</strong>
      </h2>
      <p style="color:#bbb; font-size:15px; line-height:1.8; margin-bottom:24px;">Quello che riceverai:</p>
      <ul style="list-style:none; padding:0; margin-bottom:32px;">
        {[
          "Accesso alla risorsa con l'elenco di tutte le piattaforme",
          "Le informazioni da sapere per partire subito",
          "Possibilità di fare domande commentando nella risorsa",
          "2 Video lezioni di quasi due ore",
          "Tutto il materiale è in descrizione sul video YouTube",
        ].map(i => (
          <li style="display:flex; gap:10px; align-items:flex-start; padding:8px 0; border-bottom:1px solid rgba(255,255,255,.08); font-size:15px; color:#ddd;">
            <span style="color:#16A34A; font-weight:700; flex-shrink:0;">✓</span> {i}
          </li>
        ))}
      </ul>
      <a href="https://www.youtube.com/playlist?list=PLKgzAWOyM8xtciXhSPbj32fMzEXbYPUuC" target="_blank" rel="noopener"
        style="display:inline-flex; align-items:center; gap:10px; background:#FF0000; color:#fff; font-weight:700; font-size:15px; text-decoration:none; padding:14px 28px; border-radius:4px;">
        <svg viewBox="0 0 576 512" style="width:20px; height:20px; fill:#fff;"><path d="M549.655 124.083c-6.281-23.65-24.787-42.276-48.284-48.597C458.781 64 288 64 288 64S117.22 64 74.629 75.486c-23.497 6.322-42.003 24.947-48.284 48.597-11.412 42.867-11.412 132.305-11.412 132.305s0 89.438 11.412 132.305c6.281 23.65 24.787 41.5 48.284 47.821C117.22 448 288 448 288 448s170.78 0 213.371-11.486c23.497-6.321 42.003-24.171 48.284-47.821 11.412-42.867 11.412-132.305 11.412-132.305s0-89.438-11.412-132.305zm-317.51 213.508V175.185l142.739 81.205-142.739 81.201z"></path></svg>
        <strong>Inizia ora su YouTube</strong>
      </a>
    </div>
  </div>
</section>

<!-- ── COSTI PRIVATO ───────────────────────────────────────────────────── -->
<section id="costi" style="padding: 80px 24px; background: #f7f7f7;">
  <div style="max-width:1000px; margin:0 auto;">
    <p style="color:#16A34A; font-weight:700; font-size:13px; letter-spacing:2px; text-transform:uppercase; text-align:center; margin-bottom:12px;">Costi</p>
    <h2 style="text-align:center; font-size:clamp(26px,3vw,38px); font-weight:800; margin-bottom:12px;">Scegli come vuoi iniziare</h2>
    <p style="text-align:center; color:#555; margin-bottom:48px; font-size:16px;">Puoi guardare il corso gratuitamente su YouTube o farlo in privato con me.</p>

    <div class="costs-grid" style="display:grid; grid-template-columns:1fr 1fr; gap:24px;">

      <!-- Card Gratuita -->
      <div style="background:#fff; border-radius:12px; padding:36px; border:2px solid #eee;">
        <p style="font-size:13px; font-weight:700; color:#888; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">In autonomia</p>
        <div style="margin-bottom:4px;">
          <span style="font-size:48px; font-weight:900; color:#052e1a;">Gratis</span>
        </div>
        <p style="color:#999; font-size:13px; margin-bottom:20px;">su YouTube, quando vuoi</p>
        <p style="color:#555; font-size:15px; line-height:1.7; margin-bottom:24px;">
          Guarda le due video lezioni ai tuoi ritmi, con accesso a tutta la risorsa e ai materiali.
        </p>
        <ul style="list-style:none; padding:0; margin-bottom:32px;">
          {[
            "2 Video lezioni (~2 ore)",
            "Risorsa con tutti i link agli strumenti",
            "Possibilità di fare domande nella risorsa",
          ].map(i => (
            <li style="display:flex; gap:10px; align-items:flex-start; padding:8px 0; border-bottom:1px solid #f0f0f0; font-size:15px; color:#333;">
              <span style="color:#16A34A; font-weight:700; flex-shrink:0;">✓</span> {i}
            </li>
          ))}
        </ul>
        <a href="https://www.youtube.com/playlist?list=PLKgzAWOyM8xtciXhSPbj32fMzEXbYPUuC" target="_blank" rel="noopener"
          style="display:block; text-align:center; padding:14px; border:2px solid #16A34A; color:#16A34A; font-weight:700; font-size:15px; text-decoration:none; border-radius:4px;">
          Guarda su YouTube →
        </a>
      </div>

      <!-- Card €300 -->
      <div class="cost-card-featured" style="background:#052e1a; border-radius:12px; padding:36px; border:2px solid #16A34A; position:relative;">
        <div style="position:absolute; top:-14px; left:50%; transform:translateX(-50%); background:#16A34A; color:#fff; font-size:12px; font-weight:700; letter-spacing:1px; padding:4px 16px; border-radius:100px; white-space:nowrap;">CONSIGLIATO</div>
        <p style="font-size:13px; font-weight:700; color:#86efac; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px;">Percorso Privato con Marco</p>
        <div style="margin-bottom:4px;">
          <span style="font-size:48px; font-weight:900; color:#fff;">€300</span>
        </div>
        <p style="color:#999; font-size:13px; margin-bottom:20px;">oppure 2 rate da €150</p>
        <p style="color:#bbb; font-size:15px; line-height:1.7; margin-bottom:24px;">
          Facciamo insieme tutto il lavoro: installazione delle piattaforme, configurazione degli strumenti, revisione completa.
        </p>
        <ul style="list-style:none; padding:0; margin-bottom:32px;">
          {[
            "3 Sessioni private con Marco",
            "Installazione di tutte le piattaforme insieme",
            "Accesso alla risorsa completa",
            "2 Video lezioni per quasi due ore",
            "60 min di Call in regalo (Messaggio Autentico)",
          ].map(i => (
            <li style="display:flex; gap:10px; align-items:flex-start; padding:8px 0; border-bottom:1px solid rgba(255,255,255,.08); font-size:15px; color:#ddd;">
              <span style="color:#16A34A; font-weight:700; flex-shrink:0;">✓</span> {i}
            </li>
          ))}
        </ul>
        <a href="https://wa.link/qracm2" target="_blank" rel="noopener" class="btn-green"
          style="display:block; text-align:center;">
          3 Sessioni — 300€ →
        </a>
        <p style="text-align:center; margin-top:12px; font-size:13px; color:#888;">
          <a href="https://wa.link/qracm2" target="_blank" rel="noopener" style="color:#86efac;">Scrivimi per pagare in 2 rate da 150€</a>
        </p>
      </div>

    </div>

    <!-- WhatsApp CTA -->
    <div style="text-align:center; margin-top:48px; padding:32px; background:#fff; border-radius:12px;">
      <p style="font-size:18px; font-weight:700; margin-bottom:8px;">Hai domande prima di iniziare?</p>
      <p style="color:#555; margin-bottom:20px;">Scrivimi su WhatsApp, rispondo personalmente.</p>
      <a href="https://wa.link/qracm2" target="_blank" rel="noopener"
        style="display:inline-flex; align-items:center; gap:10px; background:#25D366; color:#fff; font-weight:700; font-size:15px; text-decoration:none; padding:14px 28px; border-radius:4px;">
        <svg viewBox="0 0 448 512" style="width:20px; height:20px; fill:#fff;"><path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path></svg>
        Scrivimi su WhatsApp
      </a>
    </div>
  </div>
</section>

</div><!-- /green-page -->

</BaseLayout>
