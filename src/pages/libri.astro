---
import BaseLayout from '@layouts/BaseLayout.astro';

const AMAZON_ICON = `<svg viewBox="0 0 448 512" fill="currentColor" width="14" height="14" aria-hidden="true"><path d="M257.2 162.7c-48.7 1.8-169.5 15.5-169.5 117.5 0 109.5 138.3 114 183.5 43.2 6.5 10.2 35.4 37.5 45.3 46.8l56.8-56S341 288.9 341 261.4V114.3C341 89 316.5 32 228.7 32 140.7 32 94 87 94 136.3l73.5 6.8c16.3-49.5 54.2-49.5 54.2-49.5 40.7-.1 35.5 29.8 35.5 69.1zm0 86.8c0 80-84.2 68-84.2 17.2 0-47.2 50.5-56.7 84.2-57.8v40.6zm136 163.5c-7.7 10-70 67-174.5 67S34.2 408.5 9.7 379c-6.8-7.7 1-11.3 5.5-8.3C88.5 415.2 203 488.5 387.7 401c7.5-3.7 13.3 2 5.5 12zm39.8 2.2c-6.5 15.8-16 26.8-21.2 31-5.5 4.5-9.5 2.7-6.5-3.8s19.3-46.5 12.7-55c-6.5-8.3-37-4.3-48-3.2-10.8 1-13 2-14-.3-2.3-5.7 21.7-15.5 37.5-17.5 15.7-1.8 41-.8 46 5.7 3.7 5.1 0 27.1-6.5 43.1z"/></svg>`;

const libri = [
  {
    n: '01',
    href: 'https://www.amazon.it/dp/B0BW28MMWL',
    img: 'https://m.media-amazon.com/images/I/61qgDt7YdlL._SY466_.jpg',
    alt: 'Copertina Content Marketing Olistico',
    tag: 'Personal Branding · 2023',
    titolo: 'Content Marketing Olistico',
    sub: 'Come promuoversi online in modo autentico nel settore olistico se sei Counselor, Coach o Operatore',
    rating: '4,3',
    stars: 4,
    recensioni: 12,
    desc: 'Per chi si è già scontrato con la sensazione fastidiosa di doversi "vendere". Riflessioni, domande, esercizi e un diario di 21 giorni per tornare a scrivere da un luogo più vicino a te. Non tecniche aggressive, non strategie di manipolazione: una presenza coerente, rispettosa, vera.',
    pagine: '85 pagine',
    data: 'Febbraio 2023',
    kindle: '5,98 €',
    print: '13,90 €',
    pdfSlug: 'content-marketing-olistico',
    pdfPrice: '9,90 €',
  },
  {
    n: '02',
    href: 'https://www.amazon.it/dp/B0F4MPN3GS',
    img: 'https://m.media-amazon.com/images/I/6134ncB9yjL._SY425_.jpg',
    alt: 'Copertina Scrivere per Restare',
    tag: 'Personal Branding · Aprile 2025',
    titolo: 'Scrivere per Restare',
    sub: 'Il personal branding olistico spiegato attraverso piccoli spaccati di vita',
    rating: '5,0',
    stars: 5,
    recensioni: 4,
    desc: 'Il racconto di una strada diversa verso la visibilità online. Per counselor, coach, operatori olistici che sentono il bisogno di essere visibili, ma non vogliono snaturarsi per farlo. Diciassette spaccati di vita, ognuno con una riflessione pratica e una domanda di lavoro.',
    pagine: '156 pagine',
    data: 'Aprile 2025',
    kindle: '5,98 €',
    print: '14,90 €',
    pdfSlug: 'scrivere-per-restare',
    pdfPrice: '7,90 €',
    landingHref: '/libri/scrivere-per-restare',
    hasPdf: true,
  },
  {
    n: '03',
    href: 'https://www.amazon.it/dp/B0FQ57R899',
    img: 'https://m.media-amazon.com/images/I/61USebxXAkL._SY425_.jpg',
    alt: "Copertina Restare Autentici Scrivendo con l'AI",
    tag: 'Intelligenza Artificiale · Settembre 2025',
    titolo: "Restare Autentici Scrivendo con l'AI",
    sub: "Guida pratica per counselor, coach e operatori olistici",
    rating: '5,0',
    stars: 5,
    recensioni: 1,
    desc: "Una guida pratica per usare l'AI senza perdere la tua voce. Impari a costruire prompt che portano dentro la tua esperienza, la tua posizione, il tuo tono. Il risultato è un testo che suona come te, prodotto in meno tempo.",
    pagine: '140 pagine',
    data: 'Settembre 2025',
    kindle: '5,97 €',
    print: '17,58 €',
    pdfSlug: 'restare-autentici-con-ai',
    pdfPrice: '9,90 €',
    landingHref: '/libri/restare-autentici-con-ai',
    hasPdf: true,
  },
  {
    n: '04',
    href: 'https://www.amazon.it/dp/B0FPB8NBQW',
    img: 'https://m.media-amazon.com/images/I/31J4xWp14TL._SY445_SX342_ML2_.jpg',
    alt: 'Copertina Un Anno di Scrittura per Scoprire Chi Sei Davvero',
    tag: 'Scrittura · Agosto 2025',
    titolo: 'Un Anno di Scrittura per Scoprire Chi Sei Davvero',
    sub: '52 settimane, 10 minuti al giorno, per scoprire chi sei davvero',
    rating: null,
    stars: 0,
    recensioni: 0,
    desc: 'Un capitolo a settimana per tutto l\'anno. Ogni settimana ha un tema, tre finestre di scrittura e una domanda finale. Alla fine dell\'anno hai 52 capitoli della tua storia professionale e personale. Materia grezza per contenuti, ma soprattutto una chiarezza su chi sei.',
    pagine: '154 pagine',
    data: 'Agosto 2025',
    kindle: '6,99 €',
    print: '17,58 €',
    pdfSlug: 'un-anno-di-scrittura',
    pdfPrice: '12,90 €',
    landingHref: '/libri/un-anno-di-scrittura',
    hasPdf: true,
  },
];
---

<BaseLayout
  title="I miei libri — Marco Munich"
  description="I libri di Marco Munich sul Personal Branding Olistico: Content Marketing Olistico, Scrivere per Restare, Restare Autentici con l'AI e Un Anno di Scrittura."
  currentPath="/libri/"
>

<!-- ══ HERO ═══════════════════════════════════════════════════════════════ -->
<section class="lb-hero">
  <div class="lb-hero__inner">
    <span class="lb-label">Marco Munich</span>
    <h1 class="lb-hero__title">
      <span class="lb-hl-plain">I miei</span>
      <em class="lb-hl-gold">libri.</em>
    </h1>
    <p class="lb-hero__sub">
      Quattro libri per chi vuole promuoversi online restando se stesso.
      Disponibili su Amazon (Kindle e cartaceo) e in PDF direttamente da questo sito.
    </p>
  </div>
</section>

<!-- ══ LIBRI ═══════════════════════════════════════════════════════════════ -->
<section class="lb-section">
  <div class="lb-section__inner">
    {libri.map((libro) => (
      <article class="lb-libro">
        <div class="lb-libro__n-col">
          <span class="lb-libro__n">{libro.n}</span>
        </div>
        <div class="lb-libro__cover-col">
          <a href={libro.href} target="_blank" rel="nofollow noopener" class="lb-libro__cover-link" tabindex="-1" aria-hidden="true">
            <img
              class="lb-libro__cover"
              src={libro.img}
              alt={libro.alt}
              width="150" height="215"
              loading="lazy"
            />
          </a>
        </div>
        <div class="lb-libro__content">
          <span class="lb-libro__tag">{libro.tag}</span>
          <h2 class="lb-libro__title">{libro.titolo}</h2>
          <p class="lb-libro__sub">{libro.sub}</p>
          {libro.rating && (
            <div class="lb-libro__rating">
              <span class="lb-stars" aria-label={`${libro.rating} stelle su 5`}>
                {'★'.repeat(libro.stars)}{'☆'.repeat(5 - libro.stars)}
              </span>
              <span class="lb-rating-val">{libro.rating}</span>
              <span class="lb-rating-count">({libro.recensioni} {libro.recensioni === 1 ? 'recensione' : 'recensioni'})</span>
            </div>
          )}
          <p class="lb-libro__desc">{libro.desc}</p>
          <div class="lb-libro__meta">
            <span>{libro.pagine}</span>
            <span class="lb-sep" aria-hidden="true">·</span>
            <span>{libro.data}</span>
          </div>
          <div class="lb-libro__prices">
            <span class="lb-price lb-price--kindle">Kindle <strong>{libro.kindle}</strong></span>
            <span class="lb-price lb-price--print">Cartaceo <strong>{libro.print}</strong></span>
            {libro.hasPdf && <span class="lb-price lb-price--pdf">PDF <strong>{libro.pdfPrice}</strong></span>}
          </div>
          <div class="lb-libro__btns">
            <a href={libro.href} target="_blank" rel="nofollow noopener" class="lb-btn">
              <Fragment set:html={AMAZON_ICON} />
              Amazon
            </a>
            {libro.hasPdf && (
              <a href={libro.landingHref ?? `/api/libri/checkout.php?book=${libro.pdfSlug}`} class="lb-btn lb-btn--pdf">
                ↓ PDF {libro.pdfPrice}
              </a>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- ══ BUNDLE ══════════════════════════════════════════════════════════════ -->
<section class="lb-bundle">
  <div class="lb-bundle__inner">
    <div class="lb-bundle__badge">Offerta</div>
    <h2 class="lb-bundle__title">Tutti e tre i PDF <em>insieme.</em></h2>
    <p class="lb-bundle__sub">
      Scrivere per Restare, Restare Autentici con l'AI e Un Anno di Scrittura
      in un unico acquisto. Scarichi tutto subito, paghi meno di due libri singoli.
    </p>

    <div class="lb-bundle__covers">
      <img src="/libri/copertine/cover-scrivere-per-restare.png"     alt="Scrivere per Restare"          width="110" height="157" loading="lazy" />
      <img src="/libri/copertine/cover-restare-autentici-con-ai.png" alt="Restare Autentici con l'AI"    width="110" height="157" loading="lazy" />
      <img src="/libri/copertine/cover-un-anno-di-scrittura.png"     alt="Un Anno di Scrittura"          width="110" height="157" loading="lazy" />
    </div>

    <div class="lb-bundle__price-row">
      <span class="lb-bundle__price-old">
        <span class="lb-bundle__price-label">Singoli</span>
        <span class="lb-bundle__strikethrough">30,70 €</span>
      </span>
      <span class="lb-bundle__price-new">
        <span class="lb-bundle__price-label">Bundle</span>
        <strong>24,90 €</strong>
      </span>
    </div>

    <a href="/api/libri/checkout.php?book=bundle-tutti" class="lb-btn lb-btn--orange lb-btn--xl">
      ↓ Acquista il pacchetto — 24,90 €
    </a>
    <p class="lb-bundle__note">Pagamento sicuro · PDF consegnati via email entro 1 minuto</p>
  </div>
</section>

<!-- ══ CTA ════════════════════════════════════════════════════════════════ -->
<section class="lb-cta">
  <div class="lb-cta__inner">
    <span class="lb-label lb-label--light">Hai domande?</span>
    <h2 class="lb-cta__title">Vuoi sapere da dove <em>iniziare?</em></h2>
    <p class="lb-cta__desc">
      Se non sai quale libro fa più al caso tuo, scrivimi su WhatsApp.
      Ti dico in due righe quale dei quattro si adatta meglio a dove sei adesso.
    </p>
    <a href="https://wa.link/eemovr" target="_blank" class="lb-btn lb-btn--lg">
      <svg viewBox="0 0 448 512" width="16" height="16" fill="currentColor" aria-hidden="true">
        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
      </svg>
      Chiacchierata su WhatsApp
    </a>
  </div>
</section>

</BaseLayout>

<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

.lb-label {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  display: block;
  margin-bottom: 1.5rem;
}
.lb-label--light { color: rgba(255,255,255,0.35); }

/* ══ HERO ══════════════════════════════════════════════════════════════════ */
.lb-hero {
  background: var(--black);
  padding: 7rem var(--pad) 6rem;
}
.lb-hero__inner {
  max-width: var(--max);
  margin: 0 auto;
  max-width: 700px;
}
.lb-hero__title {
  display: flex;
  flex-direction: column;
  line-height: 0.92;
  margin-bottom: 2rem;
}
.lb-hl-plain {
  font: 800 clamp(3.2rem, 6vw, 6.5rem)/1 var(--display);
  color: var(--white);
  display: block;
  letter-spacing: -0.03em;
}
.lb-hl-gold {
  font: 300 clamp(3.6rem, 7vw, 7.5rem)/1 var(--serif);
  font-style: italic;
  color: var(--gold);
  display: block;
  letter-spacing: -0.02em;
  margin-top: 0.05em;
}
.lb-hero__sub {
  font: 300 1rem/1.7 var(--sans);
  color: rgba(255,255,255,0.38);
  max-width: 500px;
}

/* ══ LIBRI ══════════════════════════════════════════════════════════════════ */
.lb-section {
  background: var(--white);
  padding: 5rem var(--pad) 6rem;
}
.lb-section__inner {
  max-width: 880px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.lb-libro {
  display: grid;
  grid-template-columns: 2.5rem 160px 1fr;
  gap: 0 2rem;
  padding: 3rem 0;
  border-bottom: 1px solid rgba(10,10,10,0.07);
  align-items: start;
}
.lb-libro:first-child { border-top: 1px solid rgba(10,10,10,0.07); }
.lb-libro__n-col { padding-top: 0.5rem; }
.lb-libro__n {
  display: block;
  font: 300 2.5rem/0.9 var(--serif);
  font-style: italic;
  color: var(--gold);
  opacity: 0.25;
  letter-spacing: -0.04em;
}
.lb-libro__cover-link { display: block; }
.lb-libro__cover {
  width: 140px;
  height: auto;
  box-shadow: 0 6px 24px rgba(0,0,0,0.12);
  transition: transform 0.2s, box-shadow 0.2s;
}
.lb-libro__cover:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.18); }

.lb-libro__tag {
  display: block;
  font: 700 0.58rem/1 var(--sans);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 0.75rem;
}
.lb-libro__title {
  font: 400 clamp(1.3rem, 2vw, 1.65rem)/1.2 var(--serif);
  color: var(--black);
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
}
.lb-libro__sub {
  font: 300 0.88rem/1.5 var(--sans);
  color: var(--muted);
  margin-bottom: 0.75rem;
}
.lb-libro__rating {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1rem;
}
.lb-stars {
  color: var(--gold);
  font-size: 0.85rem;
  letter-spacing: 0.05em;
}
.lb-rating-val {
  font: 700 0.78rem/1 var(--sans);
  color: var(--black);
}
.lb-rating-count {
  font: 400 0.75rem/1 var(--sans);
  color: var(--muted);
}
.lb-libro__desc {
  font: 300 0.88rem/1.7 var(--sans);
  color: rgba(10,10,10,0.6);
  margin-bottom: 1.25rem;
}
.lb-libro__meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font: 400 0.75rem/1 var(--sans);
  color: var(--muted);
  margin-bottom: 1rem;
}
.lb-sep { opacity: 0.4; }
.lb-libro__prices {
  display: flex;
  gap: 1.25rem;
  margin-bottom: 1.5rem;
}
.lb-price {
  font: 400 0.78rem/1 var(--sans);
  color: var(--muted);
}
.lb-price strong { font-weight: 700; color: var(--black); }

/* ── Button ──────────────────────────────────────────────────────────────── */
.lb-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font: 700 0.75rem/1 var(--sans);
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.8rem 1.5rem;
  border-radius: 1px;
  background: var(--gold);
  color: var(--white);
  transition: background 0.15s, transform 0.12s;
  white-space: nowrap;
}
.lb-btn:hover { background: var(--gold-d); transform: translateY(-1px); opacity: 1; }
.lb-btn--lg { padding: 1.05rem 2rem; font-size: 0.82rem; }
.lb-btn--pdf { background: var(--mm-orange, #e85d00); }
.lb-btn--pdf:hover { background: #d05200; }
.lb-libro__btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
.lb-price--pdf { background: rgba(232,93,0,.1); color: var(--mm-orange, #e85d00); }

/* ══ BUNDLE ══════════════════════════════════════════════════════════════════ */
.lb-bundle {
  background: #0a0a0a;
  padding: 6rem var(--pad);
  border-top: 2px solid var(--gold);
}
.lb-bundle__inner {
  max-width: 700px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1.5rem;
}
.lb-bundle__badge {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(197,138,55,0.1);
  border: 1px solid rgba(197,138,55,0.25);
  padding: 0.35rem 0.9rem;
  border-radius: 100px;
  display: inline-block;
}
.lb-bundle__title {
  font: 800 clamp(2rem, 4vw, 3.2rem)/1.05 var(--display);
  color: var(--white);
  letter-spacing: -0.03em;
}
.lb-bundle__title em {
  font-style: italic;
  color: var(--gold);
  font-weight: 300;
  font-family: var(--serif);
}
.lb-bundle__sub {
  font: 300 1rem/1.7 var(--sans);
  color: rgba(255,255,255,0.45);
  max-width: 520px;
}
.lb-bundle__covers {
  display: flex;
  gap: 1rem;
  align-items: flex-end;
  justify-content: center;
  padding: 0.5rem 0;
}
.lb-bundle__covers img {
  border-radius: 3px;
  box-shadow: 0 12px 40px rgba(0,0,0,0.5);
  transition: transform 0.2s;
}
.lb-bundle__covers img:hover { transform: translateY(-4px); }
.lb-bundle__price-row {
  display: flex;
  align-items: center;
  gap: 2rem;
  justify-content: center;
  flex-wrap: wrap;
}
.lb-bundle__price-label {
  display: block;
  font: 400 0.7rem/1 var(--sans);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 0.3rem;
}
.lb-bundle__price-old {
  text-align: center;
}
.lb-bundle__strikethrough {
  font: 400 1.4rem/1 var(--sans);
  color: rgba(255,255,255,0.25);
  text-decoration: line-through;
}
.lb-bundle__price-new {
  text-align: center;
}
.lb-bundle__price-new strong {
  font: 800 2.2rem/1 var(--display);
  color: var(--white);
  letter-spacing: -0.03em;
}
.lb-btn--xl {
  padding: 1.1rem 2.4rem;
  font-size: 1.05rem;
}
.lb-bundle__note {
  font: 400 0.78rem/1.4 var(--sans);
  color: rgba(255,255,255,0.25);
}

/* ══ CTA ════════════════════════════════════════════════════════════════════ */
.lb-cta {
  background: var(--black);
  padding: 7rem var(--pad);
  text-align: center;
}
.lb-cta__inner {
  max-width: 580px;
  margin: 0 auto;
}
.lb-cta__title {
  font: 300 clamp(2rem, 4vw, 3.2rem)/1.2 var(--serif);
  color: var(--white);
  margin-bottom: 1.25rem;
}
.lb-cta__title em { font-style: italic; color: var(--gold); }
.lb-cta__desc {
  font: 300 0.92rem/1.7 var(--sans);
  color: rgba(255,255,255,0.4);
  margin-bottom: 2.5rem;
}

/* ── Responsive ─────────────────────────────────────────────────────────── */
@media (max-width: 640px) {
  .lb-libro {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  .lb-libro__n-col { display: none; }
  .lb-libro__cover-link { display: inline-block; }
  .lb-libro__cover { width: 110px; }
}
</style>
