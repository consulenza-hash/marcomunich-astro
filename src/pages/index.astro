---
import BaseLayout from '@layouts/BaseLayout.astro';
import jsYaml from 'js-yaml';

const rawFiles = import.meta.glob('/src/content/articoli/*/index.mdoc', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

const latestPosts = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug   = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
  const fmStr  = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm     = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    titolo:      (fm.titolo      as string) ?? slug,
    categoria:   (fm.categoria   as string) ?? 'Articolo',
    data:        fm.data ? String(fm.data) : '',
    bozza:       fm.bozza === true,
  };
})
  .filter(p => p.titolo && p.data && !p.bozza)
  .sort((a, b) => new Date(b.data).getTime() - new Date(a.data).getTime())
  .slice(0, 5);
---

<BaseLayout
  title="Personal Branding Olistico — Marco Munich"
  description="Aiuto coach, counselor e operatori olistici a costruire una presenza online che li fa trovare dalle persone giuste. Articoli, siti web e percorsi di personal branding."
  currentPath="/"
>

<div class="mm-page">

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="home-hero">
    <video
      class="home-hero__video"
      id="hero-vid"
      autoplay muted loop playsinline
      poster="/og/marco-munich.png"
    ></video>
    <div class="home-hero__overlay" aria-hidden="true"></div>

    <div class="home-hero__content mm-container">
      <p class="home-hero__byline">Marco Munich —</p>
      <h1 class="mm-h1">Siti, app,<br>e il tuo brand online.</h1>
      <p class="home-hero__sub">
        Costruisco <strong>siti e applicazioni</strong> per chi vende se stesso. Lo faccio sapendo cosa stai vendendo, perché vengo da sette anni di personal branding nel settore olistico.
      </p>
      <div class="home-hero__ctas">
        <a href="/dev/" class="mm-btn mm-btn-orange">Vedi cosa costruisco →</a>
        <a href="/contatti/" class="mm-btn mm-btn-outline">Lavoriamo insieme</a>
      </div>
    </div>

    <span class="home-hero__caption" aria-hidden="true">Sviluppo · Personal Branding · Contenuti</span>
  </section>

  <!-- ── NUMERI ─────────────────────────────────────────────────────────────── -->
  <section class="mm-section-light home-stats">
    <div class="home-stats__grid mm-container">
      <div class="home-stat">
        <div class="home-stat__num">200<span>+</span></div>
        <div class="home-stat__label">Articoli pubblicati<br>sul blog</div>
      </div>
      <div class="home-stat">
        <div class="home-stat__num">50<span>+</span></div>
        <div class="home-stat__label">Professionisti seguiti<br>in sette anni</div>
      </div>
      <div class="home-stat">
        <div class="home-stat__num">0</div>
        <div class="home-stat__label">Template usati. Ogni progetto<br>è costruito da zero.</div>
      </div>
    </div>
  </section>

  <!-- ── DUE STRADE ────────────────────────────────────────────────────────── -->
  <section class="mm-section-dark home-strade">
    <div class="mm-container">
      <div class="home-strade__header">
        <h2 class="mm-h2">Due strade.<br>Lo stesso modo di lavorare.</h2>
        <p class="home-strade__intro">
          Da una parte costruisco. Dall'altra ti aiuto a posizionarti. Spesso le due cose vanno insieme — ma non è obbligatorio.
        </p>
      </div>
      <div class="home-strade__grid">
        <a href="/dev/" class="home-strada home-strada--primary">
          <div class="mm-tag">Servizio principale</div>
          <h3 class="mm-h3">Costruisco siti e applicazioni.</h3>
          <p class="mm-body">Per chi vuole un sito vero, non un template — o un'applicazione web che fa qualcosa di specifico. Astro, FastAPI, codice pulito, performance verificabili, piena proprietà dei file. Niente plugin, niente manutenzione mensile.</p>
          <span class="home-strada__cta">Vedi cosa costruisco →</span>
        </a>
        <a href="/servizi/" class="home-strada home-strada--secondary">
          <div class="mm-tag">Consulenza</div>
          <h3 class="mm-h3">Ti aiuto a posizionarti online.</h3>
          <p class="mm-body">Per coach, counselor, operatori olistici e professionisti che vendono se stessi. Sette anni di personal branding nel settore olistico, oltre duecento articoli, e un metodo per trovare un punto di vista che non sia il copia-incolla di tutti gli altri.</p>
          <span class="home-strada__cta">Scopri come →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── ARTICOLI ──────────────────────────────────────────────────────────── -->
  <section class="mm-section-light home-articles">
    <div class="mm-container">
      <div class="home-articles__header">
        <h2 class="mm-h2" style="color:#0d0d0d">Ultimi articoli.</h2>
        <a href="/blog/" class="home-articles__all">Archivio completo →</a>
      </div>
      {latestPosts.map((post, i) => (
        <a href={`/${post.slug}/`} class="home-article-row">
          <span class="home-article-row__n">0{i+1}</span>
          <span class="home-article-row__cat">{post.categoria}</span>
          <span class="home-article-row__title">{post.titolo}</span>
          <span class="home-article-row__arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── CHI SONO ──────────────────────────────────────────────────────────── -->
  <section class="mm-section-dark home-about">
    <div class="mm-container home-about__grid">
      <div class="home-about__photo">
        <img src="/og/marco-munich.png" alt="Marco Munich — Personal Branding Olistico" loading="lazy" />
      </div>
      <div class="home-about__text">
        <div class="mm-tag" style="margin-bottom:1.2rem">Chi sono</div>
        <h2 class="mm-h2" style="margin-bottom:1.5rem">Marco Munich.</h2>
        <p class="mm-body" style="margin-bottom:1rem">
          Da sette anni mi occupo di presenza online per professionisti che vendono se stessi. Ho scritto oltre duecento articoli, seguito coach, counselor e operatori di ogni tipo, e a un certo punto ho iniziato a costruire io stesso i loro siti — perché vedere coach con siti tutti uguali aveva stancato anche me.
        </p>
        <p class="mm-body" style="margin-bottom:2rem">
          Oggi lavoro su due fronti che si parlano: costruisco siti e applicazioni web custom, e aiuto chi vende se stesso a trovare un modo di presentarsi online che non sia il copia-incolla di tutti gli altri.
        </p>
        <a href="/chi-sono/" class="mm-btn mm-btn-orange">Scopri di più →</a>
      </div>
    </div>
  </section>

  <!-- ── CTA FINALE ────────────────────────────────────────────────────────── -->
  <section class="home-cta">
    <div class="mm-container home-cta__inner">
      <div>
        <h2 class="mm-h2">Hai un progetto<br>in mente?</h2>
        <p style="color:rgba(255,255,255,0.75);font-size:0.9rem;margin-top:0.5rem">Fissa una chiamata gratuita. Ti dico subito se posso aiutarti e come lo farei.</p>
      </div>
      <a href="/contatti/" class="mm-btn mm-btn-white">Parliamo →</a>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  /* ── HERO ── */
  .home-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: #0d0d0d;
  }
  .home-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
      rgba(0,0,0,0.35) 0%,
      rgba(0,0,0,0.1)  30%,
      rgba(0,0,0,0.65) 70%,
      rgba(0,0,0,0.92) 100%);
    z-index: 1;
  }
  .home-hero__content {
    position: relative;
    z-index: 2;
    padding-bottom: 5rem;
    padding-top: 8rem;
  }
  .home-hero__byline {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 0.8rem;
  }
  .home-hero__content h1 { margin-bottom: 1.5rem; }
  .home-hero__sub {
    font-size: clamp(0.88rem, 1.4vw, 1rem);
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
    max-width: 480px;
    margin-bottom: 2rem;
    font-weight: 400;
  }
  .home-hero__sub strong { color: #fff; font-weight: 700; }
  .home-hero__ctas {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .home-hero__caption {
    position: absolute;
    bottom: 1.8rem;
    right: 2rem;
    z-index: 2;
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  /* ── STATS ── */
  .home-stats { padding: 0; }
  .home-stats__grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    border-top: 1px solid var(--mm-border-light);
  }
  .home-stat {
    padding: 3.5rem 2.5rem;
    border-right: 1px solid var(--mm-border-light);
    text-align: center;
  }
  .home-stat:last-child { border-right: none; }
  .home-stat__num {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: #0d0d0d;
    margin-bottom: 0.5rem;
  }
  .home-stat__num span { color: #e85d00; }
  .home-stat__label {
    font-size: 0.78rem;
    color: #888;
    line-height: 1.55;
  }

  /* ── DUE STRADE ── */
  .home-strade { padding: 5rem 0; }
  .home-strade__header {
    margin-bottom: 3rem;
    max-width: 720px;
  }
  .home-strade__intro {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255,255,255,0.65);
    margin-top: 1.2rem;
  }
  .home-strade__grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 1px;
    background: #1a1a1a;
    border: 1px solid #1a1a1a;
    border-radius: 4px;
    overflow: hidden;
  }
  .home-strada {
    background: #0d0d0d;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease;
  }
  .home-strada:hover { background: #141414; }
  .home-strada .mm-h3 { color: #fff; line-height: 1.25; }
  .home-strada--primary {
    background: #111111;
    border-right: 2px solid #e85d00;
  }
  .home-strada--primary:hover { background: #181818; }
  .home-strada--primary .mm-tag { color: #e85d00; }
  .home-strada__cta {
    margin-top: auto;
    padding-top: 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #e85d00;
  }
  .home-strada--secondary .home-strada__cta { color: rgba(255,255,255,0.85); }

  /* ── ARTICOLI ── */
  .home-articles { padding: 5rem 0; }
  .home-articles__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .home-articles__all {
    font-size: 0.8rem;
    font-weight: 600;
    color: #0d0d0d;
    text-decoration: none;
    opacity: 0.5;
  }
  .home-articles__all:hover { opacity: 1; }
  .home-article-row {
    display: grid;
    grid-template-columns: 2.5rem 7rem 1fr 2rem;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--mm-border-light);
    text-decoration: none;
    color: inherit;
  }
  .home-article-row:first-of-type { border-top: 1px solid var(--mm-border-light); }
  .home-article-row:hover .home-article-row__title { color: #e85d00; }
  .home-article-row__n {
    font-size: 0.68rem;
    font-weight: 700;
    color: #ccc;
    font-family: 'Inter', sans-serif;
  }
  .home-article-row__cat {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .home-article-row__title {
    font-size: 0.92rem;
    font-weight: 600;
    color: #0d0d0d;
    transition: color 0.15s;
    line-height: 1.4;
  }
  .home-article-row__arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #0d0d0d;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
    justify-self: end;
  }

  /* ── CHI SONO ── */
  .home-about { padding: 5rem 0; }
  .home-about__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 5rem;
    align-items: center;
  }
  .home-about__photo {
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 3/4;
  }
  .home-about__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    display: block;
  }

  /* ── CTA ── */
  .home-cta {
    background: #e85d00;
    padding: 4.5rem 0;
  }
  .home-cta__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .home-stats__grid { grid-template-columns: 1fr; }
    .home-stat { border-right: none; border-bottom: 1px solid var(--mm-border-light); }
    .home-stat:last-child { border-bottom: none; }
    .home-strade__grid { grid-template-columns: 1fr; }
    .home-strada { padding: 2.5rem 1.8rem; }
    .home-strada--primary { border-right: none; border-bottom: 2px solid #e85d00; }
    .home-article-row { grid-template-columns: 2rem 1fr 2rem; }
    .home-article-row__cat { display: none; }
    .home-about__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .home-about__photo { aspect-ratio: 4/3; }
    .home-cta__inner { flex-direction: column; align-items: flex-start; }
    .home-strade__header { max-width: 100%; }
    .home-articles__header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .home-hero__content { padding-bottom: 4rem; }
  }
</style>

<script>
  // Video meteo reattivo
  (async () => {
    const vid = document.getElementById('hero-vid') as HTMLVideoElement | null;
    if (!vid) return;
    let src = '/videos/hero-pomeriggio.mp4';
    try {
      const r = await fetch('https://api.open-meteo.com/v1/forecast?latitude=45.5455&longitude=11.5354&current=weather_code,is_day');
      const d = await r.json();
      const wc = d.current?.weather_code ?? 0;
      const isDay = d.current?.is_day ?? 1;
      if (!isDay) src = '/videos/hero-notte.mp4';
      else if (wc <= 1) src = '/videos/hero-sole.mp4';
      else if (wc <= 48) src = '/videos/hero-pomeriggio.mp4';
      else if (wc <= 82) src = '/videos/hero-mattina.mp4';
      else src = '/videos/hero-sera.mp4';
    } catch {}
    vid.src = src;
    vid.load();
  })();
</script>
