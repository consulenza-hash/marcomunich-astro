---
import BaseLayout from '@layouts/BaseLayout.astro';
import jsYaml from 'js-yaml';

const rawFiles = import.meta.glob('/src/content/articoli/*/index.mdoc', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

const latestPosts = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug  = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
  const fmStr = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm    = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    titolo:     (fm.titolo     as string) ?? slug,
    descrizione:(fm.descrizione as string) ?? '',
    data:       fm.data ? String(fm.data) : '',
    immagine:   (fm.immagine   as string) ?? '',
  };
})
  .sort((a, b) => new Date(b.data).getTime() - new Date(a.data).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Marco Munich — Personal Branding Olistico"
  description="Sviluppa un punto di vista per promuoverti online come voce diversa dalle altre."
  currentPath="/"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- ══ HERO ═══════════════════════════════════════════════════════════════ -->
<section class="v2-hero">
  <div class="v2-hero__inner">

    <div class="v2-hero__content">
      <p class="v2-eyebrow">
        <span>Marco Munich</span>
        <span class="v2-eyebrow__sep" aria-hidden="true">—</span>
        <span>Vicenza</span>
      </p>

      <h1 class="v2-hero__headline">
        <span class="v2-hl-plain">Personal</span>
        <span class="v2-hl-plain">Branding</span>
        <em class="v2-hl-gold">Olistico.</em>
      </h1>

      <p class="v2-hero__sub">
        <span class="v2-hero__sub-and">e</span>
        Sviluppo Siti Web ad Alte Prestazioni
      </p>

      <p class="v2-hero__body">
        Costruisci una presenza autentica — senza funnel, senza maschere.<br />
        O costruiamo insieme il sito che riflette davvero chi sei.
      </p>

      <div class="v2-hero__ctas">
        <a href="https://wa.link/zva8dp" class="v2-btn v2-btn--gold">
          <svg viewBox="0 0 448 512" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
          </svg>
          Chiacchierata introduttiva
        </a>
        <a href="/risorse/" class="v2-btn v2-btn--ghost-light">Risorse gratuite →</a>
      </div>
    </div>

    <div class="v2-hero__photo-col">
      <video id="hero-vid" class="v2-hero__video" autoplay muted loop playsinline poster="/og/marco-munich.png"></video>
      <span class="v2-hero__vid-caption">Coach · Counselor · Operatori Olistici</span>
    </div>

  </div>

  <div class="v2-hero__rule" aria-hidden="true"></div>

  <div class="v2-hero__ticker" aria-hidden="true">
    <div class="v2-ticker__track">
      {Array.from({length: 3}).map(() => (
        <>
          <span>Personal Branding Olistico</span>
          <span class="v2-ticker__dot">◆</span>
          <span>Siti Web ad Alte Prestazioni</span>
          <span class="v2-ticker__dot">◆</span>
          <span>Voce Autentica</span>
          <span class="v2-ticker__dot">◆</span>
          <span>Punto di Vista</span>
          <span class="v2-ticker__dot">◆</span>
          <span>Autenticità</span>
          <span class="v2-ticker__dot">◆</span>
          <span>Vicenza</span>
          <span class="v2-ticker__dot">◆</span>
        </>
      ))}
    </div>
  </div>
</section>

<!-- ══ MANIFESTO ══════════════════════════════════════════════════════════ -->
<section class="v2-manifesto">
  <div class="v2-manifesto__inner">

    <header class="v2-manifesto__header">
      <span class="v2-label v2-label--gold">Il problema</span>
      <h2 class="v2-manifesto__title">
        Chi non ha un punto di vista<br />
        <em>recita un personaggio.</em>
      </h2>
    </header>

    <div class="v2-manifesto__body">
      <div class="v2-manifesto__list">
        {[
          "Si presenta come vorrebbe essere visto, mai per quello che è.",
          "Sceglie sfondi e contesti studiati per costruire un'immagine.",
          "Cancella ogni traccia di errore. Tutto deve sembrare perfetto.",
          "Pesa ogni parola per portarti alla vendita.",
          "Pubblica quando «dovrebbe», non quando ha qualcosa da dire.",
          "È difficile parlarci davvero. C'è sempre un muro, filtri, deleghe.",
          "Dice cose che risuonano, ma usa la tua sofferenza come leva.",
          "Tocca il cuore per calcolo. C'è sempre un secondo fine.",
          "Sei un numero. Parla di «onboarding» come se fossi salito su una nave.",
          "È stanco, ma non lo dice mai. Anzi, predica che non bisogna mollare.",
          "Non è mai contento di parlare se non c'è un ritorno.",
        ].map((item, i) => (
          <div class="v2-manifesto__item">
            <span class="v2-manifesto__n">{String(i + 1).padStart(2, '0')}</span>
            <p>{item}</p>
          </div>
        ))}
        <div class="v2-manifesto__item v2-manifesto__item--verdict">
          <span class="v2-manifesto__n" aria-hidden="true"></span>
          <p><strong>Risultato: infelicità. Nonostante ricchezza e successo.</strong></p>
        </div>
      </div>

      <aside class="v2-manifesto__aside">
        <div class="v2-manifesto__aside-inner">
          <p class="v2-manifesto__aside-question">
            Non la vuoi?
          </p>
          <p class="v2-manifesto__aside-sub">
            Allora non fare niente di quello che hai appena letto.
          </p>
          <a href="https://wa.link/zva8dp" class="v2-btn v2-btn--gold v2-btn--sm">
            Parliamone
          </a>
        </div>
      </aside>
    </div>

  </div>
</section>

<!-- ══ SERVIZI ════════════════════════════════════════════════════════════ -->
<section class="v2-services">
  <div class="v2-services__inner">
    <span class="v2-label v2-label--muted">Di cosa mi occupo</span>
    <div class="v2-services__grid">

      <article class="v2-service">
        <div class="v2-service__bar" aria-hidden="true"></div>
        <h3 class="v2-service__title">Personal Branding<br /><em>Olistico</em></h3>
        <p class="v2-service__desc">
          Costruisci un punto di vista forte e autentico. Impari a stare
          online senza recitare — mostrando chi sei davvero, non chi
          vorresti sembrare.
        </p>
        <div class="v2-service__tags">
          <span>Coaching</span>
          <span>Counseling</span>
          <span>Operatori Olistici</span>
        </div>
        <a href="/risorse/" class="v2-service__link">Esplora le risorse →</a>
      </article>

      <div class="v2-services__divider" aria-hidden="true"></div>

      <article class="v2-service">
        <div class="v2-service__bar" aria-hidden="true"></div>
        <h3 class="v2-service__title">Siti Web<br /><em>ad Alte Prestazioni</em></h3>
        <p class="v2-service__desc">
          Siti veloci, ben costruiti, ottimizzati per farsi trovare.
          Nessun template generico — ogni progetto parte dalla tua
          identità e da quello che vuoi comunicare.
        </p>
        <div class="v2-service__tags">
          <span>Astro</span>
          <span>Performance</span>
          <span>SEO</span>
        </div>
        <a href="/servizi/" class="v2-service__link">Scopri come lavoro →</a>
      </article>

    </div>
  </div>
</section>

<!-- ══ CHI HA ══════════════════════════════════════════════════════════════ -->
<section class="v2-haves">
  <div class="v2-haves__inner">

    <header class="v2-haves__header">
      <span class="v2-label v2-label--gold">La differenza</span>
      <h2 class="v2-haves__title">
        Chi ha un punto di vista<br /><em>forte e onesto</em>
      </h2>
    </header>

    <div class="v2-haves__grid">
      {[
        { n: "01", text: "Si mostra per quello che è, dalla stanza in cui vive davvero." },
        { n: "02", text: "Usa mezzi, tempistiche e orari che vuole. Pubblica alle 3 di notte se ha qualcosa da dire." },
        { n: "03", text: "Dialoga direttamente con le persone. Zero funnel, zero moduli, zero muri." },
        { n: "04", text: "Parla la tua lingua. Risuona subito, senza sforzo." },
        { n: "05", text: "Tocca il cuore in modo onesto, con voglia di aiutare — non per calcolo." },
        { n: "06", text: "Non si stanca quasi mai. È innamorato dell'argomento. Ci starebbe ore." },
        { n: "07", text: "È felice di parlare, senza quel peso che si sente quando «si sta vendendo»." },
        { n: "08", text: "Crede veramente in quello che dice, anche a costo di sembrare un po' fissato." },
        { n: "09", text: "Si percepisce una fedeltà alla propria natura. Sempre, in ogni contesto." },
      ].map(item => (
        <div class="v2-have">
          <span class="v2-have__n">{item.n}</span>
          <p>{item.text}</p>
        </div>
      ))}
    </div>

    <div class="v2-haves__cta">
      <a href="https://wa.link/zva8dp" class="v2-btn v2-btn--white">
        Ti riconosci in questo? Parliamo.
      </a>
    </div>

  </div>
</section>

<!-- ══ PROCESSO ═══════════════════════════════════════════════════════════ -->
<section class="v2-process">
  <div class="v2-process__inner">
    <span class="v2-label v2-label--muted">Come lavoro</span>
    <div class="v2-process__steps">
      {[
        {
          n: "01",
          title: "Scopriamo il tuo perché",
          body: "Facciamo una chiacchierata e vediamo quante bugie ti racconti. Sulla base di questo, ti propongo come agire.",
        },
        {
          n: "02",
          title: "Ti illustro le opzioni",
          body: "Dopo la chiacchierata ti dico apertamente cosa penso di te e del potenziale che vedo. A volte la risposta è cambiare strada totalmente.",
        },
        {
          n: "03",
          title: "Mi dedico a te",
          body: "Rapporti aperti e diretti. Ti darò tutto quello che posso, compatibilmente con lo spazio e le possibilità che mi mostrerai.",
        },
      ].map(step => (
        <div class="v2-step">
          <span class="v2-step__n" aria-hidden="true">{step.n}</span>
          <div class="v2-step__body">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ══ CITAZIONE ══════════════════════════════════════════════════════════ -->
<section class="v2-quote">
  <div class="v2-quote__inner">
    <div class="v2-quote__left">
      <span class="v2-quote__mark" aria-hidden="true">"</span>
      <blockquote>
        Ti aiuto a capire come la vita mostra costantemente
        ciò che ti serve a svoltare e aiutare il prossimo,
        o la collettività.
      </blockquote>
      <cite>— Marco Munich</cite>
    </div>
    <div class="v2-quote__right">
      <p class="v2-quote__warning">Non adatto a chi crede di avere già le risposte.</p>
      <p class="v2-quote__note">
        Non posso aiutare chi crede di sapersi già promuovere.
        Se non funziona, non sai ancora niente — né del tuo pubblico,
        né del perché sei qui a fare questo lavoro.
      </p>
      <a href="https://wa.link/zva8dp" class="v2-btn v2-btn--gold">
        In ogni caso, iniziamo
      </a>
    </div>
  </div>
</section>

<!-- ══ ARTICOLI ═══════════════════════════════════════════════════════════ -->
<section class="v2-articles">
  <div class="v2-articles__inner">
    <header class="v2-articles__header">
      <div>
        <span class="v2-label v2-label--muted">Dal blog</span>
        <h2 class="v2-articles__title">Ultimi articoli</h2>
      </div>
      <a href="/blog/" class="v2-btn v2-btn--ghost-dark v2-articles__all">Tutti gli articoli →</a>
    </header>

    <div class="v2-articles__grid">
      {latestPosts.map((post, i) => (
        <a href={`/${post.slug}/`} class="v2-article">
          <div class="v2-article__img-wrap">
            {post.immagine
              ? <img
                  src={`/images/articoli/${post.immagine}`}
                  alt={post.titolo}
                  loading="lazy"
                  class="v2-article__img"
                />
              : <div class="v2-article__img-placeholder" aria-hidden="true"></div>
            }
            <span class="v2-article__badge">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <div class="v2-article__body">
            <h3 class="v2-article__title">{post.titolo}</h3>
            {post.descrizione && <p class="v2-article__desc">{post.descrizione}</p>}
            <span class="v2-article__cta">Leggi →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style>
/* ─── TOKENS ────────────────────────────────────────────────────────────── */
:root {
  --gold:   #C58A37;
  --gold-d: #A06E22;
  --black:  #0A0A0A;
  --white:  #FFFFFF;
  --ink:    #1C1C1C;
  --paper:  #F2EFE9;
  --muted:  rgba(10,10,10,0.42);
  --serif:   'Cormorant', Georgia, serif;
  --sans:    'Syne', system-ui, sans-serif;
  --display: 'Bricolage Grotesque', system-ui, sans-serif;
  --max:    1200px;
  --pad:    clamp(1.5rem, 5vw, 5rem);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ─── UTILITY ───────────────────────────────────────────────────────────── */
.v2-label {
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  display: block;
  margin-bottom: 1.5rem;
}
.v2-label--gold  { color: var(--gold); }
.v2-label--muted { color: var(--muted); }
.v2-label--light { color: rgba(255,255,255,0.35); }

/* ─── BUTTONS ───────────────────────────────────────────────────────────── */
.v2-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font: 700 0.78rem/1 var(--sans);
  letter-spacing: 0.04em;
  text-decoration: none;
  padding: 0.9rem 1.75rem;
  border-radius: 1px;
  transition: background 0.15s, color 0.15s, transform 0.12s;
  white-space: nowrap;
}
.v2-btn--sm { padding: 0.7rem 1.35rem; font-size: 0.74rem; }
.v2-btn svg { flex-shrink: 0; }

.v2-btn--gold {
  background: var(--gold);
  color: var(--black);
}
.v2-btn--gold:hover { background: var(--gold-d); transform: translateY(-1px); }

.v2-btn--white {
  background: var(--white);
  color: var(--black);
}
.v2-btn--white:hover { background: #e8e8e8; transform: translateY(-1px); }

.v2-btn--ghost-light {
  background: transparent;
  color: rgba(255,255,255,0.5);
  padding-left: 0;
}
.v2-btn--ghost-light:hover { color: var(--white); }

.v2-btn--ghost-dark {
  background: transparent;
  color: var(--muted);
  padding-left: 0;
  padding-right: 0;
}
.v2-btn--ghost-dark:hover { color: var(--black); }

/* ════════════════════════════════════════════════════════════════════════
   HERO
════════════════════════════════════════════════════════════════════════ */
.v2-hero {
  background: var(--black);
  position: relative;
  overflow: hidden;
}

.v2-hero__inner {
  display: grid;
  grid-template-columns: 1fr 42%;
  min-height: 96vh;
}

/* Content col */
.v2-hero__content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 7rem var(--pad) 6rem clamp(2rem, 8vw, 8rem);
  max-width: 740px;
}

.v2-eyebrow {
  font: 500 0.62rem/1 var(--sans);
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.28);
  margin-bottom: 3rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.v2-eyebrow__sep { color: var(--gold); opacity: 0.6; }

/* Headline */
.v2-hero__headline {
  display: flex;
  flex-direction: column;
  line-height: 0.92;
  margin-bottom: 2rem;
  letter-spacing: -0.03em;
}

.v2-hl-plain {
  font: 800 clamp(3.8rem, 7.5vw, 8rem)/1 var(--display);
  color: var(--white);
  display: block;
  letter-spacing: -0.03em;
}

.v2-hl-gold {
  font: 300 clamp(4.2rem, 8.5vw, 9rem)/1 var(--serif);
  font-style: italic;
  color: var(--gold);
  display: block;
  letter-spacing: -0.02em;
  margin-top: 0.08em;
}

/* Sub-headline (siti web) */
.v2-hero__sub {
  font: 400 0.82rem/1 var(--sans);
  color: rgba(255,255,255,0.28);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 0.7rem;
}
.v2-hero__sub-and {
  font: 300 0.72rem/1 var(--serif);
  font-style: italic;
  color: rgba(255,255,255,0.18);
  text-transform: none;
  letter-spacing: 0;
}

.v2-hero__body {
  font: 300 1rem/1.75 var(--sans);
  color: rgba(255,255,255,0.45);
  max-width: 400px;
  margin-bottom: 3rem;
}

.v2-hero__ctas {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
}

/* Photo col */
.v2-hero__photo-col {
  position: relative;
  overflow: hidden;
  background: #0a0a0f url('/og/marco-munich.png') center top / cover no-repeat;
  background-size: cover;
  filter: grayscale(100%) contrast(1.08) brightness(0.92);
}

.v2-hero__video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  filter: brightness(0.82) saturate(0.88);
}

.v2-hero__vid-caption {
  position: absolute;
  bottom: 2rem;
  left: 1.5rem;
  font: 700 0.58rem/1 var(--sans);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  z-index: 1;
}

/* Gold rule */
.v2-hero__rule {
  height: 2px;
  background: var(--gold);
  width: 100%;
}

/* Ticker */
.v2-hero__ticker {
  overflow: hidden;
  padding: 0.8rem 0;
  background: rgba(255,255,255,0.025);
  border-top: 1px solid rgba(255,255,255,0.06);
}

.v2-ticker__track {
  display: flex;
  gap: 2rem;
  white-space: nowrap;
  animation: v2-ticker 35s linear infinite;
  font: 700 0.62rem/1 var(--sans);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(197,138,55,0.45);
}
.v2-ticker__dot { color: rgba(197,138,55,0.25); }

@keyframes v2-ticker {
  from { transform: translateX(0); }
  to   { transform: translateX(-33.33%); }
}

/* ════════════════════════════════════════════════════════════════════════
   MANIFESTO
════════════════════════════════════════════════════════════════════════ */
.v2-manifesto {
  background: var(--paper);
  padding: 6rem var(--pad);
}

.v2-manifesto__inner {
  max-width: var(--max);
  margin: 0 auto;
}

.v2-manifesto__header {
  margin-bottom: 3rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid rgba(10,10,10,0.1);
}

.v2-manifesto__title {
  font: 300 clamp(2.2rem, 5vw, 4.5rem)/1.1 var(--serif);
  color: var(--black);
  letter-spacing: -0.01em;
  margin-top: 0.5rem;
}
.v2-manifesto__title em {
  font-style: italic;
  color: rgba(10,10,10,0.4);
}

/* Asymmetric layout: list left (wider), aside right (sticky) */
.v2-manifesto__body {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 0 4rem;
  align-items: start;
}

.v2-manifesto__list { }

.v2-manifesto__item {
  display: grid;
  grid-template-columns: 2.25rem 1fr;
  gap: 0 1rem;
