    color: rgba(10,10,10,0.8);
  }

  /* ── Steps grid (sezione 4) ──────────────────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 40px;
    max-width: 960px;
    margin: 0 auto;
  }

  .step__number {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #0A0A0A;
  }

  .step__divider {
    width: 32px;
    height: 2px;
    background: #0A0A0A;
