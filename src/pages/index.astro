    font-size: 14px;
    line-height: 1.7;
    color: rgba(10,10,10,0.7);
  }

  /* ── Dark CTA (sezione 5) ────────────────────────────────────────────────── */
  .dark-cta__title {
    font-size: clamp(24px, 4vw, 40px);
    font-weight: 700;
