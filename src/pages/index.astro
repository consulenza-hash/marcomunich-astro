    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 40px 32px;
  }

  /* ── Bio section (sezione 7) ─────────────────────────────────────────────── */
  .bio-section {
    background: #F7F7F7;
    padding: 64px 24px;
  }

  .bio-section__inner {
    display: grid;
    grid-template-columns: 330px 1fr;
    gap: 64px;
    align-items: center;
    max-width: 900px;
  }

  .bio-section__photo img {
    width: 100%;
    height: auto;
    display: block;
    filter: grayscale(100%);
  }

  .bio-section__quote-icon {
    font-size: 48px;
    color: rgba(10,10,10,0.15);
    line-height: 1;
    display: block;
    margin-bottom: -16px;
  }

  .bio-section__quote {
    font-size: 20px;
    line-height: 1.5;
    font-weight: 500;
    color: #0A0A0A;
    border: none;
    padding: 0;
    margin: 0 0 16px;
  }

  .bio-section__name {
    font-size: 15px;
    font-weight: 700;
    color: #0A0A0A;
    margin-bottom: 2px;
  }

  .bio-section__url {
    font-size: 13px;
    color: rgba(10,10,10,0.45);
  }

  /* ── Responsive ──────────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .steps-grid     { grid-template-columns: minmax(0, 1fr); }
    .latest-grid    { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .bio-section__inner { grid-template-columns: minmax(0, 1fr); }
    .bio-section__photo { max-width: 280px; margin: 0 auto; }
  }

  @media (max-width: 560px) {
    .features-grid { grid-template-columns: minmax(0, 1fr); }
    .latest-grid    { grid-template-columns: minmax(0, 1fr); }
  }
</style>
