---
import BaseLayout from '@layouts/BaseLayout.astro';
import jsYaml from 'js-yaml';

const rawFiles = import.meta.glob('/src/content/articoli/*/index.mdoc', {
  eager: true,
  as: 'raw',
}) as Record<string, string>;

const latestPosts = Object.entries(rawFiles).map(([filePath, content]) => {
  const slug   = filePath.match(/\/([^/]+)\/index\.mdoc$/)?.[1] ?? '';
  const fmStr  = content.match(/^---\r?\n([\s\S]*?)\r?\n---/)?.[1] ?? '';
  const fm     = (jsYaml.load(fmStr) as Record<string, any>) ?? {};
  return {
    slug,
    titolo:      (fm.titolo      as string) ?? slug,
    categoria:   (fm.categoria   as string) ?? 'Articolo',
    data:        fm.data ? String(fm.data) : '',
    bozza:       fm.bozza === true,
  };
})
  .filter(p => p.titolo && p.data && !p.bozza)
  .sort((a, b) => new Date(b.data).getTime() - new Date(a.data).getTime())
  .slice(0, 5);
---

<BaseLayout
  title="Personal Branding Olistico — Marco Munich"
  description="Aiuto coach, counselor e operatori olistici a costruire una presenza online che li fa trovare dalle persone giuste. Articoli, siti web e percorsi di personal branding."
  currentPath="/"
>

<div class="mm-page">

  <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
  <section class="home-hero">
    <video
      class="home-hero__video"
      id="hero-vid"
      autoplay muted loop playsinline
      poster="/og/marco-munich.png"
    ></video>
    <div class="home-hero__overlay" aria-hidden="true"></div>

    <div class="home-hero__content mm-container">
      <p class="home-hero__byline">Marco Munich —</p>
      <h1 class="mm-h1">Personal Branding<br>Olistico.</h1>
      <p class="home-hero__sub">
        Se lavori come <strong>coach, counselor o operatore olistico</strong>, ti aiuto a costruire una presenza online che corrisponde a quello che fai davvero e attira le persone giuste.
      </p>
      <div class="home-hero__ctas">
        <a href="/contatti/" class="mm-btn mm-btn-orange">Parliamo →</a>
        <a href="/risorse/" class="mm-btn mm-btn-outline">Risorse gratuite</a>
      </div>
    </div>

    <span class="home-hero__caption" aria-hidden="true">Coach · Counselor · Operatori Olistici</span>
  </section>

  <!-- ── NUMERI ─────────────────────────────────────────────────────────────── -->
  <section class="mm-section-light home-stats">
    <div class="home-stats__grid mm-container">
      <div class="home-stat">
        <div class="home-stat__num">200<span>+</span></div>
        <div class="home-stat__label">Articoli sul personal branding<br>per il mondo olistico</div>
      </div>
      <div class="home-stat">
        <div class="home-stat__num">50<span>+</span></div>
        <div class="home-stat__label">Coach, counselor e operatori<br>olistici già seguiti</div>
      </div>
      <div class="home-stat">
        <div class="home-stat__num">0</div>
        <div class="home-stat__label">Percorsi identici fatti<br>in sette anni di lavoro</div>
      </div>
    </div>
  </section>

  <!-- ── SERVIZI ───────────────────────────────────────────────────────────── -->
  <section class="mm-section-dark home-services">
    <div class="mm-container">
      <div class="home-services__header">
        <h2 class="mm-h2">Cosa faccio per<br>coach, counselor e operatori olistici.</h2>
        <a href="/servizi/" class="home-services__all">Tutti i servizi →</a>
      </div>
      <div class="home-services__grid">
        <div class="home-service-card">
          <div class="mm-tag">01 / Per coach e counselor</div>
          <h3 class="mm-h3">Personal Branding Olistico</h3>
          <p class="mm-body">Lavoriamo su come ti presenti online partendo da quello che già sai fare bene. Il risultato è una comunicazione che le persone giuste riconoscono come loro prima ancora di contattarti.</p>
        </div>
        <div class="home-service-card">
          <div class="mm-tag">02 / Per operatori olistici</div>
          <h3 class="mm-h3">Sito Web su misura</h3>
          <p class="mm-body">Costruisco siti per chi lavora nel mondo olistico e vuole essere trovato online. Ogni pagina è scritta e strutturata per il tuo tipo di cliente, con il tuo linguaggio.</p>
        </div>
        <div class="home-service-card">
          <div class="mm-tag">03 / Contenuti & Presenza</div>
          <h3 class="mm-h3">Strategia di Contenuto</h3>
          <p class="mm-body">Ti aiuto a pubblicare articoli e contenuti che portano traffico da ricerca organica. Chi cerca un counselor o un coach olistico online deve trovare prima te.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── ARTICOLI ──────────────────────────────────────────────────────────── -->
  <section class="mm-section-light home-articles">
    <div class="mm-container">
      <div class="home-articles__header">
        <h2 class="mm-h2" style="color:#0d0d0d">Ultimi articoli.</h2>
        <a href="/blog/" class="home-articles__all">Archivio completo →</a>
      </div>
      {latestPosts.map((post, i) => (
        <a href={`/${post.slug}/`} class="home-article-row">
          <span class="home-article-row__n">0{i+1}</span>
          <span class="home-article-row__cat">{post.categoria}</span>
          <span class="home-article-row__title">{post.titolo}</span>
          <span class="home-article-row__arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ── CHI SONO ──────────────────────────────────────────────────────────── -->
  <section class="mm-section-dark home-about">
    <div class="mm-container home-about__grid">
      <div class="home-about__photo">
        <img src="/og/marco-munich.png" alt="Marco Munich — Personal Branding Olistico" loading="lazy" />
      </div>
      <div class="home-about__text">
        <div class="mm-tag" style="margin-bottom:1.2rem">Chi sono</div>
        <h2 class="mm-h2" style="margin-bottom:1.5rem">Marco Munich.</h2>
        <p class="mm-body" style="margin-bottom:1rem">
          Da sette anni mi occupo di personal branding per chi lavora nel settore olistico. Ho scritto oltre duecento articoli, seguito coach, counselor e operatori di ogni tipo, e costruito siti che portano clienti reali.
        </p>
        <p class="mm-body" style="margin-bottom:2rem">
          Il mio punto di partenza è sempre la persona. Cosa sa fare, come parla, a chi si rivolge. Da lì costruiamo una presenza online che funziona perché è vera, non perché segue una formula.
        </p>
        <a href="/chi-sono/" class="mm-btn mm-btn-orange">Scopri di più →</a>
      </div>
    </div>
  </section>

  <!-- ── CTA FINALE ────────────────────────────────────────────────────────── -->
  <section class="home-cta">
    <div class="mm-container home-cta__inner">
      <div>
        <h2 class="mm-h2">Lavori nel mondo<br>olistico?</h2>
        <p style="color:rgba(255,255,255,0.75);font-size:0.9rem;margin-top:0.5rem">Fissa una chiamata gratuita. Ti dico subito cosa farei per la tua situazione specifica.</p>
      </div>
      <a href="/contatti/" class="mm-btn mm-btn-white">Parliamo →</a>
    </div>
  </section>

</div>

</BaseLayout>

<style>
  /* ── HERO ── */
  .home-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    background: #0d0d0d;
  }
  .home-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  .home-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom,
      rgba(0,0,0,0.35) 0%,
      rgba(0,0,0,0.1)  30%,
      rgba(0,0,0,0.65) 70%,
      rgba(0,0,0,0.92) 100%);
    z-index: 1;
  }
  .home-hero__content {
    position: relative;
    z-index: 2;
    padding-bottom: 5rem;
    padding-top: 8rem;
  }
  .home-hero__byline {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 0.8rem;
  }
  .home-hero__content h1 { margin-bottom: 1.5rem; }
  .home-hero__sub {
    font-size: clamp(0.88rem, 1.4vw, 1rem);
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
    max-width: 480px;
    margin-bottom: 2rem;
    font-weight: 400;
  }
  .home-hero__sub strong { color: #fff; font-weight: 700; }
  .home-hero__ctas {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }
  .home-hero__caption {
    position: absolute;
    bottom: 1.8rem;
    right: 2rem;
    z-index: 2;
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }

  /* ── STATS ── */
  .home-stats { padding: 0; }
  .home-stats__grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    border-top: 1px solid var(--mm-border-light);
  }
  .home-stat {
    padding: 3.5rem 2.5rem;
    border-right: 1px solid var(--mm-border-light);
    text-align: center;
  }
  .home-stat:last-child { border-right: none; }
  .home-stat__num {
    font-family: 'Inter', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 5vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: #0d0d0d;
    margin-bottom: 0.5rem;
  }
  .home-stat__num span { color: #e85d00; }
  .home-stat__label {
    font-size: 0.78rem;
    color: #888;
    line-height: 1.55;
  }

  /* ── SERVIZI ── */
  .home-services { padding: 5rem 0; }
  .home-services__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
  }
  .home-services__all {
    font-size: 0.82rem;
    font-weight: 600;
    color: #e85d00;
    text-decoration: none;
  }
  .home-services__grid {
    display: grid;
    grid-template-columns: repeat(3,1fr);
    gap: 1px;
    background: #1a1a1a;
    border: 1px solid #1a1a1a;
    border-radius: 4px;
    overflow: hidden;
  }
  .home-service-card {
    background: #0d0d0d;
    padding: 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .home-service-card:hover { background: #111; }
  .home-service-card .mm-h3 { color: #fff; }

  /* ── ARTICOLI ── */
  .home-articles { padding: 5rem 0; }
  .home-articles__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }
  .home-articles__all {
    font-size: 0.8rem;
    font-weight: 600;
    color: #0d0d0d;
    text-decoration: none;
    opacity: 0.5;
  }
  .home-articles__all:hover { opacity: 1; }
  .home-article-row {
    display: grid;
    grid-template-columns: 2.5rem 7rem 1fr 2rem;
    align-items: center;
    gap: 1.2rem;
    padding: 1.2rem 0;
    border-bottom: 1px solid var(--mm-border-light);
    text-decoration: none;
    color: inherit;
  }
  .home-article-row:first-of-type { border-top: 1px solid var(--mm-border-light); }
  .home-article-row:hover .home-article-row__title { color: #e85d00; }
  .home-article-row__n {
    font-size: 0.68rem;
    font-weight: 700;
    color: #ccc;
    font-family: 'Inter', sans-serif;
  }
  .home-article-row__cat {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .home-article-row__title {
    font-size: 0.92rem;
    font-weight: 600;
    color: #0d0d0d;
    transition: color 0.15s;
    line-height: 1.4;
  }
  .home-article-row__arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #0d0d0d;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
    justify-self: end;
  }

  /* ── CHI SONO ── */
  .home-about { padding: 5rem 0; }
  .home-about__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 5rem;
    align-items: center;
  }
  .home-about__photo {
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 3/4;
  }
  .home-about__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    display: block;
  }

  /* ── CTA ── */
  .home-cta {
    background: #e85d00;
    padding: 4.5rem 0;
  }
  .home-cta__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    .home-stats__grid { grid-template-columns: 1fr; }
    .home-stat { border-right: none; border-bottom: 1px solid var(--mm-border-light); }
    .home-stat:last-child { border-bottom: none; }
    .home-services__grid { grid-template-columns: 1fr; }
    .home-article-row { grid-template-columns: 2rem 1fr 2rem; }
    .home-article-row__cat { display: none; }
    .home-about__grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .home-about__photo { aspect-ratio: 4/3; }
    .home-cta__inner { flex-direction: column; align-items: flex-start; }
    .home-services__header { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
    .home-articles__header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .home-hero__content { padding-bottom: 4rem; }
  }
</style>

<script>
  // Video meteo reattivo
  (async () => {
    const vid = document.getElementById('hero-vid') as HTMLVideoElement | null;
    if (!vid) return;
    let src = '/videos/hero-pomeriggio.mp4';
    try {
      const r = await fetch('https://api.open-meteo.com/v1/forecast?latitude=45.5455&longitude=11.5354&current=weather_code,is_day');
      const d = await r.json();
      const wc = d.current?.weather_code ?? 0;
      const isDay = d.current?.is_day ?? 1;
      if (!isDay) src = '/videos/hero-notte.mp4';
      else if (wc <= 1) src = '/videos/hero-sole.mp4';
      else if (wc <= 48) src = '/videos/hero-pomeriggio.mp4';
      else if (wc <= 82) src = '/videos/hero-mattina.mp4';
      else src = '/videos/hero-sera.mp4';
    } catch {}
    vid.src = src;
    vid.load();
  })();
</script>
