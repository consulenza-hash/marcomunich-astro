---
const previews = [
  { id: 1,  slug: 'preview-home',    name: 'editorial-mono.astro',  label: 'A · Editorial / Mono' },
  { id: 2,  slug: 'preview-home-2',  name: 'brutalist-swiss.astro', label: 'B · Brutalist / Swiss' },
  { id: 3,  slug: 'preview-home-3',  name: 'soft-studio.astro',     label: 'C · Soft Studio' },
  { id: 4,  slug: 'preview-home-4',  name: 'terminal-crt.astro',    label: 'D · Terminal / CRT' },
  { id: 5,  slug: 'preview-home-5',  name: 'cinematic.astro',       label: 'E · Cinematic' },
  { id: 6,  slug: 'preview-home-6',  name: 'memphis-play.astro',    label: 'F · Memphis Play' },
  { id: 7,  slug: 'preview-home-7',  name: 'bauhaus.astro',         label: 'G · Bauhaus geometrico' },
  { id: 8,  slug: 'preview-home-8',  name: 'risograph.astro',       label: 'H · Risograph print' },
  { id: 9,  slug: 'preview-home-9',  name: 'y2k-chrome.astro',      label: 'I · Y2K Chrome' },
  { id: 10, slug: 'preview-home-10', name: 'newspaper.astro',       label: 'J · Newspaper / NYT' },
  { id: 11, slug: 'preview-home-11', name: 'bento-grid.astro',      label: 'K · Bento Grid' },
  { id: 12, slug: 'preview-home-12', name: 'glassmorphic.astro',    label: 'L · Glassmorphic / Vision OS' },
  { id: 13, slug: 'preview-home-13', name: 'blueprint.astro',       label: 'M · Blueprint architettonico' },
  { id: 14, slug: 'preview-home-14', name: 'sketchbook.astro',      label: 'N · Sketchbook hand-drawn' },
  { id: 15, slug: 'preview-home-15', name: 'web1-raw.astro',        label: 'O · Web 1.0 raw' },
];
---
<!doctype html>
<html lang="it">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Preview Gallery — Marco Munich</title>
<meta name="robots" content="noindex,nofollow">
<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
  body {
    background: #1e1e1e;
    color: #d4d4d4;
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 13px;
    display: grid;
    grid-template-rows: 38px 32px 1fr 22px;
    height: 100vh;
  }

  /* TITLE BAR (macOS) */
  .ide-titlebar {
    background: #2d2d2d;
    border-bottom: 1px solid #1a1a1a;
    display: flex;
    align-items: center;
    padding: 0 12px;
    position: relative;
  }
  .ide-dots { display: flex; gap: 8px; }
  .ide-dot { width: 12px; height: 12px; border-radius: 50%; }
  .ide-dot--r { background: #ff5f57; }
  .ide-dot--y { background: #febc2e; }
  .ide-dot--g { background: #28c840; }
  .ide-titlebar__title {
    position: absolute; left: 50%; transform: translateX(-50%);
    color: #b0b0b0; font-size: 12px;
  }
  .ide-titlebar__right { margin-left: auto; color: #666; font-size: 11px; font-family: 'JetBrains Mono', monospace; }

  /* TABS */
  .ide-tabs {
    background: #252526;
    border-bottom: 1px solid #1a1a1a;
    display: flex;
    overflow-x: auto;
    scrollbar-width: thin;
  }
  .ide-tab {
    padding: 6px 14px;
    border-right: 1px solid #1a1a1a;
    color: #969696;
    font-size: 12px;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    background: transparent;
    border-top: 2px solid transparent;
    border-bottom: 0;
    border-left: 0;
    font-family: inherit;
    transition: background 0.1s ease;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .ide-tab:hover { background: #2a2d2e; color: #d4d4d4; }
  .ide-tab.is-active {
    background: #1e1e1e;
    color: #fff;
    border-top: 2px solid #007acc;
  }
  .ide-tab__icon { color: #519aba; font-size: 11px; }

  /* MAIN: sidebar + content */
  .ide-main {
    display: grid;
    grid-template-columns: 280px 1fr;
    overflow: hidden;
    min-height: 0;
  }
  .ide-sidebar {
    background: #252526;
    border-right: 1px solid #1a1a1a;
    overflow-y: auto;
    padding: 6px 0;
  }
  .ide-sidebar__head {
    padding: 8px 14px;
    color: #b0b0b0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .ide-tree-folder {
    padding: 4px 14px 4px 18px;
    color: #d4d4d4;
    font-size: 12px;
    cursor: default;
    user-select: none;
  }
  .ide-tree-folder::before { content: '▾ '; color: #b0b0b0; }
  .ide-tree-file {
    padding: 4px 14px 4px 36px;
    color: #b0b0b0;
    font-size: 12px;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 0;
    background: transparent;
    width: 100%;
    text-align: left;
    font-family: inherit;
    transition: background 0.1s ease;
  }
  .ide-tree-file:hover { background: #2a2d2e; color: #fff; }
  .ide-tree-file.is-active { background: #094771; color: #fff; }
  .ide-tree-file__icon { color: #519aba; font-size: 11px; flex-shrink: 0; }
  .ide-tree-file__id { color: #6a6a6a; font-size: 10px; margin-left: auto; font-family: 'JetBrains Mono', monospace; }

  /* CONTENT */
  .ide-content {
    background: #1e1e1e;
    overflow: hidden;
    position: relative;
  }
  .ide-iframe-wrap {
    width: 100%;
    height: 100%;
    background: #fff;
    position: relative;
  }
  .ide-iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .ide-loader {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e1e1e;
    color: #666;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .ide-loader.is-hidden { opacity: 0; }

  /* STATUS BAR */
  .ide-statusbar {
    background: #007acc;
    color: #fff;
    display: flex;
    align-items: center;
    padding: 0 12px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    gap: 18px;
  }
  .ide-statusbar__sep { opacity: 0.5; }
  .ide-statusbar__right { margin-left: auto; display: flex; gap: 18px; }
  .ide-statusbar__open {
    background: rgba(255,255,255,0.15);
    color: #fff;
    padding: 0 8px;
    border-radius: 3px;
    text-decoration: none;
    border: 0;
    font: inherit;
    cursor: pointer;
  }
  .ide-statusbar__open:hover { background: rgba(255,255,255,0.3); }

  @media (max-width: 800px) {
    .ide-main { grid-template-columns: 1fr; }
    .ide-sidebar { display: none; }
    .ide-titlebar__title { font-size: 10px; }
  }
</style>
</head>
<body>

<!-- TITLE BAR -->
<div class="ide-titlebar">
  <div class="ide-dots">
    <span class="ide-dot ide-dot--r"></span>
    <span class="ide-dot ide-dot--y"></span>
    <span class="ide-dot ide-dot--g"></span>
  </div>
  <span class="ide-titlebar__title">marco-munich-mockups — Visual Studio Code</span>
  <span class="ide-titlebar__right">v.0.15.0</span>
</div>

<!-- TABS -->
<div class="ide-tabs" id="tabs">
  {previews.map(p => (
    <button class={`ide-tab${p.id === 1 ? ' is-active' : ''}`} data-id={p.id} data-slug={p.slug}>
      <span class="ide-tab__icon">▣</span>{p.name}
    </button>
  ))}
</div>

<!-- MAIN -->
<div class="ide-main">
  <aside class="ide-sidebar">
    <div class="ide-sidebar__head">EXPLORER</div>
    <div class="ide-tree-folder">src/pages/mockups</div>
    {previews.map(p => (
      <button class={`ide-tree-file${p.id === 1 ? ' is-active' : ''}`} data-id={p.id} data-slug={p.slug}>
        <span class="ide-tree-file__icon">▣</span>
        <span>{p.name}</span>
        <span class="ide-tree-file__id">{p.label.split(' · ')[0]}</span>
      </button>
    ))}
  </aside>

  <main class="ide-content">
    <div class="ide-iframe-wrap">
      <div class="ide-loader" id="loader">Loading mockup …</div>
      <iframe class="ide-iframe" id="frame" src="/preview-home/" title="Mockup preview"></iframe>
    </div>
  </main>
</div>

<!-- STATUS BAR -->
<div class="ide-statusbar">
  <span id="statusLabel">A · Editorial / Mono</span>
  <span class="ide-statusbar__sep">·</span>
  <span id="statusFile">/preview-home/</span>
  <span class="ide-statusbar__right">
    <a class="ide-statusbar__open" id="openInNew" href="/preview-home/" target="_blank" rel="noopener">Open in new tab ↗</a>
  </span>
</div>

<script is:inline>
  const previews = [
    { id: 1,  slug: 'preview-home',    label: 'A · Editorial / Mono' },
    { id: 2,  slug: 'preview-home-2',  label: 'B · Brutalist / Swiss' },
    { id: 3,  slug: 'preview-home-3',  label: 'C · Soft Studio' },
    { id: 4,  slug: 'preview-home-4',  label: 'D · Terminal / CRT' },
    { id: 5,  slug: 'preview-home-5',  label: 'E · Cinematic' },
    { id: 6,  slug: 'preview-home-6',  label: 'F · Memphis Play' },
    { id: 7,  slug: 'preview-home-7',  label: 'G · Bauhaus geometrico' },
    { id: 8,  slug: 'preview-home-8',  label: 'H · Risograph print' },
    { id: 9,  slug: 'preview-home-9',  label: 'I · Y2K Chrome' },
    { id: 10, slug: 'preview-home-10', label: 'J · Newspaper / NYT' },
    { id: 11, slug: 'preview-home-11', label: 'K · Bento Grid' },
    { id: 12, slug: 'preview-home-12', label: 'L · Glassmorphic / Vision OS' },
    { id: 13, slug: 'preview-home-13', label: 'M · Blueprint architettonico' },
    { id: 14, slug: 'preview-home-14', label: 'N · Sketchbook hand-drawn' },
    { id: 15, slug: 'preview-home-15', label: 'O · Web 1.0 raw' },
  ];

  const frame = document.getElementById('frame');
  const loader = document.getElementById('loader');
  const statusLabel = document.getElementById('statusLabel');
  const statusFile = document.getElementById('statusFile');
  const openInNew = document.getElementById('openInNew');

  function activate(id) {
    const p = previews.find(x => x.id === Number(id));
    if (!p) return;
    document.querySelectorAll('[data-id]').forEach(el => el.classList.toggle('is-active', Number(el.dataset.id) === p.id));
    loader.classList.remove('is-hidden');
    frame.src = '/' + p.slug + '/';
    statusLabel.textContent = p.label;
    statusFile.textContent = '/' + p.slug + '/';
    openInNew.href = '/' + p.slug + '/';
    history.replaceState(null, '', '#' + p.id);
  }

  document.querySelectorAll('[data-id]').forEach(el => {
    el.addEventListener('click', e => activate(el.dataset.id));
  });

  frame.addEventListener('load', () => loader.classList.add('is-hidden'));

  // Open from hash (e.g. /preview/#5)
  const hash = location.hash.replace('#', '');
  if (hash && Number(hash) >= 1 && Number(hash) <= 15) activate(hash);

  // Keyboard shortcuts: arrows
  document.addEventListener('keydown', e => {
    if (e.target.tagName === 'INPUT') return;
    const active = document.querySelector('.ide-tab.is-active');
    if (!active) return;
    let id = Number(active.dataset.id);
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') id = Math.min(15, id + 1);
    else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') id = Math.max(1, id - 1);
    else return;
    e.preventDefault();
    activate(id);
  });
</script>
</body>
</html>
