---
/**
 * BaseLayout.astro
 * Layout base condiviso da tutte le pagine.
 * Gestisce: <head> con meta SEO, GA4, Schema JSON-LD, GDPR, Header, Footer.
 *
 * Props:
 *   title:       string  — <title> della pagina
 *   description: string  — meta description
 *   image:       string  — og:image (opzionale)
 *   currentPath: string  — path corrente per highlight nav (opzionale)
 *   noIndex:     boolean — true per pagine che non devono essere indicizzate
 *   schemaType:  string  — 'WebPage' | 'Article' | 'CollectionPage' (opzionale, default: 'WebPage')
 */
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import CookieBanner from '@components/CookieBanner.astro';
import '@styles/global.css';

const {
  title = 'Marco Munich - Personal Branding Olistico',
  description = "L'autenticità è la strada per fare qualsiasi cosa nella vita",
  image = 'https://marcomunich.com/og-image.jpg',
  currentPath = '/',
  noIndex = false,
  schemaType = 'WebPage',
} = Astro.props;

const siteUrl = 'https://marcomunich.com';
const canonicalUrl = `${siteUrl}${currentPath}`;
const fullTitle = title.includes('Marco Munich') ? title : `${title} - Marco Munich`;

// JSON-LD Schema
const schemaGraph = [
  {
    "@type": ["Organization", "Person"],
    "@id": `${siteUrl}/#person`,
    "name": "Marco Munich - CONTENT MARKETING PER IL SETTORE OLISTICO",
    "url": siteUrl,
    "image": {
      "@id": `${siteUrl}/#logo`
    }
  },
  {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/og-image.jpg`,
    "width": "330",
    "height": "330",
    "caption": "Marco Munich - CONTENT MARKETING PER IL SETTORE OLISTICO",
    "inLanguage": "it-IT"
  },
  {
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    "url": siteUrl,
    "name": "Marco Munich - Personal Branding Olistico",
    "publisher": { "@id": `${siteUrl}/#person` },
    "inLanguage": "it-IT",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${siteUrl}/?s={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@type": schemaType,
    "@id": `${canonicalUrl}#webpage`,
    "url": canonicalUrl,
    "name": fullTitle,
    "description": description,
    "isPartOf": { "@id": `${siteUrl}/#website` },
    "about": { "@id": `${siteUrl}/#person` },
    "inLanguage": "it-IT"
  }
];
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO base -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Google Search Console verification -->
  <meta name="google-site-verification" content="32fAEP-qgKaM8ugnFjGu7XPcAtbzNr0PSsHgUwyPRB0" />

  <!-- Open Graph / Social -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:site_name" content="Marco Munich - Personal Branding Olistico" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- JSON-LD Schema (equivalente Rank Math) -->
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })} />

  <!-- ═══════════════════════════════════════════════
       GOOGLE ANALYTICS 4 — Consent Mode v2
       is:inline → script letterale (non ESM module), gtag globale.
       Default: tutti denied (GDPR EU compliance).
       Il CookieBanner aggiorna i consent dopo la scelta.
  ═══════════════════════════════════════════════ -->
  <script is:inline>
    // Consent Mode v2 — DEVE essere prima del caricamento di gtag.js
    window.dataLayer = window.dataLayer || [];
    window.gtag = function(){ window.dataLayer.push(arguments); };
    gtag('consent', 'default', {
      analytics_storage:   'denied',
      ad_storage:          'denied',
      ad_user_data:        'denied',
      ad_personalization:  'denied',
      wait_for_update:     500,
    });
  </script>

  <!-- GA4 async load -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-24JGZFXFEP"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
    gtag('js', new Date());
    gtag('config', 'G-24JGZFXFEP');
    gtag('config', 'G-354107331');
  </script>

  <!-- Slot per <head> extra (es. meta SEO specifici per articolo) -->
  <slot name="head" />
</head>

<body>
  <!-- Padding top per compensare header fisso (64px) -->
  <div class="pt-16">
    <Header currentPath={currentPath} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </div>

  <!-- GDPR Cookie Consent Banner (in italiano) -->
  <CookieBanner />
</body>
</html>
