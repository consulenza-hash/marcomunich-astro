---
/**
 * BaseLayout.astro
 * Layout base condiviso da tutte le pagine.
 * Gestisce: <head> con meta SEO, GA4, Schema JSON-LD, GDPR, Header, Footer.
 *
 * Props:
 *   title:          string  — <title> della pagina
 *   description:    string  — meta description
 *   image:          string  — og:image (opzionale)
 *   currentPath:    string  — path corrente per highlight nav (opzionale)
 *   noIndex:        boolean — true per pagine che non devono essere indicizzate
 *   schemaType:     string  — 'WebPage' | 'Article' | 'CollectionPage' (opzionale, default: 'WebPage')
 *   datePublished:  string  — ISO date, solo per articoli (es. post.date)
 *   dateModified:   string  — ISO date, solo per articoli (es. post.modified)
 */
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import CookieBanner from '@components/CookieBanner.astro';
import '@styles/global.css';

const {
  title = 'Marco Munich - Personal Branding Olistico',
  description = "L'autenticità è la strada per fare qualsiasi cosa nella vita",
  image = 'https://marcomunich.com/og-image.jpg',
  currentPath = '/',
  ctaLink = '',
  ctaLabel = '',
  noIndex = false,
  schemaType = 'WebPage',
  datePublished,
  dateModified,
  canonicalOverride,
} = Astro.props;

const siteUrl = 'https://marcomunich.com';
const canonicalUrl = canonicalOverride || `${siteUrl}${currentPath}`;
const fullTitle = title.includes('Marco Munich') ? title : `${title} - Marco Munich`;

// JSON-LD Schema
const schemaGraph = [
  {
    "@type": ["Organization", "Person"],
    "@id": `${siteUrl}/#person`,
    "name": "Marco Munich",
    "alternateName": "Marco Munich Personal Branding Olistico",
    "url": siteUrl,
    "email": "consulenza@marcomunich.com",
    "image": {
      "@id": `${siteUrl}/#logo`
    },
    "knowsAbout": [
      "Personal Branding",
      "Marketing Autentico",
      "Content Marketing",
      "Marketing per Coach",
      "Marketing per Counselor",
      "Marketing per Operatori Olistici",
      "Comunicazione Online Autentica",
      "Settore Olistico",
      "Creazione di Contenuti",
      "Intelligenza Artificiale per Contenuti",
      "Benessere e Crescita Personale",
      "Personal Branding Olistico"
    ],
    "hasOccupation": {
      "@type": "Occupation",
      "name": "Consulente di Personal Branding Olistico",
      "description": "Specializzato in marketing autentico e comunicazione online per coach, counselor, terapeuti e operatori olistici in Italia",
      "occupationLocation": {
        "@type": "Country",
        "name": "Italia"
      }
    },
    "areaServed": {
      "@type": "Country",
      "name": "Italia"
    },
    "knowsLanguage": "it-IT",
    "sameAs": [
      "https://www.youtube.com/@personalbrandingolistico",
      "https://www.instagram.com/marcomunich1983/",
      "https://www.facebook.com/personalbrandingolistico/",
      "https://www.linkedin.com/in/marcomunich/",
      "https://x.com/marcomunich_",
      "https://open.spotify.com/show/2WwJsiCJYSZnawH2TQ6N2n"
    ]
  },
  {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/og-image.jpg`,
    "width": "330",
    "height": "330",
    "caption": "Marco Munich - Personal Branding Olistico",
    "inLanguage": "it-IT"
  },
  {
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    "url": siteUrl,
    "name": "Marco Munich - Personal Branding Olistico",
    "publisher": { "@id": `${siteUrl}/#person` },
    "inLanguage": "it-IT",
    "potentialAction": {
      "@type": "SearchAction",
      "target": `${siteUrl}/?s={search_term_string}`,
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@type": schemaType,
    "@id": `${canonicalUrl}#webpage`,
    "url": canonicalUrl,
    "name": fullTitle,
    "description": description,
    "isPartOf": { "@id": `${siteUrl}/#website` },
    "about": { "@id": `${siteUrl}/#person` },
    "inLanguage": "it-IT",
    ...(datePublished && { "datePublished": datePublished }),
    ...(dateModified  && { "dateModified":  dateModified  }),
    ...(schemaType === 'Article' && {
      "author":    { "@id": `${siteUrl}/#person` },
      "publisher": { "@id": `${siteUrl}/#person` },
    }),
  }
];
---

<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO base -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Google Search Console verification -->
  <meta name="google-site-verification" content="32fAEP-qgKaM8ugnFjGu7XPcAtbzNr0PSsHgUwyPRB0" />

  <!-- Open Graph / Social -->
  <meta property="og:type" content={schemaType === 'Article' ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:locale" content="it_IT" />
  <meta property="og:site_name" content="Marco Munich - Personal Branding Olistico" />
  {datePublished && <meta property="article:published_time" content={datePublished} />}
  {dateModified  && <meta property="article:modified_time"  content={dateModified}  />}
  {dateModified && <meta property="og:updated_time" content={dateModified} />}
  {schemaType === 'Article' && <meta property="article:author" content="Marco Munich" />}

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@marcomunich" />
  <meta name="twitter:creator" content="@marcomunich" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Bing / Microsoft Copilot discoverability + IndexNow -->
  <meta name="robots" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="bingbot" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="indexnow-verification" content="marcomunich2024indexnow" />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- JSON-LD Schema (equivalente Rank Math) -->
  <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", "@graph": schemaGraph })} />

  <!-- ═══════════════════════════════════════════════
       GOOGLE ANALYTICS 4 — Consent Mode v2
       is:inline → script letterale (non ESM module), gtag globale.
       Default: tutti denied (GDPR EU compliance).
       Il CookieBanner aggiorna i consent dopo la scelta.
  ═══════════════════════════════════════════════ -->
  <script is:inline>
    // Consent Mode v2 — DEVE essere prima del caricamento di gtag.js
    window.dataLayer = window.dataLayer || [];
    window.gtag = function(){ window.dataLayer.push(arguments); };
    gtag('consent', 'default', {
      analytics_storage:   'denied',
      ad_storage:          'denied',
      ad_user_data:        'denied',
      ad_personalization:  'denied',
      wait_for_update:     500,
    });
  </script>

  <!-- GA4 async load -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-24JGZFXFEP"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function(){ window.dataLayer.push(arguments); };
    gtag('js', new Date());
    gtag('config', 'G-24JGZFXFEP');
    gtag('config', 'G-354107331');
  </script>

  <!-- Slot per <head> extra (es. BreadcrumbList schema per articoli) -->
  <slot name="head" />
</head>

<body>
  <!-- Y2K Chrome global mesh gradient background -->
  <div class="mm-bg" aria-hidden="true">
    <span class="mm-bg__blob mm-bg__blob--magenta"></span>
    <span class="mm-bg__blob mm-bg__blob--cyan"></span>
    <span class="mm-bg__blob mm-bg__blob--violet"></span>
  </div>

  <div class="mm-site">
    <Header currentPath={currentPath} ctaLink={ctaLink} ctaLabel={ctaLabel} />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </div>

  <!-- GDPR Cookie Consent Banner (in italiano) -->
  <CookieBanner />

  <style is:global>
    body { background: #0a0512; color: #f0e9ff; font-family: 'Inter', system-ui, sans-serif; margin: 0; padding: 0; min-height: 100vh; overflow-x: hidden; }
    .mm-site { position: relative; z-index: 1; }
    .mm-bg { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 0; }
    .mm-bg__blob { position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.45; }
    .mm-bg__blob--magenta { background: #ff2d92; width: 600px; height: 600px; top: 10%; left: -10%; animation: mmfloat 18s ease-in-out infinite; }
    .mm-bg__blob--cyan { background: #00e5ff; width: 500px; height: 500px; top: 50%; right: -8%; animation: mmfloat 22s ease-in-out infinite reverse; }
    .mm-bg__blob--violet { background: #8a3aff; width: 700px; height: 700px; bottom: -20%; left: 30%; animation: mmfloat 25s ease-in-out infinite; }
    @keyframes mmfloat { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(40px,-60px) scale(1.1); } }
    /* Reset legacy pt-16 padding (Tailwind) — Y2K nav è sticky, non fixed */
    .pt-16 { padding-top: 0 !important; }
  </style>
</body>
</html>
