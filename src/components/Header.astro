---
/**
 * Header.astro — Y2K Chrome sticky nav (globale)
 */
const { currentPath = '/' } = Astro.props;

const navItems = [
  { label: '// cosa costruisco', href: '/#cosa' },
  { label: '// lavori',           href: '/#lavori' },
  { label: '// metodo',           href: '/#metodo' },
  { label: '// chi sono',         href: '/#chi' },
  { label: '// articoli',         href: '/blog/' },
];
---

<header class="ps4-nav-global" id="ps4-header">
  <div class="ps4-nav-container">
    <a href="/" class="ps4-logo" aria-label="Marco Munich">
      <span class="ps4-logo__sym">▸</span>marco.dev
    </a>
    <nav class="ps4-menu" aria-label="Navigazione principale">
      {navItems.map(item => (
        <a href={item.href}>{item.label}</a>
      ))}
      <a href="/#contatti" class="ps4-menu__cta">[ contattami ]</a>
    </nav>
    <button class="ps4-burger" id="ps4-burger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<div class="ps4-mobile" id="ps4-mobile" aria-hidden="true">
  <ul role="list">
    {navItems.map(item => (
      <li><a href={item.href}>{item.label}</a></li>
    ))}
    <li><a href="/#contatti" class="ps4-mobile__cta">[ contattami ]</a></li>
  </ul>
</div>

<style>
  .ps4-nav-global { background: rgba(10,5,18,0.7); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(240,233,255,0.1); position: sticky; top: 0; z-index: 50; }
  .ps4-nav-container { max-width: 1200px; margin: 0 auto; padding: 1.1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
  .ps4-logo { font-family: 'JetBrains Mono', 'Courier New', monospace; color: #f0e9ff; text-decoration: none; font-weight: 600; font-size: 1rem; display: flex; align-items: center; gap: 0.4rem; flex-shrink: 0; }
  .ps4-logo__sym { color: #00e5ff; }
  .ps4-menu { display: flex; gap: 1.4rem; align-items: center; }
  .ps4-menu a { color: rgba(240,233,255,0.7); text-decoration: none; font-family: 'JetBrains Mono', 'Courier New', monospace; font-size: 0.85rem; transition: color 0.2s ease; white-space: nowrap; }
  .ps4-menu a:hover { color: #00e5ff; }
  .ps4-menu__cta { background: linear-gradient(180deg,#fff 0%,#b5b5b5 100%); color: #0a0512 !important; padding: 0.5rem 1rem; border-radius: 4px; font-weight: 700 !important; box-shadow: 0 0 20px rgba(255,255,255,0.3); }
  .ps4-burger { display: none; flex-direction: column; gap: 5px; background: transparent; border: 1px solid rgba(240,233,255,0.3); border-radius: 4px; cursor: pointer; padding: 0.5rem 0.6rem; }
  .ps4-burger span { display: block; width: 18px; height: 1.5px; background: #f0e9ff; transition: transform 0.2s, opacity 0.2s; }
  .ps4-burger[aria-expanded="true"] span:first-child { transform: translateY(6.5px) rotate(45deg); }
  .ps4-burger[aria-expanded="true"] span:last-child { transform: translateY(-6.5px) rotate(-45deg); }
  .ps4-mobile { position: fixed; inset: 0; z-index: 49; background: rgba(10,5,18,0.97); backdrop-filter: blur(20px); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
  .ps4-mobile[aria-hidden="false"] { opacity: 1; pointer-events: all; }
  .ps4-mobile ul { list-style: none; padding: 0; margin: 0; text-align: center; display: flex; flex-direction: column; gap: 0.4rem; }
  .ps4-mobile a { display: block; color: rgba(240,233,255,0.85); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: clamp(1.4rem, 4.5vw, 2rem); padding: 0.4rem 0; }
  .ps4-mobile a:hover { color: #00e5ff; }
  .ps4-mobile__cta { color: #00e5ff !important; margin-top: 1.2rem; }
  @media (max-width: 768px) { .ps4-menu { display: none; } .ps4-burger { display: flex; } }
</style>

<script>
  const burger = document.getElementById('ps4-burger') as HTMLButtonElement | null;
  const mobile = document.getElementById('ps4-mobile');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    mobile?.setAttribute('aria-hidden', String(open));
    document.body.style.overflow = open ? '' : 'hidden';
  });
  mobile?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      burger?.setAttribute('aria-expanded', 'false');
      mobile.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    });
  });
</script>
