---
/**
 * Header.astro
 * Header fisso nero con logo + navigazione principale.
 * Replica esatta dell'header di marcomunich.com.
 *
 * Props:
 *   currentPath: string — percorso corrente per evidenziare la voce attiva
 */
const { currentPath = '/' } = Astro.props;

const navItems = [
  { label: 'Homepage',    href: '/' },
  { label: 'Servizi',     href: '/servizi/' },
  { label: 'Video',       href: '/video/' },
  { label: 'Blog',        href: '/blog/' },
  { label: 'Risorse',     href: '/risorse/' },
];

// Determina se una voce è attiva
const isActive = (href) => {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
};
---

<header class="header">
  <div class="header__inner site-wrapper">

    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Marco Munich - Homepage">
      <span class="header__logo-name">Marco Munich</span>
      <span class="header__logo-star" aria-hidden="true">✦</span>
      <span class="header__logo-tagline">Personal Branding Olistico</span>
    </a>

    <!-- Navigazione desktop -->
    <nav class="header__nav" aria-label="Navigazione principale">
      <ul class="header__nav-list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class={`header__nav-link ${isActive(item.href) ? 'header__nav-link--active' : ''}`}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Hamburger mobile -->
    <button class="header__burger" aria-label="Apri menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Menu mobile (nascosto di default) -->
  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Menu mobile">
      <ul>
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="header__mobile-link">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  /* ── Header container ──────────────────────────────────────────────────── */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: #1E1E1F;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    max-width: 1200px;
  }

  /* ── Logo ──────────────────────────────────────────────────────────────── */
  .header__logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: white;
    flex-shrink: 0;
  }

  .header__logo-name {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: white;
  }

  .header__logo-star {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
    margin: 0 2px;
  }

  .header__logo-tagline {
    font-size: 11px;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.01em;
  }

  /* ── Nav desktop ───────────────────────────────────────────────────────── */
  .header__nav-list {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .header__nav-link {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.15s;
  }

  .header__nav-link:hover,
  .header__nav-link--active {
    color: #ffffff;
  }

  .header__nav-link--active {
    border-bottom: 2px solid white;
    padding-bottom: 2px;
  }

  /* ── Hamburger mobile ──────────────────────────────────────────────────── */
  .header__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .header__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: white;
    transition: transform 0.2s;
  }

  /* ── Menu mobile ───────────────────────────────────────────────────────── */
  .header__mobile-menu {
    display: none;
    background: #1E1E1F;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 16px 24px 24px;
  }

  .header__mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .header__mobile-link {
    display: block;
    padding: 12px 0;
    font-size: 15px;
    font-weight: 500;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .header__nav { display: none; }
    .header__burger { display: flex; }
    .header__mobile-menu.is-open { display: block; }
    .header__logo-tagline { display: none; }
  }
</style>

<!-- Script minimo per toggle menu mobile (nessuna dipendenza) -->
<script>
  const burger = document.querySelector('.header__burger');
  const mobileMenu = document.querySelector('.header__mobile-menu');

  burger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('is-open');
    burger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });
</script>
