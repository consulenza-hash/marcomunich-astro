---
/**
 * Footer.astro — Minimal dark footer con navigazione completa
 */
---

<footer class="mm-footer">
  <div class="mm-footer__inner">

    <div class="mm-footer__brand">
      <a href="/" class="mm-footer__logo">Marco<span class="mm-dot">.</span>Munich</a>
      <p class="mm-footer__tagline">Personal Branding Olistico<br>per coach, counselor e operatori olistici</p>
    </div>

    <nav class="mm-footer__nav" aria-label="Navigazione footer">
      <div class="mm-footer__col">
        <h3>Pagine</h3>
        <a href="/chi-sono/">Chi sono</a>
        <a href="/blog/">Articoli</a>
        <a href="/servizi/">Servizi</a>
        <a href="/sviluppo-siti-web/">Siti web</a>
        <a href="/risorse/">Risorse</a>
        <a href="/contatti/">Contatti</a>
      </div>
      <div class="mm-footer__col">
        <h3>Seguimi</h3>
        <a href="https://www.instagram.com/marcomunich1983/" target="_blank" rel="noopener">Instagram</a>
        <a href="mailto:consulenza@marcomunich.com">Email</a>
        <a href="https://amzn.eu/d/hD0k4Yv" target="_blank" rel="noopener">Libro Amazon</a>
      </div>
      <div class="mm-footer__col">
        <h3>Legale</h3>
        <a href="/privacy-policy/">Privacy Policy</a>
        <a href="/cookie-policy/">Cookie Policy</a>
        <a href="/termini/">Termini</a>
      </div>
    </nav>

  </div>

  <div class="mm-footer__bottom">
    <span>© {new Date().getFullYear()} Marco Munich. Tutti i diritti riservati.</span>
    <span>Vicenza, Italia</span>
  </div>
</footer>

<style>
  .mm-footer {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    font-family: 'Inter', sans-serif;
    color: #fff;
  }
  .mm-footer__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 4rem;
  }
  .mm-footer__logo {
    display: inline-block;
    font-size: 1.6rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    color: #fff;
    text-decoration: none;
    margin-bottom: 0.8rem;
  }
  .mm-dot { color: #e85d00; }
  .mm-footer__tagline {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.35);
    line-height: 1.6;
  }
  .mm-footer__nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .mm-footer__col h3 {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #1a1a1a;
  }
  .mm-footer__col a {
    display: block;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    margin-bottom: 0.45rem;
    transition: color 0.15s;
  }
  .mm-footer__col a:hover { color: #fff; opacity: 1; }
  .mm-footer__bottom {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.2rem 2rem;
    border-top: 1px solid #1a1a1a;
    display: flex;
    justify-content: space-between;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.2);
  }
  @media (max-width: 768px) {
    .mm-footer__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .mm-footer__nav { grid-template-columns: repeat(2, 1fr); }
    .mm-footer__bottom { flex-direction: column; gap: 0.4rem; }
  }
</style>
