---
/**
 * Footer.astro — Y2K Chrome footer (globale)
 */
---

<footer class="ps4-foot-global">
  <div class="ps4-foot-container">
    <div class="ps4-foot__inner">
      <div>
        <a href="/" class="ps4-foot__logo"><span class="ps4-foot__sym">▸</span>marco.dev</a>
        <p class="ps4-foot__tag">// sviluppo web · Vicenza, IT · 2019—{new Date().getFullYear()}</p>
      </div>
      <div class="ps4-foot__cols">
        <div class="ps4-foot__col">
          <h3>// pagine</h3>
          <a href="/#cosa">cosa costruisco</a>
          <a href="/#lavori">lavori</a>
          <a href="/#metodo">metodo</a>
          <a href="/#chi">chi sono</a>
          <a href="/#contatti">contattami</a>
        </div>
        <div class="ps4-foot__col">
          <h3>// approfondimenti</h3>
          <a href="/blog/">articoli</a>
          <a href="/vibe-coding/">vibe coding</a>
          <a href="/servizi/posizionamento-online/">posizionamento</a>
          <a href="/portfolio/">portfolio</a>
        </div>
        <div class="ps4-foot__col">
          <h3>// rete</h3>
          <a href="https://www.instagram.com/marcomunich1983/" target="_blank" rel="noopener">instagram</a>
          <a href="mailto:consulenza@marcomunich.com">email</a>
          <a href="https://open.spotify.com/show/2WwJsiCJYSZnawH2TQ6N2n" target="_blank" rel="noopener">podcast</a>
        </div>
        <div class="ps4-foot__col">
          <h3>// legale</h3>
          <a href="/privacy-policy/">privacy</a>
          <a href="/cookie-policy/">cookie</a>
          <a href="/termini/">termini</a>
        </div>
      </div>
    </div>
    <div class="ps4-foot__bottom">
      <span>// © {new Date().getFullYear()} Marco Munich · marco.dev</span>
      <span>// session terminated ✦</span>
    </div>
  </div>
</footer>

<style>
  .ps4-foot-global { border-top: 1px solid rgba(240,233,255,0.1); background: rgba(10,5,18,0.6); backdrop-filter: blur(20px); padding: 4rem 0 1.5rem; }
  .ps4-foot-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  .ps4-foot__inner { display: grid; grid-template-columns: 1.2fr 3fr; gap: 4rem; padding-bottom: 3rem; border-bottom: 1px dashed rgba(240,233,255,0.1); margin-bottom: 1.5rem; }
  .ps4-foot__logo { font-family: 'JetBrains Mono', monospace; color: #f0e9ff; text-decoration: none; font-weight: 600; font-size: 1.1rem; display: inline-flex; align-items: center; gap: 0.4rem; }
  .ps4-foot__sym { color: #00e5ff; }
  .ps4-foot__tag { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: rgba(240,233,255,0.5); margin: 0.6rem 0 0; }
  .ps4-foot__cols { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .ps4-foot__col h3 { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; font-weight: 700; color: #ff2d92; margin: 0 0 1rem; letter-spacing: 0.05em; }
  .ps4-foot__col a { display: block; color: rgba(240,233,255,0.65); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; padding: 0.3rem 0; transition: color 0.15s ease; }
  .ps4-foot__col a:hover { color: #00e5ff; }
  .ps4-foot__bottom { display: flex; justify-content: space-between; align-items: center; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: rgba(240,233,255,0.4); flex-wrap: wrap; gap: 1rem; }
  @media (max-width: 768px) {
    .ps4-foot__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .ps4-foot__cols { grid-template-columns: 1fr 1fr; }
    .ps4-foot__bottom { flex-direction: column; align-items: flex-start; gap: 0.4rem; }
  }
</style>
