<script is:inline>
(function () {
  // Un solo cookie per tutto l'admin: stats_auth (1 anno)
  // Stesso cookie usato da app.html e da tutte le API PHP
  function hasCookie() {
    return document.cookie.split(';').some(function(c) {
      return c.trim().startsWith('stats_auth=');
    });
  }

  if (hasCookie()) return;

  document.documentElement.style.visibility = 'hidden';

  function buildOverlay() {
    var overlay = document.createElement('div');
    overlay.id = 'mm-admin-overlay';
    overlay.style.cssText = 'position:fixed;inset:0;background:#0a0a0a;display:flex;align-items:center;justify-content:center;z-index:99999;font-family:system-ui,sans-serif;';
    overlay.innerHTML =
      '<div style="background:#141414;border:1px solid rgba(255,255,255,.08);padding:2.5rem 2rem;border-radius:14px;width:340px;max-width:90vw;">'
      + '<div style="color:#555;font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;margin-bottom:.6rem;">marcomunich.com</div>'
      + '<h2 style="color:#fff;margin:0 0 .4rem;font-size:1.15rem;font-weight:700;">Area admin</h2>'
      + '<p style="color:#666;font-size:.82rem;margin-bottom:1.8rem;">Inserisci la password per accedere.</p>'
      + '<input id="mm-pwd" type="password" placeholder="Password" autocomplete="current-password" '
      + 'style="width:100%;box-sizing:border-box;padding:.75rem 1rem;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:#0a0a0a;color:#fff;font-size:.95rem;outline:none;margin-bottom:.6rem;">'
      + '<div id="mm-err" style="color:#f87171;font-size:.8rem;margin-bottom:.75rem;display:none;">Password errata. Riprova.</div>'
      + '<button id="mm-btn" style="width:100%;padding:.8rem;background:#e85d00;color:#fff;border:none;border-radius:8px;font-size:.95rem;font-weight:700;cursor:pointer;">Accedi →</button>'
      + '</div>';
    document.body.appendChild(overlay);
    document.documentElement.style.visibility = '';
    setTimeout(function () { document.getElementById('mm-pwd').focus(); }, 40);

    var attempts = 0;

    function attempt() {
      var pwd = document.getElementById('mm-pwd').value;
      if (!pwd) return;

      attempts++;
      if (attempts > 5) {
        document.getElementById('mm-err').textContent = 'Troppi tentativi. Ricarica la pagina.';
        document.getElementById('mm-err').style.display = 'block';
        document.getElementById('mm-btn').disabled = true;
        return;
      }

      document.getElementById('mm-btn').disabled = true;
      document.getElementById('mm-btn').textContent = '...';

      fetch('/api/admin-auth.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password: pwd }),
        credentials: 'include',
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            // Stesso cookie usato da app.html — 1 anno
            document.cookie = 'stats_auth=' + encodeURIComponent(pwd) + ';path=/;max-age=31536000;SameSite=Lax';
            overlay.remove();
            location.reload();
          } else {
            document.getElementById('mm-err').style.display = 'block';
            document.getElementById('mm-pwd').value = '';
            document.getElementById('mm-pwd').focus();
            document.getElementById('mm-btn').disabled = false;
            document.getElementById('mm-btn').textContent = 'Accedi →';
          }
        })
        .catch(function () {
          document.getElementById('mm-err').textContent = 'Errore di rete. Riprova.';
          document.getElementById('mm-err').style.display = 'block';
          document.getElementById('mm-btn').disabled = false;
          document.getElementById('mm-btn').textContent = 'Accedi →';
        });
    }

    document.getElementById('mm-btn').addEventListener('click', attempt);
    document.getElementById('mm-pwd').addEventListener('keydown', function (e) {
      if (e.key === 'Enter') attempt();
    });
  }

  if (document.body) { buildOverlay(); }
  else { document.addEventListener('DOMContentLoaded', buildOverlay); }
})();
</script>
