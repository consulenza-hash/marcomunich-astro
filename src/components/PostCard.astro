---
/**
 * PostCard.astro — Y2K Chrome
 * Card articolo usata da categoria/[slug] e tag/[slug].
 */
import { getFeaturedImageUrl, getPrimaryCategory } from '@lib/wordpress';

const { post } = Astro.props;

const isMdoc   = !!post.titolo;
const title    = isMdoc ? String(post.titolo ?? '') : (post.title?.rendered ?? '');
const slug     = post.slug ?? '';
const imageUrl = isMdoc ? (post.immagine ?? null) : getFeaturedImageUrl(post, 'medium_large');
const excerpt  = isMdoc ? String(post.descrizione ?? '') : (post.excerpt?.rendered ?? '');
const category = isMdoc ? null : getPrimaryCategory(post);
const tags     = isMdoc ? [] : (post._embedded?.['wp:term']?.[1] ?? []);
const catName  = isMdoc ? (post.categoria ?? '') : (category?.name ?? '');
---

<a href={`/${slug}/`} class="pc-card">
  <div class="pc-card__img">
    {imageUrl
      ? <img src={imageUrl} alt={title} loading="lazy" decoding="async" width="600" height="340" />
      : <div class="pc-card__placeholder" aria-hidden="true">
          <span class="pc-card__letter">{title.charAt(0).toUpperCase()}</span>
        </div>
    }
  </div>
  <div class="pc-card__body">
    <div class="pc-card__meta">
      {catName && <span class="pc-card__cat">{catName}</span>}
      {!isMdoc && tags.slice(0, 2).map((t: any) => (
        <span class="pc-card__tag">#{t.name}</span>
      ))}
    </div>
    <h3 class="pc-card__title"><Fragment set:html={title} /></h3>
    <span class="pc-card__cta">// leggi →</span>
  </div>
</a>

<style>
  .pc-card { display: flex; flex-direction: column; text-decoration: none; background: rgba(255,255,255,0.03); border: 1px solid rgba(240,233,255,0.15); border-radius: 12px; overflow: hidden; backdrop-filter: blur(10px); transition: all 0.2s ease; color: #f0e9ff; }
  .pc-card:hover { border-color: #00e5ff; box-shadow: 0 0 40px rgba(0,229,255,0.12); transform: translateY(-3px); }
  .pc-card:nth-child(even) { border-color: rgba(255,45,146,0.15); }
  .pc-card:nth-child(even):hover { border-color: #ff2d92; box-shadow: 0 0 40px rgba(255,45,146,0.12); }

  .pc-card__img { width: 100%; aspect-ratio: 16/9; overflow: hidden; flex-shrink: 0; background: rgba(10,5,18,0.6); }
  .pc-card__img img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.3s ease; }
  .pc-card:hover .pc-card__img img { transform: scale(1.04); }
  .pc-card__placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, rgba(138,58,255,0.2) 0%, rgba(0,229,255,0.1) 100%); display: flex; align-items: center; justify-content: center; }
  .pc-card__letter { font-size: 3rem; font-weight: 900; color: rgba(240,233,255,0.12); font-family: 'Inter', sans-serif; }

  .pc-card__body { padding: 1.3rem; display: flex; flex-direction: column; flex: 1; gap: 0.55rem; }
  .pc-card__meta { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; }
  .pc-card__cat { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #ff2d92; }
  .pc-card:nth-child(even) .pc-card__cat { color: #00e5ff; }
  .pc-card__tag { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(240,233,255,0.35); }
  .pc-card__title { font-family: 'Inter', sans-serif; font-size: 0.95rem; font-weight: 700; color: #f0e9ff; line-height: 1.38; margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; flex: 1; }
  .pc-card__cta { font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: rgba(240,233,255,0.4); margin-top: auto; padding-top: 0.6rem; border-top: 1px dashed rgba(240,233,255,0.1); transition: color 0.15s; }
  .pc-card:hover .pc-card__cta { color: #00e5ff; }
  .pc-card:nth-child(even):hover .pc-card__cta { color: #ff2d92; }
</style>
