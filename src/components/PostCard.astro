---
/**
 * PostCard.astro
 * Card articolo usata nel blog e nella sezione "Ultimi Articoli" della homepage.
 * Replica lo stile originale: immagine in cima, titolo link colorato, bottone "LEGGI".
 *
 * Props:
 *   post: oggetto articolo WP (con _embed=true)
 */
import { getFeaturedImageUrl, getPrimaryCategory } from '@lib/wordpress';

const { post } = Astro.props;

const imageUrl  = getFeaturedImageUrl(post, 'medium_large');
const category  = getPrimaryCategory(post);
const title     = post.title?.rendered ?? '';
const slug      = post.slug ?? '';
const excerpt   = post.excerpt?.rendered ?? '';
---

<article class="post-card">

  <!-- Immagine in evidenza -->
  {imageUrl && (
    <a href={`/${slug}/`} class="post-card__image-wrap" tabindex="-1" aria-hidden="true">
      <img
        src={imageUrl}
        alt={title}
        class="post-card__image"
        loading="lazy"
        decoding="async"
        width="600"
        height="340"
      />
    </a>
  )}

  <!-- Categoria (opzionale) -->
  {category && (
    <a href={`/categoria/${category.slug}/`} class="post-card__category">
      {category.name}
    </a>
  )}

  <!-- Titolo -->
  <h3 class="post-card__title">
    <a href={`/${slug}/`}>
      <Fragment set:html={title} />
    </a>
  </h3>

  <!-- Bottone "LEGGI" -->
  <a href={`/${slug}/`} class="post-card__btn">Leggi</a>

</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
  }

  .post-card__image-wrap {
    display: block;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .post-card__image {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .post-card__image-wrap:hover .post-card__image {
    transform: scale(1.02);
  }

  .post-card__category {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(10,10,10,0.45);
    text-decoration: none;
    margin-bottom: 6px;
    display: block;
  }

  .post-card__category:hover {
    color: #0A0A0A;
  }

  .post-card__title {
    font-size: 15px;
    font-weight: 600;
    line-height: 1.4;
    margin: 0 0 12px;
  }

  .post-card__title a {
    color: #0A0A0A;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .post-card__title a:hover {
    opacity: 0.7;
  }

  .post-card__btn {
    display: inline-block;
    padding: 8px 18px;
    border: 1px solid #0A0A0A;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: #0A0A0A;
    align-self: flex-start;
    transition: background-color 0.15s, color 0.15s;
  }

  .post-card__btn:hover {
    background-color: #0A0A0A;
    color: #ffffff;
  }
</style>
