---
/**
 * PostCard.astro
 * Card articolo usata nel blog e nella sezione "Ultimi Articoli" della homepage.
 * Replica lo stile originale: immagine in cima, titolo link colorato, bottone "LEGGI".
 *
 * Props:
 *   post: oggetto articolo WP (con _embed=true)
 */
import { getFeaturedImageUrl, getPrimaryCategory } from '@lib/wordpress';

const { post } = Astro.props;

const imageUrl  = getFeaturedImageUrl(post, 'medium_large');
const category  = getPrimaryCategory(post);
const tags      = post._embedded?.['wp:term']?.[1] ?? [];
const title     = post.title?.rendered ?? '';
const slug      = post.slug ?? '';
const excerpt   = post.excerpt?.rendered ?? '';

// Stringhe per la ricerca lato client
const catNames  = category ? category.name.toLowerCase() : '';
const tagNames  = tags.map(t => t.name.toLowerCase()).join(' ');
---

<article 
  class="post-card" 
  data-search={`${title.toLowerCase()} ${catNames} ${tagNames}`}
>
  <a href={`/${slug}/`} class="post-card__overlay-link" aria-label={`Leggi ${title}`}></a>

  <!-- Immagine in evidenza -->
  {imageUrl && (
    <div class="post-card__image-wrap">
      <img
        src={imageUrl}
        alt={title}
        class="post-card__image"
        loading="lazy"
        decoding="async"
        width="600"
        height="340"
      />
    </div>
  )}

  <div class="post-card__content">
    <div class="post-card__meta">
      <!-- Categoria -->
      {category && (
        <span class="post-card__category">
          {category.name}
        </span>
      )}
      
      <!-- Tag (Semplificati per la card) -->
      {tags.length > 0 && (
        <div class="post-card__tags">
          {tags.slice(0, 2).map(tag => (
            <span class="post-card__tag">#{tag.name}</span>
          ))}
        </div>
      )}
    </div>

    <!-- Titolo -->
    <h3 class="post-card__title">
      <Fragment set:html={title} />
    </h3>

    <!-- Bottone finto (per feedback visivo, il link vero è l'overlay) -->
    <span class="post-card__fake-btn">Leggi l'articolo</span>
  </div>

</article>

<style>
  .post-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #F0F0F0;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    height: 100%;
  }
  
  .post-card__overlay-link {
    position: absolute;
    inset: 0;
    z-index: 10;
  }

  .post-card:hover {
    border-color: #0A0A0A;
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }

  .post-card__image-wrap {
    display: block;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .post-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .post-card:hover .post-card__image {
    transform: scale(1.04);
  }

  .post-card__content {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    gap: 12px;
  }

  .post-card__category {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0A0A0A;
    background: #F5F5F5;
    padding: 2px 8px;
  }

  .post-card__tags {
    display: flex;
    gap: 6px;
    overflow: hidden;
  }
  
  .post-card__tag {
    font-size: 10px;
    font-weight: 600;
    color: rgba(10,10,10,0.4);
    white-space: nowrap;
  }

  .post-card__title {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 20px;
    color: #0A0A0A;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__fake-btn {
    display: inline-block;
    margin-top: auto;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #0A0A0A;
    border-bottom: 2px solid #0A0A0A;
    padding-bottom: 2px;
    align-self: flex-start;
    transition: all 0.2s;
  }

  .post-card:hover .post-card__fake-btn {
    border-bottom-width: 4px;
    padding-bottom: 0;
  }
</style>
